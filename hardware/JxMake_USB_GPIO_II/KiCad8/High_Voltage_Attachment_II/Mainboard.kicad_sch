				(face "Liberation Mono")
				(size 1.0922 1.0922)
				(thickness 0.508)
				(bold yes)
				(color 0 0 255 1)
			)
			(justify left)
		)
		(uuid "ae416268-ba1a-4781-bf6c-d2c438bc1ae2")
	)
