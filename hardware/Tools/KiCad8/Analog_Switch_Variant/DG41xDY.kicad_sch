	(text_box "Do not forget to bridge this jumper after testing the negative voltage generator.\n\nDo not plug in this ASW module until this jumper has been bridged."
		(exclude_from_sim no)
		(at 128.27 110.49 0)
		(size 40.64 14.605)
		(stroke
			(width 0)
			(type default)
			(color 255 0 0 1)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(face "Liberation Mono")
				(size 1.27 1.27)
				(thickness 0.508)
				(bold yes)
				(color 255 0 0 1)
			)
			(justify left)
		)
		(uuid "131e10c6-602f-4cb1-98b8-9f885f856f1c")
	)
	(text_box "The DG411DY has active-low  control pins (IN1, IN2, IN3, IN4).\n\nThe DG412DY has active-high control pins (IN1, IN2, IN3, IN4).\n\nThis module uses the DG412DY by default. You can replace it with the DG411DY and modify JP1 accordingly. The firmware will automatically detect the selected configuration."
		(exclude_from_sim no)
		(at 189.23 17.78 0)
		(size 90.17 49.53)
		(stroke
			(width 0)
			(type default)
			(color 0 0 255 1)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(face "Liberation Mono")
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
				(color 0 0 255 1)
			)
			(justify left)
		)
		(uuid "6c377130-04a4-49c3-8dd1-158233c46a5c")
	)
	(text_box "!!! CAUTION !!!\n\nVDD2    must remain between 3.3V and  5.5V.\nVDD2_47 must remain between 4.0V and  7.0V.\nV+_In   must remain between 4.5V and 20.0V.\n\nThe switchable analog voltage range is from -(VDD2_47 - 1.5V) to {max(V+_In, VDD2) - 0.5V}. The maximum switchable current is 30mA, and the on-resistance (Ron) varies between 65Ω at lower supply voltages and 25Ω at higher supply voltages."
		(exclude_from_sim no)
		(at 17.78 17.78 0)
		(size 139.7 45.72)
		(stroke
			(width 0)
			(type default)
			(color 255 0 0 1)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(face "Liberation Mono")
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
				(color 255 0 0 1)
			)
			(justify left)
		)
		(uuid "981523a7-eae2-42cb-a5aa-0e820a4aa88a")
	)
