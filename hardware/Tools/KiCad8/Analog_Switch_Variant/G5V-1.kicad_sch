	(text_box "The 'SN~{C}On' signals can be driven with either 5V or 3.3V logic. If driven with 3.3V logic, replace the 4k7 resistors for the 'SN~{C}On' indicator LEDs with 2k2 to maintain adequate brightness."
		(exclude_from_sim no)
		(at 81.28 166.37 0)
		(size 87.63 24.13)
		(stroke
			(width 0)
			(type default)
