##### Function to print help messages when using AVRDUDE with FT232*
function __avrdude_ft232x_print_help__(chipName, modeName)
    echoln __c_white__  '---------------------------------------------------------------------------------------------------------' __c_reset__
    echoln
    echoln __c_white__  "To use ${chipName} ${modeName}, you need to have libFTDI (and libusb) installed and AVRDUDE built" __c_reset__
    echoln __c_white__  'to support it (most modern AVRDUDE binary releases should already be built to support libFTDI).' __c_reset__
    echoln
    echoln __c_white__  'Please refer to these URLs for more information:' __c_reset__
    echoln              '    https://hackaday.com/2009/09/22/introduction-to-ftdi-bitbang-mode'
    echoln
    echoln              '    https://libusb.info'
    echoln              '    https://github.com/libusb/libusb'
    echoln              '    https://sourceforge.net/projects/libusb-win32/files'
    echoln              '    https://ports.macports.org/port/libusb'
    echoln
    echoln              '    https://www.intra2net.com/en/developer/libftdi'
    echoln              '    https://sourceforge.net/projects/picusb/files'
    echoln              '    https://formulae.brew.sh/formula/libftdi'
    echoln
    echoln __c_white__  'On Windows, the FTDI Virtual Com Port (VCP) driver must be replaced with the WinUSB driver using Zadig' __c_reset__
    echoln __c_white__  '(it can also be used to restore the original driver). Please download Zadig from \'https://zadig.akeo.ie\'.' __c_reset__
    echoln
    echoln __c_white__  'On MacOS, the FTDI Virtual Com Port (VCP) driver must be unloaded using the command:' __c_reset__
    echoln              '    sudo kextunload /System/Library/Extensions/FTDIUSBSerialDriver.kext'
    echoln __c_white__  'It can be restored using the command:' __c_reset__
    echoln              '    sudo kextload /System/Library/Extensions/FTDIUSBSerialDriver.kext'
    echoln
    echoln __c_white__  "On Linux, the process should be automatic. However, you may need to unplug and replug your ${chipName} module" __c_reset__
    echoln __c_white__  'to restore its Virtual Com Port (VCP) capability.' __c_reset__
    echoln
    echoln __c_yellow__ "Please note that ${chipName} ${modeName} may not be compatible with some MCUs and configurations." __c_reset__
    echoln
    echoln __c_white__  '---------------------------------------------------------------------------------------------------------' __c_reset__
    echoln
endfunction


##### Function to check for error and print help messages when using AVRDUDE with FT232R Synchronous Bit Banging
function __avrdude_check_ft232r_error_and_print_help__(funcName)
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    $call(__exit_error_build_process_fail__, :"${funcName}()", true)
    $call(__avrdude_ft232x_print_help__, 'FT232R', 'Synchronous Bit Banging')
    # Exit program
    $exit($[excode])
endfunction


##### Function to check for error and print help messages when using AVRDUDE with FT232H MPSSE and Bit Banging
function __avrdude_check_ft232h_error_and_print_help__(funcName)
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    $call(__exit_error_build_process_fail__, :"${funcName}()", true)
    $call(__avrdude_ft232x_print_help__, 'FT232H', 'MPSSE and Bit Banging')
    # Exit program
    $exit($[excode])
endfunction


##### Function to check for error and print help messages when using AVRDUDE with USBtinyISP
function __avrdude_check_usbtinyisp_error_and_print_help__(funcName, ?mcs51)
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    $call(__exit_error_build_process_fail__, :"${funcName}()", true)
    local SysSpecificMsgPrinted := false
    if __os_linux__
        if !$valid_path('/etc/udev/rules.d/99-usbtiny.rules')
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            echoln __c_white__ 'Either the programming device is not connected or access is denied.' __c_reset__
            echoln
            echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/99-usbtiny.rules\' as \'root\'' __c_reset__
            echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
            echoln
            echoln             'SUBSYSTEM!="usb", ACTION!="add", GOTO="usbtiny_end"'
            echoln
            echoln             '# Make various variations of \'USBtinyISP\' writable by all users'
            echoln             'ATTRS{idVendor}=="0x1781", ATTRS{idProduct}=="0x0c9f", MODE="0666"'
            echoln             'ATTRS{idVendor}=="0x2341", ATTRS{idProduct}=="0x0c9f", MODE="0666"'
            echoln             'ATTRS{idVendor}=="0x2341", ATTRS{idProduct}=="0x0049", MODE="0666"'
            echoln             'ATTRS{idVendor}=="0x2a03", ATTRS{idProduct}=="0x0049", MODE="0666"'
            echoln             'ATTRS{idVendor}=="0x16d0", ATTRS{idProduct}=="0x0ba5", MODE="0666"'
            echoln             'ATTRS{idVendor}=="0x1209", ATTRS{idProduct}=="0x6570", MODE="0666"'
            echoln
            echoln             'LABEL="usbtiny_end"'
            echoln
            echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
            echoln
            echoln             'udevadm control --reload-rules && udevadm trigger'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            SysSpecificMsgPrinted := true
        endif
    endif
    # If the target is an MCS51 MCU, print some more helper information messages
    if ${mcs51}
        if !${SysSpecificMsgPrinted}
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
        endif
        echoln __c_white__ 'It seems you are trying to program an MCS51 MCU using USBtinyISP. You may need to:' __c_reset__
        echoln __c_white__ '    # update your USBtinyISP firmware so that the ISP reset signal is active high; or' __c_reset__
        echoln __c_white__ '    # modify your MCS51 circuit so that the ISP reset signal is active low.' __c_reset__
        echoln
        echoln __c_white__ 'Additionally, unlike other MCS51 MCUs that require SPI mode 0, the \'AT89S8253\' MCU requires SPI mode 1,' __c_reset__
        echoln __c_white__ 'you would definitely need to update your USBtinyISP firmware for this.' __c_reset__
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    endif
    # Exit program
    $exit($[excode])
endfunction


##### Function to check for error and print help messages when using AVRDUDE with USBasp
function __avrdude_check_usbasp_error_and_print_help__(funcName, ?xmega, ?mcs51)
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    $call(__exit_error_build_process_fail__, :"${funcName}()", true)
    local SysSpecificMsgPrinted := false
    if __os_linux__
        if !$valid_path('/etc/udev/rules.d/99-USBasp.rules')
            # Based on 'https://fischl.de/usbasp/usbasp.2011-05-28.tar.gz'
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            echoln __c_white__ 'Either the programming device is not connected or access is denied.' __c_reset__
            echoln
            echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/99-USBasp.rules\' as \'root\'' __c_reset__
            echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
            echoln
           #echoln             '# USBasp - USB programmer for Atmel AVR controllers'
           #echoln             'SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", SYSFS{idVendor}=="16c0", SYSFS{idProduct}=="05dc", MODE="0666"'
            echoln             '# Make \'USBasp\' writable by all users'
            echoln             'SUBSYSTEM=="usb", ACTION=="add", ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="05dc", MODE="0666"'
            echoln
            echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
            echoln
            echoln             'udevadm control --reload-rules && udevadm trigger'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            SysSpecificMsgPrinted := true
        endif
    endif
    if !${SysSpecificMsgPrinted}
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    endif
    echoln __c_white__ 'If the programming fails and an error message about SCK period such as below appears:' __c_reset__
    echoln             '    ...'
    echoln             '    avrdude: warning: cannot set sck period. please check for USBasp firmware update.'
    echoln             '    ...'
    echoln __c_white__ 'you may need to use slower SCK frequency.' __c_reset__
    echoln
    echoln __c_white__ 'If your USBasp has a \'Slow SCK\' jumper, please set the jumper and try again, it might be possible to use' __c_reset__
    echoln __c_white__ 'your USBasp without updating the firmware.' __c_reset__
    echoln
    echoln __c_white__ 'If programming still fails, please update your USBasp firmware from:' __c_reset__
    echoln             '    https://fischl.de/usbasp'
    echoln             '    https://fischl.de/usbasp/usbasp.2011-05-28.tar.gz'
    echoln
    echoln __c_white__ 'Please refer to these articles for more details:' __c_reset__
    echoln             '    https://blog.podkalicki.com/how-to-update-avr-usbasp-firmware-to-latest-version'
    echoln             '    https://octopuslabs.io/blog/how-to-update-usbasp-firmware-using-another-usbasp'
    echoln             '    https://www.bitbanging.space/posts/usbasp-firmware-update'
    echoln             '    https://www.electronics-lab.com/project/usbasp-firmware-update-guide'
    echoln             '    https://www.instructables.com/How-to-Update-the-Firmware-on-a-Cheap-USBasp-Clone'
    echoln             '    https://www.bestsoldering.com/usbasp-firmware-update'
    echoln
    echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
    echoln
    # If the target is an ATxmega MCU, print some more helper information messages
    if ${xmega}
        echoln __c_white__ 'It seems you are trying to program an ATxmega MCU using USBasp. You may need to update your USBasp' __c_reset__
        echoln __c_white__ 'firmware so that it can be used to program ATxmega MCUs, please refer to the following articles:' __c_reset__
        echoln
        echoln             'Playing with AtXmega16e5 breakout - Converting USBASP to support PDI'
        echoln             'https://morf.lv/playing-with-atxmega16e5-breakout'
        echoln
        echoln             'ATxmega programmer for $0.50'
        echoln             'https://szulat.blogspot.com/2012/08/atxmega-programmer-for-050.html'
        echoln             '    USBASP Firmware supporting PDI'
        echoln             '        https://www.fischl.de/usbasp/usbasp.2011-05-28.tar.gz'
        echoln             '        http://sz.toyspring.com/usbasp-pdi-usbaspfirmware-20120816.diff'
        echoln             '    AVRDUDE supporting USBASP with PDI (5.11svn)'
        echoln             '        http://sz.toyspring.com/usbasp-pdi-avrdude2091-20120816.diff'
        echoln             '        svn co svn://svn.sv.gnu.org/avrdude/trunk -r 1092'
        echoln
        echoln             'Как прошить XMEGA при помощи USBASP программатора'
        echoln             'How to flash XMEGA using USBASP programmer'
        echoln             'https://service4u.narod.ru/html/atxmega_avrdude.html'
        echoln             'https://service4u.narod.ru/assets/xmega/usbasp_pdi_atmega8_20120816.hex'
        echoln             'https://service4u.narod.ru/assets/xmega/avrdude-r1092-usbasp-pdi.zip'
        echoln
        echoln             'USBASP-PDI'
        echoln             'Modified USBASP to work as a PDI Programmer'
        echoln             'https://github.com/nieldk/USBASP-PDI'
        echoln             'https://github.com/nieldk/USBASP-PDI/tree/master/bin/firmware'
        echoln
        echoln             'AVRDUDE 6.3 for USBASP-PDI'
        echoln             'https://github.com/nieldk/avrdude'
        echoln
        echoln __c_white__ 'It is recommended to use AVRDUDE r1092 (5.11svn) instead of 6.3 because the patched \'avrdude.conf\' for' __c_reset__
        echoln __c_white__ 'version 6.3 contains a bug for the \'.xmega\' common part definition (missing \'chip_erase_delay = 40000\').' __c_reset__
        echoln
        echoln __c_white__ 'It is possible to use AVRDUDE 6.3 with the \'avrdude.conf\' from r1092 (5.11svn), or, edit the file and add' __c_reset__
        echoln __c_white__ 'the missing \'chip_erase_delay = 40000\' to the \'.xmega\' common part definition; without the chip erase' __c_reset__
        echoln __c_white__ 'delay, programming will always fail.' __c_reset__
        echoln
        echoln __c_white__ 'There is also a bug in the USBasp patch that will cause programming using TPI to always fail. To fix it,' __c_reset__
        echoln __c_white__ 'after applying the patch, edit \'firmware/main.c\' and add the following lines:' __c_reset__
        echoln             '    } else if (data[1] == USBASP_FUNC_TPI_WRITEBLOCK) {'
        echoln             '        prog_address = (data[3] << 8) | data[2];'
        echoln             '        prog_nbytes = (data[7] << 8) | data[6];'
        echoln             '        prog_state = PROG_STATE_TPI_WRITE;'
        echoln             '        len = 0xff; /* multiple out */'
        echoln __c_white__ 'before the line that contains:' __c_reset__
        echoln             '        } else if (data[1] == USBASP_FUNC_GETCAPABILITIES) {'
        echoln __c_white__ '(the patch removed those lines).' __c_reset__
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
        echoln __c_cyan__  'The corrected USBasp patch as well as the updated AVRDUDE patch (for version 7.1, 7.2, 7.3, and 8.0)' __c_reset__
        echoln __c_cyan__  'can be obtained from:' __c_reset__
        echoln             '    https://github.com/blue-wind-25/PDI-Patch-for-USBasp-and-AVRDUDE'
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    endif
    # If the target is an MCS51 MCU, print some more helper information messages
    if ${mcs51}
        echoln __c_white__ 'It seems you are trying to program an MCS51 MCU using USBasp. You may need to:' __c_reset__
        echoln __c_white__ '    # update your USBasp firmware so that the ISP reset signal is active high; or' __c_reset__
        echoln __c_white__ '    # modify your MCS51 circuit so that the ISP reset signal is active low.' __c_reset__
        echoln
        echoln __c_white__ 'Additionally, unlike other MCS51 MCUs that require SPI mode 0, the \'AT89S8253\' MCU requires SPI mode 1,' __c_reset__
        echoln __c_white__ 'you would definitely need to update your USBasp firmware for this.' __c_reset__
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    endif
    # Exit program
    $exit($[excode])
endfunction


##### Function to check for error and print help messages when using AVRDUDE with advanced Atmel ISP programmer
function __avrdude_check_advanced_atmel_isp_programmer_error_and_print_help__(funcName)
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    $call(__exit_error_build_process_fail__, :"${funcName}()", true)
    if __os_linux__
        if !$valid_path('/etc/udev/rules.d/60-avrisp.rules')
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            echoln __c_white__ 'Either the programming device is not connected or access is denied.' __c_reset__
            echoln
            echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/60-avrisp.rules\' as \'root\'' __c_reset__
            echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
            echoln
            echoln             'SUBSYSTEM!="usb", ACTION!="add", GOTO="avrisp_end"'
            echoln
            echoln             '# Make \'Atmel ICE\' writable by all users'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2141", MODE="0666"'
            echoln
            echoln             '# Make \'Atmel JTAG ICE 3 v3.x\' writable by all users'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2140", MODE="0666"'
            echoln
            echoln             '# Make \'Atmel JTAG ICE 3\' writable by all users'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2110", MODE="0666"'
            echoln
            echoln             '# Make \'Atmel JTAG ICE mkII\' writable by all users'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2103", MODE="0666"'
            echoln
            echoln             '# Make \'Atmel AVRISP mkII\' writable by all users'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2104", MODE="0666"'
            echoln
            echoln             '# Make \'Atmel Dragon\' writable by all users'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2107", MODE="0666"'
            echoln
            echoln             'LABEL="avrisp_end"'
            echoln
            echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
            echoln
            echoln             'udevadm control --reload-rules && udevadm trigger'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
        endif
    endif
    # Exit program
    $exit($[excode])
endfunction


