##### Function to return the programmer definitions for a custom AVRDUDE configuration file
function __get_custom_avrdude_config_programmers__()
    # Determine the custom AVRDUDE configuration file content
    local ProgText := [["
#[>=00700300000000] #
#[>=00700300000000] # AVRDUDE Configuration File
#[>=00700300000000] #

#[>=00700300000000] avrdude_conf_version = "#[{AVRDUDE_VERSION}]";

                    #
                    # PROGRAMMER DEFINITIONS
                    #

                    #
                    # Based on:
                    #     https://raw.githubusercontent.com/avrdudes/avrdude/main/NEWS
                    #     https://raw.githubusercontent.com/avrdudes/avrdude/main/src/avrdude.conf.in
                    #
                    #     https://github.com/facchinm/avrdude/archive/refs/tags/5.11.0.tar.gz   [avrdude.conf.in]
                    #     https://github.com/facchinm/avrdude/archive/refs/tags/6.*.*.tar.gz    [avrdude.conf.in]
                    #
                    #     https://download.savannah.gnu.org/releases/avrdude/avrdude-6.*.tar.gz [avrdude.conf.in]
                    #
                    #     https://github.com/avrdudes/avrdude/archive/refs/tags/v7.*.tar.gz     [avrdude.conf.in]
                    #

                    programmer
                        id               = "stk500";
                        desc             = "Atmel STK500; probes STK500v2 first then STK500v1";
                        type             = "stk500generic";
#[>=00700100000000]     prog_modes       = PM_ISP;
#[>=00700200000000]     extra_features   = HAS_VTARG_READ | HAS_VTARG_ADJ | HAS_FOSC_ADJ | HAS_VAREF_ADJ;
                        connection_type  = serial;
                    ;

                    programmer
                        id               = "stk500v1";
                        desc             = "Atmel STK500 with Version 1.x Firmware";
                        type             = "stk500";
#[>=00700100000000]     prog_modes       = PM_ISP;
#[>=00700200000000]     extra_features   = HAS_VTARG_READ | HAS_VTARG_ADJ | HAS_FOSC_ADJ | HAS_VAREF_ADJ;
                        connection_type  = serial;
                    ;

                    programmer
                        id               = "stk500v2";
                        desc             = "Atmel STK500 with Version 2.x Firmware";
                        type             = "stk500v2";
#[>=00700100000000]     prog_modes       = PM_ISP | PM_TPI;
#[>=00700200000000]     extra_features   = HAS_VTARG_READ | HAS_VTARG_ADJ | HAS_FOSC_ADJ | HAS_VAREF_ADJ;
                        connection_type  = serial;
                    ;

                    programmer
                        id               = "stk600";
                        desc             = "Atmel STK600";
                        type             = "stk600";
#[>=00700100000000]     prog_modes       = PM_ISP | PM_TPI | PM_PDI;
#[>=00700200000000]     extra_features   = HAS_VTARG_READ | HAS_VTARG_ADJ | HAS_FOSC_ADJ | HAS_VAREF_ADJ;
                        connection_type  = usb;
                    ;

                    programmer
                        id               = "avrisp";
                        desc             = "Atmel AVR ISP";
                        type             = "stk500";
#[>=00700100000000]     prog_modes       = PM_ISP;
                        connection_type  = serial;
                    ;

                    programmer
                        id               = "avrispv2";
                        desc             = "Atmel AVR ISP V2";
                        type             = "stk500v2";
#[>=00700100000000]     prog_modes       = PM_ISP | PM_TPI;
                        connection_type  = serial;
                    ;

                    programmer
                        id               = "avrispmkII";
                        desc             = "Atmel AVR ISP mkII";
                        type             = "stk500v2";
#[>=00700100000000]     prog_modes       = PM_ISP | PM_TPI | PM_PDI;
#[>=00700200000000]     extra_features   = HAS_VTARG_READ;
                        connection_type  = usb;
                    ;

                    programmer parent "avrispmkII"
                        id               = "avrisp2";
                    ;

#[>=00600000000000] programmer
#[>=00600000000000]     id               = "ft232r";
#[>=00600000000000]     desc             = "FT232R Synchronous Bit Banging";
#[>=00600000000000]     type             = "ftdi_syncbb";
#[>=00700100000000]     prog_modes       = PM_TPI | PM_ISP;
#[>=00600000000000]     connection_type  = usb;
#[>=00700300000000]     is_serialadapter = yes;
#[>=00600000000000]     usbvid           = 0x0403;
#[>=00600000000000]     usbpid           = 0x6001;
#[>=00600000000000]     reset            = 4; # DTR
#[>=00600000000000]     sck              = 0; # TxD
#[>=00600000000000]     mosi             = 2; # RTS
#[>=00600000000000]     miso             = 1; # RxD
#[>=00600000000000] ;

#[>=00600000000000] programmer
#[>=00600000000000]     id               = "ft232h";
#[>=00600000000000]     desc             = "FT232H-Based Generic Programmer";
#[>=00600000000000]     type             = "avrftdi";
#[>=00700100000000]     prog_modes       = PM_TPI | PM_ISP;
#[>=00600000000000]     connection_type  = usb;
#[>=00700300000000]     is_serialadapter = yes;
#[>=00600000000000]     usbvid           = 0x0403;
#[>=00600000000000]     usbpid           = 0x6014;
#[>=00600000000000]     usbdev           = "A";
#[>=00600000000000]     reset            = 3; # AD3 (TMS)
#[>=00600000000000]     sck              = 0; # AD0 (TCK)
#[>=00600000000000]     mosi             = 1; # AD1 (TDI)
#[>=00600000000000]     miso             = 2; # AD2 (TDO)
#[>=00600000000000] ;

#[>=00700300000000] programmer
#[>=00700300000000]     id               = "ft232h_jtag";
#[>=00700300000000]     desc             = "FT232H-Based Generic JTAG Programmer";
#[>=00700300000000]     type             = "avrftdi_jtag";
#[>=00700300000000]     prog_modes       = PM_JTAG;
#[>=00700300000000]     connection_type  = usb;
#[>=00700300000000]     usbvid           = 0x0403;
#[>=00700300000000]     usbpid           = 0x6014;
#[>=00700300000000]     usbdev           = "A";
#[>=00700300000000]     tck              = 0; # AD0 (TCK)
#[>=00700300000000]     tdi              = 1; # AD1 (TDI)
#[>=00700300000000]     tdo              = 2; # AD2 (TDO)
#[>=00700300000000]     tms              = 3; # AD3 (TMS)
#[>=00700300000000] ;

                    programmer
                        id              = "usbtiny";
                        desc            = "USBtiny Simple USB Programmer; https://learn.adafruit.com/usbtinyisp";
                        type            = "usbtiny";
#[>=00700100000000]     prog_modes      = PM_ISP | PM_TPI;
                        connection_type = usb;
                        usbvid          = 0x1781;
                        usbpid          = 0x0C9F;
                    ;

                    programmer
                        id              = "arduinoisp";
                        desc            = "Arduino ISP Programmer";
                        type            = "usbtiny";
#[>=00700100000000]     prog_modes      = PM_ISP | PM_TPI;
                        connection_type = usb;
                        usbvid          = 0x2341;
                        usbpid          = 0x0049;
                    ;

                    programmer
                        id              = "arduinoisporg";
                        desc            = "Arduino ISP Programmer";
                        type            = "usbtiny";
#[>=00700100000000]     prog_modes      = PM_ISP | PM_TPI;
                        connection_type = usb;
                        usbvid          = 0x2A03;
                        usbpid          = 0x0049;
                    ;

                    programmer
                        id              = "usbasp";
                        desc            = "USBasp; https://www.fischl.de/usbasp";
                        type            = "usbasp";
#[>=00700100000000]     prog_modes      = PM_ISP | PM_TPI;
                        connection_type = usb;
                        usbvid          = 0x16C0; # VOTI
                        usbpid          = 0x05DC; # Obdev's free shared PID
                        usbvendor       = "www.fischl.de";
                        usbproduct      = "USBasp";
                    ;

                    programmer
                        id              = "usbasp-clone";
                        desc            = "Any USBasp Clone with the Correct VID/PID";
                        type            = "usbasp";
#[>=00700100000000]     prog_modes      = PM_ISP | PM_TPI;
                        connection_type = usb;
                        usbvid          = 0x16C0; # VOTI
                        usbpid          = 0x05DC; # Obdev's free shared PID
                    ;

                    programmer
                        id              = "jtag2";
                        desc            = "Atmel JTAG ICE mkII in JTAG Mode";
                        type            = "jtagmkii";
#[>=00700100000000]     prog_modes      = PM_JTAG | PM_XMEGAJTAG | PM_AVR32JTAG;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
                        connection_type = usb;
                        baudrate        = 115200;
                    ;

                    programmer
                        id              = "jtag2isp";
                        desc            = "Atmel JTAG ICE mkII in ISP Mode";
                        type            = "jtagmkii_isp";
#[>=00700100000000]     prog_modes      = PM_TPI | PM_ISP;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
                        connection_type = usb;
                        baudrate        = 115200;
                    ;

                    programmer
                        id              = "jtag2pdi";
                        desc            = "Atmel JTAG ICE mkII in PDI Mode";
                        type            = "jtagmkii_pdi";
#[>=00700100000000]     prog_modes      = PM_PDI;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
                        connection_type = usb;
                        baudrate        = 115200;
                    ;

                    programmer
                        id              = "jtag2updi";
                        desc            = "JTAGv2 to UPDI Bridge";
#[< 00700100000000]     type            = "jtagmkii_pdi";
#[>=00700100000000]     type            = "jtagmkii_updi";
#[>=00700100000000]     prog_modes      = PM_UPDI;
                        connection_type = serial;
                        baudrate        = 115200;
#[>=00700100000000]     hvupdi_support  = 1;
                    ;

#[>=00700000000000] programmer
#[>=00700000000000]     id              = "serialupdi";
#[>=00700000000000]     desc            = "SerialUPDI";
#[>=00700000000000]     type            = "serialupdi";
#[>=00700100000000]     prog_modes      = PM_UPDI;
#[>=00700000000000]     connection_type = serial;
#[>=00700100000000]     hvupdi_support  = 1;
#[>=00700000000000] ;

#[>=00600000000000] programmer
#[>=00600000000000]     id              = "jtag3";
#[>=00600000000000]     desc            = "Atmel AVR JTAGICE3 in JTAG Mode";
#[>=00600000000000]     type            = "jtagice3";
#[>=00700100000000]     prog_modes      = PM_JTAG | PM_XMEGAJTAG | PM_AVR32JTAG;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
#[>=00600000000000]     connection_type = usb;
#[>=00600100000000]     usbpid          = 0x2110, 0x2140;
#[>=00600000000000] ;

#[>=00600000000000] programmer
#[>=00600000000000]     id              = "jtag3isp";
#[>=00600000000000]     desc            = "Atmel AVR JTAGICE3 in ISP Mode";
#[>=00600000000000]     type            = "jtagice3_isp";
#[>=00700100000000]     prog_modes      = PM_ISP;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
#[>=00600000000000]     connection_type = usb;
#[>=00600100000000]     usbpid          = 0x2110, 0x2140;
#[>=00600000000000] ;

#[>=00600000000000] programmer
#[>=00600000000000]     id              = "jtag3pdi";
#[>=00600000000000]     desc            = "Atmel AVR JTAGICE3 in PDI Mode";
#[>=00600000000000]     type            = "jtagice3_pdi";
#[>=00700100000000]     prog_modes      = PM_PDI;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
#[>=00600000000000]     connection_type = usb;
#[>=00600100000000]     usbpid          = 0x2110, 0x2140;
#[>=00600000000000] ;

#[>=00700000000000] programmer
#[>=00700000000000]     id              = "jtag3updi";
#[>=00700000000000]     desc            = "Atmel AVR JTAGICE3 in UPDI Mode";
#[>=00700000000000]     type            = "jtagice3_updi";
#[>=00700100000000]     prog_modes      = PM_UPDI;
#[>=00700200000000]     extra_features  = HAS_VTARG_READ;
#[>=00700000000000]     connection_type = usb;
#[>=00700000000000]     usbpid          = 0x2110, 0x2140;
