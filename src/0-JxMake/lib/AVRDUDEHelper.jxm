#####
#####


##### Function to print help messages about supported bit clocks when using AVRDUDE with USBasp
function __avrdude_print_usbasp_supported_bit_clock__(bSpcCnt)
    local BSpc := $repeat(' ', ${bSpcCnt})
    local MSpc := ${BSpc} '    '
    echoln __c_white__   ${BSpc} 'Due to the ' __c_yellow__ '12MHz' __c_white__ ' crystal used by ' __c_cyan__ 'USBasp' __c_white__ ', supported bit clocks (SCK frequencies) are limited to:'
    echoln __c_magenta__ ${MSpc} 'Hardware SPI          SCK Frequency   Bit Clock Period'
    echoln __c_white__   ${MSpc} 'XTAL /   8            1500000 Hz      ~' __c_green__ ' 0.6 ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL /  16             750000 Hz      ~' __c_green__ ' 1.3 ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL /  32             375000 Hz      ~' __c_green__ ' 2.6 ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL /  64             187500 Hz      ~' __c_green__ ' 5.3 ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 128              93750 Hz      ~' __c_green__ '10.6 ' __c_white__ 'uS'
    echoln __c_magenta__ ${MSpc} 'Software SPI          SCK Frequency   Bit Clock Period'
    echoln __c_white__   ${MSpc} 'XTAL / 64 /   3 / 2   ~32000 Hz       ' __c_green__ '  31.25 ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 64 /   6 / 2   ~16000 Hz       ' __c_green__ '  62.5  ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 64 /  12 / 2   ~ 8000 Hz       ' __c_green__ ' 125    ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 64 /  24 / 2   ~ 4000 Hz       ' __c_green__ ' 250    ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 64 /  48 / 2   ~ 2000 Hz       ' __c_green__ ' 500    ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 64 /  96 / 2   ~ 1000 Hz       ' __c_green__ '1000    ' __c_white__ 'uS'
    echoln __c_white__   ${MSpc} 'XTAL / 64 / 192 / 2   ~  500 Hz       ' __c_green__ '2000    ' __c_white__ 'uS'
    echoln __c_white__   ${BSpc} 'Passing values other than those listed above to ' __c_green__ 'bitClock' __c_white__ ' will cause the nearest lower'
    echoln __c_white__   ${BSpc} 'frequency to be selected.'
endfunction


