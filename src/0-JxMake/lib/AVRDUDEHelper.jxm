#####
#####


##### Function to check if the selected AVRDUDE configuration file supports the given ID(s)
function __chk_sel_avrdude_id_support_ext__(cfName, ids)
    # Convert the IDs to lowercase
    ids := $lcase(${ids})
    # Get the program path
    local ProgPath := ${AVRDUDE_Cmd}<1>
   #local ProgPath := 'C:/avrdude-v7.1-windows-x64/avrdude'
   #local ProgPath := '/opt/avrdude-7.1/bin/avrdude'
    # Create the combined IDs string
    local CombIDStr := $ftpipes(${ids})
    # Try to get the result from the cache file first
    local LatestIDCacheFilePath := $cat_path( $ptd(), :"LatestAVRDUDEID${cfName}Support.cache" )
    if $uptodate_path(${LatestIDCacheFilePath})
        Lines := $get_file(${LatestIDCacheFilePath})
        if ${Lines}<1> &== ${ProgPath}
            if ${Lines}<2> &== ${CombIDStr}
                # Return the result from the cache file only and only if both the program path and IDs are the same
                return {{ ${Lines}<3>, $sfpipes(${Lines}<4>) }}
            endif
        endif
    endif
    # Check the version
    local VerC := $partn( $call( __get_avrdude_version_cached__, ${ProgPath}, $call(__get_LDLibraryPaths__) ), 1 )
    local V70P := $cmp( ${VerC}, '>=', $call(__calc_avrdude_version_numeric__, 7, 0, 0) )
    local V71P := $cmp( ${VerC}, '>=', $call(__calc_avrdude_version_numeric__, 7, 1, 0) )
    # Get the configuration file(s)
    local IsLocalBSD := $and( __os_bsd__, $str_begwith(${ProgPath}, '/usr/local') )
    local CFiles     := ${AVRDUDE_Cmd}<3>
    if !&${CFiles}
        local CF
        if $or(__os_windows__, ${V70P})
            CF := $cat_path( $dir_name(${ProgPath}), 'avrdude.conf' )
            if $valid_path(${CF}) : CFiles +:= ${CF}
        endif
        if !&${CFiles}
            if ${IsLocalBSD}
                CF := '/usr/local/etc/avrdude.conf'
                if $valid_path(${CF}) : CFiles +:= ${CF}
            elif __os_posix__
                CF := '/etc/avrdude.conf'
                if $valid_path(${CF}) : CFiles +:= ${CF}
            endif
        endif
        if !&${CFiles}
            if ${IsLocalBSD}
                CF := '/usr/local/etc/avrdude/avrdude.conf'
                if $valid_path(${CF}) : CFiles +:= ${CF}
            elif __os_posix__
                CF := '/etc/avrdude/avrdude.conf'
                if $valid_path(${CF}) : CFiles +:= ${CF}
            elif __os_windows__
                CF := $cat_path( $dir_name(${ProgPath}), '../etc/avrdude.conf' )
                if $valid_path(${CF}) : CFiles +:= ${CF}
            endif
        endif
    endif
    if __os_windows__
        CF := $cat_path( $dir_name(${ProgPath}), 'avrdude.rc' )
        if $valid_path(${CF}) : CFiles +:= ${CF}
    else
        local gotPerUserCF := false
        if ${V71P}
            CF := $cat_path( $uhd(), '.config/avrdude/avrdude.rc' )
            if $valid_path(${CF})
                CFiles       +:= ${CF}
                gotPerUserCF  := true
            endif
        endif
        if !${gotPerUserCF}
            CF := $cat_path( $uhd(), '.avrduderc' )
            if $valid_path(${CF}) : CFiles +:= ${CF}
        endif
    endif
    # Check the configuration file(s)
    local HasAllIDs := false
    local WholeCheck
    foreach local CFile in ${CFiles}
        # Extract the IDs and convert them to lowercase
        local ExIDs := $erase_ifnot( $get_file(${CFile}), `^\s*id\s*=\s*(?:"\S+"\s*,?\s*)*;\s*$`, true )
              ExIDs := ${ExIDs/^\s*id\s*=\s*\s"(.+?)"\s*;\s*$/$1/}
              ExIDs := $lcase( $erase_if( $re_split(${ExIDs}, `([^",\s]+)`), `^\..+`, true ) )
        # Check if the IDs list contains the IDs
        local Check := $contains(${ExIDs}, ${ids})
        # Combine the check results
        if !&${WholeCheck} ; WholeCheck :=                    ${Check}
        else               ; WholeCheck := $or(${WholeCheck}, ${Check})
        endif
        # Check if the IDs list contains all the ids
        if !$contains(${Check}, '0')
            HasAllIDs := true
            break
        endif
    endforeach
    if !$contains(${WholeCheck}, '0') : HasAllIDs := true
    # Save the results to the cache file
    $put_file( ${LatestIDCacheFilePath}, {{ \
                 ${ProgPath}   ,            \
                 ${CombIDStr}  ,            \
                 ${HasAllIDs}  ,            \
        $ftpipes(${WholeCheck})             \
    }} )
    # Return the results
    return { ${HasAllIDs} ${WholeCheck} }
endfunction


##### Function to check if the selected AVRDUDE configuration file supports the given programmer(s)
function __chk_sel_avrdude_programmer_support_ext__(programmers)
    return $call(__chk_sel_avrdude_id_support_ext__, 'Programmer', ${programmers})
endfunction

function __chk_sel_avrdude_programmer_support__(programmers)
    return $partn( $call(__chk_sel_avrdude_programmer_support_ext__, ${programmers}), 1 )
endfunction


##### Function to check if the selected AVRDUDE configuration file supports the given part(s)
function __chk_sel_avrdude_part_support_ext__(parts)
    return $call(__chk_sel_avrdude_id_support_ext__, 'Part', ${parts})
endfunction

function __chk_sel_avrdude_part_support__(parts)
    return $partn( $call(__chk_sel_avrdude_part_support_ext__, ${parts}), 1 )
endfunction


