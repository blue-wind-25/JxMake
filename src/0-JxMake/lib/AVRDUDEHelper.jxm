#[>=00600000000000] ;

#[>=00700100000000] programmer
#[>=00700100000000]     id              = "atmelice_tpi";
#[>=00700100000000]     desc            = "Atmel-ICE (ARM/AVR) in TPI Mode";
#[>=00700100000000]     type            = "jtagice3_tpi";
