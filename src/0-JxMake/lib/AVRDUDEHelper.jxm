##### Include the basic platform utility
:::include_once 'BasicPlatformUtil.jxm'


##### Define some AVRDUDE-specific tools
const __Def_AVRDUDE_Cmd__   := 'avrdude'
        AVRDUDE_Cmd         := ${__Def_AVRDUDE_Cmd__}
        AVRDUDE_CmdSafeMode := '-u' '-s'


##### Functions to get the AVRDUDE version
function __calc_avrdude_version_numeric__(major, minor, patch, ?patchDot)
    # A patch number with a dot separator has a higher numerical comparison value than a patch number with a dash separator
    patchDot ?:= 1                                     # If not specified, assume it has a dot separator
    if ${patchDot} : eval patch := ${patch} + 99990000 # Use the year 9999 so that the value has a higher numerical comparison value
    # Calculate and return the numeric version number
    return $call(calc_ver_numeric_338, ${major}, ${minor}, ${patch})
endfunction

function __get_avrdude_version_exec__(progPath, ldLibraryPath)
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
    if __os_windows__ : $cmd_stdout_chk_on() # Workaround to prevent hung because AVRDUDE somehow has a non-standard stdout in case of error (on Windows only?)
   -@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   -@${progPath} -?
    $nop($[excode]) # Ensure all pending commands are executed
    if __os_windows__ : $cmd_stdout_chk_off()
    $restore_sem()
    return $cmp($[lserr], '&==', '') # Check and return if the command can actually be executed
endfunction

function __get_avrdude_version__(progPath, ldLibraryPath)
    if !$exec(__get_avrdude_version_exec__, ${progPath}, ${ldLibraryPath}) : return 0
    local text   := $erase_ifempty( $sflines( $stack($[stderr], $[stdout]) ) )
          text   := $partn( ${text}, $part_count(${text}) )
          text   := $sfpipes(${text/.*?(\d+)\.(\d+)([.-]?)(\d+)?.*/$1|$2|$3|$4/})
    local psDash := $csel( $cmp(${text}<3>, '&==', '-'), 1, 0 )
    local verStr := $ftdots(${text})
    if ${psDash} : verStr := $str_replace(${verStr}, '.-.', '-')
    return {{ $call( __calc_avrdude_version_numeric__, ${text}<1>, ${text}<2>, ${text}<4>, $not(${psDash}) ), ${verStr} }}
endfunction

function __get_avrdude_version_cached__(progPath, ldLibraryPath)
    # Create a new map as needed
    if !&${__AVRDUDE_Ver_MH__} : __AVRDUDE_Ver_MH__ := $map_new()
    # Try to get the version from the map first
    local Ver := $map_get(${__AVRDUDE_Ver_MH__}, ${progPath})
    if &${Ver} : return ${Ver}
    # Get the version from the executable
    Ver := $call(__get_avrdude_version__, ${progPath}, ${ldLibraryPath})
    # Save the version to the map
    $map_put(${__AVRDUDE_Ver_MH__}, ${progPath}, ${Ver})
    # Return the version
    return ${Ver}
endfunction


##### Function to find the latest AVRDUDE from Arduino package(s)
function __find_latest_arduino_avrdude_cmd_impl__()
    # Try to get the path from the cache file first
    local LatestCmdCacheFilePath := $cat_path( $ptd(), 'LatestAVRDUDECmd.cache' )
    local LatestCmd
    if $uptodate_path(${LatestCmdCacheFilePath})
        LatestCmd := $get_file(${LatestCmdCacheFilePath})
        return ${LatestCmd}
    endif
    # List directories
    local SearchDirPath1
    local SearchDirPath2
    local SearchDirList
    foreach local DirItem in ${ArduinoPackageDirs}
        SearchDirPath1 := $cat_path(${DirItem}, 'packages/arduino/tools/avrdude')
        SearchDirPath2 := $cat_path(${DirItem}, 'hardware/tools/avr'            )
        if $valid_path(${SearchDirPath1}) : SearchDirList  := $lsdir(${SearchDirPath1}, 'd')
        if $valid_path(${SearchDirPath2}) : SearchDirList +:= $lsdir(${SearchDirPath2}, 'd')
    endforeach
    # Try the default AVRDUDE first
    local LatestVersion := 0
    local CheckVersion  := $partn( $call(__get_avrdude_version__, ${__Def_AVRDUDE_Cmd__}, ''), 1 )
    if ${CheckVersion}
        LatestVersion := ${CheckVersion}
        LatestCmd     := ${__Def_AVRDUDE_Cmd__}
    endif
    # Find the latest AVRDUDE version
    local LDLibPaths := $call(__get_LDLibraryPaths__)
    local ProgPath
    local ConfPath
    foreach local DirItem in ${SearchDirList}
        # Get the AVRDUDE binary path
        ProgPath := $cat_path(${DirItem}, 'bin'             )
        ConfPath := $cat_path(${DirItem}, 'etc/avrdude.conf')
        if !$valid_path(${ProgPath}) : continue
        ProgPath := $cat_path(${ProgPath}, 'avrdude')
        # Get the AVRDUDE version
        CheckVersion := $partn( $call(__get_avrdude_version__, ${ProgPath}, ${LDLibPaths}), 1 )
        # Compare the AVRDUDE versions
        if ${CheckVersion} > ${LatestVersion}
            LatestVersion := ${CheckVersion}
            LatestCmd     := ${ProgPath}
            if $valid_path(${ConfPath})
                LatestCmd +:= '-C'
                LatestCmd +:= ~${ConfPath}
            endif
        endif
    endforeach
    # Use the default AVRDUDE if nothing was found
    if !&${LatestCmd} : LatestCmd := ${__Def_AVRDUDE_Cmd__}
    # Save the path to the cache file
    $put_file(${LatestCmdCacheFilePath}, ${LatestCmd})
    # Return the path to the latest AVRDUDE
    return ${LatestCmd}
endfunction

function __find_latest_arduino_avrdude_cmd__()
    # Find the latest AVRDUDE only if the user has not changed it from its default value
    if ${AVRDUDE_Cmd} &== ${__Def_AVRDUDE_Cmd__}
        # Find the latest AVRDUDE only if the variable containing the Arduino package directories is not empty
        if &${ArduinoPackageDirs}
            AVRDUDE_Cmd := $call(__find_latest_arduino_avrdude_cmd_impl__)
        endif
    endif
    # Check if the AVRDUDE command is executable
    if __os_windows__ : $cmd_stdout_chk_on() # Workaround to prevent hung because AVRDUDE somehow has a non-standard stdout in case of error (on Windows only?)
    if !$call(cmd_is_executable, '', ${AVRDUDE_Cmd}) : $call(__exit_error_nup__, ${__Def_AVRDUDE_Cmd__})
    if __os_windows__ : $cmd_stdout_chk_off()
    # Remove the 'safemode' command line arguments as needed
    $call(__sel_avrdude_remove_safemode__)
endfunction


##### Function to remove the 'safemode' command line arguments from the selected AVRDUDE command as needed
function __sel_avrdude_remove_safemode__()
    # Check if it has been removed
    if !&${AVRDUDE_CmdSafeMode} : return
    # The 'safemode' feature has been removed in version 7.0
    local VerC := $partn( $call( __get_avrdude_version_cached__, ${AVRDUDE_Cmd}<1>, $call(__get_LDLibraryPaths__) ), 1 )
    local V70P := $cmp( ${VerC}, '>=', $call(__calc_avrdude_version_numeric__, 7, 0, 0) )
    if ${V70P} : AVRDUDE_CmdSafeMode := ''
endfunction


##### Function to add the selected AVRDUDE command to the build tool extra information
function __add_sel_avrdude_cmd_to_bt_extra_info__()
    # Check if the AVRDUDE command is not defined
    if !&${AVRDUDE_Cmd} : return
    # Add the extra information
        __BuildTool_ExtraInfoName__  +:= '-'
        __BuildTool_ExtraInfoValue__ +:= '-'
        __BuildTool_ExtraInfoName__  +:= 'AVRDUDE Program'
        __BuildTool_ExtraInfoValue__ +:= ${AVRDUDE_Cmd}<1>
    if $part_count(${AVRDUDE_Cmd}) == 3
        __BuildTool_ExtraInfoName__  +:= 'AVRDUDE Configuration File'
        __BuildTool_ExtraInfoValue__ +:= $abs_path(${AVRDUDE_Cmd}<3>)
    endif
        __BuildTool_ExtraInfoName__  +:= 'AVRDUDE Version'
        __BuildTool_ExtraInfoValue__ +:= $partn( $call( __get_avrdude_version_cached__, ${AVRDUDE_Cmd}<1>, $call(__get_LDLibraryPaths__) ), 2 )
    # Remove the 'safemode' command line arguments as needed
    $call(__sel_avrdude_remove_safemode__)
endfunction


##### Function to translate AVR MCU name to AVRDUDE part name
function __avr_mcu_to_avrdude_part__(mcu)
    # Based on 'https://www.nongnu.org/avrdude/user-manual/avrdude_3.html'
    local mcu := $lcase(${mcu})
       if $re_match(${mcu}, 'atmega.+' ) ; mcu := ${mcu/atmega(.+)/m$1/}
     elif $re_match(${mcu}, 'atxmega.+') ; mcu := ${mcu/atxmega(.+)/x$1/}   ; mcu := ${mcu/(.+?(?<!p))rev(.)$/$1$2/}
     elif $re_match(${mcu}, 'attiny.+' ) ; mcu := ${mcu/attiny(.+)/t$1/}
     elif $re_match(${mcu}, 'at90usb.+') ; mcu := ${mcu/at90usb(.+)/usb$1/}
     elif $re_match(${mcu}, 'at90s.+'  ) ; mcu := ${mcu/at90s(.+)/$1/}
     elif $re_match(${mcu}, 'at90pwm.+') ; mcu := ${mcu/at90pwm(.+)/pwm$1/}
     elif $re_match(${mcu}, 'at90can.+') ; mcu := ${mcu/at90can(.+)/c$1/}
     elif $re_match(${mcu}, 'at32uc3.+') ; mcu := ${mcu/at32uc3(.+)/uc3$1/}
    endif
    return ${mcu/(.+?(?<!p))a$/$1/} # Remove the 'a' suffix because older AVRDUDE does not recognize it
endfunction


#####
#####
#####


##### Function to determine the appropriate serial baudrate from the given AVR CPU frequency when using AVRDUDE with UPDI programmers with serial connections
function __avrdude_det_serialupdi_baudrate_for_avr__(fcpu)
    # Assume that when a user selects a lower CPU frequency, it means that the user also selects a lower UPDI clock
    # and possibly a longer programming cable
      if ${fcpu} >= 8000000 ; return '115200' # The safe maximum baudrate that all USB to serial adapters should support
    elif ${fcpu} >= 2000000 ; return  '57600'
    elif ${fcpu} >=  500000 ; return  '28800'
    elif ${fcpu} >=  125000 ; return  '14400'
    elif                    ; return   '7200'
    endif
endfunction


##### Function to get (determine) the safe bit clock from the given AVR CPU frequency when using AVRDUDE
function __avrdude_get_safe_bit_clock_for_avr__(fcpu)
      if ${fcpu} >= 16000000 ; return    '0.6'  # 1500000 Hz
    elif ${fcpu} >=  8000000 ; return    '1.3'  #  750000 Hz
    elif ${fcpu} >=  4000000 ; return    '2.6'  #  375000 Hz
    elif ${fcpu} >=  2000000 ; return    '5.3'  #  187500 Hz
    elif ${fcpu} >=  1000000 ; return   '10.6'  #   93750 Hz
    elif ${fcpu} >    256000 ; return   '31.25' #  ~32000 Hz
    elif ${fcpu} >    128000 ; return   '62.5'  #  ~16000 Hz
    elif ${fcpu} >     64000 ; return  '125'    #  ~ 8000 Hz
    elif ${fcpu} >     32000 ; return  '250'    #  ~ 4000 Hz
    elif ${fcpu} >     16000 ; return  '500'    #  ~ 2000 Hz
    elif ${fcpu} >      8000 ; return '1000'    #  ~ 1000 Hz
    else                     ; return '2000'    #  ~  500 Hz
    endif
endfunction


##### Function to get (determine) the safe bit clock from the given MCS51 CPU frequency when using AVRDUDE
function __avrdude_get_safe_bit_clock_for_mcs51__(fcpu)
    div fcpu, ${fcpu}, 64
    return $call(__avrdude_get_safe_bit_clock_for_avr__, ${fcpu})
endfunction


