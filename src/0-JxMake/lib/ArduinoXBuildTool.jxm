##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__()
    $call(__btlib_help_print_title_main__)
    $call(__btlib_help_print_title_variables__)
    echoln __c_green__ '    __arduino__               ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __x_arduino__             ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln
    echoln __c_green__ '    __BuildTool_Name__        ' __c_white__ ': evaluate to the Arduino CLI name'
    echoln __c_green__ '    __BuildTool_Version__     ' __c_white__ ': evaluate to the Arduino CLI version'
    echoln __c_green__ '    __BuildTool_Version_Num__ ' __c_white__ ': evaluate to the Arduino CLI version (in the form of combined numeric value)'
    echoln
    echoln __c_green__ '    ArduinoBuildDir           ' __c_white__ ': set the build directory under the source tree - the default is \'' __c_yellow__ 'build' __c_white__ '\'     ; can only be changed before calling \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '    ArduinoCLIBinDir          ' __c_white__ ': set the location of the Arduino CLI binary    - override \'' __c_yellow__ 'ARDUINO_CLI_PATH' __c_white__ '\'; can only be changed before calling \'' __c_green__ 'init_project' __c_white__ '\''
    echoln
   #$call(__btlib_help_print_title_functions__, 9, 12, 1)
    $call(__btlib_help_print_title_functions__, 0,  0, 0)
    echoln __c_green__ '    init_project           (            ) ' __c_white__ ': initialize the project build; ' __c_red__ 'must be called first and as early as possible' __c_white__ ' (after changing the global values of the'
    echoln __c_green__ '                                          ' __c_white__ '  variables above, if necessary)'
    echoln __c_green__ '    clean_project          (            ) ' __c_white__ ': clean the project build (delete all the generated files)'
    echoln __c_green__ '    print_devenv_config    (            ) ' __c_white__ ': print the development environment configuration summary; must only be called after \'' __c_green__ 'init_project' __c_white__ '\''
    echoln
    echoln __c_green__ '    silent_stdxxx          (?silent     ) ' __c_white__ ': silent/unsilent all    stderr/stdout outputs, unless the exit code is non-zero - the default is \'' __c_green__ 'false' __c_white__ '\''
    echoln __c_green__ '    silent_stdxxx_syslib   (?silent     ) ' __c_white__ ': silent/unsilent system stderr/stdout outputs, unless the exit code is non-zero - the default is \'' __c_green__ 'true' __c_white__ '\''
    echoln
    echoln __c_green__ '    arduino_cli_ver_min    (mj, mn, pl  ) ' __c_white__ ': check if the Arduino CLI version is at least ' __c_yellow__ '<major>.<minor>.<patch>'
    echoln __c_green__ '    arduino_cli_ver_max    (mj, mn, pl  ) ' __c_white__ ': check if the Arduino CLI version is at most  ' __c_yellow__ '<major>.<minor>.<patch>'
    echoln
    echoln __c_green__ '    enable_debug_info      (enabled     ) ' __c_white__ ': enable/disable debugging information - the default is disabled'
    echoln
    echoln __c_green__ '    ac_set_sketch_dir      (directory   ) ' __c_white__ ': set the sketch directory to be used'
    echoln
    echoln __c_green__ '    ac_set_fqbn            (fqbn        ) ' __c_white__ ': set the FQBN to be used'
    echoln __c_green__ '                                          ' __c_green__  '     fqbn' __c_white__ ' fully qualified board name - for example \'' __c_yellow__ 'arduino:avr:mega' __c_white__ '\', \'' __c_yellow__ 'esp8266:esp8266:nodemcuv2' __c_white__ '\', etc.'
    echoln
    echoln __c_green__ '    ac_list_all_cores      (            ) ' __c_white__ ': list all supported cores'
    echoln __c_green__ '    ac_list_all_boards     (?filter     ) ' __c_white__ ': list all supported boards'
    echoln __c_green__ '    ac_list_boards_details (?fqbn       ) ' __c_white__ ': list all the board\'s details - if no FQBN is specified, the one set using \'' __c_green__ 'ac_set_fqbn' __c_white__ '\' will be used'
    echoln
    echoln __c_green__ '    ac_set_board_options   (options     ) ' __c_white__ ': set the board options to be used'
    echoln __c_green__ '                                          ' __c_green__  '     options' __c_white__ ' key-value pairs separated by set members and/or commas - for example:'
    echoln __c_green__ '                                          ' __c_green__  '                 ' __c_white__ '\'' __c_yellow__ '{{ \'baud=460800\', \'ip=lm6f\' }}' __c_white__ '\''
    echoln __c_green__ '                                          ' __c_green__  '                 ' __c_white__ '\'' __c_yellow__ 'baud=460800,ip=lm6f' __c_white__ '\''
    echoln
    echoln __c_green__ '    ac_set_build_properties(properties  ) ' __c_white__ ': set the build properties to be used'
    echoln __c_green__ '                                          ' __c_green__  '     properties' __c_white__ ' key-value pairs separated by set members - for example:'
    echoln __c_green__ '                                          ' __c_green__  '                    ' __c_white__ '\'' __c_yellow__ '{{ \'build.mcu=atmega2560\', \'build.extra_flags=\\\'-DDUMMY_MACRO="Dummy Value"\\\'\' }}' __c_white__ '\''
    echoln
    echoln __c_green__ '                                          ' __c_white__  '     If a parameter can be set by both \'' __c_green__ 'ac_set_board_options' __c_white__ '\' and \'' __c_green__ 'ac_set_build_properties' __c_white__ '\', using the former is recommended.'
    echoln
    echoln __c_green__ '    ac_set_keychain_dir    (directory   ) ' __c_white__ ': set the keychain directory containing the keys to be used to sign and encrypt the binary (used only by the platforms '
    echoln __c_green__ '                                          ' __c_white__ '  that support it)'
    echoln __c_green__ '                                          ' __c_green__ '      directory' __c_white__ ' the directory that contains the files \'' __c_yellow__ 'private.key' __c_white__ '\' and \'' __c_yellow__ 'public.key' __c_white__ '\''
    echoln
    echoln __c_green__ '                                          ' __c_white__ '      Please ensure the sketch directory does not contains the files \'' __c_yellow__ 'private.key' __c_white__ '\' and \'' __c_yellow__ 'public.key' __c_white__ '\' as those files'
    echoln __c_green__ '                                          ' __c_white__ '      will be copied from the location specified using \'' __c_green__ 'ac_set_keychain_dir' __c_white__ '\' and deleted as needed by the build system.'
    echoln
    echoln __c_green__ '    ac_build_sketch        (            ) ' __c_white__ ': build the sketch'
    echoln
    echoln __c_green__ '    ac_upload_sketch       (port        ) ' __c_white__ ': upload the sketch'
    echoln __c_green__ '                                          ' __c_green__  '     port' __c_white__ ' target port (e.g. \'' __c_yellow__ 'COM1' __c_white__ '\'' __c_white__ ' or \'' __c_yellow__ '/dev/ttyACM0' __c_white__ '\')'
    echoln
    echoln __c_green__ '    ac_prg_upload_sketch   (prog, ?port ) ' __c_white__ ': upload the sketch using programmer'
    echoln __c_green__ '                                          ' __c_green__  '     prog' __c_white__ ' programmer name (e.g. \'' __c_yellow__ 'USBasp' __c_white__ '\'' __c_white__ ' or \'' __c_yellow__ 'AVRISP mkII' __c_white__ '\' )'
    echoln __c_green__ '                                          ' __c_green__  '     port' __c_white__ ' programmer port (e.g. \'' __c_yellow__ 'COM1' __c_white__ '\'  ' __c_white__ ' or \'' __c_yellow__ '/dev/ttyACM0' __c_white__ '\') - the default is not specified'
    echoln
    echoln __c_green__ '    ac_net_upload_sketch   (net_address ) ' __c_white__ ': upload the sketch using network protocol'
    echoln __c_green__ '                                          ' __c_green__  '     net_address' __c_white__ ' IP address or hostname of the target'
    echoln
    $call(__btlib_help_print_note_arduino_environment__)
    echoln __c_reset__
endfunction

