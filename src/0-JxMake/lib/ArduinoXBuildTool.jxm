##### Function to set the board options
ArduinoBoardOptions := ''

function ac_set_board_options(options)
    ArduinoBoardOptions := $implode( $strim(${options}), ',' )
endfunction


##### Function to set the build properties
ArduinoBuildProperties := ''

function ac_set_build_properties(properties)
    ArduinoBuildProperties := $interleave( '--build-property', $strim(${properties}) )
endfunction


##### Function to set the keychain directory (used only by the platforms that support it)
ArduinoKeychainDir := ''
ArduinoSignFlags   := ''

function ac_set_keychain_dir(directory)
    ArduinoKeychainDir := $strim(${directory})
    if &${ArduinoKeychainDir}
        ArduinoSignFlags := '--keys-keychain' ~${ArduinoSketchDir} '--sign-key' 'private.key' '--encrypt-key' 'public.key'
    else
        ArduinoSignFlags := ''
    endif
endfunction

function __ac_rm_keychain_files__()
    # Determine the destination keychain files
    local const prvKeyFileDst := :"~${ArduinoSketchDir}/private.key"
    local const pubKeyFileDst := :"~${ArduinoSketchDir}/public.key"
    # Delete the destination keychain files
    $rmfile(${prvKeyFileDst})
    $rmfile(${pubKeyFileDst})
    # Delete the signed binary files as needed
    if &${ArduinoBuildDirFQBN}
        if &${ArduinoSketchDir}
            $rmfile(:"${ArduinoBuildDirFQBN}/${ArduinoSketchDir}.ino.bin.signed"    )
            $rmfile(:"${ArduinoBuildDirFQBN}/${ArduinoSketchDir}.ino.bin.legacy_sig")
        endif
    endif
endfunction

function __ac_cp_keychain_files__()
    # Copy the keychain files
    if &${ArduinoKeychainDir}
        # Determine the source keychain files
        local const prvKeyFileSrc := :"~${ArduinoKeychainDir}/private.key"
        local const pubKeyFileSrc := :"~${ArduinoKeychainDir}/public.key"
        # Determine the destination keychain files
        local const prvKeyFileDst := :"~${ArduinoSketchDir}/private.key"
        local const pubKeyFileDst := :"~${ArduinoSketchDir}/public.key"
        # Copy the source keychain files to the destination keychain files as needed
        if $newer_path(${prvKeyFileSrc}, ${prvKeyFileDst}) : $cpfile(${prvKeyFileSrc}, ${prvKeyFileDst})
        if $newer_path(${pubKeyFileSrc}, ${pubKeyFileDst}) : $cpfile(${pubKeyFileSrc}, ${pubKeyFileDst})
    # Delete the keychain files
    else
        $call(__ac_rm_keychain_files__)
    endif
endfunction


##### Function to set the common build and upload flags
ArduinoBuildFlags  := ''
ArduinoUploadFlags := ''

function __ac_set_common_build_upload_flags__()
    # Check if the flags already set
    if &${ArduinoBuildFlags}  : local DoneBF := true
    if &${ArduinoUploadFlags} : local DoneUF := true
    if $and(${DoneBF}, ${DoneUF}) : return
    # Ensure the sketch's build directory name contains the FQBN
    $call(__ac_set_arduino_build_dir_fqbn__)
    # Set the build flags as needed
    if !${DoneBF}
                                        ArduinoBuildFlags   := '--fqbn'               ${ArduinoFQBN}
        if &${ArduinoBoardOptions}    : ArduinoBuildFlags  +:= '--board-options'      ${ArduinoBoardOptions}
        if &${ArduinoBuildProperties} : ArduinoBuildFlags  +:=                        ${ArduinoBuildProperties}
        if &${ArduinoSignFlags}       : ArduinoBuildFlags  +:=                        ${ArduinoSignFlags}
                                        ArduinoBuildFlags  +:= '--build-path'       :"${ArduinoBuildDirFQBN}"

        if !$call(arduino_cli_ver_min, 1, 1, 0)
                                        ArduinoBuildFlags  +:= '--build-cache-path' :"${ArduinoBuildDirFQBN}/cache"
        endif
                                        ArduinoBuildFlags  +:= '--output-dir'       :"${ArduinoBuildDirFQBN}/output"
        if &${ArduinoDebugFlags}      : ArduinoBuildFlags  +:=                        ${ArduinoDebugFlags}
                                        ArduinoBuildFlags  +:= '--warnings'          'default'
                                        ArduinoBuildFlags  +:= '--log-level'         'info'
                                        ArduinoBuildFlags  +:= '--verbose'
    endif
    # Set the upload flags as needed
    if !${DoneUF}
                                        ArduinoUploadFlags  := '--fqbn'               ${ArduinoFQBN}
        if &${ArduinoBoardOptions}    : ArduinoUploadFlags +:= '--board-options'     "${ArduinoBoardOptions}"
                                        ArduinoUploadFlags +:= '--input-dir'        :"${ArduinoBuildDirFQBN}/output"
    endif
endfunction


##### Helper macros to build and upload sketch
.macro __arduino_cli_bu_common_entry_code__
    # Set the common build and upload flags
    $call(__ac_set_common_build_upload_flags__)
    # Ensure the keychain file are up to date
    $call(__ac_cp_keychain_files__)
    # Enable streaming for '@' as needed
    local ES := ${__ARDUINO_CLI_FORCE_CMD_STREAMING__}
    if !${ES} : ES := $not( $call(is_all_stdxxx_silent) )
    if  ${ES} : $cmd_streaming_on()
.endmacro

.macro __arduino_cli_bu_common_leave_code__
    # Disable streaming for '@' or perform conditional print and check as needed
    if ${ES} ; $cmd_streaming_off()
    else     ; $call(__conditional_print_stdxxx_and_check_excode__)
    endif
    # Check for error
    if $[excode] : $exit($[excode])
.endmacro


##### Function to build sketch
function __ac_build_sketch_exec__()
    # --show-properties
    +@${ArduinoCLI} compile ${ArduinoBuildFlags} ~${ArduinoSketchDir}
endfunction

function ac_build_sketch()
    # Execute the common entry code
    .$__arduino_cli_bu_common_entry_code__
    # Perform build
    $call(__bpt_arduino_build__, ${ArduinoSketchDir})
    $exec(__ac_build_sketch_exec__                  )
    # Execute the common leave code
    .$__arduino_cli_bu_common_leave_code__
endfunction


##### Functions to upload sketch
function __ac_upload_sketch_exec__(addUploadFlags)
    +@${ArduinoCLI} upload ${ArduinoUploadFlags} ${addUploadFlags} ~${ArduinoSketchDir}
endfunction

function ac_upload_sketch(port)
    # Set the additional upload flags
    local addUploadFlags := '--port' ${port}
    # Execute the common entry code
    .$__arduino_cli_bu_common_entry_code__
    # Perform upload
    $call(__bpt_arduino_upload_std__, ${ArduinoSketchDir})
    $exec(__ac_upload_sketch_exec__, ${addUploadFlags}   )
    # Execute the common leave code
    .$__arduino_cli_bu_common_leave_code__
endfunction

function ac_prg_upload_sketch(prog, ?port)
    # Set the additional upload flags
            local prog            := $lcase(${prog/\s//})
            local addUploadFlags  := '--programmer' ${prog}
    if &${port} : addUploadFlags +:= '--port'       ${port}
    # Execute the common entry code
    .$__arduino_cli_bu_common_entry_code__
    # Perform upload
    $call(__bpt_arduino_upload_prg__, ${ArduinoSketchDir})
    $exec(__ac_upload_sketch_exec__, ${addUploadFlags}   )
    # Execute the common leave code
    .$__arduino_cli_bu_common_leave_code__
endfunction

function ac_net_upload_sketch(net_address)
    # Set the additional upload flags
    $call(__bpt_arduino_upload_net__, ${ArduinoSketchDir})
          local addUploadFlags  := '--discovery-timeout' '3s'
                addUploadFlags +:= '--protocol'          'network'
                addUploadFlags +:= '--port'
                addUploadFlags +:=                       $resolve_ip(${net_address})
    # Execute the common entry code
    local __ARDUINO_CLI_FORCE_CMD_STREAMING__ := true # Force enable streaming for '@'
    .$__arduino_cli_bu_common_entry_code__
    # Perform upload
    $exec(__ac_upload_sketch_exec__, ${addUploadFlags})
    # Print some helper information messages
    if $[excode]
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
        echoln __c_white__ 'If an error message about getting port metadata such as below appears:' __c_reset__
        echoln             '    ...'
        echoln             '    Error getting port metadata: port not found: xxx.xxx.xxx.xxx network.'
        echoln             '    ...'
        echoln __c_white__ 'you may be using an incorrect IP addres or full access to \'224.0.0.251:5353\' or \'[ff02::fb]:5353\' is' __c_reset__
        echoln __c_white__ 'blocked by your operating system\'s firewall; mDNS discovery needs full access to the specified network' __c_reset__
        echoln __c_white__ 'address and port. Please refer to this article for more details:' __c_reset__
        echoln             '    https://en.wikipedia.org/wiki/Multicast_DNS'
        echoln
        echoln __c_white__ 'If an error message about getting user input such as below appears:' __c_reset__
        echoln             '    ...'
        echoln             '    Uploading to specified board using network protocol requires the following info:'
        echoln             '    Error getting user input: user input not supported in non interactive mode'
        echoln             '    ...'
        echoln __c_white__ 'try to restart the target, reboot your PC, or use a different terminal program.' __c_reset__
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    endif
    # Execute the common leave code
    .$__arduino_cli_bu_common_leave_code__
endfunction

