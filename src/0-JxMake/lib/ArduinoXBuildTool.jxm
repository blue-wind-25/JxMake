##### Include the basic platform utility and other utilities
:::include_once 'BasicPlatformUtil.jxm'
:::include_once 'C++XBuildTool_ArduinoUtil.jxm'


##### Set flags
const __arduino__                  := 1
const __x_arduino__                := 1
const __ArduinoBuildTool_Defined__ := 1
const __BuildTool_Name__           := 'Arduino CLI'
const __BuildTool_Target__         := 'Arduino'
const __BuildTool_Title__          := 'Arduino CLI'
      __BuildTool_Version__        := 0
      __BuildTool_Version_Num__    := 0


##### Define build directory
ArduinoBuildDir := 'build'


##### Define the executables, paths, and options
ARDUINO_CLI_PATH ?:= $getenv('ARDUINO_CLI_PATH', '')

ArduinoCLIBinDir  := ''
ArduinoCLI        := 'arduino-cli'

ArduinoBuildFlags := ''


##### Function to check if 'ArduinoBuildDir' is a relative path
function __check_ArduinoBuildDir__()
    $call(__exit_error_if_not_rel_path__, ${ArduinoBuildDir}, 'ArduinoBuildDir')
endfunction


##### Get the Arduino CLI version
function __calc_arduino_cli_ver_numeric__(major, minor, patch)
    return $call(calc_ver_numeric_333, ${major}, ${minor}, ${patch})
endfunction

function __get_arduino_cli_ver_exec__()
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@${ArduinoCLI} version
    local excode := $[excode]
    $restore_sem()
    if &$[lserr] : return -1 # Check if the command turns out to be unexecutable
    return ${excode}
endfunction

function __get_arduino_cli_ver_impl__()
    # Prepare a zero result
    local result := '0' '0'
    # Get the version
    if !$exec(__get_arduino_cli_ver_exec__)
        # Get and extract the version number
        local lines := $flatten( $sflines($[stdout]) )
        local parts := $sfdots(${lines/(?s)arduino-cli.+?(\d+)\.(\d+)\.(\d+).+/$1.$2.$3/})
        local major := ${parts}<1>
        local minor := ${parts}<2>
        local patch := ${parts}<3>
        # Store the version number
        result  := $call(__calc_arduino_cli_ver_numeric__, ${major}, ${minor}, ${patch})
        result +:= :"${major}.${minor}.${patch}"
    endif
    # Return the result
    return ${result}
endfunction

function __get_arduino_cli_ver__()
    local result  := $call(__get_arduino_cli_ver_impl__)
    local numeric := ${result}<1>
    if ${numeric}
        __BuildTool_Version__     := ${result}<2>
        __BuildTool_Version_Num__ := ${numeric}
    endif
    return ${numeric}
endfunction


##### Check if the compiler version is at least/most
function arduino_cli_ver_min(major, minor, patch)
    return $cmp( ${__BuildTool_Version_Num__}, '>=', $call(__calc_arduino_cli_ver_numeric__, ${major}, ${minor}, ${patch}) )
endfunction

function arduino_cli_ver_max(major, minor, patch)
    return $cmp( ${__BuildTool_Version_Num__}, '<=', $call(__calc_arduino_cli_ver_numeric__, ${major}, ${minor}, ${patch}) )
endfunction


##### Function to ensure the sketch's build directory name contains the FQBN
function __ac_set_arduino_build_dir_fqbn__()
    if !&${ArduinoBuildDir} : return
    if !&${ArduinoFQBN}     : return
    ArduinoBuildDirFQBN := $cat_path( ~${ArduinoBuildDir}, $series(__os_name__, '-', ${ArduinoFQBN/:/_/}) )
endfunction


##### Function to initialize the project build
function init_project()
    # Determine the tool full path
    if !&${ArduinoCLIBinDir} : ArduinoCLIBinDir := ${ARDUINO_CLI_PATH}
    if  &${ArduinoCLIBinDir} : ArduinoCLI       := $cat_path(${ArduinoCLIBinDir}, ${ArduinoCLI})
    # Get the tool version
    $call(__get_arduino_cli_ver__)
    # Ensure the Arduino CLI is executable
    if !${__BuildTool_Version_Num__}
        $call(__exit_error_nup_ext__, ${ArduinoCLI}, ${ArduinoCLIBinDir}, true)
        echoln "Please use your operating system package manager to install the Arduino CLI tool or download and install it from:"
        echoln '    https://arduino.github.io/arduino-cli'
        echoln
        echoln 'Set \'ARDUINO_CLI_PATH\' to the Arduino CLI tool location if the installation location is not in the system-wide PATH.'
        echoln
        $exit(-1)
    endif
    # Check the tool version
    if !$call(arduino_cli_ver_min, 0, 30, 0)
        $call( __exit_error_ns_desc__, $flatten( {{ __c_cyan__, 'Arduino CLI', __c_white__, ' less than version' }} ), '0.30.0' )
    endif
    # Create the build directory
    $mkdir(~${ArduinoBuildDir})
    # Ensure the sketch's build directory name contains the FQBN
    $call(__ac_set_arduino_build_dir_fqbn__)
    # Set extra configuration information text
    __BuildTool_ExtraInfoName__  +:= 'Arduino CLI Path'
    __BuildTool_ExtraInfoValue__ +:= ${ArduinoCLI}
endfunction


##### Function to clean the project build (delete all the generated files)
function clean_project()
    $call         (__check_ArduinoBuildDir__)
    $rmdir_rec    (~${ArduinoBuildDir}      )
    $call         (__ac_rm_keychain_files__ )
    $clear_project(true                     )
endfunction


##### Function to enable/disable debugging
ArduinoBuildType  := 'Release'
ArduinoDebugFlags := ''

function enable_debug_info(enabled)
    if ${enabled}
        ArduinoBuildType  := 'Debug'
        ArduinoDebugFlags := '--optimize-for-debug'
    else
        ArduinoBuildType  := 'Release'
        ArduinoDebugFlags := ''
    endif
endfunction


##### Function to set the sketch directory
ArduinoSketchDir := ''

function ac_set_sketch_dir(directory)
    ArduinoSketchDir := $strim(${directory})
endfunction


##### Function to set the fully qualified board name (FQBN)
ArduinoFQBN := ''

function ac_set_fqbn(fqbn)
    # Set the FQBN
    ArduinoFQBN := $strim(${fqbn})
    # Ensure the sketch's build directory name contains the FQBN
    $call(__ac_set_arduino_build_dir_fqbn__)
endfunction


##### Function to list all supported cores
function __ac_list_all_cores_exec__()
    @${ArduinoCLI} core list
endfunction

function ac_list_all_cores()
    $cmd_stderr_chk_on()
    $exec(__ac_list_all_cores_exec__                   )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_stderr_chk_off()
endfunction


##### Function to list all supported boards
function __ac_list_all_boards_exec__(filter)
    @${ArduinoCLI} board listall ${filter}
endfunction

function ac_list_all_boards(?filter)
    $cmd_stderr_chk_on()
    $exec(__ac_list_all_boards_exec__, ${filter}       )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_stderr_chk_off()
endfunction


##### Function to list the board's details
function __ac_list_boards_details_exec__(fqbn)
    @${ArduinoCLI} board details --fqbn ${fqbn}
endfunction

function ac_list_boards_details(?fqbn)
    fqbn ?:= ${ArduinoFQBN}
    $cmd_stderr_chk_on()
    $exec(__ac_list_boards_details_exec__, ${fqbn}     )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_stderr_chk_off()
endfunction


