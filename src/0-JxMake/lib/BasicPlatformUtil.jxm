##### Default maximum number of warning and/or error messages before the build process terminates
##### (only for build systems that support it)
DEFAULT_JXMAKELIB_MAX_WARNINGS_AND_ERRORS := 5


##### A target and helper functions to show the build tool library help
target btlib_help
    $call(__btlib_help__)
endtarget

function __btlib_help_print_title_main__()
    echoln __c_magenta__ '========== Build Tool Library for ' __c_cyan__ ${__BuildTool_Title__} __c_magenta__ ' Target =========='
    echoln
endfunction

function __btlib_help_print_title_cross__()
    echoln __c_magenta__ '========== Cross-Compiler Specific Features and Options =========='
    echoln
endfunction

function __btlib_help_print_title_variables__(?addText)
    echoln __c_cyan__  'Variables ' ${addText} __c_white__ '(Evaluate Using \'' __c_green__ '${...}' __c_white__ '\')'
    echoln
endfunction

function __btlib_help_print_title_functions__(bSpcCnt, mSpcCnt, eSpcCnt, ?addText)
    echoln __c_cyan__  'Functions ' ${addText} __c_white__ '(Call Using \'' __c_green__ '$call(...)' __c_white__ '\')'
    echoln
    if $and(${bSpcCnt}, ${mSpcCnt}, ${eSpcCnt})
        local BSpc := $repeat(' ', ${bSpcCnt})
        local MSpc := $repeat(' ', ${mSpcCnt})
        local ESpc := $repeat(' ', ${eSpcCnt})
        echoln __c_green__ '    __btlib_help__' ${BSpc} '(' ${MSpc} ')' ${ESpc} __c_white__ ': show this help information'
        echoln
    endif
endfunction

function __btlib_help_print_title_targets__(eSpcCnt, ?addText)
    local ESpc := $repeat(' ', ${eSpcCnt})
    echoln __c_cyan__  'Targets ' ${addText}
    echoln
    if ${eSpcCnt}
        echoln __c_green__ '    btlib_help' ${ESpc} __c_white__ ': show this help information by executing \'' __c_green__ '$call(__btlib_help__)' __c_white__ '\''
        echoln
    endif
endfunction

function __btlib_help_print_title_note__(?addText)
    if &${addText} : addText := ." for ${addText}"
    echoln __c_cyan__ 'Note' ${addText}
    echoln
endfunction

function __btlib_help_print_note_auto_parallelize__(plural)
    plural := $csel(${plural}, 's', '')
    echoln __c_white__ '    The JxMake library ' __c_red__ 'will parallelize the build automatically' __c_white__ "; therefore, please run the above target${plural} using \'" __c_cyan__ 'jxmake' __c_white__ '\' (instead of \'' __c_cyan__ '+jxmake' __c_white__ '\').'
    echoln
endfunction

function __btlib_help_print_note_clean_build_after_path_conf_change__()
    $call(__btlib_help_print_title_note__, 'Path and Configuration Changes')
    echoln __c_white__ '    If you change the SDK path, toolchain path, or other configurations, you must clean and restart the entire project build process'
    echoln             '    to ensure that subsequent builds are performed correctly.'
    echoln
    echoln             '    This can be done by creating a target in your JxMake specification file that executes \'' __c_green__ '$call(clean_project)' __c_white__ '\' and run the target.'
    echoln             '    In some cases, you may also need to clear the whole project cache by running the build process (the JxMake specification file)'
    echoln             '    with the command line option \'' __c_yellow__ '--rm-prj-cache' __c_white__ '\' or at least \'' __c_yellow__ '--rm-jxm-cache' __c_white__ '\'.'
    echoln
endfunction

function __btlib_help_build_string_tested_version_range__(descStr, verListRange, ?forcePlural)
    # Get the number of version specifiers
    local verCnt := $part_count(${verListRange})
    if !${verCnt} : return ''
    # Determine whether to use plural form or not
    local plural := $csel( $or( ${forcePlural}, $cmp(${verCnt}, '>', 1) ), 's', '' )
    # Add color to the description string
    local descStr := __c_cyan__ ${descStr} __c_white__
    # Build the version specification string
    local sub verCntM1, ${verCnt}, 1
    local     verSpecStr
    foreach local I, V in ${verListRange}
        verSpecStr +:= __c_cyan__ ${V} __c_white__
        if ${I} == ${verCnt} : break
        if ${I} == ${verCntM1}
            if ${verCnt} > 2 ; verSpecStr +:= ', '
            else             ; verSpecStr +:= ' '
            endif
            verSpecStr +:= 'and '
        else
            verSpecStr +:= ', '
        endif
    endforeach
    # Process the range marker(s) as needed
    local const RangeMarker := '\\-'
    if !${forcePlural}
        if $str_fidx(${verSpecStr}, ${RangeMarker}) : plural := 's'
    endif
    verSpecStr := $str_replace( ${verSpecStr}, ${RangeMarker}, $flatten( { __c_white__ '-' __c_cyan__ } ) )
    # Build and return the final string
    return __c_white__ "this JxMake library should support ${descStr} version${plural} ${verSpecStr}" __c_reset__
endfunction


#####
#####
#####


##### Functions to silent '$[stderr]' and '$[stdout]' outputs (except in case of non-zero exit code);
##### affect '__conditional_print_stdxxx_and_check_excode__'
__silent_stdxxx_allsrc_except_on_error__ := false
__silent_stdxxx_syslib_except_on_error__ := true

__stdxxx_from_syslib__                   := false

function silent_stdxxx(?silent)
    silent ?:= false
    __silent_stdxxx_allsrc_except_on_error__ := ${silent}
endfunction

function silent_stdxxx_syslib(?silent)
    silent ?:= true
    __silent_stdxxx_syslib_except_on_error__ := ${silent}
endfunction

function is_all_stdxxx_silent()
    return ${__silent_stdxxx_allsrc_except_on_error__}
endfunction

function is_sys_stdxxx_silent()
    return $or(${__silent_stdxxx_allsrc_except_on_error__}, ${__silent_stdxxx_syslib_except_on_error__})
endfunction


##### Function to conditionally print '$[stderr]' and '$[stdout]' as well as exit the program if '$[excode]' is not zero
function __conditional_print_stdxxx_and_check_excode__()
    if $or( ${__silent_stdxxx_allsrc_except_on_error__}, $and(${__silent_stdxxx_syslib_except_on_error__}, ${__stdxxx_from_syslib__}) )
        if !$[excode]
            if $[cmdecho] : echoln
            return
        endif
    endif
    $call(__print_stderr_stdxxx__)
    if $[excode]  : $exit($[excode])
    if $[cmdecho] : echoln
endfunction


##### Function to unconditionally print '$[stderr]' and '$[stdout]' as well as exit the program if '$[excode]' is not zero
function __print_stdxxx_and_check_excode__()
    $call(__print_stderr_stdxxx__)
    if $[excode] : $exit($[excode])
    echoln
endfunction


##### Function to unconditionally print '$[stderr]' and '$[stdout]'
const __FilterOut_libstdcpp_NVIA__ := '.+?libstdc\\+\\+.+?no version information available.*?[\\n\\r]+'

function __print_stderr_stdxxx__()
    if !__os_linux__
        if &$[stderr] : echoln $[stderr]
        if &$[stdout] : echoln $[stdout]
    else
        local err := $re_replace($[stderr], ${__FilterOut_libstdcpp_NVIA__}, '')
        local out := $re_replace($[stdout], ${__FilterOut_libstdcpp_NVIA__}, '')
        if &${err} : echoln ${err}
        if &${out} : echoln ${out}
    endif
endfunction


##### Functions to print error message and then exit the program
function __format_exit_error_multi_whats__(whats)
    return $implode(${whats}, {{ __c_white__, '/', __c_green__ }})
endfunction

function __exit_error_nd__(what, where)
    echoln __c_white__ "\nSorry, '" __c_green__ ${what} __c_white__ '\' is ' __c_red__ 'is not defined' \
           __c_white__ ' in \'' __c_green__ ${where} __c_white__ "'!\n" __c_reset__
    $exit(-1)
endfunction

function __exit_error_nd_cmake_list__(what, where)
    local what := $flatten( {{ 'CMake:', __c_cyan__, ' list ', __c_yellow__, ${what} }} )
    $call(__exit_error_nd__, ${what}, :"${where}/CMakeLists.txt")
endfunction


function __exit_error_xx_bsjx__(what, where, whycolor, why, ?desc, ?bsver, ?bsname)
    if  &${desc}   : desc   := "${desc} "
    if !&${bsname} : bsname := 'build system/host'
    if &${where}
        if    ${bsver} ; bsver := '\' version \'' __c_cyan__ ${__BuildTool_Version__} __c_white__
        elif &${bsver} ; bsver := '\' version \'' __c_cyan__ ${bsver} __c_white__
        endif
        if $str_begwith(${bsname}, '-')
            bsname := $str_rmfchr(${bsname})
            echo   __c_white__ "\nSorry, ${desc}'" __c_green__ ${what} __c_white__ ${bsver} __c_white__ '\' is ' ${whycolor} ${why}
            echoln __c_white__ " on ${bsname} '" __c_green__ ${where} __c_white__ "!\n" __c_reset__
        elif ${bsname} &== '[SPROG]'
            echo   __c_white__ "\nSorry, ${desc}'" __c_green__ ${what} __c_white__ ${bsver} __c_white__ '\' is ' ${whycolor} ${why}
            echoln __c_white__ " by the selected '" __c_green__ ${where} __c_white__ " program!\n" __c_reset__
        else
            echo   __c_white__ "\nSorry, ${desc}'" __c_green__ ${what} __c_white__ '\' is ' ${whycolor} ${why}
            echoln __c_white__ ' for \'' __c_green__ ${where} __c_white__ "${bsver}' ${bsname}!\n" __c_reset__
        endif
    else
        if ${bsver} : bsver := ' \'' __c_cyan__ __jxm_ver_major__ . __jxm_ver_minor__ . __jxm_ver_patch__ - __jxm_ver_devel__ __c_white__ '\''
        echo   __c_white__ "\nSorry, ${desc}'" __c_green__ ${what} __c_white__ '\' is ' ${whycolor} ${why}
        echoln __c_white__ " in JxMake${bsver} loadable script libraries!\n" __c_reset__
    endif
    $exit(-1)
endfunction

function __exit_error_ni__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet implemented')
endfunction

function __exit_error_ni_ver__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet implemented', ?, true)
endfunction

function __exit_error_ni_desc__(desc, what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet implemented', ${desc})
endfunction

function __exit_error_ni_desc_ver__(desc, what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet implemented', ${desc}, true)
endfunction

function __exit_error_ni_cmake_eval__(what)
    local what := $flatten( {{ 'CMake:', __c_cyan__, ' evaluating ', __c_green__, ${what} }} )
    $call(__exit_error_xx_bsjx__, ${what}, '', __c_yellow__, 'not yet implemented', ?, true)
endfunction

function __exit_error_na__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet available')
endfunction

function __exit_error_na_ver__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet available', ?, true)
endfunction

function __exit_error_na_desc__(desc, what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet available', ${desc})
endfunction

function __exit_error_na_desc_ver__(desc, what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_yellow__, 'not yet available', ${desc}, true)
endfunction

function __exit_error_na_osna__(what, ?desc)
    local OSNameArch := __os_name__ '-' __os_arch__
    if &${desc} : what +:= ' ' ${desc}
    $call(__exit_error_na__, ${what}, ${OSNameArch})
endfunction

function __exit_error_na_path__(desc, what, where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not available', ${desc}, ?, '-path')
endfunction

function __exit_error_na_path_ver__(desc, what, where, ?ver)
    ver ?:= true
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not available', ${desc}, ${ver}, '-path')
endfunction

function __exit_error_na_dev__(what, ?noExit)
    echoln __c_white__ "\nSorry, the '" __c_green__ ${what} __c_white__ '\' device was ' __c_red__ 'not available' __c_white__ "!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_ns__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not supported')
endfunction

function __exit_error_ns_ver__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not supported', ?, true)
endfunction

function __exit_error_ns_desc__(desc, what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not supported', ${desc})
endfunction

function __exit_error_ns_desc_ver__(desc, what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not supported', ${desc}, true)
endfunction

function __exit_error_ns_benv__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not supported', ?, ?, 'build environment')
endfunction

function __exit_error_ns_sprog__(what, ?where)
    $call(__exit_error_xx_bsjx__, ${what}, ${where}, __c_red__, 'not supported', ?, ?, '[SPROG]')
