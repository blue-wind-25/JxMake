##### Functions to calculate numerical version numbers
function calc_ver_numeric_222(a, b, c)
    local eval numeric := ${a} * 10000  + ${b} * 100 + ${c} # AA.BB.CC
    return ${numeric}
endfunction

function calc_ver_numeric_333(a, b, c)
    local eval numeric := ${a} * 1000000 + ${b} * 1000 + ${c} # AAA.BBB.CCC
    return ${numeric}
endfunction

function calc_ver_numeric_338(a, b, c)
    local eval numeric := ${major} * 100000000000 + ${minor} * 100000000 + ${patch} # AAA.BBB.CCCCCCCC
    return ${numeric}
endfunction

function calc_ver_numeric_2252(a, b, c, d)
    local eval numeric := ${a} * 1000000000 + ${b} * 10000000 + ${c} * 100  + ${d} # AA.BB.CCCCC.DD
    return ${numeric}
endfunction

function calc_ver_numeric_3363(a, b, c, d)
    local eval numeric := ${a} * 1000000000000 + ${b} * 1000000000 + ${c} * 1000 + ${d} # AAA.BBB.CCCCCC.DDD
    return ${numeric}
endfunction


##### A function to get the current numerical timestamp
function get_timestamp()
    local ms := $millis()
    div   ms, ${ms}, 1000
    return ${ms}
endfunction


##### Function to format the text of section sizes and total size
function __format_section_size_text__(text)
    # Extract the lines and parts
    local lines := $strim( $sflines(${text}) )
          lines := ${lines/\s+/ /}
    local partf
    local part1 := $sfspaces(${lines}<1>)
    local part2 := $sfspaces(${lines}<2>)
    local partn := $part_count(${part1})
    dec   partn
          part1 := ${part1}<1:partn>
          part2 := ${part2}<1:partn>
    local slen1
    local slen2
    foreach local p in ${part1}
        slen1 +:= $strlen(${p})
    endforeach
    foreach local p in ${part2}
        slen2 +:= $strlen(${p})
    endforeach
    for local i := 1 to ${partn} step 1
        local     l1 := ${slen1}<i>
        local     l2 := ${slen2}<i>
        local max lm, ${l1}, ${l2}
        partf +:= ${lm}
    endfor
    # Generate the final text
    local fmt
    local text := '    ║ '
    foreach local i, part in ${part1}
        text +:= $sprintf({{ '%', ${partf}<i>, 's   ' }}, ${part})
    endforeach
    text +:= "\n    ║ "
    foreach local i, part in ${part2}
        text +:= $sprintf({{ '%', ${partf}<i>, 's   ' }}, ${part})
    endforeach
    text +:= "\n"
    # Return the final text and the text and data sizes
    return {{ $flatten(${text}), ${part2}<1:2> }}
endfunction


