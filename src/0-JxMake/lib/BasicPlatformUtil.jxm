#####
#####


##### Function to check if the given command is executable
function __cmd_is_executable__(optBinDir, chkCmd, params)
    # Append the optional directory as needed
    if &${optBinDir} : chkCmd := $cat_path(${optBinDir}, ${chkCmd})
    # Execute the command and get the exit code
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@${chkCmd} ${params}
    $nop($[excode]) # Ensure all pending commands are executed
    $restore_sem()
    # Check and return if the command can actually be executed
    return $cmp($[lserr], '&==', '')
endfunction

function cmd_is_executable(optBinDir, chkCmd, ?params)
    return $exec(__cmd_is_executable__, ${optBinDir}, ${chkCmd}, ${params})
endfunction


##### Function to check if the given command can be executed successfully
function cmd_executed_successfully(optBinDir, chkCmd, ?params)
    # Check if the given command is executable
    if !$exec(__cmd_is_executable__, ${optBinDir}, ${chkCmd}, ${params}) : return 0
    # Check if the exit code is zero
    return $cmp($[excode], '==', 0)
endfunction


##### Function to find available commands
function __find_available_commands__(basicName, regexp)
    # Simply exit if the OS is not POSIX
    if !__os_posix__ : return
    # Use 'compgen' to get the available commands
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@bash -c :"compgen -c ${basicName}"
    $nop($[excode]) # Ensure all pending commands are executed
    $restore_sem()
    # Check for error
    if $[lserr] : return
    # Process the results
              local Lines := $sflines($[stdout])
    if &${regexp} : Lines := $unique( $erase_ifnot(${Lines}, ${regexp}, true) )
    (*
              local CSelV := 1
    if &${regexp} : CSelV := $re_match(${Lines}, ${regexp})
                    Lines := $unique( $erase_ifempty( $csel(${CSelV}, ${Lines}, '') ) )
    *)
    # Return the results
    return ${Lines}
endfunction

function find_available_commands(basicName, ?regexp)
    return $exec(__find_available_commands__, ${basicName}, ${regexp})
endfunction


