#####


##### Constant to determine whether to use LD_LIBRARY_PATH or DYLD_FALLBACK_LIBRARY_PATH for 'LDLibraryPaths'
  if __os_mac__          ; const __Real_LDLibraryPath__   := 'DYLD_FALLBACK_LIBRARY_PATH'
elif __os_posix__        ; const __Real_LDLibraryPath__   := 'LD_LIBRARY_PATH'
elif __os_posix_compat__ ; const __Real_LDLibraryPath__   := 'LD_LIBRARY_PATH'
else                     ; const __Real_LDLibraryPath__   := '__DUMMY_UNUSED_LD_LIBRARY_PATH__'
endif


##### Constant to save the original 'LDLibraryPaths' value
const __LDLibraryPath_OriVal__ := $explode( $getenv(${__Real_LDLibraryPath__}, ''), __os_psep_char__ )


##### Function to get 'LDLibraryPaths' value
function __get_LDLibraryPaths__()
    local Value := $unique( $stack(~${LDLibraryPath}, ${__LDLibraryPath_OriVal__}) )
    return $implode(${Value}, __os_psep_char__)
endfunction


##### Function to conditionally return either an empty string or the concatenated 'LDLibraryPaths' value
function __ccat_LDLibraryPaths__(extraPaths)
    if !&${extraPaths} : return ''
    local Value := $unique( $stack(${extraPaths}, ~${LDLibraryPath}, ${__LDLibraryPath_OriVal__}) )
    return $implode(${Value}, __os_psep_char__)
endfunction

