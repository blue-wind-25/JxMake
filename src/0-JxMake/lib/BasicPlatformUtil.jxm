function __exit_error_nf__(what, ?noExit)
    echoln __c_white__ "\nSorry, the '" __c_green__ ${what} __c_white__ '\' was ' __c_red__ 'not found' __c_white__ "!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction


function __exit_error_nxx_str__(what)
    echo __c_white__ "\nSorry, " __c_red__ 'no usable ' __c_white__ '\'' __c_green__ ${what} __c_white__
endfunction

function __exit_error_nup__(what, ?noExit)
    $call(__exit_error_nxx_str__, ${what})
    echoln "' program was found!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_nup_ext__(what, where, ?noExit)
    if !&${where}
        $call(__exit_error_nup__, ${what}, ${noExit})
        return
    endif
    $call(__exit_error_nxx_str__, ${what})
    echoln "' program was found in '" __c_green__ ${where} __c_white__  "'!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_nut__(what, ?noExit)
    $call(__exit_error_nxx_str__, ${what})
    echoln "' tool was found!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_nut_ext__(what, where, ?noExit)
    if !&${where}
        $call(__exit_error_nut__, ${what}, ${noExit})
        return
    endif
    $call(__exit_error_nxx_str__, ${what})
    echoln "' tool was found in '" __c_green__ ${where} __c_white__  "'\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction


function __exit_error_if_not_rel_path__(path, where, ?noExit)
    if $path_is_rel(${path}) : return
    echoln __c_white__ "\nThe path specified in '" __c_green__ ${where} __c_white__ '\' must be ' __c_yellow__ 'a relative' __c_white__ " path!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_if_not_abs_path__(path, where, ?noExit)
    if $path_is_abs(${path}) : return
    echoln __c_white__ "\nThe path specified in '" __c_green__ ${where} __c_white__ '\' must be ' __c_yellow__ 'an absolute' __c_white__ " path!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction


function __exit_error_xxx_fail__(desc, what, ?noExit)
    echoln __c_white__ "\n${desc} " __c_red__ 'failed' __c_white__ ' for \'' __c_green__ ${what} __c_white__ "'!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_rest_api_fail__(?noExit)
    $call(__exit_error_xxx_fail__, 'HTTP request', 'REST API', ${noExit})
endfunction

function __exit_error_download_fail__(what, ?noExit)
    $call(__exit_error_xxx_fail__, 'Download', ${what}, ${noExit})
endfunction

function __exit_error_archive_extract_fail__(what, ?noExit)
    $call(__exit_error_xxx_fail__, 'Archive extraction', ${what}, ${noExit})
endfunction

function __exit_error_cpfile_fail__(what, ?noExit)
    $call(__exit_error_xxx_fail__, 'Copy file', ${what}, ${noExit})
endfunction

function __exit_error_build_process_fail__(what, ?noExit)
    $call(__exit_error_xxx_fail__, 'Build process', ${what}, ${noExit})
endfunction

function __exit_error_build_process_fail_ext__(what, where, ?noExit)
    if !&${where}
        $call(__exit_error_build_process_fail__, ${what}, ${noExit})
        return
    endif
    echoln __c_white__ "\nBuild process " __c_red__ 'failed' __c_white__ ' for \'' __c_green__ ${what} __c_white__ "' in '" __c_green__ ${where} __c_white__  "'!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_build_process_fail_desc__(what, desc, ?noExit)
    if !&${desc}
        $call(__exit_error_build_process_fail__, ${what}, ${noExit})
        return
    endif
    echoln __c_white__ "\nBuild process " __c_red__ 'failed' __c_white__ ' for \'' __c_green__ ${what} __c_white__ "' (${desc})!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction


function __exit_error_build_process_cancel__(what, ?why, ?noExit)
    if &${why} : why := :" because ${why}"
    echoln __c_white__ "\nBuild process " __c_yellow__ 'canceled' __c_white__ ' for \'' __c_green__ ${what} __c_white__ "'${why}!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction

function __exit_error_build_process_cancel_ext__(what, where, ?why, ?noExit)
    if !&${where}
        $call(__exit_error_build_process_cancel__, ${what}, ${noExit})
        return
    endif
    if &${why} : why := :" because ${why}"
    echoln __c_white__ "\nBuild process " __c_yellow__ 'canceled' __c_white__ ' for \'' __c_green__ ${what} __c_white__ "' in '" __c_green__ ${where} __c_white__  "'${why}!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction


function __exit_error_run_target_call_function_(targetName, funcName, ?noExit)
    echoln __c_white__ "\nPlease run the target '" __c_green__ ${targetName} __c_white__ "' before calling '" __c_green__ ${funcName} __c_white__ "'!\n" __c_reset__
    if !${noExit} : $exit(-1)
endfunction


##### Macro to exit the program by printing an error message stating that the function is not supported
.macro __exit_error_function_ns__
    $call(__exit_error_ns__, :"$[function]()", ${__BuildTool_Name__})
.endmacro


#####
#####
#####


##### A function to print indent
function print_indent(level)
    local i := 0
    while ${i} < ${level}
        inc i
        echo '    '
    endwhile
endfunction


##### A function to print indented messages
function print_indented_messages(level, ?msg)
    if !&${msg}
        $call(print_indent, ${level})
    endif
    foreach local m in ${msg}
        $call(print_indent, ${level})
        echoln ${m}
    endforeach
endfunction


##### Functions to dump a map object
function dump_map_object(mapHandle, ?deleteAfterDump)
    # Dump the object
    foreach local K in $map_keys(${mapHandle})
        $printf("[%s]\n", ${K})
        foreach local V in $map_get(${mapHandle}, ${K})
            $printf("    %s\n", ${V})
        endforeach
    endforeach
    # Delete the object as needed
    if ${deleteAfterDump} : $map_delete(${mapHandle})
endfunction

function dump_map_object_and_exit(mapHandle, ?exitCode)
    exitCode ?:= -1
    $call(dump_map_object, ${mapHandle}, true)
    $exit(${exitCode})
endfunction


##### Functions to dump map objects
function dump_map_objects(mapHandles, ?deleteAfterDump)
    foreach local mapHandle in ${mapHandles}
        $call(dump_map_object, ${mapHandle}, ${deleteAfterDump})
        echoln
    endforeach
endfunction

function dump_map_objects_and_exit(mapHandles, ?exitCode)
    exitCode ?:= -1
    $call(dump_map_objects, ${mapHandles}, true)
    $exit(${exitCode})
endfunction


##### Functions to dump a nested map object
function __dump_nmap_object__(level, mapHandle)
    # Dump the object
    local nextLevel
    local isUA
    local isMH
    local valArray
    local valCount
    local valIndex
    local valMHStr
    local keyPrint
    foreach local K in $map_keys(${mapHandle})
        add nextLevel, ${level}, 1
            isUA     := $cmp(${K}, '&==', '__Array__')
            valArray := $map_get(${mapHandle}, ${K})
            valCount := $part_count(${valArray})
            valIndex := 0
            keyPrint := 0
        foreach local val in ${valArray}
                         isMH     := $map_valid_handle(${val})
            if ${isMH} : valMHStr := ${val/(?:\000\000)(.+?)(?:\000)/──$1─/}
            if !${keyPrint}
                if $and( $not(${isUA}), ${isMH}) ; $call( print_indented_messages, ${level}, $sprintf( "[%s:%s]", ${K}, ${valMHStr} ) )
                else                             ; $call( print_indented_messages, ${level}, $sprintf( "[%s]"   , ${K}              ) )
                endif
                keyPrint := 1
            endif
            if   $and(${isUA}, ${isMH}) ; $call( print_indented_messages, ${nextLevel}, $sprintf( "#%d:%s", ${valIndex}, ${valMHStr} ) ) ; inc valIndex
            elif ${valCount} > 1        ; $call( print_indented_messages, ${nextLevel}, $sprintf( "#%d"   , ${valIndex}              ) ) ; inc valIndex
            endif
            if ${isMH} ; $call( __dump_nmap_object__   , ${nextLevel}, ${val} )
            else       ; $call( print_indented_messages, ${nextLevel}, ${val} )
            endif
        endforeach
    endforeach
    # Delete the object as needed
    if ${deleteAfterDump} : $map_delete(${mapHandle})
endfunction

function dump_nmap_object(mapHandle, ?deleteAfterDump)
    $call(__dump_nmap_object__, 0, ${mapHandle})
    if ${deleteAfterDump} : $map_delete(${mapHandle})
endfunction

function dump_nmap_object_and_exit(mapHandle, ?exitCode)
    exitCode ?:= -1
    $call(dump_nmap_object, ${mapHandle}, true)
    $exit(${exitCode})
endfunction


##### Functions to dump a BSE object
function dump_bse_object(bseHandle, ?deleteAfterDump)
    # Dump the object
    local Cursor := $bse_cursor(${bseHandle})
    local Size   := $bse_size  (${bseHandle})
    $printf("[C=%d] [N=%d]\n",${Cursor}, ${Size})
    $bse_seek_beg(${bseHandle}, 0)
    for local I := 1 to ${Size} step 1
        $printf( "%02X ", $bse_rd_uint08(${bseHandle}) )
    endfor
    if  !${Size} ; echoln '<empty>'
    else         ; echoln
    endif
    echoln
    # Delete the object as needed
    if ${deleteAfterDump} ; $bse_delete  (${bseHandle}           )
    else                  ; $bse_seek_abs(${bseHandle}, ${Cursor})
    endif
endfunction

function dump_bse_object_and_exit(bseHandle, ?exitCode)
    exitCode ?:= -1
    $call(dump_bse_object, ${bseHandle}, true)
    $exit(${exitCode})
endfunction

function dump_bse_object_ext(bseHandle, ?extraMsg, ?deleteAfterDump)
    # Print the extra message as needed
    if &${extraMsg} : echoln ${extraMsg}
    # Dump the object
    local Cursor := $bse_cursor(${bseHandle})
    local Size   := $bse_size  (${bseHandle})
    $printf("[%s] [C=%d] [N=%d]\n",${bseHandle}, ${Cursor}, ${Size})
    if !${Size}
        echoln '<empty>'
    else
        # Print the indexes
        echo '# '
        for local I := 1 to ${Size} step 1
            $printf("%02X ", ${I})
        endfor
        echoln
        # Print the values
        $bse_seek_beg(${bseHandle}, 0)
        echo '= '
        for local I := 1 to ${Size} step 1
            $printf( "%02X ", $bse_rd_uint08(${bseHandle}) )
        endfor
        echoln
        # Print the cursor
        local eval Padding := ${Cursor} - 1
        echo '  '
        for local I := 1 to ${Padding} step 1
            echo '   '
        endfor
        echoln '^^ '
    endif
    echoln
    # Delete the object or restore the cursor position
    if ${deleteAfterDump} ; $bse_delete  (${bseHandle}           )
    else                  ; $bse_seek_abs(${bseHandle}, ${Cursor})
    endif
endfunction

function dump_bse_object_ext_and_exit(bseHandle, ?extraMsg, ?exitCode)
    exitCode ?:= -1
    $call(dump_bse_object_ext, ${bseHandle}, ${extraMsg}, true)
    $exit(${exitCode})
endfunction


##### A function to print the development environment configuration summary
function print_devenv_config()
      if __os_64bit__ ; local __BuildTool_Target__ ?:= 'Native (64-Bit)'
    elif __os_32bit__ ; local __BuildTool_Target__ ?:= 'Native (32-Bit)'
    else              ; local __BuildTool_Target__ ?:= 'Native'
    endif
    echoln
    echoln    __c_white__  '========================================================================================='
    echoln    __c_white__  '=================== Summary of Development Environment Configurations ==================='
    echoln    __c_white__  '========================================================================================='
    echoln    __c_green__  'Host CPU Architecture        = ' __c_cyan__ __os_arch__
    echoln    __c_green__  'Host CPU Bit Count           = ' __c_cyan__ __os_bit_count__
    echoln    __c_green__  'Host Operating System        = ' __c_cyan__ __os_name_actual__
    echoln    __c_white__  '-----------------------------------------------------------------------------------------'
    echoln {{ __c_green__, 'Current Working    Directory = ', __c_cyan__, $cwd() }}
    echoln {{ __c_green__, 'Project Temporary  Directory = ', __c_cyan__, $ptd() }}
    echoln {{ __c_green__, 'User    Home       Directory = ', __c_cyan__, $uhd() }}
    echoln {{ __c_green__, 'JxMake  Executable Directory = ', __c_cyan__, $jxd() }}
    echoln    __c_white__  '-----------------------------------------------------------------------------------------'
    echoln    __c_green__  'Target Architecture          = ' __c_cyan__ ${__BuildTool_Target__}
    echoln    __c_green__  'Compiler Name                = ' __c_cyan__ ${__BuildTool_Name__}
    echoln    __c_green__  'Compiler Version             = ' __c_cyan__ ${__BuildTool_Version__} ' (' ${__BuildTool_Version_Num__} ')'
    if &${__BuildTool_ExtraInfoName__}
        echoln    __c_white__  '-----------------------------------------------------------------------------------------'
        foreach local I, N in ${__BuildTool_ExtraInfoName__}
            if ${N} &== '-'
                echoln __c_white__ '-----------------------------------------------------------------------------------------'
            else
                local V := $partn(${__BuildTool_ExtraInfoValue__}, ${I})
                      N := $sprintf("%-28s", ${N})
                echoln __c_green__ "${N} = " __c_cyan__ ${V}
            endif
        endforeach
    endif
    echoln __c_white__ '========================================================================================='
    echoln __c_reset__
endfunction


