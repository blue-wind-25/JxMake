##### A special string constant to indicate that the variable for the generic toolchain path should not be used
const __GTCP_NA__ := 'Generic_Toolchain_Path_is_Not_Applicable'


##### The default check interval for downloading the latest files in seconds
const JxMake_Download_ChkIntervalS := $getenv('JXMAKELIB_DOWNLOAD_CHK_INTERVAL_SECONDS', 432000) # The default is 5 days (5 * 24 * 3600 = 432000)


##### Function to extract the given file to the specified path
function extract_archive_to(filePath, dstPath, errDetail)
    local errMsg
      if $str_lidx(${filePath}, '.tar.xz' ) > 0 ; errMsg := $untxz_rec (${filePath}, ${dstPath}, false)
    elif $str_lidx(${filePath}, '.tar.bz2') > 0 ; errMsg := $untbz2_rec(${filePath}, ${dstPath}, false)
    elif $str_lidx(${filePath}, '.tar.gz' ) > 0 ; errMsg := $untgz_rec (${filePath}, ${dstPath}, false)
    elif $str_lidx(${filePath}, '.tar.zip') > 0 ; errMsg := $untzip_rec(${filePath}, ${dstPath}, false)
    elif $str_lidx(${filePath}, '.tar'    ) > 0 ; errMsg := $untar_rec (${filePath}, ${dstPath}, false)
    elif $str_lidx(${filePath}, '.zip'    ) > 0 ; errMsg := $unzip_rec (${filePath}, ${dstPath}, false)
    else                                        ; $call(__exit_error_ns_desc__, 'extracting', ${errDetail})
    endif
    if &${errMsg}
        $call(__exit_error_archive_extract_fail__, ${errDetail}, true)
        echoln ${errMsg}
        echoln
        $exit(-1)
    endif
    if !$valid_path(${dstPath}) : $call(__exit_error_archive_extract_fail__, ${errDetail})
endfunction


##### Functions to install Apple Rosetta 2
function __install_apple_rosetta_exec__()
    +@/usr/sbin/softwareupdate --install-rosetta
endfunction

function __install_apple_rosetta__()
    if !$valid_path('/Library/Apple/usr/share/rosetta') : $exec(__install_apple_rosetta_exec__)
endfunction


