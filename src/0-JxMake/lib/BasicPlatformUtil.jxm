#####
#####


##### Function to wait for the specified serial port to (re-)appear
const __WaitForSerialPort_DelayMS__ := 500

function __wait_for_serial_port_to_appear__(device, timeout_seconds)
    # Sanitize the timeout
    if ${timeout_seconds} <= 0 : timeout_seconds := 1
    # Get the start time
    local start := $millis()
    local now
    local delta
    # Loop until the port has appeared or timeout
    loop
        # Wait for a while and check if the port has appeared
        $sleep(${__WaitForSerialPort_DelayMS__})
        if $contains( $ls_serial_ports(), ${device} ) : return true
        # Check for timeout
             now   := $millis()
        eval delta := ( ${now} - ${start} + 500 ) / 1000
        if ${delta} > ${timeout_seconds} : return false
    endloop
endfunction


##### Function to check if the specified serial port exists
function __check_if_serial_port_exists__(device, ?waitDelayMS)
    # Wait for a while
    waitDelayMS ?:= ${__WaitForSerialPort_DelayMS__}
    $sleep(${waitDelayMS})
    # Check if the port does not exist
    if !$contains( $ls_serial_ports(), ${device} ) : return false
    # Wait for a while
    $sleep(${waitDelayMS})
    # Check if the port exists
    return $contains( $ls_serial_ports(), ${device} )
endfunction


