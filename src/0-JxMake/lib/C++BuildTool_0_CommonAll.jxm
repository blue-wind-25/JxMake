##### Define build directory
CppBuildDir := 'build'


##### Define the combined options
CppAssemblerFlags  = ${CppCommonAssemblerFlags}  ${CppArchFlags} ${CppWarningAsErrorFlags} ${AsmDebugFlags}
CppCcCompileFlags  = ${CppCommonCcCompileFlags}  ${CppArchFlags} ${CppWarningAsErrorFlags} ${CppDebugFlags} ${CppOptimizationFlags}
CppCxxCompileFlags = ${CppCommonCxxCompileFlags} ${CppArchFlags} ${CppWarningAsErrorFlags} ${CppDebugFlags} ${CppOptimizationFlags}


##### Function to check if 'CppBuildDir' is a relative path
function __check_CppBuildDir__()
    $call(__exit_error_if_not_rel_path__, ${CppBuildDir}, 'CppBuildDir')
endfunction


##### Function to generate the correct dependency list file name from the given base name (without extension)
function deplist_fname(baseName)
    return $series(${baseName}, '.', ${DepListFileExt})
   #return :"${baseName}.${DepListFileExt}"
endfunction

##### Function to generate the correct dependency list file path from the given base name (without extension)
function deplist_fpath(baseName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(deplist_fname, ${baseName}) )
endfunction


##### Function to generate the correct linker script file name from the given base name (without extension)
function ld_fname(baseName)
    return $series(${baseName}, '.', ${LDFileExt})
   #return :"${baseName}.${LDFileExt}"
endfunction

##### Function to generate the correct linker script file path from the given base name (without extension)
function ld_fpath(baseName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(ld_fname, ${baseName}) )
endfunction


##### Function to generate the correct object file name from the given source file name (with extension)
function obj_fname(srcFileName)
    return $series(${srcFileName}, '.', ${ObjFileExt})
   #return :"${srcFileName}.${ObjFileExt}"
endfunction

##### Function to generate the correct object file path from the given source file name (with extension)
function obj_fpath(srcFileName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(obj_fname, ${srcFileName}) )
endfunction


##### Function to generate the correct assembly source file name from the given base name (without extension)
function ssrc_fname(baseName)
    return $series(${baseName}, '.', ${AsmFileExt})
   #return :"${baseName}.${AsmFileExt}"
endfunction

##### Function to generate the correct assembly object file name from the given base name (without extension)
function sobj_fname(baseName)
    return $series(${baseName}, '.', ${AsmFileExt}, '.', ${ObjFileExt})
   #return :"${baseName}.${AsmFileExt}.${ObjFileExt}"
endfunction

##### Function to generate the correct assembly object file path from the given base name (without extension)
function sobj_fpath(baseName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(sobj_fname, ${baseName}) )
endfunction


##### Function to generate the correct glob prerequisite name to build assembly object file for shared library
function sobj_preq_glob_dlib(objFiles)
    $call(__check_CppBuildDir__)
    return $re_replace(${objFiles}, :"(.+)\.${AsmFileExt}", :"$1.shared.${AsmFileExt}")
endfunction

##### Function to generate the correct glob prerequisite name to build C object file for shared library
function cobj_preq_glob_dlib(objFiles)
    $call(__check_CppBuildDir__)
    return ${objFiles/(.+)\.c/$1.shared.c/}
endfunction

##### Function to generate the correct glob prerequisite name to build C++ object file for shared library
function cppobj_preq_glob_dlib(objFiles)
    $call(__check_CppBuildDir__)
    return ${objFiles/(.+)\.cpp/$1.shared.cpp/}
endfunction


##### Function to generate the correct glob target name to build assembly object file
function sobj_target_glob(?forSharedLibObj)
    $call(__check_CppBuildDir__)
    if ${forSharedLibObj} : return $series(${CppBuildDir}, '/%.shared.', ${AsmFileExt}, '.', ${ObjFileExt})
                            return $series(${CppBuildDir}, '/%.'       , ${AsmFileExt}, '.', ${ObjFileExt})
   #if ${forSharedLibObj} : return :"${CppBuildDir}/%.shared.${AsmFileExt}.${ObjFileExt}"
   #                        return :"${CppBuildDir}/%.${AsmFileExt}.${ObjFileExt}"
endfunction

##### Function to generate the correct glob target name to build C object file
function cobj_target_glob(?forSharedLibObj)
    $call(__check_CppBuildDir__)
    if ${forSharedLibObj} : return $series(${CppBuildDir}, '/%.shared.c.', ${ObjFileExt})
                            return $series(${CppBuildDir}, '/%.c.'       , ${ObjFileExt})
   #if ${forSharedLibObj} : return :"${CppBuildDir}/%.shared.c.${ObjFileExt}"
   #                        return :"${CppBuildDir}/%.c.${ObjFileExt}"
endfunction

##### Function to generate the correct glob target name to build C++ object file
function cppobj_target_glob(?forSharedLibObj)
    $call(__check_CppBuildDir__)
    if ${forSharedLibObj} : return $series(${CppBuildDir}, '/%.shared.cpp.', ${ObjFileExt})
                            return $series(${CppBuildDir}, '/%.cpp.'       , ${ObjFileExt})
   #if ${forSharedLibObj} : return :"${CppBuildDir}/%.shared.cpp.${ObjFileExt}"
   #                        return :"${CppBuildDir}/%.cpp.${ObjFileExt}"
endfunction


##### Function to generate the correct glob target name to build C++20 system header unit
function cpp20syshu_target_glob()
    $call(__check_CppBuildDir__)
    return :"${CppBuildDir}/%.sys.unit"
endfunction

##### Function to generate the correct glob target name to build C++20 user header unit
function cpp20usrhu_target_glob()
    $call(__check_CppBuildDir__)
    return :"${CppBuildDir}/%.h.usr.unit"
endfunction


##### Function to generate the correct executable file name from the given base name (without extension)
function exe_fname(baseName)
    return $series(${baseName}, '.', ${ExeFileExt})
   #return :"${baseName}.${ExeFileExt}"
endfunction

##### Function to generate the correct executable file path from the given base name (without extension)
function exe_fpath(baseName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(exe_fname, ${baseName}) )
endfunction


##### Function to generate the correct shared library file name from the given base name (without extension)
function dlib_fname(baseName)
    return $series(${LibFilePrefix}, ${baseName}, '.', ${DLibFileExt})
   #return :"${LibFilePrefix}${baseName}.${DLibFileExt}"
endfunction

##### Function to generate the correct shared library file path from the given base name (without extension)
function dlib_fpath(baseName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(dlib_fname, ${baseName}) )
endfunction


##### Function to generate the correct static library file name from the given base name (without extension)
function slib_fname(baseName)
    return $series(${LibFilePrefix}, ${baseName}, '.', ${SLibFileExt})
   #return :"${LibFilePrefix}${baseName}.${SLibFileExt}"
endfunction

##### Function to generate the correct static library file path from the given base name (without extension)
function slib_fpath(baseName)
    $call(__check_CppBuildDir__)
    return $cat_path( ${CppBuildDir}, $call(slib_fname, ${baseName}) )
endfunction


##### Function to generate the correct link flag to use linker script from the given source file name (with extension)
function use_ld(srcFileName)
    return $series('-T', ~${srcFileName})
endfunction


##### Function to demangle C++ symbol string
function cpp_demangle(symbolStr)
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
    local DemangleStr := $exec( __cpp_demangle__, ${symbolStr}, $call(__get_LDLibraryPaths__) ) # Call the platform-specific function implementation
    $restore_sem()
    return ${DemangleStr}
endfunction


#####
#####
#####


##### Function to get the compiler version
function __get_cpp_compiler_ver__(?doNotUseCache)
    if $or( $not(${__BuildTool_Version_Num__}), ${doNotUseCache} )
        local result  := $call(__get_cpp_compiler_ver_impl__)
        local numeric := $partn(${result}, 1)
        if ${numeric}
            __BuildTool_Version__     := $partn(${result}, 2)
            __BuildTool_Version_Num__ := ${numeric}
            return ${__BuildTool_Version_Num__}
        endif
    endif
    if ${doNotUseCache} : return 0
    return ${__BuildTool_Version_Num__}
endfunction


##### Functions to ensure the executable are rebuilt if the linked libraries are updated
const __Executable_DLib_SLib_Depend_FilePath__ :=  $cat_path( $ptd(), 'exe_slib_dlib.depend' )

function __store_exe_dlib_slib_depend__()
    # Load/create the map
    if $valid_path(${__Executable_DLib_SLib_Depend_FilePath__}) ; local mh := $map_from_edata( $get_file(${__Executable_DLib_SLib_Depend_FilePath__}) )
    else                                                        ; local mh := $map_new()
    endif
    # Add entries to the map
    local dl := $call(dlib_fpath, ${CppUsrSharedLib})
    local sl := $call(slib_fpath, ${CppUsrStaticLib})
    $map_add( ${mh}, '__ExecutableList__', ~$[target]           )
    $map_add( ${mh}, ~$[target]          , {{ ~${dl}, ~${sl} }} )
    # Save the map
    $put_file(${__Executable_DLib_SLib_Depend_FilePath__}, $map_to_edata(${mh}) )
    # Delete the map
    $map_delete(${mh})
endfunction

function __check_exe_dlib_slib_depend__()
    # Exit if the file does not exist
    if !$valid_path(${__Executable_DLib_SLib_Depend_FilePath__}) : return
    # Load the map
        local mh := $map_from_edata( $get_file(${__Executable_DLib_SLib_Depend_FilePath__}) )
    # Delete the executables that depends on the library
    foreach local exe in $map_get(${mh}, '__ExecutableList__')
        if $contains( $map_get(${mh}, ${exe}), ~$[target]) : $rmfile(${exe})
    endforeach
    # Delete the map
    $map_delete(${mh})
endfunction


#####
#####
#####


##### Function to initialize the project build
function init_project(?buildSubdirectories)
    # Set additional LD paths as needed
    if !__os_windows__
        if &${CppToolBinDir}
            if !&${LDLibraryPath}
                LDLibraryPath +:= $cat_path(${CppToolBinDir}, '../lib'  )
                LDLibraryPath +:= $cat_path(${CppToolBinDir}, '../lib64')
            endif
        endif
    endif
    # Get the compiler version
    $call(__get_cpp_compiler_ver__)
    if !${__BuildTool_Version_Num__} : $call(__exit_error_nup_ext__, ${CppCxxCompiler}, ${CppToolBinDir})
    # Create the build directory
    if &${buildSubdirectories}
        $mkdir( $cat_path(~${CppBuildDir}, ${buildSubdirectories} ) )
    else
        $mkdir(~${CppBuildDir})
    endif
endfunction


##### Function to clean the project build (delete all the generated files)
function clean_project()
    $call         (__check_CppBuildDir__)
    $call         (__clean_project__    )
    $rmdir_rec    (~${CppBuildDir}      )
    $clear_project(true                 )
endfunction


