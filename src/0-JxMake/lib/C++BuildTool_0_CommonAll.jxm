            echoln __c_green__ '    select_optimization     (level                     ' ${spc1} ') ' __c_white__ ': select the optimization level (' __c_yellow__ 'none' __c_white__ '/' __c_yellow__ 'size' __c_white__ '/' __c_yellow__ 'speed' __c_white__ ')'
            echoln
            echoln __c_green__ '    select_c_langstd        (langstd, ?gnu             ' ${spc1} ') ' __c_white__ ': select the C   language standard (for non MSVC) (' __c_yellow__ 'c89' __c_white__ '/' __c_yellow__ 'c90' __c_white__ '/' __c_yellow__ 'c95' __c_white__ '/' __c_yellow__ 'c99' __c_white__ '/' __c_yellow__ 'c11' __c_white__ '/' __c_yellow__ 'c17' __c_white__ '/' __c_yellow__ 'c23' __c_white__ ')               - the default is platform-specific'
            echoln __c_green__ '    select_cxx_langstd      (langstd, ?gnu             ' ${spc1} ') ' __c_white__ ': select the C++ language standard (for non MSVC) (' __c_yellow__ 'c++98' __c_white__ '/' __c_yellow__ 'c++03' __c_white__ '/' __c_yellow__ 'c++11' __c_white__ '/' __c_yellow__ 'c++14' __c_white__ '/' __c_yellow__ 'c++17' __c_white__ '/' __c_yellow__ 'c++20' __c_white__ '/' __c_yellow__ 'c++23' __c_white__ ') - the default is platform-specific'
            echoln
            echoln __c_green__ '    select_c_langstd        (langstd, ?dummyIgnored    ' ${spc1} ') ' __c_white__ ': select the C   language standard (for     MSVC) (' __c_yellow__ 'c89' __c_white__ '/' __c_yellow__ 'c90' __c_white__ '/' __c_yellow__ 'c95' __c_white__ '/' __c_yellow__ 'c99' __c_white__ '/' __c_yellow__ 'c11' __c_white__ '/' __c_yellow__ 'c17' __c_white__ '/' __c_yellow__ 'c23' __c_white__ ')               - the default is platform-specific'
            echoln __c_green__ '    select_cxx_langstd      (langstd, ?dummyIgnored    ' ${spc1} ') ' __c_white__ ': select the C++ language standard (for     MSVC) (' __c_yellow__ 'c++98' __c_white__ '/' __c_yellow__ 'c++03' __c_white__ '/' __c_yellow__ 'c++11' __c_white__ '/' __c_yellow__ 'c++14' __c_white__ '/' __c_yellow__ 'c++17' __c_white__ '/' __c_yellow__ 'c++20' __c_white__ '/' __c_yellow__ 'c++23' __c_white__ ') - the default is platform-specific'
            echoln
            echoln __c_green__ '    compile_ld              (?extraOptions             ' ${spc1} ') ' __c_white__ ': compile a  linker script source code (for GCC & Clang only)'
            echoln __c_green__ '    compile_s               (?extraOptions             ' ${spc1} ') ' __c_white__ ': compile an assembly      source code'
    if !${noSharedLib}
            echoln __c_green__ '    compile_c               (?extraOptions, ?forSharedLibObj) '       __c_white__ ': compile a  C             source code'
            echoln __c_green__ '    compile_cpp             (?extraOptions, ?forSharedLibObj) '       __c_white__ ': compile a  C++           source code'
        if !${noCpp20M}
            echoln __c_green__ '    compile_cpp20m          (?extraOptions, ?forSharedLibObj) '       __c_white__ ': compile a  C++20 module  source code'
        endif
    else
            echoln __c_green__ '    compile_c               (?extraOptions             ' ${spc1} ') ' __c_white__ ': compile a  C             source code'
            echoln __c_green__ '    compile_cpp             (?extraOptions             ' ${spc1} ') ' __c_white__ ': compile a  C++           source code'
        if !${noCpp20M}
            echoln __c_green__ '    compile_cpp20m          (?extraOptions             ' ${spc1} ') ' __c_white__ ': compile a  C++20 module  source code'
        endif
    endif
    if !${noCpp20M}
            echoln __c_green__ '    compile_sys_hunit       (                          ' ${spc1} ') ' __c_white__ ': compile a  C++20         system header unit'
            echoln __c_green__ '    compile_usr_hunit       (                          ' ${spc1} ') ' __c_white__ ': compile a  C++20         user   header unit'
    endif
            echoln
            echoln __c_green__ '    use_ld                  (srcFileName               ' ${spc1} ') ' __c_white__ ': generate the correct link flag to use linker script from the given source file name (with extension) (for GCC & Clang only)'
            echoln
            echoln __c_green__ '    link_exe                (?extraOptions             ' ${spc1} ') ' __c_white__ ': link an executable'
    if !${noSharedLib}
            echoln __c_green__ '    link_dlib               (?extraOptions             ' ${spc1} ') ' __c_white__ ': link a shared library'
    endif
            echoln __c_green__ '    link_slib               (                          ' ${spc1} ') ' __c_white__ ': link a static library'
    if !${noRunExe}
            echoln __c_green__ '    run_exe                 (progName                  ' ${spc1} ') ' __c_white__ ': run the given executable file'
    endif
    if ${__CPP_BTLIB_HELP_EN_gen_lst__}
            echoln
            echoln __c_green__ '    gen_lst                 (progName                  ' ${spc1} ') ' __c_white__ ': generate a listing file from the given executable file'
    endif
    if &${userExtraFuncs} : $call(${userExtraFuncs})
            echoln
            echoln __c_green__ '    cpp_demangle            (symbolStr                 ' ${spc1} ') ' __c_white__ ': demangle the given C++ symbol string'
            echoln
            $call(__btlib_help_print_title_targets__, 1)
            $call(__btlib_help_print_note_clean_build_after_path_conf_change__)
            echoln __c_reset__
endfunction
