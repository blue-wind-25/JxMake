            echoln __c_green__ '    cpp_compiler_ver_max    (mj, mn1, mn2, ?mn3        ' ${spc1} ') ' __c_white__ ': check if the C/C++ compiler version is at most  ' __c_yellow__ '<major>.<minor1>.<minor2>.<minor3>' __c_white__ ' (for     MSVC)'
    else
            echoln __c_green__ '    cpp_compiler_ver_min    (mj, mn , pl, ?dummyIgnored' ${spc1} ') ' __c_white__ ': check if the C/C++ compiler version is at least ' __c_yellow__ '<major>.<minor>.<patch>'
            echoln __c_green__ '    cpp_compiler_ver_max    (mj, mn , pl, ?dummyIgnored' ${spc1} ') ' __c_white__ ': check if the C/C++ compiler version is at most  ' __c_yellow__ '<major>.<minor>.<patch>'
    endif
            echoln
            echoln __c_green__ '    deplist_fname           (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct          dependency list file name from the given base   name (without extension)'
            echoln __c_green__ '    deplist_fpath           (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct          dependency list file path from the given base   name (without extension)'
            echoln
            echoln __c_green__ '    ld_fname                (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct output   linker script   file name from the given base   name (without extension) (for GCC & Clang only)'
            echoln __c_green__ '    ld_fpath                (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct output   linker script   file path from the given base   name (without extension) (for GCC & Clang only)'
            echoln
            echoln __c_green__ '    obj_fname               (srcFileName               ' ${spc1} ') ' __c_white__ ': generate the correct          object          file name from the given source name (with    extension)'
            echoln __c_green__ '    obj_fpath               (srcFileName               ' ${spc1} ') ' __c_white__ ': generate the correct          object          file path from the given source name (with    extension)'
            echoln
            echoln __c_green__ '    ssrc_fname              (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct assembly source          file name from the given base   name (without extension)'
            echoln __c_green__ '    sobj_fname              (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct assembly object          file name from the given base   name (without extension)'
            echoln __c_green__ '    sobj_fpath              (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct assembly object          file path from the given base   name (without extension)'
            echoln
            echoln __c_green__ '    exe_fname               (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct          executable      file name from the given base   name (without extension)'
            echoln __c_green__ '    exe_fpath               (baseName                  ' ${spc1} ') ' __c_white__ ': generate the correct          executable      file path from the given base   name (without extension)'
            echoln
    if !${noSharedLib}
