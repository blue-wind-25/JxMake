            echoln __c_green__ '    treat_warnings_as_errors(enabled                   ' ${spc1} ') ' __c_white__ ': enable/disable treat all warnings as errors - the default is disabled'
            echoln __c_green__ '    enable_debug_info       (enabled                   ' ${spc1} ') ' __c_white__ ': enable/disable debugging information        - the default is disabled'
