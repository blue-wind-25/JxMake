##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__(?hideComSel, ?noCpp20M, ?noSharedLib, ?noRunExe, ?userCompSel, ?userExtraFuncs)
            $call(__btlib_help_print_title_main__)
            $call(__btlib_help_print_title_variables__)
    if !${hideComSel}
            echoln __c_green__ '    PreferClang               ' __c_white__ ': the default compiler in POSIX system is GCC, set this variable to a non-zero value to use Clang before \'' __c_green__ ':::include <C++BuildTool>' __c_white__ '\''
            echoln
            echoln __c_green__ '    __gcc__                   ' __c_white__ ': evaluate to the value ' __c_yellow__ '1' __c_white__ ' in case the C/C++ compiler is GCC'
            echoln __c_green__ '    __clang__                 ' __c_white__ ': evaluate to the value ' __c_yellow__ '1' __c_white__ ' in case the C/C++ compiler is Clang'
            echoln __c_green__ '    __msvc__                  ' __c_white__ ': evaluate to the value ' __c_yellow__ '1' __c_white__ ' in case the C/C++ compiler is MSVC'
            echoln
    endif
    if &${userCompSel}
            $call(${userCompSel})
            echoln
    endif
            echoln __c_green__ '    __BuildTool_Name__        ' __c_white__ ': evaluate to the C/C++ compiler name'
            echoln __c_green__ '    __BuildTool_Version__     ' __c_white__ ': evaluate to the C/C++ compiler version'
            echoln __c_green__ '    __BuildTool_Version_Num__ ' __c_white__ ': evaluate to the C/C++ compiler version (in the form of combined numeric value)'
            echoln __c_green__ '    __BuildTool_Target__      ' __c_white__ ': evaluate to the target architecture'
            echoln
            echoln __c_green__ '    LDLibraryPath             ' __c_white__ ': set additional paths which the linker should look in to when executing programs (POSIX only)'
            echoln
            echoln __c_green__ '    CppAssembler              ' __c_white__ ': executable file name for the C/C++ compatible assembler - the default value is platform-specific'
            echoln __c_green__ '    CppCcCompiler             ' __c_white__ ': executable file name for the C     compiler             - the default value is platform-specific'
            echoln __c_green__ '    CppCxxCompiler            ' __c_white__ ': executable file name for the C++   compiler             - the default value is platform-specific'
            echoln __c_green__ '    SLibBuilder               ' __c_white__ ': executable file name for the static library builder     - the default value is platform-specific'
            echoln
            echoln __c_green__ '    CppBuildDir               ' __c_white__ ': set the build directory under the source tree                  - the default is \'' __c_yellow__ 'build' __c_white__ '\'; can only be changed before calling \'' __c_green__ 'init_project' __c_white__ '\''
            echoln __c_green__ '    CppToolBinDir             ' __c_white__ ': set the location of the C/C++ binaries        (non MSVC  only) - the default is empty (use the system\'s default)'
            echoln __c_green__ '    CppLDToolBin              ' __c_white__ ': set the location of the LD    binaries        (    Clang only) - the default is empty (use the system\'s default)'
            echoln
            echoln __c_green__ '    CppSysHeaderDir           ' __c_white__ ': set the system header file locations'
            echoln
    if !${noSharedLib}
            echoln __c_green__ '    CppSysSharedLib           ' __c_white__ ': set the system shared library files'
            echoln __c_green__ '    CppSysSharedLibDir        ' __c_white__ ': set the system shared library locations'
    endif
            echoln __c_green__ '    CppSysStaticLib           ' __c_white__ ': set the system static library files'
            echoln __c_green__ '    CppSysStaticLibDir        ' __c_white__ ': set the system static library locations'
            echoln
    if !${noSharedLib}
            echoln __c_green__ '    CppUsrSharedLib           ' __c_white__ ': set the user shared library files'
            echoln __c_green__ '    CppUsrSharedLibDir        ' __c_white__ ': set the user shared library locations'
    endif
            echoln __c_green__ '    CppUsrStaticLib           ' __c_white__ ': set the user system static library files'
            echoln __c_green__ '    CppUsrStaticLibDir        ' __c_white__ ': set the user static library locations'
            echoln
    if !${noSharedLib}
            local lenf := 31
            local spc1 := '     '
            local spc2 := ' '
    else
            local lenf := 26
            local spc1 := ''
            local spc2 := ''
    endif
            $call(__btlib_help_print_title_functions__, 10, ${lenf}, 1)
            echoln __c_green__ '    init_project            (?buildSubdirectories      ' ${spc1} ') ' __c_white__ ': initialize the project build; ' __c_red__ 'must be called first and as early as possible' __c_white__ ' (after changing the global values of the'
            echoln __c_green__ '                                                       ' ${spc1} '  ' __c_white__ '  above variables, if necessary)'
            echoln __c_green__ '    clean_project           (                          ' ${spc1} ') ' __c_white__ ': clean the project build (delete all the generated files)'
            echoln __c_green__ '    print_devenv_config     (                          ' ${spc1} ') ' __c_white__ ': print the development environment configuration summary; must only be called after \'' __c_green__ 'init_project' __c_white__ '\''
            echoln
            echoln __c_green__ '    silent_stdxxx           (?silent                   ' ${spc1} ') ' __c_white__ ': silent/unsilent all    stderr/stdout outputs, unless the exit code is non-zero - the default is \'' __c_green__ 'false' __c_white__ '\''
            echoln __c_green__ '    silent_stdxxx_syslib    (?silent                   ' ${spc1} ') ' __c_white__ ': silent/unsilent system stderr/stdout outputs, unless the exit code is non-zero - the default is \'' __c_green__ 'true' __c_white__ '\''
