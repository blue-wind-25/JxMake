##### Set flags
const __msvc__                  := 1
const __CppBuildTool_Defined__  := 1
const __BuildTool_Name__        := 'Microsoft(R) Visual C++(R)'
      __BuildTool_Version__     := 0
      __BuildTool_Version_Num__ := 0


#####
#####
#####


##### Function to define macros
function def_macro(name, ?value)
    value ?:= 1
    return :"/D${name}=${value}"
endfunction


##### Function to select whether to treat warnings as errors
CppWarningAsErrorFlags := ''

function treat_warnings_as_errors(enabled)
    if ${enabled} ; CppWarningAsErrorFlags := '/WX'
    else          ; CppWarningAsErrorFlags := ''
    endif
endfunction


##### Function to enable/disable debugging
CppBuildType  := 'Release'

AsmDebugFlags := '/DNDEBUG'
CppDebugFlags := '/DNDEBUG'

function enable_debug_info(enabled)
    if ${enabled}
        CppBuildType  := 'Debug'
        AsmDebugFlags := '/Zd' '/Zi' '/DDEBUG'
        CppDebugFlags :=       '/Zi' '/DDEBUG'
    else
        CppBuildType  := 'Release'
        AsmDebugFlags :=            '/DNDEBUG'
        CppDebugFlags :=            '/DNDEBUG'
    endif
endfunction


##### Function to select optimization level
CppOptimizationFlags := '/O1'

function select_optimization(level)
    if ${level} &== 'none'
        CppOptimizationFlags := '/Od'
    elif ${level} &== 'size'
        CppOptimizationFlags := '/O1'
    elif ${level} &== 'speed'
        CppOptimizationFlags := '/O2'
    else
        CppOptimizationFlags := ${level}
    endif
endfunction


##### Function to select language standard
(*
 * The '/std' options are available in Microsoft(R) Visual Studio(R) 2017 and later; it does
 * not support standards modes earlier than C++14:
 *     https://learn.microsoft.com/en-us/cpp/build/reference/std-specify-language-standard-version?view=msvc-170
 * The front part of version number printed by 'cl.exe' seems to match the '_MSC_VER' value:
 *     https://en.wikipedia.org/wiki/Microsoft_Visual_C%2B%2B#Internal_version_numbering
 *     https://blog.knatten.org/2022/08/26/microsoft-c-versions-explained
 *     https://stackoverflow.com/a/49990327
 *)
CppCcLangStdFlags  := ''
CppCxxLangStdFlags := ''

function select_c_langstd(langstd, ?dummyIgnored)
    if !$call(cpp_compiler_ver_min, 19, 28, 0, 0) : return
    if ${langstd} &== 'c89'
        CppCcLangStdFlags := ''
    elif ${langstd} &== 'c90'
        CppCcLangStdFlags := ''
    elif ${langstd} &== 'c95'
        CppCcLangStdFlags := ''
    elif ${langstd} &== 'c99'
        CppCcLangStdFlags := ''
    elif ${langstd} &== 'c11'
        CppCcLangStdFlags := '/std:c11'
    elif ${langstd} &== 'c17'
        CppCcLangStdFlags := '/std:c17'
    elif ${langstd} &== 'c23'
        CppCcLangStdFlags := '/std:c23'
    else
        CppCcLangStdFlags := ${langstd}
    endif
endfunction

function select_cxx_langstd(langstd, ?dummyIgnored)
    if !$call(cpp_compiler_ver_min, 19, 10, 0, 0) : return
    if ${langstd} &== 'c++98'
        CppCxxLangStdFlags := ''
    elif ${langstd} &== 'c++03'
        CppCxxLangStdFlags := ''
    elif ${langstd} &== 'c++11'
        CppCxxLangStdFlags := '/std:c++14'
    elif ${langstd} &== 'c++14'
        CppCxxLangStdFlags := '/std:c++14'
    elif ${langstd} &== 'c++17'
        if $call(cpp_compiler_ver_min, 19, 11, 0, 0)
            CppCxxLangStdFlags := '/std:c++17'
        else
            CppCxxLangStdFlags := '/std:c++latest'
        endif
    elif ${langstd} &== 'c++20'
        if $call(cpp_compiler_ver_min, 19, 30, 0, 0)
            CppCxxLangStdFlags := '/std:c++20'
        else
            CppCxxLangStdFlags := '/std:c++latest'
        endif
    elif ${langstd} &== 'c++23'
        CppCxxLangStdFlags := '/std:c++latest'
    else
        CppCxxLangStdFlags := ${langstd}
    endif
endfunction


##### Functions to get the compiler version and target architecture
function __calc_cpp_compiler_ver_numeric__(major, minor1, minor2, minor3)
    return $call(calc_ver_numeric_2252, ${major}, ${minor1}, ${minor2}, ${minor3})
endfunction

function __get_cpp_compiler_info_exec__()
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@${CppCxxCompiler}
    local excode := $[excode]
    $restore_sem()
    return ${excode}
endfunction

function __get_cpp_compiler_arch__()
    # Get the architecture
    if !$exec(__get_cpp_compiler_info_exec__)
        local     text := $partn( $erase_ifempty( $sflines($[stderr]) ), 1 )
        local     len  := $strlen(${text})
        local sub pos, ${len}, 4
        if $str_lidx(${text}, 'arm64') == ${pos} : return 'arm64'
              sub pos, ${len}, 2
        if $str_lidx(${text}, 'arm'  ) == ${pos} : return 'arm'
        if $str_lidx(${text}, 'x64'  ) == ${pos} : return 'x64'
        if $str_lidx(${text}, 'x86'  ) == ${pos} : return 'x86'
    endif
    echoln "\nERROR: unknown target architecture from text:"
    echoln "${text}\n"
    $exit(-1)
endfunction

function __get_cpp_compiler_ver_impl__()
    # Prepare a zero result
    local result := '0' '0'
    # Get the version
    if !$exec(__get_cpp_compiler_info_exec__)
        local text   := $partn( $erase_ifempty( $sflines($[stderr]) ), 1 )
              text   := $sfdots(${text/(?:.+?\s)(\d+\.\d+\.\d+(\.\d+)?)(?:.*)/$1/})
        local major  := $partn(${text}, 1)
        local minor1 := $partn(${text}, 2)
        local minor2 := $partn(${text}, 3)
        local minor3 := $partn(${text}, 4)
        result := $call(__calc_cpp_compiler_ver_numeric__, ${major}, ${minor1}, ${minor2}, ${minor3})
        if &${minor3}
            result +:= :"${major}.${minor1}.${minor2}.${minor3}"
        else
            result +:= :"${major}.${minor1}.${minor2}"
        endif
    endif
    # Return the version
    return ${result}
endfunction


##### Check if the compiler version is at least/most
function cpp_compiler_ver_min(major, minor1, minor2, ?minor3)
    minor3 ?:= 0
    return $cmp( ${__BuildTool_Version_Num__}, '>=', $call(__calc_cpp_compiler_ver_numeric__, ${major}, ${minor1}, ${minor2}, ${minor3}) )
endfunction

function cpp_compiler_ver_max(major, minor1, minor2, ?minor3)
    minor3 ?:= 0
    return $cmp( ${__BuildTool_Version_Num__}, '<=', $call(__calc_cpp_compiler_ver_numeric__, ${major}, ${minor1}, ${minor2}, ${minor3}) )
endfunction


##### Define the dependency list file extension
DepListFileExt := dep

##### Define the object, executable, and library file extensions
AsmFileExt  := asm
ObjFileExt  := obj
ExeFileExt  := exe
SLibFileExt := lib
DLibFileExt := dll

##### Define the library file name prefix
LibFilePrefix := ''

##### Define the module file extension
ModFileExt := ifc


##### Define the executables, paths, and options
CppToolBinDir            := ''
CppLDToolBin             := ''

CppAssembler             := 'ml'
CppCommonAssemblerFlags  := '/nologo' '/Cp' '/Cx' '/W3' '/WX'

CppCcCompiler            := 'cl'
CppCommonCcCompileFlags  := '/nologo' '/EHsc'     '/W4' '/WX'

CppCxxCompiler           := 'cl'
CppCommonCxxCompileFlags := '/nologo' '/EHsc'     '/W4' '/WX'
CppCxx20MCompileFlags    := ''

CppLinker                := 'cl'
CppCommonLinkFlags       := '/nologo'                   '/WX'
CppDemangler             := 'undname'

CppSysHeaderDir          := ''

CppSysSharedLib          := ''
CppSysStaticLib          := ''
CppSysSharedLibDir       := ''
CppSysStaticLibDir       := ''

CppUsrSharedLib          := ''
CppUsrStaticLib          := ''
CppUsrSharedLibDir        = ${CppBuildDir}
CppUsrStaticLibDir        = ${CppBuildDir}

SLibBuilder              := 'lib'
SLibBuilderCommonFlags   := '/nologo'


##### These functions are not supported by SDCC
