##### Function to compile C source codes
function __compile_c__(extraOptions, forSharedLibObj)
    local I := $path_ndsep( $abs_path( $stack(__include_paths__, ${CppSysHeaderDir}) ) )
          I := ${I/(.+)/\/I$1/}
   +@${CppCcCompiler} ${CppCcCompileFlags} ${I} ${CppCcLangStdFlags} ${extraOptions} :"/Fo~$[target]" /c ~$[preq*]
endfunction

function compile_c(?extraOptions, ?forSharedLibObj)
    $call(__bpt_cc__                                        )
    $exec(__compile_c__, ${extraOptions}, ${forSharedLibObj})
    $call(__conditional_print_stdxxx_and_check_excode__     )
endfunction


##### Function to compile C++ and C++20 source codes
function __compile_cpp__(cpp20m, extraOptions, forSharedLibObj)
    local I := $path_ndsep( $abs_path( $stack(__include_paths__, ${CppSysHeaderDir}) ) )
          I := ${I/(.+)/\/I$1/}
   +@${CppCxxCompiler} ${CppCxxCompileFlags} ${I} ${CppCxxLangStdFlags} ${extraOptions} :"/Fo~$[target]" /c ~$[preq*]
endfunction

function compile_cpp(?extraOptions, ?forSharedLibObj)
    $call(__bpt_cxx__                                                )
    $exec(__compile_cpp__, false, ${extraOptions}, ${forSharedLibObj})
    $call(__conditional_print_stdxxx_and_check_excode__              )
endfunction

function compile_cpp20m(?extraOptions, ?forSharedLibObj)
    (*
     * https://visualstudio.microsoft.com/downloads
     * https://c2rsetup.officeapps.live.com/c2r/downloadVS.aspx?sku=community&channel=Release&version=VS2022&source=VSLandingPage&includeRecommended=true&cid=2030:79999d322bd84b4ca2d5f2bb6a4373a6
     *
     * https://devblogs.microsoft.com/cppblog/standard-c20-modules-support-with-msvc-in-visual-studio-2019-version-16-8
     * https://devblogs.microsoft.com/cppblog/using-cpp-modules-in-msvc-from-the-command-line-part-1
     *
     * https://learn.microsoft.com/en-us/cpp/build/reference/module-reference?view=msvc-160
     * https://learn.microsoft.com/en-us/cpp/build/reference/module-exportheader?view=msvc-160
     * https://learn.microsoft.com/en-us/cpp/build/reference/headername?view=msvc-160
     *
     * /interface         Tells the compiler that the input file is a module interface unit.
     * /internalPartition Tells the compiler that the input file is an internal partition unit.
     * /reference         Provides the compiler with an IFC file to reference for the nominated module interface name.
     * /ifcSearchDir      When the compiler falls back to implicit module interface search, directories specified by this option will be used.
     * /ifcOutput         Tells the compiler where the IFC resulting from compilation should go. If that destination is a directory the compiler will generate a name based on the interface name or the header unit name.
     * /ifcOnly           Instructs the compiler to only produce an IFC as the result of compilation. No other outputs will be produced as the result of compilation even if other options are specified.
     * /exportHeader      Instructs the compiler to create a header unit from the input.
     * /headerName        Tells the compiler that the input designates the name of a header.
     *)
    ##### !!! TODO !!! #####
    $call(__exit_error_ni__, :"$[function]()", ${__BuildTool_Name__})
    $call(__bpt_cxx20m__                                            )
endfunction


##### Function to link executable and shared library files
function __link_pe__(extraOptions, genSharedLib)
    local AllLibDir
    local AllLibLst
    if &${SharedLib}
        AllLibDir +:= ${SharedLibDir}
        AllLibLst +:= ${SharedLib/(.+)/$1.\${SLibFileExt}/}
    endif
    if &${StaticLib}
        AllLibDir +:= ${StaticLibDir}
        AllLibLst +:= ${StaticLib/(.+)/$1.\${SLibFileExt}/}
    endif
    if &${AllLibDir}
        AllLibDir := $series('/LIBPATH:', ~${AllLibDir})
    endif
    local OutFile := ~$[target]
          OutFile := :"/Fe${OutFile}"
    if ${genSharedLib}
        +@${CppLinker} ${CppCommonLinkFlags} ${extraOptions} ~$[preq*] ~${CppExtraLinkObjects} ${AllLibLst} ${OutFile} /LD   ${AllLibDir}
    else
        +@${CppLinker} ${CppCommonLinkFlags} ${extraOptions} ~$[preq*] ~${CppExtraLinkObjects} ${AllLibLst} ${OutFile} /link ${AllLibDir}
    endif
    #/SUBSYSTEM:CONSOLE
endfunction

function link_exe(?extraOptions)
    local SharedLib    := $stack(${CppSysSharedLib}   , ${CppUsrSharedLib}   )
    local StaticLib    := $stack(${CppSysStaticLib}   , ${CppUsrStaticLib}   )
    local SharedLibDir := $stack(${CppSysSharedLibDir}, ${CppUsrSharedLibDir})
    local StaticLibDir := $stack(${CppSysStaticLibDir}, ${CppUsrStaticLibDir})
    $call(__bpt_link_exe__                             )
    $exec(__link_pe__, ${extraOptions}, false          )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $call(__store_exe_dlib_slib_depend__               )
endfunction

function link_dlib(?extraOptions)
    local SharedLib    := ${CppSysSharedLib}
    local StaticLib    := ${CppSysStaticLib}
    local SharedLibDir := ${CppSysSharedLibDir}
    local StaticLibDir := ${CppSysStaticLibDir}
    $call(__bpt_link_dlib__                            )
    $exec(__link_pe__, ${extraOptions}, true           )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $call(__check_exe_dlib_slib_depend__               )
endfunction


##### Function to create static libraries
function __link_slib__()
    local OutFile := ~$[target]
          OutFile := :"/OUT:${OutFile}"
   +@${SLibBuilder} ${SLibBuilderCommonFlags} ${OutFile} ~$[preq*]
endfunction

function link_slib()
    $call(__bpt_link_slib__                            )
    $exec(__link_slib__                                )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $call(__check_exe_dlib_slib_depend__               )
endfunction


##### Function to run the given executable file
function __run_exe__(progName)
   +@~${progName}
endfunction

function run_exe(progName)
    $exec(__run_exe__, ${progName}          )
    $call( __print_stdxxx_and_check_excode__)
endfunction


##### Function to initialize the project build
function init_project(?buildSubdirectories) supersede
    # Call the origin function
    $call(__origin__, ${buildSubdirectories})
    # Get the compiler target architecture
    CppCompilerArch := $call(__get_cpp_compiler_arch__)
    # Use GCC style pre-defined macros as specified in:
    #     https://sourceforge.net/p/predef/wiki/Architectures
      if ${CppCompilerArch} &== 'arm64' ; __BuildTool_Target__ := 'ARM64'           ;                          CppArchFlags +:= '/D__aarch64__'
    elif ${CppCompilerArch} &== 'arm'   ; __BuildTool_Target__ := 'ARM'             ;                          CppArchFlags +:= '/D__arm__'
    elif ${CppCompilerArch} &== 'x64'   ; __BuildTool_Target__ := 'Native (64-Bit)' ; CppAssembler := 'ml64' ; CppArchFlags +:= '/D__x86_64__'
    elif ${CppCompilerArch} &== 'x86'   ; __BuildTool_Target__ := 'Native (32-Bit)' ;                        ; CppArchFlags +:= '/D__i386__'
    endif
endfunction


##### Function to clean the project build (delete all the generated files)
function __clean_project__()
    $rmfiles_rec( $cwd(), '.+?\\.pdb' )
endfunction


