##### Function to compile assembly source codes
function __compile_s__(extraOptions)
    # https://www.codeproject.com/Articles/1250804/Creating-Assembly-Language-DLL-Modules-for-Windows
    # https://stackoverflow.com/questions/29265736/is-it-possible-to-dllexport-and-then-dllimport-function-written-in-assembly
    +@${CppAssembler} ${CppAssemblerFlags} ${extraOptions} :"/Fo~$[target]" /c ~$[preq*]
endfunction

function compile_s(?extraOptions)
    $call(__bpt_s__)
    $exec(__compile_s__, ${extraOptions}               )
    $call(__conditional_print_stdxxx_and_check_excode__)
endfunction


##### Function to check for C++20 module support
function __check_cpp20m_support__(functionName)
    # https://learn.microsoft.com/en-us/cpp/overview/visual-cpp-language-conformance?view=msvc-170
    # https://en.wikipedia.org/wiki/Microsoft_Visual_C%2B%2B#Internal_version_numbering
    if !$call(cpp_compiler_ver_min, 19, 28, 0, 0) : $call(__exit_error_ns_ver__, :"${functionName}()", ${__BuildTool_Name__})
endfunction


