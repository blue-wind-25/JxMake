##### Function to demangle C++ symbol string
function __cpp_demangle__(symbolStr, __dummyLDLibraryPath_ignored__)
    # undname /show_flags
    #     0x0080 Disable expansion of access specifiers for members
    #     0x0200 Disable expansion of 'static' or 'virtual'ness of members
    #     0x8000 Disable enum/class/struct/union prefix
  -@${CppDemangler} 0x8280 ${symbolStr}
    if $[excode] : return ${symbolStr}
    if &$[lserr] : return ${symbolStr}
    local Res := $erase_ifempty( $sflines($[stdout]) )
          Res := $partn( ${Res}, $part_count(${Res}) )
    local Len := $strlen  (${Res}     ) ; dec Len
    local Beg := $str_fidx(${Res}, '"') ; inc Beg
    return $substr(${Res}, ${Beg}, ${Len})
endfunction


