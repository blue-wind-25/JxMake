##### Include the native C/C++ build tool and other utilities
__ForceGCC__ := 1

:::include_once 'AVRDUDEHelper.jxm'
:::include_once 'C++BuildTool.jxm'
:::include_once 'C++XBuildTool_ArduinoUtil.jxm'
:::include_once 'DownloadDFUProgrammer.jxm'


##### MSys may cause weird errors so exclude it from the supported build environment
if __os_msys__
    $call(__exit_error_ns_benv__, 'AVR GCC', 'MSys')
endif


##### Update the flags
const __x_gcc__            := 1
const __avr_gcc__          := 1
const __BuildTool_Name__   := 'AVR GNU Compiler Collection (GCC)'
      __BuildTool_Target__  = "AVR (${AVR_MCUType_TCase} - ${AVR_CPUFrequency} Hz)"
const __BuildTool_Title__  := 'AVR C/C++'


##### Fix the file extensions as needed
if !__os_linux__
    ExeFileExt  := elf
    DLibFileExt := so
endif


##### Update the definitions of executables, paths, and options
##### !!! TODO : Which of the following is more suitable for this use case? !!! #####
if true
        CppAssembler              := 'avr-gcc'
        CppCommonAssemblerFlags  +:= '-x' 'assembler-with-cpp'

        CppCcCompiler             := 'avr-gcc'
        CppCommonCcCompileFlags  +:= '-fmerge-constants' '-fmerge-all-constants' '-fdata-sections' '-ffunction-sections'
        CppCommonCcCompileFlags  +:=                           '-fno-exceptions' '-fno-unwind-tables'

        CppCxxCompiler            := 'avr-g++'
        CppCommonCxxCompileFlags +:= '-fmerge-constants' '-fmerge-all-constants' '-fdata-sections' '-ffunction-sections'
        CppCommonCxxCompileFlags +:= '-fno-threadsafe-statics' '-fno-exceptions' '-fno-unwind-tables' '-fno-rtti'

        CppLinker                 := 'avr-gcc'
        CppCommonLinkFlags       +:= '-Wl,--relax' '-Wl,--gc-sections'
else
        CppAssembler              := 'avr-gcc'
        CppCommonAssemblerFlags  +:= '-mrelax'
        CppCommonAssemblerFlags  +:= '-x' 'assembler-with-cpp'

        CppCcCompiler             := 'avr-gcc'
        CppCommonCcCompileFlags  +:= '-mrelax'
        CppCommonCcCompileFlags  +:= '-fmerge-constants' '-fmerge-all-constants' '-fdata-sections' '-ffunction-sections'
        CppCommonCcCompileFlags  +:=                           '-fno-exceptions' '-fno-unwind-tables'

        CppCxxCompiler            := 'avr-g++'
        CppCommonCxxCompileFlags +:= '-mrelax'
        CppCommonCxxCompileFlags +:= '-fmerge-constants' '-fmerge-all-constants' '-fdata-sections' '-ffunction-sections'
        CppCommonCxxCompileFlags +:= '-fno-threadsafe-statics' '-fno-exceptions' '-fno-unwind-tables' '-fno-rtti'

        CppLinker                 := 'avr-gcc'
        CppCommonLinkFlags       +:= '-mrelax'
        CppCommonLinkFlags       +:= '-Wl,--gc-sections'
endif

const __Def_SLibBuilder__         := 'avr-ar'
        SLibBuilder               := ${__Def_SLibBuilder__}


##### Define some AVR-specific tools
AVRObjCopy         := 'avr-objcopy'
AVRObjCopyFlagsBIN := '-R' '.eeprom' '-O' 'binary'
AVRObjCopyFlagsHEX := '-R' '.eeprom' '-O' 'ihex'

AVRObjDump         := 'avr-objdump'
AVRObjDumpFlagsLST := '-S' '-d' '-z'


##### Define some AVR-specific options
const AVR_Default_MCUType := atmega328p
const AVR_Default_CPUFreq := 16000000

      AVR_MCUType      := ${AVR_Default_MCUType}
      AVR_CPUFrequency := ${AVR_Default_CPUFreq}


###################################################################################
##### =============== Arduino & Native AVR Detection Functions ============== #####
###################################################################################

##### Function to find the latest AVR GCC from Arduino package(s) and other directories
function __dummy__find_latest_avr_gcc_dir__()
    return { 0 '' }
endfunction

function __find_latest_avr_gcc_dir_impl__(searchDirList)
    # Find the latest AVR GCC version
    local LatestVersion := 0
    local LatestPath    := ''
    local CppToolBinDir
    local LDLibraryPath
    foreach local BinDir in ${searchDirList}
        .$__lb_cmp_gcc_ver_and_get_the_newer_path_and_ver__
    endforeach
    # Return the latest AVR GCC version and path
    return { ${LatestVersion} ${LatestPath} }
endfunction

function __find_latest_arduino_avr_gcc_dir__()
    # Determine the possible search directories
    local SearchDirPath1
    local SearchDirPath2
    local SearchDirList
    foreach local DirItem in ${ArduinoPackageDirs}
        # Check the standard paths first
        SearchDirPath1 := $cat_path(${DirItem}, 'packages/arduino/tools/avr-gcc')
        SearchDirPath2 := $cat_path(${DirItem}, 'tools'                         )
          if $valid_path(${SearchDirPath1}) ; SearchDirList  := $lsdir(${SearchDirPath1}, 'd') ;
        elif $valid_path(${SearchDirPath2}) ; SearchDirList +:= $lsdir(${SearchDirPath2}, 'd') ;
        # If both the above paths are not valid, perhaps the user has set the path to the specific package directory
        else
            loop
                # Search for the 'avr' directory
                SearchDirPath := $cat_path(${DirItem}, 'avr')
                if $valid_path(${SearchDirPath})
                    SearchDirList +:= ${DirItem}
                    break
                endif
                # Remove the last part from the path
                local DirRedux := $path_rm_last_part(${DirItem})
                if ${DirRedux} &== ${DirItem} : break
                DirItem := ${DirRedux}
            endloop
        endif
    endforeach
    # Sort in descending order so that newer packages have higher priority; this method is not perfect, but it is better than nothing
    SearchDirList := $sort_descending(${SearchDirList})
    # Get the latest AVR GCC version and path
    local Ret := $call(__find_latest_avr_gcc_dir_impl__, ${SearchDirList})
    # Get the selected Arduino package directory
    __SelArduinoPackageDir__ := ${Ret}<2>
    # Return the latest AVR GCC version and path
    return ${Ret}
endfunction

function __find_latest_custdir_avr_gcc_dir__()
    # Determine the directories that will be excluded from the search
    __JXMAKELIB_EXCLUDE_AVR_GCC_CUSTOM_DIRS__ ?:= $sfpseps( $getenv('JXMAKELIB_EXCLUDE_AVR_GCC_CUSTOM_DIRS', ${JXMAKELIB_EXCLUDE_AVR_GCC_CUSTOM_DIRS}) )
    # Determine the possible search directories
    local SearchDirList
    foreach local Dir in $lsdir('/opt', 'd')
        if $contains(${__JXMAKELIB_EXCLUDE_AVR_GCC_CUSTOM_DIRS__}, ${Dir}) : continue
        if $re_match( $substr( ${Dir}, 6, $strlen(${Dir}) ), '^(.+.)?avr-gcc.*') : SearchDirList +:= ${Dir}
    endforeach
    # Return the latest AVR GCC version and path
    return $call(__find_latest_avr_gcc_dir_impl__, ${SearchDirList})
endfunction

function __find_latest_avr_gcc_dir__()
    return $call(find_latest_cross_gcc_dir_arduino_custdir, 'LatestAVRGCCPath.cache', __find_latest_arduino_avr_gcc_dir__, __find_latest_custdir_avr_gcc_dir__)
endfunction

function find_latest_arduino_avr_gcc_dir()
    if !&${ArduinoPackageDirs} : ArduinoPackageDirs := $call(find_arduino_package_dirs)
    local CppToolBinDirSaved  := ${CppToolBinDir}
    unset CppToolBinDir
    local CppToolBinDirResult := $call(find_latest_cross_gcc_dir_arduino_custdir, 'LatestArduinoAVRGCCPath.cache', __find_latest_arduino_avr_gcc_dir__, __dummy__find_latest_avr_gcc_dir__)
          CppToolBinDir       := ${CppToolBinDirSaved}
    return ${CppToolBinDirResult}
endfunction

function find_latest_custdir_avr_gcc_dir()
    local CppToolBinDirSaved  := ${CppToolBinDir}
    unset CppToolBinDir
    local CppToolBinDirResult := $call(find_latest_cross_gcc_dir_arduino_custdir, 'LatestCustDirAVRGCCPath.cache', __dummy__find_latest_avr_gcc_dir__, __find_latest_custdir_avr_gcc_dir__)
          CppToolBinDir       := ${CppToolBinDirSaved}
    return ${CppToolBinDirResult}
endfunction

function find_latest_avr_gcc_dir()
    return $call(__find_latest_avr_gcc_dir__)
endfunction


##### Undefine the helper macro from 'C++XBuildTool_ArduinoUtil.jxm' here to prevent duplicated name later on
.undefmacro __lb_cmp_gcc_ver_and_get_the_newer_path_and_ver__


##### Function to check for AVR tools
function __check_avrsize_output_style_avr__(ldLibraryPath)
                     local AVRSize := 'avr-size'
    if &${CppToolBinDir} : AVRSize := $cat_path(${CppToolBinDir}, ${AVRSize})
   @setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   @${AVRSize} -h
    return $re_match($[stderr], '(?s).+?--format=\\{.+?avr.*?\\}.+')
endfunction

function __check_avrsize__()
    if !$call( cmd_executed_successfully         , ${CppToolBinDir}, 'avr-size', '-v' ) : return false
    if !$exec( __check_avrsize_output_style_avr__,  $call(__get_LDLibraryPaths__)     ) : return false
    return true
endfunction

function __check_avr_tools__()
    # Try to get the results from the cache file first
    local AVRCheckToolsCacheFilePath := $cat_path( $ptd(), 'AVRCheckTools.cache' )
    local AVRCheckTools
    $call(__check_avrsize__)
    if $uptodate_path(${AVRCheckToolsCacheFilePath})
        AVRCheckTools := $get_file(${AVRCheckToolsCacheFilePath})
        __has_avr_gcc_ar__  := $partn(${AVRCheckTools}, 1)
        __has_avr_size__    := $partn(${AVRCheckTools}, 2)
        __has_avr_objdump__ := $partn(${AVRCheckTools}, 3)
        return
    endif
    # Check if the tools are available for use
    __has_avr_gcc_ar__  := $call(cmd_executed_successfully, ${CppToolBinDir}, 'avr-gcc-ar' , '-V')
    __has_avr_size__    := $call(__check_avrsize__                                               )
    __has_avr_objdump__ := $call(cmd_executed_successfully, ${CppToolBinDir}, 'avr-objdump', '-v')
    # Save the results to the cache file
    $put_file( ${AVRCheckToolsCacheFilePath}, { \
        ${__has_avr_gcc_ar__}                   \
        ${__has_avr_size__}                     \
        ${__has_avr_objdump__}                  \
    } )
endfunction


##### Function to detect AVR GCC features
function __avr_isa_supported__(isa, ldLibraryPath)
    if &${CppToolBinDir} : local CppCxxCompiler := $cat_path(${CppToolBinDir}, ${CppCxxCompiler})
    $nop($[lserr] ) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   -@${CppCxxCompiler} :"-mmcu=${isa}"
    $nop($[excode]) # Ensure all pending commands are executed
    $restore_sem()
    return $cmp( $str_fidx($[stderr], ${isa}), '==', 0 )
endfunction

function __detect_avr_gcc_features__()
    # Try to get the results from the cache file first
    local AVRGCCFeaturesCacheFilePath := $cat_path( $ptd(), 'AVRGCCFeatures.cache' )
    local AVRGCCFeatures
    if $uptodate_path(${AVRGCCFeaturesCacheFilePath})
        AVRGCCFeatures := $get_file(${AVRGCCFeaturesCacheFilePath})
        __avr_gcc_version_            := $partn(${AVRGCCFeatures},  1)
        __avr_gcc_support_dfp__       := $partn(${AVRGCCFeatures},  2)
        __avr_gcc_support_avr1__      := $partn(${AVRGCCFeatures},  3)
        __avr_gcc_support_avr2__      := $partn(${AVRGCCFeatures},  4)
        __avr_gcc_support_avr25__     := $partn(${AVRGCCFeatures},  5)
        __avr_gcc_support_avr3__      := $partn(${AVRGCCFeatures},  6)
        __avr_gcc_support_avr31__     := $partn(${AVRGCCFeatures},  7)
        __avr_gcc_support_avr35__     := $partn(${AVRGCCFeatures},  8)
        __avr_gcc_support_avr4__      := $partn(${AVRGCCFeatures},  9)
        __avr_gcc_support_avr5__      := $partn(${AVRGCCFeatures}, 10)
        __avr_gcc_support_avr51__     := $partn(${AVRGCCFeatures}, 11)
        __avr_gcc_support_avr6__      := $partn(${AVRGCCFeatures}, 12)
        __avr_gcc_support_avrxmega2__ := $partn(${AVRGCCFeatures}, 13)
        __avr_gcc_support_avrxmega3__ := $partn(${AVRGCCFeatures}, 14)
        __avr_gcc_support_avrxmega4__ := $partn(${AVRGCCFeatures}, 15)
        __avr_gcc_support_avrxmega5__ := $partn(${AVRGCCFeatures}, 16)
        __avr_gcc_support_avrxmega6__ := $partn(${AVRGCCFeatures}, 17)
        __avr_gcc_support_avrxmega7__ := $partn(${AVRGCCFeatures}, 18)
        __avr_gcc_support_avrtiny__   := $partn(${AVRGCCFeatures}, 19)
        return
    endif
    # Detect the features
    local LDLibPaths := $call(__get_LDLibraryPaths__)
    __avr_gcc_version_            := ${__BuildTool_Version_Num__}
    __avr_gcc_support_dfp__       := $call( cpp_compiler_ver_min , 5, 0, 0                  ) # https://gcc.gnu.org/wiki/avr-gcc#Using_avr-gcc
    __avr_gcc_support_avr1__      := $exec( __avr_isa_supported__, avr1     , ${LDLibPaths} ) # https://gcc.gnu.org/onlinedocs/gcc/AVR-Options.html
    __avr_gcc_support_avr2__      := $exec( __avr_isa_supported__, avr2     , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr25__     := $exec( __avr_isa_supported__, avr25    , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr3__      := $exec( __avr_isa_supported__, avr3     , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr31__     := $exec( __avr_isa_supported__, avr31    , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr35__     := $exec( __avr_isa_supported__, avr35    , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr4__      := $exec( __avr_isa_supported__, avr4     , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr5__      := $exec( __avr_isa_supported__, avr5     , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr51__     := $exec( __avr_isa_supported__, avr51    , ${LDLibPaths} ) # ---
    __avr_gcc_support_avr6__      := $exec( __avr_isa_supported__, avr6     , ${LDLibPaths} ) # ---
    __avr_gcc_support_avrxmega2__ := $exec( __avr_isa_supported__, avrxmega2, ${LDLibPaths} ) # ---
    __avr_gcc_support_avrxmega3__ := $exec( __avr_isa_supported__, avrxmega3, ${LDLibPaths} ) # ---
    __avr_gcc_support_avrxmega4__ := $exec( __avr_isa_supported__, avrxmega4, ${LDLibPaths} ) # ---
    __avr_gcc_support_avrxmega5__ := $exec( __avr_isa_supported__, avrxmega5, ${LDLibPaths} ) # ---
    __avr_gcc_support_avrxmega6__ := $exec( __avr_isa_supported__, avrxmega6, ${LDLibPaths} ) # ---
    __avr_gcc_support_avrxmega7__ := $exec( __avr_isa_supported__, avrxmega7, ${LDLibPaths} ) # ---
    __avr_gcc_support_avrtiny__   := $exec( __avr_isa_supported__, avrtiny  , ${LDLibPaths} ) # ---
    # Save the results to the cache file
    $put_file( ${AVRGCCFeaturesCacheFilePath}, { \
        ${__avr_gcc_version_}                    \
        ${__avr_gcc_support_dfp__}               \
        ${__avr_gcc_support_avr1__}              \
        ${__avr_gcc_support_avr2__}              \
        ${__avr_gcc_support_avr25__}             \
        ${__avr_gcc_support_avr3__}              \
        ${__avr_gcc_support_avr31__}             \
        ${__avr_gcc_support_avr35__}             \
        ${__avr_gcc_support_avr4__}              \
        ${__avr_gcc_support_avr5__}              \
        ${__avr_gcc_support_avr51__}             \
        ${__avr_gcc_support_avr6__}              \
        ${__avr_gcc_support_avrxmega2__}         \
        ${__avr_gcc_support_avrxmega3__}         \
        ${__avr_gcc_support_avrxmega4__}         \
        ${__avr_gcc_support_avrxmega5__}         \
        ${__avr_gcc_support_avrxmega6__}         \
        ${__avr_gcc_support_avrxmega7__}         \
        ${__avr_gcc_support_avrtiny__}           \
    } )
endfunction


