##### Function to upload the given program via DFU
function __avr_upload_dfu_exec__(progName, ldLibraryPath)
    ##### Erase flash
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
  -+@${DFUProg_executable} ${AVR_MCUType} erase
    if $[excode] # Ensure all pending commands are executed
        if $[excode] != 5 : return # Exit here if the error code is not the one indicating flash is not blank
    endif
    ##### Upload flash
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${DFUProg_executable} ${AVR_MCUType} flash ~${progName/(.+)\.elf/$1.hex/}
   +@${DFUProg_executable} ${AVR_MCUType} launch
    $nop($[excode]) # Ensure all pending commands are executed
endfunction

function avr_upload_dfu(progName)
    # Perform upload
    $cmd_streaming_on()
    $exec( __avr_upload_dfu_exec__, ${progName}, $call(__get_LDLibraryPaths__) )
    $cmd_streaming_off()
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    if __os_linux__
        if !$valid_path('/etc/udev/rules.d/99-dfu-programmer.rules')
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            echoln __c_white__ 'Either the target device is not connected or access is denied.' __c_reset__
            echoln
            echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/99-dfu-programmer.rules\' as \'root\'' __c_reset__
            echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
            echoln
            echoln             'SUBSYSTEM!="usb", ACTION!="add", GOTO="dfu_programmer_rules_end"'
            echoln
            echoln             '# ATxmega32A4U DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2fe4", MODE="666"'
            echoln
            echoln             '# ATmega8U2 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2fee", MODE="666"'
            echoln
            echoln             '# ATmega16U2 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2fef", MODE="666"'
            echoln
            echoln             '# ATmega32U2 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ff0", MODE="666"'
            echoln
            echoln             '# ATmega16U4 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ff3", MODE="666"'
            echoln
            echoln             '# ATmega32U4 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ff4", MODE="666"'
            echoln
            echoln             '# AT90USB82 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ff7", MODE="666"'
            echoln
            echoln             '# AT90USB646/647 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ff9", MODE="666"'
            echoln
            echoln             '# AT90USB162 DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ffa", MODE="666"'
            echoln
            echoln             '# AT90USB AVR DFU bootloader'
            echoln             'ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2ffb", MODE="666"'
            echoln
            echoln             'LABEL="dfu_programmer_rules_end"'
            echoln
            echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
            echoln
            echoln             'udevadm control --reload-rules && udevadm trigger'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
        endif
    endif
    # Exit program
    $exit($[excode])
endfunction


##### Function to upload the given program via HID
if __os_windows__
    const HIDBootloaderCLI := 'hid_bootloader_cli.exe'
else
    const HIDBootloaderCLI := 'hid_bootloader_cli'
endif

function __avr_upload_hid_exec__(progName, ldLibraryPath)
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${HIDBootloaderCLI} :"-mmcu=${AVR_MCUType}" ~${progName/(.+)\.elf/$1.hex/}
endfunction

function avr_upload_hid(progName)
    # Check if the '${HIDBootloaderCLI}' program is executable
    if !$call(cmd_is_executable, '', ${HIDBootloaderCLI})
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        $call(__exit_error_nup__, ${HIDBootloaderCLI}, true)
        echoln __c_white__ 'Automatic download of the ' __c_cyan__ ${HIDBootloaderCLI} __c_white__ ' program is not supported yet.'
        echoln
        echoln __c_white__ 'Please download LUFA and compile the program manually:' __c_reset__
        echoln             '    https://github.com/abcminiuser/lufa/tree/master/Bootloaders/HID/HostLoaderApp'
        echoln
        echoln __c_white__ 'After installing, please make sure the program is in your PATH.' __c_reset__
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
        $exit(-1)
    endif
    # Perform upload
    $cmd_streaming_on()
    $exec( __avr_upload_hid_exec__, ${progName}, $call(__get_LDLibraryPaths__) )
    $cmd_streaming_off()
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    if __os_linux__
        if !$valid_path('/etc/udev/rules.d/99-hidbootloader.rules')
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            echoln __c_white__ 'Either the target device is not connected or access is denied.' __c_reset__
            echoln
            echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/99-hidbootloader.rules\' as \'root\'' __c_reset__
            echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
            echoln
            echoln             '# LUFA HID bootloader'
           #echoln             'SUBSYSTEM=="usb", ACTION=="add", ATTR{idVendor}=="03eb", ATTR{idProduct}=="2067", SYMLINK+="hidbl-%k", OWNER:="root", GROUP:="users", MODE:="0660"'
            echoln             'SUBSYSTEM=="usb", ACTION=="add", ATTR{idVendor}=="03eb", ATTR{idProduct}=="2067", MODE="666"'
            echoln
            echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
            echoln
            echoln             'udevadm control --reload-rules && udevadm trigger'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
        endif
    endif
    # Exit program
    $exit($[excode])
endfunction


##### Function to upload the given program via LPT
function __avr_upload_lpt_exec__(progName, device, directWrite, ldLibraryPath)
    # Determine the HEX file name
    local HexFile := ~${progName/(.+)\.elf/$1.hex/}
    # If the 'directWrite' flag is set, simply write the HEX file to the device
    if ${directWrite}
        # Check if the device path is not writable
        if !$path_is_writable(${device}) : return -1
        # Read and then write the HEX file
        local Lines := $get_file(${HexFile})
        echoln "Sending '${HexFile}' to '${device}' ..."
        $put_file(${device}, ${Lines})
        # Done
        return 0
    endif
    ##### Upload using LPR
    if __os_posix__
        # Check if the device is available
        ##### !!! TODO : Is this enough to force command line commands to display all the messages in English? !!! #####
       +@setenv LANG     C
       +@setenv SOFTWARE ''
       +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
       +@lpstat -p ${device}
        if !$re_match($[stdout], '(?s).+?idle.+') : return -1
        # Perform upload
        $cmd_streaming_on()
       +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
       +@lpr -l -P ${device} ${HexFile}
        local excode := $[excode]
        $cmd_streaming_off()
        # Return the exit code
        return ${excode}
    ##### Upload using Windows printjob - Please refer to 'https://ss64.com/nt/wmic.html' for more details
    else
        # Check the devices
        ##### !!! TODO : Are all the result messages always in English? !!! #####
       +@wmic printer get Name,ShareName,SystemName /format:textvaluelist
        if $[excode] : return $[excode] # Check for error
        local PCnt  := 0
        local Found := false
        local Lines := $erase_ifempty( $sflines($[stdout]) )
        local Name
        local ShareName
        local SystemName
        foreach local Line in ${Lines}
            # Extract the parts
            local Parts := $erase_ifempty( $explode(${Line}, '=') )
            if $part_count(${Parts}) != 2 : continue
            # Extract the values
            local Key   := ${Parts}<1>
            local Value := ${Parts}<2>
              if ${Key} &== 'Name'       ; Name       := ${Value} ; inc PCnt
            elif ${Key} &== 'ShareName'  ; ShareName  := ${Value} ; inc PCnt
            elif ${Key} &== 'SystemName' ; SystemName := ${Value} ; inc PCnt
            endif
            # Check the values
            if ${PCnt} >= 3
                if ${ShareName} &== ${device}
                    Found := true
                    break
                else
                    PCnt := 0
                endif
            endif
        endforeach
        if !${Found} : return -1
        # Check if there is a pending printjob for the device
       +@wmic printjob get Name
        if $[excode] : return $[excode] # Check for error
        foreach local Line in $erase_ifempty( $sflines($[stdout]) )
            if $partn( $explode(${Line}, ','), 1 ) &== ${Name}
                echoln
                echoln 'It seems there is at least one pending printjob for the device!'
                echoln 'Is the target connected and ready?'
                echoln
                echoln 'Please delete the printjob(s) and restart the upload.'
                return -1
            endif
        endforeach
        # Perform upload (create a printjob)
        $cmd_streaming_on()
       +@cmd /C copy /B ${HexFile} :"\\\\${SystemName}\\${ShareName}"
        local excode := $[excode]
        $cmd_streaming_off()
        if ${excode} : return ${excode} # Check for error
        # Wait until the printjob is completed
        local WaitCnt := 0
        loop
            # Check if the printjob still exists
            local Wait := false
            @wmic printjob get Name
            if $[excode] : return $[excode] # Check for error
            foreach local Line in $erase_ifempty( $sflines($[stdout]) )
                if $partn( $explode(${Line}, ','), 1 ) &== ${Name}
                    Wait := true
                    break
                endif
            endforeach
            # The printjob is completed, break here
            if !${Wait}
                break
            # The printjob is not completed yet, wait for a while
            else
                inc WaitCnt
                if ${WaitCnt} > 10
                    echoln
                    echoln 'It seems that the printjob for the device cannot be completed!'
                    echoln 'Is the target connected and ready?'
                    return -1
                endif
                $sleep(1000)
            endif
        endloop
        # Done
        return 0
    endif
    ##### Unknown error
    return -1
endfunction

function avr_upload_lpt(progName, device)
    # Perform upload
    local Direct := $and( __os_linux__, $str_begwith(${device}, '/dev/') )
    local Res    := $exec( __avr_upload_lpt_exec__, ${progName}, ${device}, ${Direct}, $call(__get_LDLibraryPaths__) )
    # Simply exit if there was no error
    if !${Res} : return
    # Print some helper information messages
    if $and( ${Direct}, $not( $valid_path('/etc/udev/rules.d/99-lpt-programmer.rules') ) )
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
        echoln __c_white__ 'Either the target device is not connected or access is denied.' __c_reset__
        echoln
        echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/99-lpt-programmer.rules\' as \'root\'' __c_reset__
        echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
        echoln
        echoln             '# LUFA LPT (Printer) bootloader'
        echoln             'SUBSYSTEM=="usb", ACTION=="add", ATTR{idVendor}=="03eb", ATTR{idProduct}=="206b", MODE="666"'
        echoln
        echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
        echoln
        echoln             'udevadm control --reload-rules && udevadm trigger'
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    else
        $call(__exit_error_na_dev__, ${device}, true)
    endif
    # Exit program
    $exit(${Res})
endfunction


