##### Function to initialize the project build
function init_project(?buildSubdirectories, ?dlOnlyIfNotExist) supersede
    # Find the Arduino package directories only if the user has not manually set the variable
    if !&${ArduinoPackageDirs}
        ArduinoPackageDirs := $call(find_arduino_package_dirs)
    endif
    # Find the Arduino library directories only if the user has not manually set the variable
    if !&${ArduinoLibraryDirs}
        ArduinoLibraryDirs := $call(find_arduino_library_dirs, ${ArduinoPackageDirs})
    endif
    # Find the latest AVR GCC directory
    if !&${CppToolBinDir}
        # Find the latest AVR GCC
        CppToolBinDir := $call(__find_latest_avr_gcc_dir__)
        if !${__BuildTool_Version_Num__} : $call(__exit_error_nup__, ${CppCxxCompiler})
    else
        # Find the latest Arduino AVR GCC but do not assign it to the variable because the user has manually set the variable
        $call(__find_latest_arduino_avr_gcc_dir__)
        # Ensure the AVR GCC directory given by the user is valid
        if !$call(__get_cpp_compiler_ver__, true) : $call(__exit_error_nup_ext__, ${CppCxxCompiler}, ${CppToolBinDir})
    endif
    # Workaround for "warning: array subscript 0 is outside array bounds of 'volatile uint8_t [0]'"
    if $call(cpp_compiler_ver_min, 12, 0, 0)
        CppCommonCcCompileFlags  +:= '--param=min-pagesize=0'
        CppCommonCxxCompileFlags +:= '--param=min-pagesize=0'
    endif
    # Find the latest AVRDUDE from Arduino package(s)
    $call(__find_latest_arduino_avrdude_cmd__)
    # Detect the AVR GCC features
    $call(__detect_avr_gcc_features__)
    # Check the AVR tools
    $call(__check_avr_tools__)
    if ${SLibBuilder} &== ${__Def_SLibBuilder__} # Proceed only if the user has not changed it from its default value
        if ${__has_avr_gcc_ar__} : SLibBuilder := 'avr-gcc-ar'
    endif
    if ${__has_avr_size__}
        AVRSize      := 'avr-size'
        AVRSizeFlags := '--format=avr'
    endif
    if ${__has_avr_objdump__}
        AVRObjDump      := 'avr-objdump'
        AVRObjDumpFlags := '-Pmem-usage'
    endif
    # Check the programmers supported by AVRDUDE
    local ChkProg := ft232r ft232h usbtiny usbasp avrispmkii atmelice serialupdi jtag2updi
    local ChkRes  := $call(__chk_sel_avrdude_programmer_support_ext__, ${ChkProg})
    __AVRDUDE_SupportAVRProgs__ := $erase_ifempty( $csel(${ChkRes}<2:0>, ${ChkProg}, '' ) )
    # Download (and install) the latest and DFU programmer from GitHub, unless instructed not to.
    if !${__JXMAKELIB_AVR_DO_NOT_DOWNLOAD_DFU_PROG__}
        $call(download_latest_dfuprog, ${dlOnlyIfNotExist})
    endif
    # Set extra configuration information text
    if &${CppToolBinDir}
        __BuildTool_ExtraInfoName__  +:= 'AVR GCC         Directory'
        __BuildTool_ExtraInfoValue__ +:= ${CppToolBinDir}
    endif
    if &${__SelArduinoPackageDir__}
        __BuildTool_ExtraInfoName__  +:= 'Arduino Package Directory'
        __BuildTool_ExtraInfoValue__ +:= $cat_path(${__SelArduinoPackageDir__}, '..')
    endif
    if &${ArduinoLibraryDirs}
        __BuildTool_ExtraInfoName__  +:= 'Arduino Library Directory'
        __BuildTool_ExtraInfoValue__ +:= $implode(${ArduinoLibraryDirs}, __os_psep_char__)
    endif
    $call(__add_sel_avrdude_cmd_to_bt_extra_info__)
    # Call the origin function
    $call(__origin__, ${buildSubdirectories})
endfunction


##### Function to initialize the project build
AVR_DFPSpec := ''

function set_device_pack_dir(dfpRootDir)
    # Check if the AVR GCC does not support device pack
    if !${__avr_gcc_support_dfp__} : return
    # Check if the specified directory is valid
    if !$valid_path(${dfpRootDir}) : dfpRootDir := ''
    # Check if the specified directory is empty
    if !&${dfpRootDir}
        AVR_DFP := ''
        return
    endif
    # Get the paths
    local AVR_DFP_RootDir    := $abs_path (${dfpRootDir}                                   )
    local AVR_DFP_DevSpecDir := $cat_paths(${AVR_DFP_RootDir}   , 'gcc/dev', ${AVR_MCUType})
    local AVR_DFP_HeaderDir  := $cat_paths(${AVR_DFP_RootDir}   , 'include'                )
    local AVR_DFP_LibraryDir := $srdir_rec(${AVR_DFP_DevSpecDir}, 'avr.+?'                 )
    # Generate the specification
    AVR_DFPSpec  := :"-B~${AVR_DFP_DevSpecDir}"
    AVR_DFPSpec +:= :"-isystem~${AVR_DFP_HeaderDir}"
    AVR_DFPSpec +:= :"-L~${AVR_DFP_LibraryDir}"
endfunction


###################################################################################
##### ===================== Upload-Related AVR Functions ==================== #####
###################################################################################

##### Function to check if the selected AVRDUDE support the given programmer
function __avr_chk_avrdude_prog_support__(programmer, ?descProgName)
    descProgName ?:= ${programmer}
    if !$contains( ${__AVRDUDE_SupportAVRProgs__}, $lcase(${programmer/[\s-]//}) ) : $call(__exit_error_ns_sprog__, ${descProgName}, 'AVRDUDE')
endfunction


##### Function to check signature and upload via FT232R
const AVR_Default_FT232RVariant := 'FT232R'

.macro __avr_ft232r_common_entry_code__
    # Set the default values
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_avr__, ${AVR_CPUFrequency})
    variant  ?:= ${AVR_Default_FT232RVariant}
    variant   := $lcase(${variant})
    # Check if AVRDUDE support the default programmer variant; NOTE : other variants are not checked!
    if ${variant} &== $lcase(${AVR_Default_FT232RVariant})
        $call(__avr_chk_avrdude_prog_support__, 'ft232r', 'FT232R')
    endif
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __avr_ft232r_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_ft232r_error_and_print_help__, $[function])
.endmacro

function __avr_chksig_ft232r_exec__(bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${part} -D -U signature:r:-:h
endfunction

function avr_chksig_ft232r(?bitClock, ?variant)
    # Execute the common entry code
    .$__avr_ft232r_common_entry_code__
    # Perform signature check
    $exec( __avr_chksig_ft232r_exec__, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_ft232r_common_leave_code__
endfunction

function __avr_upload_ft232r_exec__(progName, bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${part} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function avr_upload_ft232r(progName, ?bitClock, ?variant)
    # Execute the common entry code
    .$__avr_ft232r_common_entry_code__
    # Perform upload
    $exec( __avr_upload_ft232r_exec__, ${progName}, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_ft232r_common_leave_code__
endfunction

.undefmacro __avr_ft232r_common_entry_code__
.undefmacro __avr_ft232r_common_leave_code__


##### Function to check signature and upload via USBtinyISP
const AVR_Default_USBtinyISPVariant := 'USBtiny'
const AVR_ReducedCoreTinys          := t4 t5 t9 t10 t20 t40 t102 t104

.macro __avr_usbtinyisp_common_entry_code__
    # Set the default values
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_avr__, ${AVR_CPUFrequency})
    variant  ?:= ${AVR_Default_USBtinyISPVariant}
    variant   := $lcase(${variant})
    # Check if AVRDUDE support the default programmer variant; NOTE : other variants are not checked!
    if ${variant} &== $lcase(${AVR_Default_USBtinyISPVariant})
        $call(__avr_chk_avrdude_prog_support__, 'usbtiny', 'USBtinyISP')
    endif
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __avr_usbtinyisp_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_usbtinyisp_error_and_print_help__, $[function])
    # Check if the part is a reduced core tinys
    if $contains(${AVR_ReducedCoreTinys}, ${part})
        (*
        echoln __c_white__ 'It seems your are trying to program a Reduced Core Tiny AVR MCU using USBtinyISP. You may need to' __c_reset__
        echoln __c_white__ 'power cycle the programmer manually to bring your target out of the reset state.' __c_reset__
        echoln
        *)
        $exec( __avr_outrst_usbtinyisp_exec__,  ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    endif
.endmacro

function __avr_outrst_usbtinyisp_exec__(bitClock, variant, ldLibraryPath)
    # Workaround to bring a Reduced Core Tiny AVR MCU out of the reset state
    @setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    @${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p m8
endfunction

function __avr_chksig_usbtinyisp_exec__(bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${part} -D -U signature:r:-:h
endfunction

function avr_chksig_usbtinyisp(?bitClock, ?variant)
    # Execute the common entry code
    .$__avr_usbtinyisp_common_entry_code__
    # Perform signature check
    $exec( __avr_chksig_usbtinyisp_exec__, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_usbtinyisp_common_leave_code__
endfunction

function __avr_upload_usbtinyisp_exec__(progName, bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${part} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function avr_upload_usbtinyisp(progName, ?bitClock, ?variant)
    # Execute the common entry code
    .$__avr_usbtinyisp_common_entry_code__
    # Perform upload
    $exec( __avr_upload_usbtinyisp_exec__, ${progName}, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_usbtinyisp_common_leave_code__
endfunction

.undefmacro __avr_usbtinyisp_common_entry_code__
.undefmacro __avr_usbtinyisp_common_leave_code__


##### Function to check signature and upload via USBasp
const AVR_Default_USBaspVariant := 'USBasp'

.macro __avr_usbasp_common_entry_code__
    # Set the default values
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_avr__, ${AVR_CPUFrequency})
    variant  ?:= ${AVR_Default_USBaspVariant}
    variant   := $lcase(${variant})
    # Check if AVRDUDE support the default programmer variant; NOTE : other variants are not checked!
    if ${variant} &== $lcase(${AVR_Default_USBaspVariant})
        $call(__avr_chk_avrdude_prog_support__, 'usbasp', 'USBasp')
    endif
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # Check if the target is an ATxmega MCU
    local xmega := $str_begwith(${part}, 'x')
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __avr_usbasp_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_usbasp_error_and_print_help__, $[function], ${xmega})
.endmacro

function __avr_chksig_usbasp_exec__(xmega, bitClock, variant, ldLibraryPath)
        +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    if ${xmega}
        # NOTE : For some unknown reason, AVRDUDE seems to work better using this bit clock period
        #        when programming an ATxmega MCU using USBasp ???
        +@${AVRDUDE_Cmd} -c ${variant} -B 10.6        -p ${part} -D -U signature:r:-:h -E noreset
    else
        +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${part} -D -U signature:r:-:h
    endif
endfunction

function avr_chksig_usbasp(?bitClock, ?variant)
    # Execute the common entry code
    .$__avr_usbasp_common_entry_code__
    # Perform signature check
    $exec( __avr_chksig_usbasp_exec__, ${xmega}, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_usbasp_common_leave_code__
endfunction

function __avr_upload_usbasp_exec__(xmega, progName, bitClock, variant, ldLibraryPath)
        +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    if ${xmega}
        # NOTE : For some unknown reason, AVRDUDE seems to work better using this bit clock period
        #        when programming an ATxmega MCU using USBasp ???
        +@${AVRDUDE_Cmd} -c ${variant} -B 10.6        -p ${part} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i" -E noreset
    else
        +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${part} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
    endif
endfunction

function avr_upload_usbasp(progName, ?bitClock, ?variant)
    # Execute the common entry code
    .$__avr_usbasp_common_entry_code__
    # Perform upload
    $exec( __avr_upload_usbasp_exec__, ${xmega}, ${progName}, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_usbasp_common_leave_code__
endfunction

.undefmacro __avr_usbasp_common_entry_code__
.undefmacro __avr_usbasp_common_leave_code__

