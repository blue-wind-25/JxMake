###################################################################################
##### ==================== Library Help Printer Function ==================== #####
###################################################################################

##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__() supersede
    local AGText := __c_cyan__  'AVR GCC' __c_white__
    local NGText := __c_cyan__  "Native AVR" __c_white__
    local NGInfo := __c_white__ 'for ' ${NGText} ' '
    $call(__origin__, true, false, true, true)
    $call(__btlib_help_print_title_cross__)
    $call(__btlib_help_print_title_variables__, ${NGInfo})
    echoln __c_green__ '    __gcc__                               ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __x_gcc__                             ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __avr_gcc__                           ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln
    echoln __c_green__ '    JXMAKELIB_EXCLUDE_AVR_GCC_CUSTOM_DIRS ' __c_white__ ': exclude the custom directories specified here when searching for the latest ' ${AGText} ';'
    echoln __c_green__ '                                          ' __c_white__ '  paths are separated using \'' __c_green__ '__os_psep_char__' __c_white__ '\''
    echoln
    echoln __c_green__ '    ArduinoPackageDirs                    ' __c_white__ ': locations of ' __c_cyan__ 'Arduino' __c_white__ ' package directories'
    echoln __c_green__ '    ArduinoLibraryDirs                    ' __c_white__ ': locations of ' __c_cyan__ 'Arduino' __c_white__ ' library directories'
    echoln
    echoln __c_green__ '    AVRObjCopy                            ' __c_white__ ': executable file name for the program to convert create a HEX file from an ELF file'
    echoln __c_green__ '    AVRDUDE_Cmd                           ' __c_white__ ': executable file name and optional argument(s) for ' __c_cyan__ 'AVRDUDE'
    echoln
    echoln __c_green__ '    AVR_MCUType                           ' __c_white__ ': specify the ' __c_cyan__ 'AVR' __c_white__ ' instruction set architectures (ISA) or MCU type (in lowercase) - the default value is \'' __c_yellow__ ${AVR_Default_MCUType} __c_white__ '\''
    echoln __c_green__ '    AVR_CPUFrequency                      ' __c_white__ ': specify the ' __c_cyan__ 'AVR' __c_white__ ' CPU frequency (without the suffix \'UL\')                        - the default value is \'' __c_yellow__ ${AVR_Default_CPUFreq} __c_white__ '\''
    echoln
   #$call(__btlib_help_print_title_functions__, 7, 33, 1, ${NGInfo})
    $call(__btlib_help_print_title_functions__, 0,  0, 0, ${NGInfo})
    echoln __c_green__ '    init_project         (?buildSubdirectories,              ' __c_white__  ': superseding the original \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '                          ?dlOnlyIfNotExist                ) ' __c_green__  '      buildSubdirectories' __c_white__ ' same meaning as the original implementation'
    echoln __c_green__ '                                                             ' __c_green__  '      dlOnlyIfNotExist   ' __c_white__ ' passed to the \'' __c_green__ '?onlyIfNotExist' __c_white__ '\' parameters when downloading'
    echoln
    echoln __c_green__ '    avr_select_part      (partNumber         , ?cpuFreq    ) ' __c_white__  ': select the ' __c_cyan__ 'AVR' __c_white__ ' part number to use with the ' ${CGText} ' SDK; can only be called after calling \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      partNumber ' __c_cyan__ 'AVR' __c_white__ ' part number   - for example    \'' __c_yellow__ ${AVR_Default_MCUType} __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      cpuFreq    ' __c_cyan__ 'AVR' __c_white__ ' CPU frequency - the default is \'' __c_yellow__ ${AVR_Default_CPUFreq} __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_white__  '  these are the global variables that are initialized by this function:'
    echoln __c_green__ '                                                             ' __c_green__  '      AVR_MCUType'
    echoln __c_green__ '                                                             ' __c_green__  '      AVR_CPUFrequency'
    echoln
    echoln __c_green__ '    set_device_pack_dir  (dfpRootDir                       ) ' __c_white__  ': set the device pack directory; please download the necessary device pack from:'
    echoln __c_green__ '                                                             ' __c_yellow__ '      https://packs.download.microchip.com'
    echoln __c_green__ '                                                             ' __c_yellow__ '      http://packs.download.atmel.com'
    echoln __c_green__ '                                                             ' __c_white__  '  and extract (unzip) it to a directory with a name like:'
    echoln __c_green__ '                                                             ' __c_yellow__ '      Microchip.ATmega_DFP.x.x.xxx'
    echoln __c_green__ '                                                             ' __c_yellow__ '      Atmel.ATmega_DFP.x.x.xxx'
    echoln __c_green__ '                                                             ' __c_white__  '  can only be called after calling \'' __c_green__ 'avr_select_part' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_compile_s        (?extraOptions                    ) ' __c_white__  ': compile a ' ${NGText} ' assembly   source code; please use this instead of \'' __c_green__ 'compile_s' __c_white__ '\''
    echoln __c_green__ '    avr_compile_c        (?extraOptions                    ) ' __c_white__  ': compile a ' ${NGText} ' C          source code; please use this instead of \'' __c_green__ 'compile_c' __c_white__ '\''
    echoln __c_green__ '    avr_compile_cpp      (?extraOptions                    ) ' __c_white__  ': compile a ' ${NGText} ' C++        source code; please use this instead of \'' __c_green__ 'compile_cpp' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_link_exe         (?extraOptions                    ) ' __c_white__  ': link              a ' ${NGText} ' executable    ; please use this instead of \'' __c_green__ 'link_exe' __c_white__ '\''
    echoln __c_green__ '    avr_link_slib        (                                 ) ' __c_white__  ': link              a ' ${NGText} ' static library; please use this instead of \'' __c_green__ 'link_slib' __c_white__ '\''
    echoln __c_green__ '    avr_run_exe          (progName           , ?dimColor   ) ' __c_white__  ': print the size of a ' ${NGText} ' executable    ; please use this instead of \'' __c_green__ 'link_exe' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_chksig_ft232r    (                     ?bitClock   , ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'FT232R Synchronous Bit Banging'
    echoln __c_green__ '                          ?variant                         ) '
    echoln __c_green__ '    avr_upload_ft232r    (progName           , ?bitClock   , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'FT232R Synchronous Bit Banging'
    echoln __c_green__ '                          ?variant                         ) ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'AVR_CPUFrequency' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      variant ' __c_white__ ' set this to the correct programmer name       - possible values are:'
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ ${AVR_Default_USBFT232RVariant} __c_white__ '\' (the default)'
    echoln __c_green__ '                                                             ' __c_white__  '                   other programmers from \'' __c_yellow__ 'avrdude.conf' __c_white__ '\' with \'' __c_yellow__ 'type = "ftdi_syncbb"' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_chksig_usbtinyisp(                     ?bitClock   , ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'USBtinyISP'
    echoln __c_green__ '                          ?variant                         ) '
    echoln __c_green__ '    avr_upload_usbtinyisp(progName           , ?bitClock   , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'USBtinyISP'
    echoln __c_green__ '                          ?variant                         ) ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'AVR_CPUFrequency' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      variant ' __c_white__ ' set this to the correct programmer name       - possible values are:'
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ ${AVR_Default_USBtinyISPVariant} __c_white__ '\' (the default)'
    echoln __c_green__ '                                                             ' __c_white__  '                   other programmers from \'' __c_yellow__ 'avrdude.conf' __c_white__ '\' with \'' __c_yellow__ 'type = "usbtiny"' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_chksig_usbasp    (                     ?bitClock   , ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'USBasp'
    echoln __c_green__ '                          ?variant                         ) '
    echoln __c_green__ '    avr_upload_usbasp    (progName           , ?bitClock   , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'USBasp'
    echoln __c_green__ '                          ?variant                         ) ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'AVR_CPUFrequency' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      variant ' __c_white__ ' set this to the correct programmer name       - possible values are:'
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ ${AVR_Default_USBaspVariant} __c_white__ '\' (the default)'
    echoln __c_green__ '                                                             ' __c_white__  '                   other programmers from \'' __c_yellow__ 'avrdude.conf' __c_white__ '\' with \'' __c_yellow__ 'type = "usbasp"' __c_white__ '\''
    echoln
    $call(__avrdude_print_usbasp_supported_bit_clock__, 67)
    echoln
    echoln __c_green__ '    avr_chksig_avrispmkii(                     ?bitClock   ) ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'AVRISP mkII'
    echoln __c_green__ '    avr_upload_avrispmkii(progName           , ?bitClock   ) ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'AVRISP mkII'
    echoln __c_green__ '                                                             ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'AVR_CPUFrequency' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_chksig_atmelice  (          ?operMode, ?bitClock   ) ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'Atmel-ICE'
    echoln __c_green__ '    avr_upload_atmelice  (progName, ?operMode, ?bitClock   ) ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'Atmel-ICE'
    echoln __c_green__ '                                                             ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      operMode' __c_white__ ' set this to the correct operation mode        - possible values are:'
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ 'isp'  __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ 'tpi'  __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ 'pdi'  __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ 'updi' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ 'jtag' __c_white__ '\' (the default)'
    echoln __c_green__ '                                                             ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'AVR_CPUFrequency' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_chksig_serialupdi(                    device       , ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'UPDI' __c_white__ ' programmers with serial connections'
    echoln __c_green__ '                          ?variant          , ?baudrate    ) '
    echoln __c_green__ '    avr_upload_serialupdi(progName          , device       , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'UPDI' __c_white__ ' programmers with serial connections'
    echoln __c_green__ '                          ?variant          , ?baudrate    ) ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      device  ' __c_white__ ' UPDI programmer serial device path; use one of the values returned by \'' __c_green__ '$ls_serial_ports()' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      variant ' __c_white__ ' set this to the correct programmer name - possible values are:'
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ ${AVR_Reserve_SerialUPDIVariant} __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_white__  '                   \'' __c_yellow__ ${AVR_Default_SerialUPDIVariant} __c_white__ '\' (the default)'
    echoln __c_green__ '                                                             ' __c_green__  '      baudrate' __c_white__ ' set this to the correct baudrate        - the default depends on \'' __c_green__ 'AVR_CPUFrequency' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_chksig_genextprog(                    configSet    ) ' __c_white__  ': check the ' __c_cyan__ 'AVR' __c_white__ ' signature code via ' __c_cyan__ 'generic external programmer'
    echoln __c_green__ '    avr_upload_genextprog(progName          , configSet    , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'generic external programmer'
    echoln __c_green__ '                          ?verify                          ) ' __c_green__  '      progName ' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      configSet' __c_white__ ' set this to the correct configuration set \'' __c_yellow__ '{ ProgrammerName[, Option]... }' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      verify   ' __c_white__ ' set this to \'' __c_yellow__ 'true' __c_white__ '\' to enable automatic verification check - the default value is \'' __c_yellow__ 'false' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_upload_dfu       (progName                         ) ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'LUFA DFU Bootloader' __c_white__ ' using ' __c_cyan__ 'DFU-Programmer'
    echoln __c_green__ '                                                             ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_upload_hid       (progName                         ) ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'LUFA HID Bootloader' __c_white__ ' using LUFA\'s \'' __c_cyan__ 'hid_bootloader_cli' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln
    echoln __c_green__ '    avr_upload_lpt       (progName          , device       ) ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'LUFA LPT (Printer) Bootloader'
    echoln __c_green__ '                                                             ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      device  ' __c_white__ ' USB device path or printer device name - for example \'' __c_yellow__ '/dev/usb/lp0' __c_white__ '\', \'' __c_yellow__ 'LUFA_BootloaderLPT' __c_white__ '\', etc.'
    echoln
    echoln __c_white__ '                                                             '              '      On Linux, \'' __c_green__ 'device' __c_white__ '\' is the USB device path or the name of the printer.'
    echoln
    echoln __c_white__ '                                                             '              '      On MacOS, \'' __c_green__ 'device' __c_white__ '\' is the name of the printer.'
    echoln
    echoln __c_white__ '                                                             '              '      On Windows, \'' __c_green__ 'device' __c_white__ '\' is the share name of the printer:'
    echoln __c_white__ '                                                             '              '          1. Open \'Devices and Printers\''
    echoln __c_white__ '                                                             '              '          2. Right click on the printer and select \'Printer properties\''
    echoln __c_white__ '                                                             '              '          3. Go to the \'Sharing\' tab'
    echoln __c_white__ '                                                             '              '          4. Check \'Share this printer\' and fill-in the \'Share name\''
    echoln __c_white__ '                                                             '              '          5. Click \'OK\''
    echoln
    echoln __c_green__ '    avr_upload_serial    (progName          , device       , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via ' __c_cyan__ 'serial port'
    echoln __c_green__ '                          ?baudrate         , ?protocol    , ' __c_green__  '      progName         ' __c_white__ ' program name;       use        the value  returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                          ?resetToBootloader, ?resetByteSeq) ' __c_green__  '      device           ' __c_white__ ' serial device path; use one of the values returned by \'' __c_green__ '$ls_serial_ports()' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      baudrate         ' __c_white__ ' set this to the correct programming baudrate - the default is \'' __c_yellow__ '115200' __c_white__ '/' __c_yellow__ '57600' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      protocol         ' __c_white__ ' set this to the correct programming protocol - the default is \'' __c_yellow__ 'arduino' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      resetToBootloader' __c_white__ ' set this to ' __c_yellow__ '1' __c_white__ ' to reset the MCU using \'' __c_green__ '$mcu_bootloader()' __c_white__ '\' before uploading'
    echoln __c_green__ '                                                             ' __c_green__  '      resetByteSeq     ' __c_white__ ' set this argument to reset the MCU using the special byte sequence instead'
    echoln __c_green__ '                                                             ' __c_white__  '                       ' __c_white__ ' of the magic baudrate'
    echoln
    echoln __c_white__ '                                                             '              '      The target ' __c_cyan__ 'AVR' __c_white__ ' must have been burned (uploaded) with a compatible bootloader.'
    echoln
    echoln __c_green__ '    avr_upload_esplink   (progName          ,              , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via a ' __c_cyan__ 'TCP <-> Serial Bridge' __c_white__ ' device that uses ' __c_cyan__ 'ESP-LINK' __c_white__ ' firmware'
    echoln __c_green__ '                          hostNameOrIP      , progPort     , ' __c_green__  '      progName    ' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                          ?baudrate         , ?protocol    ) ' __c_green__  '      hostNameOrIP' __c_white__ ' hostname or IP   of the bridge device        - it is usually port \'' __c_yellow__ '192.168.4.1' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      progPort    ' __c_white__ ' programming port of the bridge device        - it is usually port \'' __c_yellow__ '23' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      baudrate    ' __c_white__ ' set this to the correct programming baudrate - the default is \'' __c_yellow__ '115200' __c_white__ '/' __c_yellow__ '57600' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      protocol    ' __c_white__ ' set this to the correct programming protocol - the default is \'' __c_yellow__ 'arduino' __c_white__ '\''
    echoln
    echoln __c_white__ '                                                             '              '      The target ' __c_cyan__ 'AVR' __c_white__ ' must have been burned (uploaded) with a compatible bootloader.'
    echoln
    echoln __c_green__ '    avr_upload_ecxx      (progName          ,              , ' __c_white__  ': upload program to ' __c_cyan__ 'AVR' __c_white__ ' via a ' __c_cyan__ 'TCP <-> Serial Bridge' __c_white__ ' device that uses ' __c_cyan__ 'eCxx' __c_white__ ' firmware'
    echoln __c_green__ '                          hostNameOrIP      , progPort     , ' __c_green__  '      progName    ' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                          ?baudrate         , ?protocol    ) ' __c_green__  '      hostNameOrIP' __c_white__ ' hostname or IP   of the bridge device        - it is usually port \'' __c_yellow__ '192.168.0.100' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      progPort    ' __c_white__ ' programming port of the bridge device        - it is usually port \'' __c_yellow__ '23' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      baudrate    ' __c_white__ ' set this to the correct programming baudrate - the default is \'' __c_yellow__ '115200' __c_white__ '/' __c_yellow__ '57600' __c_white__ '\''
    echoln __c_green__ '                                                             ' __c_green__  '      protocol    ' __c_white__ ' set this to the correct programming protocol - the default is \'' __c_yellow__ 'arduino' __c_white__ '\''
    echoln
    echoln __c_white__ '                                                             '              '      The target ' __c_cyan__ 'AVR' __c_white__ ' must have been burned (uploaded) with a compatible bootloader.'
    echoln
    echoln __c_green__ '    set_tsb_scbsp        (hostNameOrIP      , baudrate     ) ' __c_white__  ': set the serial console baudrate of a ' __c_cyan__ 'TCP <-> Serial Bridge' __c_white__ ' device that uses'
    echoln __c_green__ '                                                             ' __c_white__  '  ' __c_cyan__ 'ESP-LINK' __c_white__ ' or ' __c_cyan__ 'eCxx' __c_white__ ' firmware'
    echoln
    echoln __c_green__ '    avrcfg_from_arduino  (boardName                        ) ' __c_white__  ': get the ' __c_cyan__ 'AVR' __c_white__ ' configuration values from the given ' __c_cyan__ 'Arduino' __c_white__ ' board name; returned members:'
    echoln __c_green__ '                                                             ' __c_cyan__   '          #1       #2            #3              #4              #5             #6'
    echoln __c_green__ '                                                             ' __c_white__  '      \'' __c_yellow__ '{{ MCUType, CPUFrequency, UploadProtocol, UploadBaudrate, UploadResetBL, UploadPortType }}' __c_white__ '\''
    echoln
    echoln __c_white__ 'The \'' __c_green__ 'avr_chksig_*' __c_white__ '\' functions would reset the MCU after reading and checking the signature code, therefore, they can be used to reset the MCU intentionally by'
    echoln __c_white__ 'using an external programmer.'
    echoln
    echoln __c_cyan__  'Extra Utility Functions ' __c_white__ '(Call Using \'' __c_green__ '$call(...)' __c_white__ '\')'
    echoln
    echoln __c_green__ '    find_latest_arduino_avr_gcc_dir()' __c_white__  ' : find the latest ' ${AGText} ' installation directory from \'' __c_green__ 'ArduinoPackageDirs' __c_white__ '\''
    echoln __c_green__ '    find_latest_custdir_avr_gcc_dir()' __c_white__  ' : find the latest ' ${AGText} ' installation directory from \'' __c_green__ '/opt/*' __c_white__ '\' (POSIX only)'
    echoln __c_green__ '    find_latest_avr_gcc_dir        ()' __c_white__  ' : find the latest ' ${AGText} ' installation directory from the two above locations'
    echoln
    $call(__btlib_help_print_note_arduino_environment__)
    echoln __c_reset__
endfunction
