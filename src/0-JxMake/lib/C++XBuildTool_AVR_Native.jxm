#####
#####


##### A helper macro to determine the default values for uploading
.macro __avr_upload_serial_def_vals__
    local baudrate ?:= $csel( $cmp(${AVR_CPUFrequency}, '>=', 16000000), 115200, 57600 )
    local protocol ?:= 'arduino'
.endmacro


##### Function to upload the given program via serial port
function __avr_upload_serial_exec__()
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRDUDE_Cmd} -c ${protocol} -P ${device} -b ${baudrate} -p ${part} ${erase} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function __avr_upload_serial__(progName, device, baudrate, protocol, resetToBootloader, resetByteSeq, ldLibraryPath)
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # If the protocol contains 'updi' add the '-e' option
    local erase
    if $str_lidx(${protocol}, 'updi') : erase := '-e'
    # Reset to bootloader as needed
    if $and( ${resetToBootloader}, $valid_path(${device}) )
        if !&${resetByteSeq}
            $mcu_bootloader(${device}                 ) # Reset using the magic baudrate
        else
            $mcu_bootloader(${device}, ${resetByteSeq}) # Reset using the special byte sequence
        endif
    endif
    # Perform upload
    $cmd_streaming_on()
    $exec(__avr_upload_serial_exec__                   )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_streaming_off()
endfunction

function avr_upload_serial(progName, device, ?baudrate, ?protocol, ?resetToBootloader, ?resetByteSeq)
    # Set the default values
    .$__avr_upload_serial_def_vals__
    # Perform upload
    $call( __avr_upload_serial__, ${progName}, ${device}, ${baudrate}, ${protocol}, ${resetToBootloader}, ${resetByteSeq}, $call(__get_LDLibraryPaths__) )
endfunction


##### Functions to upload the given program via a 'TCP <-> Serial Bridge' device
function __avr_upload_tcp_serial_bridge__(progName, urlSetBaudrate, ?baudrate, ?protocol)
    # Set baudrate
    local url := :"http://${urlSetBaudrate}"
    local res := $http_get(${url})
    if $partn(${res}, 1) != 200
        echoln ${url}
        echoln $ftlines(${res})
        return
    endif
    # Perform upload
    $call(avr_upload_serial, ${progName}, :"net:${hostNameOrIP}:${progPort}", ${baudrate}, ${protocol})
endfunction

function avr_upload_esplink(progName, hostNameOrIP, progPort, ?baudrate, ?protocol) # Use ESP-LINK firmware
    # Set the default values
    .$__avr_upload_serial_def_vals__
    # Perform upload
    $call(__avr_upload_tcp_serial_bridge__, ${progName}, :"${hostNameOrIP}/console/baud?rate=${baudrate}", ${baudrate}, ${protocol})
endfunction

function avr_upload_ecxx(progName, hostNameOrIP, progPort, ?baudrate, ?protocol) # Use eCxx firmware
    # Set the default values
    .$__avr_upload_serial_def_vals__
    # Perform upload
    $call(__avr_upload_tcp_serial_bridge__, ${progName}, :"${hostNameOrIP}/upload/baud?rate=${baudrate}", ${baudrate}, ${protocol})
endfunction


##### Undefine the helper macro here to prevent duplicated name later on
.undefmacro __avr_upload_serial_def_vals__


##### Functions to set the baudrate of a 'TCP <-> Serial Bridge' device
function set_tsb_scb(hostNameOrIP, baudrate)
    local url := :"http://${hostNameOrIP}/console/baud?rate=${baudrate}"
    local res := $http_get(${url})
    if $partn(${res}, 1) != 200
        echoln ${url}
        echoln $ftlines(${res})
        return 0
    endif
    return 1
endfunction


###################################################################################
##### ====================== Native AVR Build Functions ===================== #####
###################################################################################

##### Function to select the part number
function avr_select_part(partNumber, ?cpuFreq)
    # Set the default value
    cpuFreq ?:= ${AVR_Default_CPUFreq}
    # Save the part number and CPU frequency
    AVR_MCUType       := $lcase(${partNumber})
    AVR_CPUFrequency  :=        ${cpuFreq}
    # Generate a proper title case name for the part number
    if $re_match( $lcase(${partNumber}), '^avr\d+\D+\d+')
        AVR_MCUType_TCase := $ucase(${partNumber})
    else
              partNumber  := $ucase(${partNumber})
        local frontPart   := $lcase(${partNumber/AT(X?MEGA|TINY).+/$1/})
        local backPart    :=        ${partNumber/AT(?:X?MEGA|TINY)(.+)/$1/}
        AVR_MCUType_TCase := :"AT${frontPart}${backPart}"
    endif
endfunction


##### A helper macro to forward function calls for compile and link
.macro __avr_compile_and_link__
    local extraOptions := $stack( :"-mmcu=${AVR_MCUType}", :"-DF_CPU=${AVR_CPUFrequency}UL", ${AVR_DFPSpec}, ${extraOptions} )
.endmacro


##### Function to compile assembly source codes
function avr_compile_s(?extraOptions)
    .$__avr_compile_and_link__
    $call(compile_s, ${extraOptions})
endfunction


##### Function to compile C++ and C++20 source codes
function avr_compile_c(?extraOptions)
    .$__avr_compile_and_link__
    $call(compile_c, ${extraOptions})
endfunction

function avr_compile_cpp(?extraOptions)
    .$__avr_compile_and_link__
    $call(compile_cpp, ${extraOptions})
endfunction

function avr_compile_cpp20m(?extraOptions)
    .$__avr_compile_and_link__
    $call(compile_cpp20m, ${extraOptions})
endfunction


##### Function to create AVR static libraries
function avr_link_slib()
    $call(link_slib)
endfunction


##### Linking shared library files is not supported
function link_dlib(?extraOptions) supersede
    .$__exit_error_function_ns__
endfunction


##### Function to link executable files (in case of AVR, also create the BIN and HEX files)
function __is_tiny_avr_012_series__(part)
    (*
     * This regular expression is constructed based on the information from:
     *     https://ww1.microchip.com/downloads/en/AppNotes/Getting-Started-with-tinyAVR0-series-DS00002712.pdf
     *     https://ww1.microchip.com/downloads/en/Appnotes/Getting-Started-with-tinyAVR1-series-00002503B.pdf
     *     https://ww1.microchip.com/downloads/en/Appnotes/AN3456-Getting-Started-with-tinyAVR-2-Family-DS00003456A.pdf
     *)
    #                                        0-Series                            1-Series                                     2-Series
    return $re_match(${part}, '(?i)attiny(?:(?:20[24]|40[246]|80[467]|160[467])|(?:21[24]|41[2467]|81[467]|161[467]|321[67])|(?:(?:[48]|16|32)2[467]))')
endfunction

function __get_fixed_avrxmega3_xn__()
    (*
     * When building for tinyAVR 0/1/2-series because currently newer versions of GCC will cause link errors like:
     *     /opt/avr-gcc-10.1.0-x64-linux/avr/bin/ld: address 0x803401 of main.elf section `.bss' is not within region `data'
     *     /opt/avr-gcc-11.1.0-x64-linux/avr/bin/ld: address 0x803401 of main.elf section `.bss' is not within region `data'
     *     /opt/avr-gcc-12.1.0-x64-linux/avr/bin/ld: address 0x803401 of main.elf section `.bss' is not within region `data'
     *
     * ----------------------------------------------------------------------------------------------------
     *
     * From:
     *     https://www.avrfreaks.net/s/topic/a5C3l000000UaSiEAK/t153954?comment=P-1378381
     *     https://www.avrfreaks.net/s/topic/a5C3l000000UaSiEAK/t153954?comment=P-1378383
     *
     * The cause of the error is from the file '<avr_gcc_dir>/avr/lib/ldscripts/avrxmega3.xn'.
     *
     * ----------------------------------------------------------------------------------------------------
     *
     * Adding a new line:
     *     __DATA_REGION_ORIGIN__ = DEFINED(__DATA_REGION_ORIGIN__) ? __DATA_REGION_ORIGIN__ : 0x802000;
     * after the line:
     *     __RODATA_PM_OFFSET__ = DEFINED(__RODATA_PM_OFFSET__) ? __RODATA_PM_OFFSET__ : 0x8000;
     *
     * and then replacing the line:
     *     data   (rw!x) : ORIGIN = 0x802000, LENGTH = __DATA_REGION_LENGTH__
     * with the line:
     *     data   (rw!x) : ORIGIN = __DATA_REGION_ORIGIN__, LENGTH = __DATA_REGION_LENGTH__
     *
     * should fix the problem.
     *)
    # Determine the original (default) linker script file path and the fixed linker script file path
    local OrgLDS := $cat_path( ${CppToolBinDir}, '../avr/lib/ldscripts/avrxmega3.xn' )
    local FixLDS := $cat_path( $ptd()          , 'avrxmega3.xn'                      )
    # Try to get the flag from the cache file first
    local FixedAVRXMega3XNCacheFilePath := $cat_path( $ptd(), 'FixedAVRXMega3XN.cache' )
    if $uptodate_path(${FixedAVRXMega3XNCacheFilePath})
        # Return the fixed linker script file path if the file does exist
        if $get_file(${FixedAVRXMega3XNCacheFilePath})
            if $valid_path(${FixLDS}) : return ${FixLDS}
        # Return an empty string
        else
            return ''
        endif
    else
        # Delete the fixed linker script file (if it exists)
        $rmfile(${FixLDS})
    endif
    # Check if the fixed linker script file already exists and up to date
    if $newer_path(${FixLDS}, ${OrgLDS})
        # Save the flag to the cache file
        $put_file(${FixedAVRXMega3XNCacheFilePath}, '1')
        # Return the fixed linker script file path
        return ${FixLDS}
    endif
    # Read the contents of the default linker script file
    local Lines  := $get_file(${OrgLDS})
    # Check if the linker script file already contains the correct script
    local Re1a := '\\s*__DATA_REGION_ORIGIN__\\s*=\\s*DEFINED\\s*\\(\\s*__DATA_REGION_ORIGIN__\\s*\\)\\s*\\?\\s*__DATA_REGION_ORIGIN__\\s*:\\s*0x802000\\s*;\\s*'
    local Re1b := '\\s*data\\s*\\(\\s*rw!x\\s*\\)\\s*:\\s*ORIGIN\\s*=\\s*__DATA_REGION_ORIGIN__\\s*,\\s*LENGTH\\s*=\\s*__DATA_REGION_LENGTH__\\s*'
    if $or( $re_match(${Lines}, ${Re1a} ), $re_match(${Lines}, ${Re1b} ) )
        # Save the flag to the cache file
        $put_file(${FixedAVRXMega3XNCacheFilePath}, '0')
        # Return an empty string
        return ''
    endif
    # Generate and save the contents of the fixed linker script file
    local Re2a := '\\s*__RODATA_PM_OFFSET__\\s*=\\s*DEFINED\\s*\\(\\s*__RODATA_PM_OFFSET__\\s*\\)\\s*\\?\\s*__RODATA_PM_OFFSET__\\s*:\\s*0x8000\\s*;\\s*'
    local Re2b := '\\s*data\\s*\\(\\s*rw!x\\s*\\)\\s*:\\s*ORIGIN\\s*=\\s*0x802000\\s*,\\s*LENGTH\\s*=\\s*__DATA_REGION_LENGTH__\\s*'
    local FixL
    foreach local Line in ${Lines}
        if $re_match(${Line}, ${Re2a})
            FixL +:= ${Line}
            FixL +:= '__DATA_REGION_ORIGIN__ = DEFINED(__DATA_REGION_ORIGIN__) ? __DATA_REGION_ORIGIN__ : 0x802000;'
        elif $re_match(${Line}, ${Re2b})
            FixL +:= '  data   (rw!x) : ORIGIN = __DATA_REGION_ORIGIN__, LENGTH = __DATA_REGION_LENGTH__'
        else
            FixL +:= ${Line}
        endif
    endforeach
    $put_file(${FixLDS}, ${FixL})
    # Save the flag to the cache file
    $put_file(${FixedAVRXMega3XNCacheFilePath}, '1')
    # Return the fixed linker script file path
    return ${FixLDS}
endfunction

function __get_fixed_avrxmega3_xn_for_tiny_avr_012_series__(extraOptions)
    # Get the fixed linker script only if the user is not currently using a custom linker script
    if !$or( $re_match( $stack(${CppCommonLinkFlags}, ${extraOptions}), '-T.*' ) )
        if $call(__is_tiny_avr_012_series__, ${AVR_MCUType})
            local FixLDS := $call(__get_fixed_avrxmega3_xn__)
            if &${FixLDS}
                # Return the modified extra options
                extraOptions +:= $series('-T',  ${FixLDS})
                return ${extraOptions}
            endif
        endif
    endif
    # Return the original extra options
    return ${extraOptions}
endfunction

function __elf_to_bin_hex__(ldLibraryPath)
    # Determine the paths
    if &${CppToolBinDir} : local AVRObjCopy := $cat_path(${CppToolBinDir}, ${AVRObjCopy})
    if &${CppToolBinDir} : local AVRObjDump := $cat_path(${CppToolBinDir}, ${AVRObjDump})
    local BinFile := ~$[target/(.+)\.elf/$1.bin/]
    local HexFile := ~$[target/(.+)\.elf/$1.hex/]
    local LstFile := ~$[target/(.+)\.elf/$1.lst/]
    # Remove the HEX, BIN, and LST files
    $rmfile(${BinFile})
    $rmfile(${HexFile})
    $rmfile(${LstFile})
    # Create the LST file
    $cmd_stderr_chk_on() # Workaround to prevent hung because ${AVRObjDump} may have a non-standard stderr
    $cmd_stdout_chk_on() # Workaround to prevent hung because ${AVRObjDump} may have a non-standard stdout
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRObjDump} ${AVRObjDumpFlagsLST} ~$[target]
    $nop($[excode]) # Ensure all pending commands are executed
    $cmd_stderr_chk_off()
    $cmd_stdout_chk_off()
    if $[excode] : return
    $put_file( ${LstFile}, $stack($[stderr], $[stdout]) )
    # Convert ELF to BIN and HEX
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRObjCopy} ${AVRObjCopyFlagsBIN} ~$[target] ${BinFile}
   +@${AVRObjCopy} ${AVRObjCopyFlagsHEX} ~$[target] ${HexFile}
endfunction

function avr_link_exe(?extraOptions)
    # Use the fixed linker script file as needed
    extraOptions := $call(__get_fixed_avrxmega3_xn_for_tiny_avr_012_series__, ${extraOptions})
    # Link the executable
    .$__avr_compile_and_link__
    $call(link_exe, ${extraOptions})
    # Convert ELF to BIN and HEX
    $call( __bpt_bin_hex__                                   )
    $exec( __elf_to_bin_hex__, $call(__get_LDLibraryPaths__) )
    $call( __conditional_print_stdxxx_and_check_excode__     )
endfunction


##### Undefine the helper macro here to prevent duplicated name later on
.undefmacro __avr_compile_and_link__


##### Function to run the given executable file (in case of AVR, print the size)
function __obj_size__(progName, ldLibraryPath, dimColor)
    # Modify the binary path(s) as needed
    if &${CppToolBinDir} : local AVRSize    := $cat_path(${CppToolBinDir}, ${AVRSize}   )
    if &${CppToolBinDir} : local AVRObjDump := $cat_path(${CppToolBinDir}, ${AVRObjDump})
    # Get the size using 'avr-size'
    local stdout
    if ${__has_avr_size__}
       @setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
       @${AVRSize} ${AVRSizeFlags} :"--mcu=${AVR_MCUType}" ~${progName}
        if $[excode] : return 0
        if !$re_match( $[stdout], '[\S\s]*Device:\s+Unknown\s*[\r\n]{1,2}[\S\s]*') : stdout := $[stdout]
    endif
    # Get the size using 'avr-objdump'
    if !&${stdout}
        if ${__has_avr_objdump__}
           @setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
           @${AVRObjDump} ${AVRObjDumpFlags} ~${progName}
            if $[excode] : return 0
            stdout := $[stdout]
        endif
    endif
    # Print the size
    local Color := __c_dgray__
    if !${dimColor}
        echoln __c_cyan__ -${progName} __c_reset__
        Color := __c_green__
    endif
    foreach local line in $sflines(${stdout})
        if $re_match(${line}, '^Device:.+')
            echoln ${Color} '    Device  : ' ${line/Device:\s+(.+)/$1/} __c_reset__
        elif $re_match( ${line}, '^(?:Program|Data):.+')
                  line := $sfpipes(${line/(Program|Data):\s+(\d+) bytes(?:\s\((\d+\.\d+)%\s.+?\))?/$1|$2|$3/})
            local type := $partn(${line}, 1)
            local byte := $partn(${line}, 2)
            local urat := $partn(${line}, 3)
            echo ${Color}
            $printf('    %-7s : %6s bytes (%5s%% Full)', ${type}, ${byte}, ${urat})
            echoln __c_reset__
        endif
    endforeach
    # Done
    return 1
endfunction

function avr_run_exe(progName, ?dimColor)
    # Exit if the executable does not actually exist
    if !$valid_path(${progName}) : return
    # Print the size
                 $call( __bpt_exe_size_linespace__                                            )
    local res := $exec( __obj_size__, ${progName}, $call(__get_LDLibraryPaths__), ${dimColor} )
    if !${res} : $call( __print_stdxxx_and_check_excode__                                     )
endfunction


###################################################################################
##### ===================== Arduino AVR Helper Functions ==================== #####
###################################################################################

##### Function to get the MCU, frequency, upload protocol, and upload speed from the given Arduino board name
function __avrcfg_from_arduino_get_subval__(valSet, selStr)
    # Simply return the whole set if the selector string is empty
    if !&${selStr} : return ${valSet}
    # Extract the part(s) and simply return the whole set if there is only one part
    local Parts := $explode(${valSet})
    if $part_count(${Parts}) == 1 : return ${valSet}
    # Search the parts
    foreach local Part in ${Parts}
        local Pair := $explode(${Part}, ':')
        if $partn(${Pair}, 1) &== ${selStr} : return $partn(${Pair}, 2)
    endforeach
    # No match
    return ''
endfunction

.macro __avr_config_extract__
    local MCU       := $partn(${AVRArduinoConfigData}, ${I}, 2)
    local CPUFreq   := $partn(${AVRArduinoConfigData}, ${I}, 3)
    local UProtocol := $partn(${AVRArduinoConfigData}, ${I}, 4)
    local UBaudrate := $partn(${AVRArduinoConfigData}, ${I}, 5)
    local UResetBL  := $partn(${AVRArduinoConfigData}, ${I}, 6)
    local UPortType := $partn(${AVRArduinoConfigData}, ${I}, 7)
.endmacro

.macro __avr_config_format_and_store__
    if !$str_fidx(${MCU}, 'at') : MCU := $ftt_stack('atmega', ${MCU})
    CD  := ${MCU}
    CD +:= $flatten( $stack(                        ${CPUFreq}  , '000000') )
    CD +:= $csel   ( $cmp(${UProtocol}, '&!=', ''), ${UProtocol}, 'arduino' )
    CD +:= $flatten( $stack(                        ${UBaudrate}, '00'    ) )
    CD +:= ${UResetBL}
    CD +:= ${UPortType}
.endmacro

function avrcfg_from_arduino(boardName)
    (* The configuration data is made based on the data obtained from:
     *     https://github.com/arduino/ArduinoCore-avr/blob/master/boards.txt
     *     https://github.com/arduino/ArduinoCore-megaavr/blob/master/boards.txt
     *     https://github.com/Thinary/ThinaryArduino/blob/master/Thinary-megaavr/boards.txt
     *)
    local const AVRArduinoConfigDataUnit  := 8
    local const AVRArduinoConfigData      :=                                                                                                                                  \
     (***   Type   Match String                                  MCU             MHz            Upload Protocol       Upload Speed (÷100)   Reset-BL   Default U̅S̅B̅/ACM   ***) \
             1     '^uno(?:mini|wifi)?$'                         '328p'          '16'           ''                    '1152'                0          0                      \
             0     'unowifirev2'                                 '4809'          '16'           'xplainedmini_updi'   '1152'                1          1                      \
            10     '^nano.+?(328p|168)$'                         ''              '16'           ''                    '328p:1152 168:192'   0          0                      \
             1     '^mega(1280)?.*?c[hp]\d+.*$'                  '1280'          '16'           ''                    '576'                 0          0                      \
             1     '^mega(?:2560|adk).*?c[hp]\d+.*$'             '2560'          '16'           'wiring'              '1152'                0          0                      \
             1     '^mega(1280)?(?:atmega\d{1,2}u\d)?$'          '1280'          '16'           ''                    '576'                 0          1                      \
             1     '^mega(?:2560|adk)(?:atmega\d{1,2}u\d)?$'     '2560'          '16'           'wiring'              '1152'                0          1                      \
             1     '^(?:pro|mini)mega(1280)?$'                   '1280'          '16'           ''                    '576'                 0          0                      \
             1     '^(?:pro|mini)mega(?:2560|adk)$'              '2560'          '16'           'wiring'              '1152'                0          0                      \
             1     '^mega(?:pro|mini)(1280)?$'                   '1280'          '16'           ''                    '576'                 0          0                      \
             1     '^mega(?:pro|mini)(?:2560|adk)$'              '2560'          '16'           'wiring'              '1152'                0          0                      \
             1     '^leonardo(?:eth)?|esplora$'                  '32u4'          '16'           'avr109'              '576'                 1          1                      \
             1     '^(?:sparkfun)?(?:pro)?micro$'                '32u4'          '16'           'avr109'              '576'                 1          1                      \
            10     '^pro(?:mini)?.+?(328p|168).*?(5|3\.3)v.*$'   ''              '5:16 3.3:8'   ''                    '328p:576  168:192'   0          0                      \
            20     '^pro(?:mini)?.+?(5|3\.3)v.+?(328p|168)$'     ''              '5:16 3.3:8'   ''                    '328p:576  168:192'   0          0                      \
            10     '^mini.+?(328p|168).*$'                       ''              '16'           ''                    '328p:1152 168:192'   0          0                      \
             0     'ethernet'                                    '328p'          '16'           ''                    '1152'                0          0                      \
            10     '^(?:duemilanove|diecimila).+?(328p|168)$'    ''              '16'           ''                    '328p:576  168:192'   0          0                      \
             0     'fio'                                         '328p'          '8'            ''                    '576'                 0          0                      \
            10     '^bt.+?(328p|168)$'                           ''              '16'           ''                    '192'                 0          0                      \
             0     'lilypad'                                     '328p'          '8'            ''                    '576'                 0          0                      \
            10     '^lilypad.+?(328p|168)$'                      ''              '8'            ''                    '328p:576  168:192'   0          0                      \
             1     '^lilypadusb(?:.*?32u4)?$'                    '32u4'          '8'            ''                    '576'                 1          1                      \
             1     '^ng(?:240|rev[.-]?c)?$'                      '168'           '16'           ''                    '192'                 0          0                      \
            10     '^ng.+?(168|8)$'                              ''              '16'           ''                    '192'                 0          0                      \
             1     '^robot(?:control|motor)$'                    '32u4'          '16'           'avr109'              '576'                 1          1                      \
             1     '^adafruitcircuitplayground.*$'               '32u4'          '8'            'avr109'              '576'                 1          1                      \
             0     'nanoevery'                                   '4809'          '16'           'jtag2updi'           '1152'                1          1                      \
             1     '^thinarynanoevery(?:.*?4808)?$'              '4808'          '16'           'jtag2updi'           '1152'                1          0                      \
             1     '^dt-?avrat90usb162cpumodule$'                'at90usb162'    '8'            'avr109'              '576'                 1          1                      \
             1     '^(?:dt-?avr)?inoduino$'                      'at90usb1286'   '16'           'avr109'              '576'                 1          1
    # Convert the board name to lowercase, remove all 'arduino' words, and remove all whitespaces
    local BN := $lcase(${boardName})
          BN := ${BN/arduino|\s//}
    # Search the configuration data
    local CD
    foreach local I, V in ${AVRArduinoConfigData} step ${AVRArduinoConfigDataUnit}
        # Get the 'use regular expression' flag and the reference name
        local UseRegExp := ${V}
        local RefName   := $partn(${AVRArduinoConfigData}, ${I}, 1)
        # Compare using regular expression
        if ${UseRegExp}
            if $re_match( ${BN}, ${RefName} )
                .$__avr_config_extract__
                local Part := $re_split( ${BN}, ${RefName} )
                if ${UseRegExp} == 10
                    local IM := 1
                    local IV := 2
                elif ${UseRegExp} == 20
                    local IM := 2
                    local IV := 1
                endif
                if ${IM}
                    MCU       := $ftt_stack(                                     ${MCU}      , $partn(${Part}, ${IM}) )
                    CPUFreq   := $call     ( __avrcfg_from_arduino_get_subval__, ${CPUFreq}  , $partn(${Part}, ${IV}) )
                    UBaudrate := $call     ( __avrcfg_from_arduino_get_subval__, ${UBaudrate}, $partn(${Part}, ${IM}) )
                endif
                .$__avr_config_format_and_store__
                break
            endif
        # Compare using exact plain text
        elif ${RefName} &== ${BN}
            .$__avr_config_extract__
            .$__avr_config_format_and_store__
            break
        endif
    endforeach
    # Error if no valid result was found
    if !&${CD} : $call(__exit_error_ns_desc__, 'decoding board specification for board', ${boardName})
    # Return the result
    return ${CD}
endfunction

.undefmacro __avr_config_extract__
.undefmacro __avr_config_format_and_store__

