    if $[excode]
        $call(__exit_error_build_process_fail__, :"$[function]()", true)
        $exit($[excode])
    endif
.endmacro

function __avr_chksig_genextprog_exec__(programmer, configSet, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${programmer} ${configSet} -p ${part} -D -U signature:r:-:h
endfunction

function avr_chksig_genextprog(configSet)
