.macro __avr_avrispmkii_common_entry_code__
    # Check if AVRDUDE support the programmer
    $call(__avr_chk_avrdude_prog_support__, 'AVRISP mkII')
    # Set the default value
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_avr__, ${AVR_CPUFrequency})
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # Check if the target is an ATxmega MCU
    local xmega := $str_begwith(${part}, 'x')
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __avr_avrispmkii_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_advanced_atmel_isp_programmer_error_and_print_help__, $[function])
.endmacro

function __avr_chksig_avrispmkii_exec__(bitClock, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c avrispmkii -B ${bitClock} -p ${part} -D -U signature:r:-:h
endfunction

function avr_chksig_avrispmkii(?bitClock)
    # Execute the common entry code
    .$__avr_avrispmkii_common_entry_code__
    # Perform signature check
    $exec( __avr_chksig_avrispmkii_exec__, ${bitClock}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_avrispmkii_common_leave_code__
endfunction

function __avr_upload_avrispmkii_exec__(xmega, progName, bitClock, ldLibraryPath)
    # NOTE : For some unknown reason, programming an ATxmega MCU using AVRISP mkII will most likely fail if automatic verification check is disabled
    if !${xmega} : local Verify := '-V'
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRDUDE_Cmd} -c avrispmkii -B ${bitClock} -p ${part} -e ${AVRDUDE_CmdSafeMode} -D ${Verify} -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function avr_upload_avrispmkii(progName, ?bitClock)
    # Execute the common entry code
    .$__avr_avrispmkii_common_entry_code__
    # Perform upload
    $exec( __avr_upload_avrispmkii_exec__, ${xmega}, ${progName}, ${bitClock}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_avrispmkii_common_leave_code__
endfunction

.undefmacro __avr_avrispmkii_common_entry_code__
.undefmacro __avr_avrispmkii_common_leave_code__

