##### Function to check signature and upload via Atmel-ICE
.macro __avr_atmelice_common_entry_code__
    # Check if AVRDUDE support the programmer
    $call(__avr_chk_avrdude_prog_support__, 'Atmel-ICE')
    # Set the operational mode
    if !&${operMode} ; operMode := 'jtag'
    else             ; operMode := $lcase(${operMode})
    endif
    if ${operMode} &== 'jtag' ; operMode := ''
    else                      ; operMode := :"_${operMode}"
    endif
    # Set the default value
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_avr__, ${AVR_CPUFrequency})
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __avr_atmelice_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_advanced_atmel_isp_programmer_error_and_print_help__, $[function])
.endmacro

function __avr_chksig_atmelice_exec__(operMode, bitClock, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c :"atmelice${operMode}" -B ${bitClock} -p ${part} -D -U signature:r:-:h
endfunction

function avr_chksig_atmelice(?operMode, ?bitClock)
    # Execute the common entry code
    .$__avr_atmelice_common_entry_code__
    # Perform signature check
    $exec( __avr_chksig_atmelice_exec__, ${operMode}, ${bitClock}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_atmelice_common_leave_code__
endfunction

function __avr_upload_atmelice_exec__(progName, operMode, bitClock, ldLibraryPath)
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRDUDE_Cmd} -c :"atmelice${operMode}" -B ${bitClock} -p ${part} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function avr_upload_atmelice(progName, ?operMode, ?bitClock)
    # Execute the common entry code
    .$__avr_atmelice_common_entry_code__
    # Perform upload
    $exec( __avr_upload_atmelice_exec__, ${progName}, ${operMode}, ${bitClock}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_atmelice_common_leave_code__
endfunction

.undefmacro __avr_atmelice_common_entry_code__
.undefmacro __avr_atmelice_common_leave_code__


##### Function to check signature and upload via UPDI programmers with serial connections
const AVR_Default_SerialUPDIVariant := 'SerialUPDI'
const AVR_Reserve_SerialUPDIVariant := 'JTAG2UPDI'

.macro __avr_serialupdi_common_entry_code__
    # Set the default values
    variant  ?:= ${AVR_Default_SerialUPDIVariant}
    variant   := $lcase(${variant})
    baudrate ?:= $call(__avrdude_det_serialupdi_baudrate_for_avr__, ${AVR_CPUFrequency})
    # Check if AVRDUDE support the programmer variant
    $call(__avr_chk_avrdude_prog_support__, ${variant})
    # Determine the part name
    local part := $call(__avr_mcu_to_avrdude_part__, ${AVR_MCUType})
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __avr_serialupdi_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    if $[excode]
        $call(__exit_error_build_process_fail__, :"$[function]()", true)
        $exit($[excode])
    endif
.endmacro

function __avr_chksig_serialupdi_exec__(device, variant, baudrate, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -P ${device} -b ${baudrate} -p ${part} -D -U signature:r:-:h
endfunction

function avr_chksig_serialupdi(device, ?variant, ?baudrate)
    # Execute the common entry code
    .$__avr_serialupdi_common_entry_code__
    # Perform upload
    $exec( __avr_chksig_serialupdi_exec__, ${device}, ${variant}, ${baudrate}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_serialupdi_common_leave_code__
endfunction

function __avr_upload_serialupdi_exec__(progName, device, variant, baudrate, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -P ${device} -b ${baudrate} -p ${part} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function avr_upload_serialupdi(progName, device, ?variant, ?baudrate)
    # Execute the common entry code
    .$__avr_serialupdi_common_entry_code__
    # Perform upload
    $exec( __avr_upload_serialupdi_exec__, ${progName}, ${device}, ${variant}, ${baudrate}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__avr_serialupdi_common_leave_code__
endfunction

.undefmacro __avr_serialupdi_common_entry_code__
.undefmacro __avr_serialupdi_common_leave_code__


##### Function to check signature and upload via generic external programmer
.macro __avr_genextprog_common_entry_code__
    # NOTE : For generic external programmers, we do not check whether AVRDUDE supports the selected programmer!
