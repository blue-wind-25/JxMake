    echoln __c_green__ '    arduino_use_littlefs   (                       ) ' __c_white__ ': use \'' __c_yellow__ 'LittleFS' __c_white__ '\' as the file system (the default if the required tool exists)'
    echoln
    echoln __c_green__ '    arduino_set_signing_key(publicKeyPath ,        ) ' __c_white__ ': set the signing public and private keys'
    echoln __c_green__ '                            privateKeyPath         ) '
    echoln
    echoln __c_green__ '    arduino_compile_c      (?extraOptions          ) ' __c_white__ ': compile           an ' ${AGText} ' C   source code; please use this instead of \'' __c_green__ 'compile_c' __c_white__ '\''
    echoln __c_green__ '    arduino_compile_cpp    (?extraOptions          ) ' __c_white__ ': compile           an ' ${AGText} ' C++ source code; please use this instead of \'' __c_green__ 'compile_cpp' __c_white__ '\''
    echoln
    echoln __c_green__ '    arduino_link_exe       (?extraOptions          ) ' __c_white__ ': link              an ' ${AGText} ' executable     ; please use this instead of \'' __c_green__ 'link_exe' __c_white__ '\''
    echoln __c_green__ '    arduino_link_slib      (                       ) ' __c_white__ ': link              an ' ${AGText} ' static library ; please use this instead of \'' __c_green__ 'link_slib' __c_white__ '\''
    echoln __c_green__ '    arduino_run_exe        (progName, ?dimColor    ) ' __c_white__ ': print the size of an ' ${AGText} ' executable     ; please use this instead of \'' __c_green__ 'link_exe' __c_white__ '\''
    echoln
    echoln __c_green__ '    arduino_make_fsimage   (fsRootDir              ) ' __c_white__ ': create a file system image file using the selected file system format'
    echoln
    echoln __c_green__ '    arduino_stdec          (progName, stContent    ) ' __c_white__ ': run ESP stack decoder using the given ' ${AGText} ' executable and stack trace content'
    echoln
    local DefASerialResetMethod := $ftspaces(${__Arduino_DefSerialUploadResetMethod__})
    echoln __c_green__ '    arduino_upload_serial  (progName    , device     ' __c_white__ ': upload program to ' __c_cyan__ 'ESP8266' __c_white__ ' via ' __c_cyan__ 'serial port' __c_white__ ' using ' __c_cyan__ 'Arduino' __c_white__ ' tool'
    echoln __c_green__ '                            ?baudrate   , ?eraseCmd, ' __c_green__ '      progName   ' __c_white__ ' program name      ; use        the value  returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                            ?resetMethod, ?signed  ) ' __c_green__ '      device     ' __c_white__ ' serial device path; use one of the values returned by \'' __c_green__ '$ls_serial_ports()' __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '      baudrate   ' __c_white__ ' set this to the correct baudrate      - the default is \'' __c_yellow__ ${__Arduino_DefSerialUploadBaudrate__} __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or the value from \'' __c_green__ 'arduino_board_selector' __c_white__ '\')'
    echoln __c_green__ '                                                     ' __c_green__ '      eraseCmd   ' __c_white__ ' set this to the correct erase command - the default is not set'
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or the value from \'' __c_green__ 'arduino_board_selector' __c_white__ '\')'
    echoln __c_green__ '                                                     ' __c_green__ '      resetMethod' __c_white__ ' set this to the correct reset method  - the default is \'' __c_yellow__ ${DefASerialResetMethod} __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or the value from \'' __c_green__ 'arduino_board_selector' __c_white__ '\')'
    echoln __c_green__ '                                                     ' __c_green__ '      signed     ' __c_white__ ' set this to ' __c_yellow__ '1' __c_white__ ' to use signed upload    - the default is not signed'
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or signed if keys are set via \'' __c_green__ 'arduino_set_signing_key' __c_white__ '\')'
    echoln __c_green__ '    arduino_upload_ota     (progName , hostNameOrIP, ' __c_white__ ': upload program to ' __c_cyan__ 'ESP8266' __c_white__ ' via ' __c_cyan__ 'OTA (Over-the-Air)' __c_white__ ' using ' __c_cyan__ 'Arduino' __c_white__ ' tool'
    echoln __c_green__ '                            ?progPort, ?otaPassword, ' __c_green__ '      progName    ' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                            ?signed                ) ' __c_green__ '      hostNameOrIP' __c_white__ ' hostname or IP   of the target'
    echoln __c_green__ '                                                     ' __c_green__ '      progPort    ' __c_white__ ' programming port of the target     - the default is \'' __c_yellow__ ${__Arduino_DefOTAPort__} __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '      otaPassword ' __c_white__ ' OTA password                       - the default is no password'
    echoln __c_green__ '                                                     ' __c_green__ '      signed      ' __c_white__ ' set this to ' __c_yellow__ '1' __c_white__ ' to use signed upload - the default is not signed'
    echoln __c_green__ '                                                     ' __c_green__ '                  ' __c_white__ '                                      (or signed if keys are set via \'' __c_green__ 'arduino_set_signing_key' __c_white__ '\')'
    echoln
    echoln __c_green__ '    arduino_uploadfs_serial(device      , ?baudrate, ' __c_white__ ': upload file system image created using \'' __c_green__ 'arduino_make_fsimage' __c_white__ '\' to ESP8266 via ' __c_cyan__ 'serial port' __c_white__ ' using ' __c_cyan__ 'Arduino' __c_white__ ' tool'
    echoln __c_green__ '                            ?resetMethod, ?signed  ) ' __c_green__ '      device     ' __c_white__ ' serial device path; use one of the values returned by \'' __c_green__ '$ls_serial_ports()' __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '      baudrate   ' __c_white__ ' set this to the correct baudrate      - the default is \'' __c_yellow__ ${__Arduino_DefSerialUploadBaudrate__} __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or the value from \'' __c_green__ 'arduino_board_selector' __c_white__ '\')'
    echoln __c_green__ '                                                     ' __c_green__ '      resetMethod' __c_white__ ' set this to the correct reset method  - the default is \'' __c_yellow__ ${DefASerialResetMethod} __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or the value from \'' __c_green__ 'arduino_board_selector' __c_white__ '\')'
    echoln __c_green__ '                                                     ' __c_green__ '      signed     ' __c_white__ ' set this to ' __c_yellow__ '1' __c_white__ ' to use signed upload    - the default is not signed'
    echoln __c_green__ '                                                     ' __c_green__ '                 ' __c_white__ '                                         (or signed if keys are set via \'' __c_green__ 'arduino_set_signing_key' __c_white__ '\')'
    echoln __c_green__ '    arduino_uploadfs_ota   (hostNameOrIP, ?progPort, ' __c_white__ ': upload file system image created using \'' __c_green__ 'arduino_make_fsimage' __c_white__ '\' to ESP8266 via ' __c_cyan__ 'OTA (Over-the-Air)' __c_white__ ' using ' __c_cyan__ 'Arduino' __c_white__ ' tool'
    echoln __c_green__ '                            ?otaPassword, ?signed  ) ' __c_green__ '      hostNameOrIP' __c_white__ ' hostname or IP   of the target'
    echoln __c_green__ '                                                     ' __c_green__ '      progPort    ' __c_white__ ' programming port of the target     - the default is \'' __c_yellow__ ${__Arduino_DefOTAPort__} __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '      otaPassword ' __c_white__ ' OTA password                       - the default is no password'
    echoln __c_green__ '                                                     ' __c_green__ '      signed      ' __c_white__ ' set this to ' __c_yellow__ '1' __c_white__ ' to use signed upload - the default is not signed'
    echoln __c_green__ '                                                     ' __c_green__ '                  ' __c_white__ '                                      (or signed if keys are set via \'' __c_green__ 'arduino_set_signing_key' __c_white__ '\')'
    echoln
   #$call(__btlib_help_print_title_targets__, 23, ${CGInfo})
    $call(__btlib_help_print_title_targets__,  0, ${CGInfo})
    echoln __c_green__ '    arduino_esp8266_compile_ld       ' __c_white__ ': compile the linker script              for the board that has been selected using \'' __c_green__ 'arduino_board_selector' __c_white__ '\''
    echoln __c_green__ '    arduino_esp8266_build_core_slib  ' __c_white__ ': build   the core  static library file  for the board that has been selected using \'' __c_green__ 'arduino_board_selector' __c_white__ '\''
    echoln __c_green__ '    arduino_esp8266_build_extra_slib ' __c_white__ ': build   the extra static library files for the board that has been selected using \'' __c_green__ 'arduino_board_selector' __c_white__ '\''
    echoln
    $call(__btlib_help_print_note_arduino_environment__)
    echoln __c_reset__
endfunction
