##### Include the native C/C++ build tool and other utilities
__ForceGCC__ := 1

:::include_once 'C++BuildTool.jxm'
:::include_once 'C++XBuildTool_ArduinoUtil.jxm'
:::include_once 'OpenSSLUtil.jxm'
:::include_once 'PythonUtil.jxm'


##### MSys may cause weird errors so exclude it from the supported build environment
if __os_msys__
    $call(__exit_error_ns_benv__, 'Xtensa LX106 (ESP8266) GCC', 'MSys')
endif


##### Update the flags
const __x_gcc__                := 1
const __xtensa_gcc__           := 1
const __xtensa_lx106_elf_gcc__ := 1

const __BuildTool_Name__       := 'Xtensa LX106 (ESP8266) GNU Compiler Collection (GCC)'
const __BuildTool_Target__     := 'Xtensa LX106 (ESP8266)'
const __BuildTool_Title__      := 'Xtensa LX106 (ESP8266) C/C++'


##### Fix the file extensions as needed
if !__os_linux__
    ExeFileExt  := elf
    DLibFileExt := so
endif


##### Update the definitions of executables, paths, and options
        CppAssembler              := 'xtensa-lx106-elf-gcc'
        CppCommonAssemblerFlags  +:= '-x' 'assembler-with-cpp' '-mlongcalls'

        CppCcCompiler             := 'xtensa-lx106-elf-gcc'
        CppCommonCcCompileFlags  +:= '-mlongcalls' '-mtext-section-literals'
        CppCommonCcCompileFlags  +:= '-fdata-sections' '-ffunction-sections' '-falign-functions=4'
        CppCommonCcCompileFlags  +:= '-free' '-fipa-pta'

        CppCxxCompiler            := 'xtensa-lx106-elf-g++'
        CppCommonCxxCompileFlags +:= '-mlongcalls' '-mtext-section-literals'
        CppCommonCxxCompileFlags +:= '-fdata-sections' '-ffunction-sections' '-falign-functions=4'
        CppCommonCxxCompileFlags +:= '-free' '-fipa-pta' '-fno-rtti'

        CppLinker                 := 'xtensa-lx106-elf-gcc'
        CppCommonLinkFlags       +:= '-Wl,-EL' '-Wl,--no-check-sections' '-Wl,--gc-sections'

const __Def_SLibBuilder__         := 'xtensa-lx106-elf-ar'
        SLibBuilder               := ${__Def_SLibBuilder__}


##### Define some Xtensa-specific tools
XtensaSize      := 'xtensa-lx106-elf-size'
XtensaFlags     := '--format=berkeley' '--radix=10'

XtensaAddr2Line := 'xtensa-lx106-elf-addr2line'


###################################################################################
##### ============= Arduino & Native ESP8266 Detection Functions ============ #####
###################################################################################

##### Function to find the latest Xtensa GCC from Arduino package(s) and other directories
function __find_latest_xtensa_gcc_dir_impl__(searchDirList)
    # Find the latest Xtensa GCC version
    local LatestVersion := 0
    local LatestPath    := ''
    local CppToolBinDir
    local LDLibraryPath
    foreach local DirItem in ${searchDirList}
        # Get the GCC binary path
        local HolderPathR := ${DirItem}                                          # Binary directory location if from a standalone Xtensa GCC installation
        local HolderPathA := $cat_path(${DirItem}, 'tools/xtensa-lx106-elf-gcc') # Parent directory location if from Arduino package installation
        if $valid_path(${HolderPathA})
              HolderPathR := $lsdir(${HolderPathA}, 'd')                         # Binary directory location if from Arduino package installation
        endif
        foreach local BinDir in ${HolderPathR}
            .$__lb_cmp_gcc_ver_and_get_the_newer_path_and_ver__
        endforeach
    endforeach
    # Return the latest Xtensa GCC version and path
    return { ${LatestVersion} ${LatestPath} }
endfunction

function __find_latest_arduino_xtensa_gcc_dir__()
    # Determine the possible search directories
    local SearchDirPath
    local SearchDirList
    foreach local DirItem in ${ArduinoPackageDirs}
        # Search for the 'packages' directory
        SearchDirPath := $cat_path(${DirItem}, 'packages')
        if $valid_path(${SearchDirPath})
            local SDPLen := $strlen(${SearchDirPath})
            add   SDPLen, ${SDPLen}, 2
            foreach local Dir in $lsdir(${SearchDirPath}, 'd')
                if $re_match( $substr(${Dir}, ${SDPLen}, -1), 'esp8266.*') : SearchDirList +:= ${Dir}
            endforeach
        # If it was not found, perhaps the user has set the path to the specific package directory
        else
            loop
                # Search for the 'hardware' directory
                SearchDirPath := $cat_path(${DirItem}, 'hardware')
                if $valid_path(${SearchDirPath})
                    SearchDirList +:= ${DirItem}
                    break
                endif
                # Remove the last part from the path
                local DirRedux := $path_rm_last_part(${DirItem})
                if ${DirRedux} &== ${DirItem} : break
                DirItem := ${DirRedux}
            endloop
        endif
    endforeach
    # Sort in descending order so that newer packages have higher priority; this method is not perfect, but it is better than nothing
    SearchDirList := $sort_descending(${SearchDirList})
    # Get the latest Xtensa GCC version and path
    local Ret := $call(__find_latest_xtensa_gcc_dir_impl__, ${SearchDirList})
    # Get the selected Arduino package directory
    if ${Ret}<1>
        __SelArduinoPackageDir__ := ${Ret}<2>
        __SelArduinoPackageDir__ := $substr( ${__SelArduinoPackageDir__}, 1, $str_fidx(${__SelArduinoPackageDir__}, '/tools') )
        __SelArduinoPackageDir__ := $lsdir( $cat_path(${__SelArduinoPackageDir__}, 'hardware/esp8266'), 'd' )
    endif
    # Return the latest Xtensa GCC version and path
    return ${Ret}
endfunction

function __find_latest_custdir_xtensa_gcc_dir__()
    # Determine the directories that will be excluded from the search
    __JXMAKELIB_EXCLUDE_XTENSA_GCC_CUSTOM_DIRS__ ?:= $sfpseps( $getenv('JXMAKELIB_EXCLUDE_XTENSA_GCC_CUSTOM_DIRS', ${JXMAKELIB_EXCLUDE_XTENSA_GCC_CUSTOM_DIRS}) )
    # Determine the possible search directories
    local SearchDirList
    foreach local Dir in $lsdir('/opt', 'd')
        if $contains(${__JXMAKELIB_EXCLUDE_XTENSA_GCC_CUSTOM_DIRS__}, ${Dir}) : continue
        if $re_match( $substr(${Dir}, 6, -1), '^(.+.)?xtensa-lx106-elf.*')
            local Sub := $cat_path(${Dir}, 'xtensa-lx106-elf'        )
            local Bin := $cat_path(${Sub}, 'bin/xtensa-lx106-elf-gcc')
            SearchDirList +:= $csel( $valid_path(${Bin}), ${Sub}, ${Dir} )
        endif
    endforeach
    # Sort in descending order so that newer packages have higher priority; this method is not perfect, but it is better than nothing
    # NOTE : Use regular expression to remove 'GGGGGGG' when sorting from something like 'x86_64-linux-gnu.xtensa-lx106-elf-GGGGGGG.YYYYMM/xtensa-lx106-elf'
    SearchDirList := $sort_descending(${SearchDirList}, '(.+?-elf-)(?:[0-9a-fA-F]{6,8})(\\.\\d{6,8}\\/.+)', '$1$2')
    # Return the latest Xtensa GCC version and path
    return $call(__find_latest_xtensa_gcc_dir_impl__, ${SearchDirList})
endfunction

function __find_latest_xtensa_gcc_dir__()
    return $call(find_latest_cross_gcc_dir_arduino_custdir, 'LatestXtensaGCCPath.cache', __find_latest_arduino_xtensa_gcc_dir__, __find_latest_custdir_xtensa_gcc_dir__)
endfunction


##### Undefine the helper macro from 'C++XBuildTool_ArduinoUtil.jxm' here to prevent duplicated name later on
.undefmacro __lb_cmp_gcc_ver_and_get_the_newer_path_and_ver__


##### Function to get the latest Xtensa header, source, and library directories from the selected Arduino package directory
function __get_latest_arduino_xtensa_hsl_dir__()
    # Try to get the path from the cache file first
    local ArduinoHLDirsCacheFilePath := $cat_path( $ptd(), 'LatestArduinoXtensaHLDirs.cache' )
    if $uptodate_path(${ArduinoHLDirsCacheFilePath})
        # Get the path to the latest directories
        local Lines := $get_file(${ArduinoHLDirsCacheFilePath})
        # Get and split the lines
        __SelArduinoPackageDir__   := $sfpipes       (${Lines}< 1>)
        ArduinoESP8266LDSourceDir  := $sfpipes       (${Lines}< 2>)
        ArduinoESP8266NonOSSDKDir  := $sfpipes       (${Lines}< 3>)
        ArduinoESP8266NonOSSDKDirs := $sfpipes       (${Lines}< 4>)
        ArduinoESP8266IncludeDir   := $sfpipes       (${Lines}< 5>)
        ArduinoESP8266LibraryDir   := $sfpipes       (${Lines}< 6>)
        ArduinoESP8266CoreSrcDir   := $sfpipes       (${Lines}< 7>)
        ArduinoESP8266LibRootDir   := $sfpipes       (${Lines}< 8>)
        ArduinoESP8266LibSrcDirs   := $sfpipes       (${Lines}< 9>)
        ArduinoESP8266LibList      := $sfpipes       (${Lines}<10>)
        ArduinoESP8266LibMH        := $map_from_edata(${Lines}<11>)
        ArduinoGenericLibSrcDirs   := $sfpipes       (${Lines}<12>)
        ArduinoGenericLibList      := $sfpipes       (${Lines}<13>)
        ArduinoGenericLibMH        := $map_from_edata(${Lines}<14>)
        ArduinoESP8266ESPToolsDir  := $sfpipes       (${Lines}<15>)
        ArduinoESP8266LittleFSBin  := $sfpipes       (${Lines}<16>)
        ArduinoESP8266SPIFFSBin    := $sfpipes       (${Lines}<17>)
    # Determine the paths
    elif &${__SelArduinoPackageDir__}
        # Set the common Arduino package source, include, and library directories
        local mklittlefs := $cat_path(${__SelArduinoPackageDir__}, '../../../tools/mklittlefs')
        local mkspiffs   := $cat_path(${__SelArduinoPackageDir__}, '../../../tools/mkspiffs'  )
        if $valid_path(${mklittlefs}) : mklittlefs := $ftt_stack( $lsdir(${mklittlefs}, 'd'), '/mklittlefs' )
        if $valid_path(${mkspiffs}  ) : mkspiffs   := $ftt_stack( $lsdir(${mkspiffs}  , 'd'), '/mkspiffs'   )
        ArduinoESP8266CoreSrcDir   :=         $cat_path(${__SelArduinoPackageDir__}, 'cores/esp8266'            )
        ArduinoESP8266LibRootDir   :=         $cat_path(${__SelArduinoPackageDir__}, 'libraries'                )
        ArduinoESP8266IncludeDir   :=         $cat_path(${__SelArduinoPackageDir__}, 'bootloaders'              )
        ArduinoESP8266IncludeDir  +:=         $cat_path(${__SelArduinoPackageDir__}, 'tools/sdk/include'        )
        ArduinoESP8266IncludeDir  +:=         $cat_path(${__SelArduinoPackageDir__}, 'tools/sdk/lwip2/include'  )
        ArduinoESP8266IncludeDir  +:= ${ArduinoESP8266CoreSrcDir}
        ArduinoESP8266IncludeDir  +:=         $cat_path(${__SelArduinoPackageDir__}, 'cores/esp8266/umm_malloc' )
        ArduinoESP8266IncludeDir  +:=         $cat_path(${__SelArduinoPackageDir__}, 'cores/esp8266/spiffs'     )
        ArduinoESP8266IncludeDir  +:=         $cat_path(${__SelArduinoPackageDir__}, 'cores/esp8266/libb64'     )
        ArduinoESP8266LibraryDir   :=         $cat_path(${__SelArduinoPackageDir__}, 'tools/sdk/lib'            )
        ArduinoESP8266LDSourceDir  :=         $cat_path(${__SelArduinoPackageDir__}, 'tools/sdk/ld'             )
        ArduinoESP8266NonOSSDKDir  :=         $cat_path(${__SelArduinoPackageDir__}, 'tools/sdk/lib'            )
        ArduinoESP8266ESPToolsDir  :=         $cat_path(${__SelArduinoPackageDir__}, 'tools'                    )
        ArduinoESP8266LittleFSBin  := ${mklittlefs}
        ArduinoESP8266SPIFFSBin    := ${mkspiffs}
        # Set the Arduino Non-OS SDK library directories
        local NonOSSDKDirPrefixLen := $strlen(${ArduinoESP8266NonOSSDKDir})
        add   NonOSSDKDirPrefixLen, ${NonOSSDKDirPrefixLen}, 2
        foreach local NSD in $lsdir(${ArduinoESP8266NonOSSDKDir}, 'd')
            if $re_match( $substr( ${NSD}, ${NonOSSDKDirPrefixLen}, $strlen(${NSD} ) ), '^NONOSDK\d{2}.+' ) : ArduinoESP8266NonOSSDKDirs +:= ${NSD}
        endforeach
        # Get the ESP8266 Arduino library list
        ArduinoESP8266LibMH := $call(list_arduino_library, ${ArduinoESP8266LibRootDir}, 'esp8266')
        foreach local SName in $map_get(${ArduinoESP8266LibMH}, '__LRDirNames__')
            ArduinoESP8266LibSrcDirs +:= $map_get(${ArduinoESP8266LibMH}, :"{${SName}}:path")
            ArduinoESP8266LibList    +:= ${SName}
        endforeach
       #$call(dump_map_object_and_exit, ${ArduinoESP8266LibMH})
        # Get the generic (non platform-spesific) Arduino library list
        ArduinoGenericLibMH := $call(list_arduino_library, ${ArduinoLibraryDirs}, 'esp8266')
        foreach local SName in $map_get(${ArduinoGenericLibMH}, '__LRDirNames__')
            ArduinoGenericLibSrcDirs +:= $map_get(${ArduinoGenericLibMH}, :"{${SName}}:path")
            ArduinoGenericLibList    +:= ${SName}
        endforeach
       #$call(dump_map_object_and_exit, ${ArduinoGenericLibMH})
        # Sort the header, source, and package library directories
        ArduinoESP8266LibSrcDirs   := $sort_ascending(${ArduinoESP8266LibSrcDirs}  )
        ArduinoESP8266LibList      := $sort_ascending(${ArduinoESP8266LibList}     )
        ArduinoESP8266NonOSSDKDirs := $sort_ascending(${ArduinoESP8266NonOSSDKDirs})
        ArduinoGenericLibSrcDirs   := $sort_ascending(${ArduinoGenericLibSrcDirs}  )
        ArduinoGenericLibList      := $sort_ascending(${ArduinoGenericLibList}     )
        # Combine and save the lines
        local Lines  := $ftpipes     (${__SelArduinoPackageDir__}  )
              Lines +:= $ftpipes     (${ArduinoESP8266LDSourceDir} )
              Lines +:= $ftpipes     (${ArduinoESP8266NonOSSDKDir} )
              Lines +:= $ftpipes     (${ArduinoESP8266NonOSSDKDirs})
              Lines +:= $ftpipes     (${ArduinoESP8266IncludeDir}  )
              Lines +:= $ftpipes     (${ArduinoESP8266LibraryDir}  )
              Lines +:= $ftpipes     (${ArduinoESP8266CoreSrcDir}  )
              Lines +:= $ftpipes     (${ArduinoESP8266LibRootDir}  )
              Lines +:= $ftpipes     (${ArduinoESP8266LibSrcDirs}  )
              Lines +:= $ftpipes     (${ArduinoESP8266LibList}     )
              Lines +:= $map_to_edata(${ArduinoESP8266LibMH}       )
              Lines +:= $ftpipes     (${ArduinoGenericLibSrcDirs}  )
              Lines +:= $ftpipes     (${ArduinoGenericLibList}     )
              Lines +:= $map_to_edata(${ArduinoGenericLibMH}       )
              Lines +:= $ftpipes     (${ArduinoESP8266ESPToolsDir} )
              Lines +:= $ftpipes     (${ArduinoESP8266LittleFSBin} )
              Lines +:= $ftpipes     (${ArduinoESP8266SPIFFSBin}   )
        $put_file(${ArduinoHLDirsCacheFilePath}, ${Lines})
    endif
endfunction


##### Function to check for Xtensa tools
function __check_xtensa_tools__()
    # Try to get the results from the cache file first
    local XtensaCheckToolsCacheFilePath := $cat_path( $ptd(), 'XtensaCheckTools.cache' )
    local XtensaCheckTools
    if $uptodate_path(${XtensaCheckToolsCacheFilePath})
        XtensaCheckTools := $get_file(${XtensaCheckToolsCacheFilePath})
        __has_xtensa_gcc_ar__ := $partn(${XtensaCheckTools}, 1)
        return
    endif
    # Check if the tools are available for use
    __has_xtensa_gcc_ar__ := $call(cmd_executed_successfully, ${CppToolBinDir}, 'xtensa-lx106-elf-gcc-ar' , '-V')
    # Save the results to the cache file
    $put_file( ${XtensaCheckToolsCacheFilePath}, { \
        ${__has_xtensa_gcc_ar__}                   \
        __dummy__                                  \
    } )
endfunction


