##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__() supersede
    local XGText := __c_cyan__  'Xtensa GCC' __c_white__
    local AGText := __c_cyan__  'Arduino Generic' __c_white__
    local CGText := __c_cyan__  'Arduino ESP8266 SDK' __c_white__
    local CGInfo := __c_white__ 'for ' ${CGText} ' '
    local VRange := $call(__btlib_help_build_string_tested_version_range__, ${CGText}, '3.x.x', true)
    $call(__origin__, true, false, true, true)
    $call(__btlib_help_print_title_cross__)
    $call(__btlib_help_print_title_variables__, ${CGInfo})
    echoln __c_green__ '    __gcc__                                  ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __x_gcc__                                ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __xtensa_gcc__                           ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __xtensa_lx106_elf_gcc__                 ' __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln
    echoln __c_green__ '    JXMAKELIB_EXCLUDE_XTENSA_GCC_CUSTOM_DIRS ' __c_white__ ': exclude the custom directories specified here when searching for the latest ' ${XGText} ';'
    echoln __c_green__ '                                             ' __c_white__ '  paths are separated using \'' __c_green__ '__os_psep_char__' __c_white__ '\''
    echoln
    echoln __c_green__ '    XtensaGCCIncludeDir                      ' __c_white__ ': locations of ' ${XGText} ' common header  files'
    echoln __c_green__ '    XtensaGCCLibraryDir                      ' __c_white__ ': locations of ' ${XGText} ' common library files'
    echoln
    echoln __c_green__ '    ArduinoPackageDirs                       ' __c_white__ ': locations of ' __c_cyan__ 'Arduino' __c_white__ ' package directories; ' ${VRange}
    echoln __c_green__ '    ArduinoLibraryDirs                       ' __c_white__ ': locations of ' __c_cyan__ 'Arduino' __c_white__ ' library directories'
    echoln
    echoln __c_green__ '    ArduinoESP8266LDSourceDir                ' __c_white__ ': locations of ' ${CGText} ' linker     script  files'
    echoln __c_green__ '    ArduinoESP8266NonOSSDKDir                ' __c_white__ ': locations of ' ${CGText} ' Non-OS SDK library directories'
    echoln __c_green__ '    ArduinoESP8266NonOSSDKDirs               ' __c_white__ ': locations of ' ${CGText} ' Non-OS SDK library files'
    echoln
    echoln __c_green__ '    ArduinoESP8266IncludeDir                 ' __c_white__ ': locations of ' ${CGText} ' common     system header  files'
    echoln __c_green__ '    ArduinoESP8266LibraryDir                 ' __c_white__ ': locations of ' ${CGText} ' common     system library files'
    echoln
    echoln __c_green__ '    ArduinoESP8266CoreSrcDir                 ' __c_white__ ': locations of ' ${CGText} ' core       source files'
    echoln
    echoln __c_green__ '    ArduinoESP8266LibRootDir                 ' __c_white__ ': locations of ' ${CGText} ' library    source root directory'
    echoln __c_green__ '    ArduinoESP8266LibSrcDirs                 ' __c_white__ ': locations of ' ${CGText} ' library    source directories'
    echoln __c_green__ '    ArduinoESP8266LibList                    ' __c_white__ ': list         ' ${CGText} ' library    source names'
    echoln
    echoln __c_green__ '    ArduinoGenericLibSrcDirs                 ' __c_white__ ': locations of ' ${AGText} '     library    source directories that are compatible with this target architecture'
    echoln __c_green__ '    ArduinoGenericLibList                    ' __c_white__ ': list         ' ${AGText} '     library    source names       that are compatible with this target architecture'
    echoln
    echoln __c_green__ '    ArduinoESP8266ESPToolsDir                ' __c_white__ ': locations of ' ${CGText} ' Python     tools   files'
    echoln
    echoln __c_green__ '    ArduinoESP8266BoardSelCacheDir           ' __c_white__ ': location  of \'' __c_green__ 'arduino_board_selector' __c_white__ '\' cache and saved files - the default is \'' __c_green__ '$ptd()' __c_white__ '\';'
    echoln __c_green__ '                                             ' __c_white__ '  you can change it so that the files are not deleted when you call \'' __c_green__ 'clean_project' __c_white__ '\''
    echoln
   #$call(__btlib_help_print_title_functions__, 9, 23, 1, ${CGInfo})
    $call(__btlib_help_print_title_functions__, 0,  0, 0, ${CGInfo})
    echoln __c_green__ '    arduino_board_selector (?alwaysSelect          ) ' __c_white__ ': select and configure a board using ' ${AGText} ' \'' __c_yellow__ 'boards.txt' __c_white__ '\''
    echoln __c_green__ '                                                     ' __c_green__ '      alwaysSelect' __c_white__ ' by default, the system will save the user\'s selection;'
    echoln __c_green__ '                                                     ' __c_green__ '                  ' __c_white__ ' set this to ' __c_yellow__ '1' __c_white__ ' to always allow (re)selection'
    echoln
