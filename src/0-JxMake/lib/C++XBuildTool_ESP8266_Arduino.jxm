##### Function to initialize the project build
function init_project(?buildSubdirectories) supersede
    (*
     * Install ESP8266 community package from Arduino IDE 'Tools/Board/Boards Manager...' by adding:
     *     http://arduino.esp8266.com/stable/package_esp8266com_index.json
     * to 'File/Preferences/Additional Boards Manager URLs'
     *)
    # Find the Arduino package directories only if the user has not has not manually set the variable
    if !&${ArduinoPackageDirs}
        ArduinoPackageDirs := $call(find_arduino_package_dirs)
    endif
    # Find the Arduino library directories only if the user has not manually set the variable
    if !&${ArduinoLibraryDirs}
        ArduinoLibraryDirs := $call(find_arduino_library_dirs, ${ArduinoPackageDirs})
    endif
    # Find the latest Xtensa GCC directory
    if !&${CppToolBinDir}
        # Find the latest Xtensa GCC
        CppToolBinDir := $call(__find_latest_xtensa_gcc_dir__)
        if !${__BuildTool_Version_Num__} : $call(__exit_error_nup__, ${CppCxxCompiler})
    else
        # Find the latest Arduino Xtensa GCC but do not assign it to the variable because the user has manually set the variable
        $call(__find_latest_arduino_xtensa_gcc_dir__)
        # Ensure the Xtensa GCC directory given by the user is valid
        if !$call(__get_cpp_compiler_ver__, true) : $call(__exit_error_nup_ext__, ${CppCxxCompiler}, ${CppToolBinDir})
    endif
    # Get the latest Xtensa header, source, and library directories from the selected Arduino package directory
    $call(__get_latest_arduino_xtensa_hsl_dir__)
    # Set the Xtensa GCC include and library directories as needed
    if &${CppToolBinDir}
        XtensaGCCIncludeDir  :=         $cat_path(${CppToolBinDir}, '../include'                 )
        XtensaGCCIncludeDir +:=         $cat_path(${CppToolBinDir}, '../xtensa-lx106-elf/include')
        XtensaGCCLibraryDir  :=         $cat_path(${CppToolBinDir}, '../xtensa-lx106-elf/lib'    )
        XtensaGCCLibraryDir +:= $lsdir( $cat_path(${CppToolBinDir}, '../lib/gcc/xtensa-lx106-elf'), 'd' )
    endif
    # Check the Xtensa tools
    $call(__check_xtensa_tools__)
    if ${SLibBuilder} &== ${__Def_SLibBuilder__} # Proceed only if the user has not changed it from its default value
        if ${__has_xtensa_gcc_ar__} : SLibBuilder := 'xtensa-lx106-elf-gcc-ar'
    endif
    # Select LittleFS or SPIFFS as needed
    if &${ArduinoESP8266LittleFSBin}
        $call(arduino_use_littlefs)
    else
        $call(arduino_use_spiffs)
    endif
    # Find OpenSSL and Python
    $call(find_openssl)
    $call(find_python)
    # Error if Python ≥ 3.7.0 is not available
    $call(exit_error_if_python3_is_less_than_version, 3, 7, 0)
    # Set extra configuration information text
    if &${CppToolBinDir}
        __BuildTool_ExtraInfoName__  +:= 'Xtensa LX106 GCC Directory'
        __BuildTool_ExtraInfoValue__ +:= ${CppToolBinDir}
    endif
    if &${ArduinoESP8266CoreSrcDir}
        __BuildTool_ExtraInfoName__  +:= 'Arduino Package  Directory'
        __BuildTool_ExtraInfoValue__ +:= $cat_path(${ArduinoESP8266CoreSrcDir}, '../..')
    endif
    if &${ArduinoLibraryDirs}
        __BuildTool_ExtraInfoName__  +:= 'Arduino Library  Directory'
        __BuildTool_ExtraInfoValue__ +:= $implode(${ArduinoLibraryDirs}, __os_psep_char__)
    endif
    if $call(python3_available)
        __BuildTool_ExtraInfoName__  +:= '-'
        __BuildTool_ExtraInfoValue__ +:= '-'
        __BuildTool_ExtraInfoName__  +:= 'Python 3 Command'
        __BuildTool_ExtraInfoValue__ +:= ${Python3}
        __BuildTool_ExtraInfoName__  +:= 'Python 3 Version'
        __BuildTool_ExtraInfoValue__ +:= ${__Python3_Version__}
    endif
    if $call(openssl_available)
        __BuildTool_ExtraInfoName__  +:= '-'
        __BuildTool_ExtraInfoValue__ +:= '-'
        __BuildTool_ExtraInfoName__  +:= 'OpenSSL Command'
        __BuildTool_ExtraInfoValue__ +:= ${OpenSSL}
        __BuildTool_ExtraInfoName__  +:= 'OpenSSL Version'
        __BuildTool_ExtraInfoValue__ +:= ${__OpenSSL_Version__}
    endif
    # Call the origin function
    $call(__origin__, ${buildSubdirectories})
endfunction


##### Function to clean the project build (delete all the generated files)
function clean_project() supersede
    # Delete the cache file for the used extra library names
    $rmfile( $call(__arduino_esp8266_extra_slib_cache_file__) )
    # Call the origin function
    $call(__origin__)
endfunction


###################################################################################
##### =================== Arduino ESP8266 Build Functions =================== #####
###################################################################################

##### Constants for building using Arduino ESP8266 tool
const ArduinoESP8266LDOutDir   := 'ld'
const ArduinoESP8266CoreOutDir := 'core'
const ArduinoESP8266ELibOutDir := 'elib'

const ArduinoESP8266SLibName   := 'ArduinoESP8266'
const ArduinoESP8266SLibPath   := $call(slib_fpath, ${ArduinoESP8266SLibName})


##### Function to select and configure a board using Arduino ESP8266 'boards.txt'
function arduino_board_selector(?alwaysSelect)
    # Simply return if the Arduino ESP8266 core directory is not found
    if !&${ArduinoESP8266CoreSrcDir} : return
    # Ensure the directory for the board selector's cache and saved files exists
    local ArduinoESP8266BoardSelCacheDir ?:= $ptd()
    if ${ArduinoESP8266BoardSelCacheDir} &!= $ptd() : $mkdir(${ArduinoESP8266BoardSelCacheDir})
    # Get the encoded representation data
    local BoardsTxtSourcePath             := $cat_path(${ArduinoESP8266CoreSrcDir}, '../../boards.txt')
    local BoardsTxtEDataCacheFilePath     := $cat_path(${ArduinoESP8266BoardSelCacheDir}, 'ArduinoESP8266BoardsTxtEData.cache')
    local BoardsTxtEData
    if $newer_path(${BoardsTxtEDataCacheFilePath}, ${BoardsTxtSourcePath})
        # Read the encoded representation data
        BoardsTxtEData := $get_file(${BoardsTxtEDataCacheFilePath})
    else
        # Parse the file and save the encoded representation data
        BoardsTxtEData := $aboard_from_file(${BoardsTxtSourcePath})
        $put_file(${BoardsTxtEDataCacheFilePath}, ${BoardsTxtEData})
    endif
    # Select and configure the board
    local SelBoardCacheFilePath := $cat_path(${ArduinoESP8266BoardSelCacheDir}, 'ArduinoESP8266SelBoard.cache')
    local MapHandle
    if !${alwaysSelect}
        if $valid_path(${SelBoardCacheFilePath})
            # Create a new map object of configuration data from the saved file
            MapHandle := $map_from_edata( $get_file(${SelBoardCacheFilePath}) )
        endif
    endif
    if !&${MapHandle}
        # Show the board selector and configuration GUI
        BoardsTxtEData := $aboard_selector(${BoardsTxtEData})
        if !&${BoardsTxtEData}
            $call(__exit_error_build_process_cancel__, :"$[function]()")
        endif
        # Save the updated encoded representation data
        $put_file(${BoardsTxtEDataCacheFilePath}, ${BoardsTxtEData})
        # Create a new map object of configuration data for the selected board and save it
        MapHandle := $aboard_getselconf(${BoardsTxtEData})
        $put_file( ${SelBoardCacheFilePath}, $map_to_edata(${MapHandle}) )
    endif
    # Extract the map data and delete the map
    if &${MapHandle}
        # Extract the data
            __ArduinoESP8266_SB__CompileFlag__     := $map_get(${MapHandle}, '#CompileFlag'          )
            __ArduinoESP8266_SB__CompileFlag__    +:= $map_get(${MapHandle}, '#CompileMDef'          )
            #                                                         Ignore '#IncludeDir'
            __ArduinoESP8266_SB__LibraryDir__      := $map_get(${MapHandle}, '#LibraryDir'           )
            __ArduinoESP8266_SB__LinkFlag__        := $map_get(${MapHandle}, '#LinkFlag'             )
            __ArduinoESP8266_SB__LinkSLib__        := $map_get(${MapHandle}, '#LinkSLib'             )
            __ArduinoESP8266_SB_FlashLD__          := $map_get(${MapHandle}, 'build:flash_ld'        )
            __ArduinoESP8266_SB_FSStart__          := $map_get(${MapHandle}, 'build:spiffs_start'    )
            __ArduinoESP8266_SB_FSEnd__            := $map_get(${MapHandle}, 'build:spiffs_end'      )
            __ArduinoESP8266_SB_FSPageSize__       := $map_get(${MapHandle}, 'build:spiffs_pagesize' )
            __ArduinoESP8266_SB_FSBlockSize__      := $map_get(${MapHandle}, 'build:spiffs_blocksize')
            __ArduinoESP8266_SB_Variant__          := $map_get(${MapHandle}, 'build:variant'         )
            __ArduinoESP8266_SB_EraseCmd__         := $map_get(${MapHandle}, 'upload:erase_cmd'      )
            __ArduinoESP8266_SB_ResetMethod__      := $map_get(${MapHandle}, 'upload:resetmethod'    )
            __ArduinoESP8266_SB_UploadSpeed__      := $map_get(${MapHandle}, 'upload:speed'          )
        # Complete the data
        local const NonOSSDK := 'NONOSDK\d{2}(?:\\d|x_\\d{6})'
        if !$re_match( $ftpipes(${__ArduinoESP8266_SB__LibraryDir__}), ${NonOSSDK} )
                __ArduinoESP8266_SB__CompileFlag__ +:= '-DNONOSDK22x_190703'
                __ArduinoESP8266_SB__LibraryDir__  +:=   'NONOSDK22x_190703'
        endif
        local SelNonOSSDK
        foreach local Item in ${__ArduinoESP8266_SB__LibraryDir__}
            if !$re_match(${Item}, ${NonOSSDK}) : continue
                __ArduinoESP8266_SB__LibraryDir__   := $erase_if(${__ArduinoESP8266_SB__LibraryDir__}, ${Item})
                __ArduinoESP8266_SB__LibraryDir__  +:= $ftt_stack( '-L', $cat_path(${ArduinoESP8266NonOSSDKDir}, ${Item}) )
            SelNonOSSDK := ${Item}
            break
        endforeach
        if $contains(${__ArduinoESP8266_SB__CompileFlag__}, '-fno-exceptions')
                __ArduinoESP8266_SB__CompileFlag__ +:= '-fno-unwind-tables'
        endif
        local const LDFilePath := $cat_path(${ArduinoESP8266LDSourceDir}, ${__ArduinoESP8266_SB_FlashLD__})
        local const EBootFile  := $cat_path(${__SelArduinoPackageDir__} , 'bootloaders/eboot/eboot.elf'   )
                __ArduinoESP8266_SB__CompileFlag__ +:= '-D__ets__' '-U__STRICT_ANSI__' '-D_GNU_SOURCE' '-DARDUINO=200' '-DESP8266' '-DICACHE_FLASH'
                __ArduinoESP8266_SB__CompileFlag__ +:= $ftt_stack( '-isystem', ~${ArduinoESP8266LDSourceDir} )
                __ArduinoESP8266_SB__CompileFlag__ +:= $ftt_stack( '-isystem', $cat_paths(~${ArduinoESP8266CoreSrcDir}, '../../variants', ${__ArduinoESP8266_SB_Variant__}) )
                __ArduinoESP8266_SB__LinkFlag__    +:= '-u' 'app_entry' '-u' '_printf_float' '-u' '_scanf_float'
                __ArduinoESP8266_SB__LinkFlag__    +:= '-Wl,-wrap,system_restart_local' '-Wl,-wrap,spi_flash_read' '-nostdlib'
                __ArduinoESP8266_SB__LinkFlag__    +:= :"-T${LDFilePath}"
                __ArduinoESP8266_SB__LinkFlag__    +:= $ftt_stack( '-L', ${ArduinoESP8266LDSourceDir} )
                __ArduinoESP8266_SB__LinkFlag__    +:= $ftt_stack( '-L', ${ArduinoESP8266LibraryDir} )
                __ArduinoESP8266_SB__LinkFlag__    +:= $ftt_stack( '-L', $cat_path(${ArduinoESP8266LibraryDir}, ${SelNonOSSDK} ) )
        eval    __ArduinoESP8266_SB_FSImageSize__   :=  ${__ArduinoESP8266_SB_FSEnd__} - ${__ArduinoESP8266_SB_FSStart__}
                __ArduinoESP8266_SB_LinkSLibs__     :=  ${ArduinoESP8266SLibName}
                __ArduinoESP8266_SB_LinkSLibs__    +:= 'airkiss' 'crypto' 'espnow' 'main' 'net80211' 'phy' 'pp' 'smartconfig' 'wpa' 'wpa2' 'wps'
                __ArduinoESP8266_SB_LinkSLibs__    +:= 'bearssl' 'hal' ${__ArduinoESP8266_SB__LinkSLib__/-l(.+)/$1/} 'm' 'c' 'gcc'
                __ArduinoESP8266_SB_Elf2BinFlags__  := '--eboot' ~${EBootFile}
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= '--path' ~${CppToolBinDir}
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= '--flash_freq'
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= $map_get(${MapHandle}, 'build:flash_freq')
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= '--flash_size'
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= $map_get(${MapHandle}, 'build:flash_size')
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= '--flash_mode'
                __ArduinoESP8266_SB_Elf2BinFlags__ +:= $map_get(${MapHandle}, 'build:flash_mode')
       #$call(dump_map_object_and_exit, ${MapHandle})
        # Delete the map
        $map_delete(${MapHandle})
    endif
    # Set the C standard version
    $call(select_c_langstd, 'c11')
    # Set the C++ standard version according to the selected Arduino ESP8266 package version
    local CppCxxLangStd := 'c++11'
    if ${__SelArduinoPackageDir__/.+?esp8266\/(\d+)\.\d+\.\d+/$1/} >= 3 : CppCxxLangStd := 'c++17'
    $call(select_cxx_langstd, ${CppCxxLangStd})
    # Create extra build subdirectories
    local extraBuildSubdirectories  := ${ArduinoESP8266LDOutDir} ${ArduinoESP8266CoreOutDir}
          buildSubdirectories      +:= extraBuildSubdirectories
    $mkdir( $cat_path(~${CppBuildDir}, ${extraBuildSubdirectories} ) )
endfunction


##### Functions to select the Arduino ESP8266 file system to be used
const __ArduinoESP8266_UseSPIFFFS__  := '-DARDUINO_SPIFFS'   '-DARDUINO_FS=SPIFFS'   '-DESP8266_SPIFFS'   '-DESP8266_FS=SPIFFS'   '-DUSE_SPIFFS'
const __ArduinoESP8266_UseLittleFS__ := '-DARDUINO_LITTLEFS' '-DARDUINO_FS=LITTLEFS' '-DESP8266_LITTLEFS' '-DESP8266_FS=LITTLEFS' '-DUSE_LITTLEFS'

function arduino_use_spiffs()
    __ArduinoESP8266_UseFSMacro__ := ${__ArduinoESP8266_UseSPIFFS__}
    __ArduinoESP8266_MakeFSBin__   = ${ArduinoESP8266SPIFFSBin}
endfunction

function arduino_use_littlefs()
    __ArduinoESP8266_UseFSMacro__ := ${__ArduinoESP8266_UseLittleFS__}
    __ArduinoESP8266_MakeFSBin__   = ${ArduinoESP8266LittleFSBin}
endfunction


##### Function to set Arduino ESP8266 the signing keys
__ArduinoESP8266_PrivateKey__ := ''

function __arduino_create_updater_signing_h__(publicKeyPath)
    local Signing := $cat_path(${ArduinoESP8266ESPToolsDir}, 'signing.py')
    local OutFile := :"${CppBuildDir}/core/Updater_Signing.h"
    if !$newer_path(${OutFile}, ${publicKeyPath})
       +@setenv PYTHONDONTWRITEBYTECODE 1
       +@${Python3} ${Signing} --mode header --publickey ~${publicKeyPath} --out ~${OutFile}
    else
        $cmd_clear_state()
    endif
endfunction

function arduino_set_signing_key(publicKeyPath, privateKeyPath)
    # Error if OpenSSL is not available
    $call(exit_error_if_openssl_is_unavailable)
    # Check if the needed Arduino tool is available
    if !&${ArduinoESP8266ESPToolsDir} : $call(__exit_error_nut__, 'signing.py')
    # Create 'Updater_Signing.h'
    $exec(__arduino_create_updater_signing_h__, ${publicKeyPath})
    $call(__conditional_print_stdxxx_and_check_excode__         )
    # Save the private key path
    __ArduinoESP8266_PrivateKey__ := ${privateKeyPath}
    # Add include path to 'Updater_Signing.h'
    __include_paths__ +:= :"~${CppBuildDir}/core"
endfunction


##### A helper macro to define extra compile options
.macro __arduino_esp8266_extra_compile_options__
    # Create a list of extra library include paths as needed
    if !&${__ArduinoESP8266_ExtraSLibSrcDirs__}
        local CFN := $call(__arduino_esp8266_extra_slib_cache_file__)
        if $valid_path(${CFN})
            foreach local UL in $get_file(${CFN})
                if $str_fidx(${UL}, '$') == 1
                    UL := $str_rmfchr(${UL})
                    local S := $map_get(${ArduinoESP8266LibMH}, :"{${UL}}:path")
                else
                    local S := $map_get(${ArduinoGenericLibMH}, :"{${UL}}:path")
                endif
                __ArduinoESP8266_ExtraSLibSrcDirs__ +:= $series('-I', ~${S})
            endforeach
        endif
    endif
    # Define extra compile options
    local extraIncludeDirs  := $series( '-I'      , ~${XtensaGCCIncludeDir}      )
          extraIncludeDirs +:= $series( '-isystem', ~${ArduinoESP8266IncludeDir} )
          extraIncludeDirs +:= ${__ArduinoESP8266_ExtraSLibSrcDirs__}
          extraIncludeDirs +:= ${__ArduinoESP8266_BuildSLib_ExtraIncludeDirs__}
    local extraOptions     +:= $stack(${extraIncludeDirs}, ${__ArduinoESP8266_SB__CompileFlag__}, ${__ArduinoESP8266_UseFSMacro__})
    if &${__ArduinoESP8266_PrivateKey__} : local __include_paths__ := :"${CppBuildDir}/core" __include_paths__
.endmacro


##### Function to compile Arduino ESP8266 user source code files
function arduino_compile_c(?extraOptions)
    .$__arduino_esp8266_extra_compile_options__
    $call(compile_c, ${extraOptions})
endfunction

function arduino_compile_cpp(?extraOptions)
    .$__arduino_esp8266_extra_compile_options__
    $call(compile_cpp, ${extraOptions})
endfunction


##### Function to link Arduino ESP8266 executable files (also create the BIN file)
Arduino_ESP8266LDCompiled     := false
Arduino_ESP8266CoreSLibBuilt  := false
Arduino_ESP8266ExtraSLibBuilt := false

function __elf_to_bin__()
    # Determine the paths
    local Elf2Bin := $cat_path(${ArduinoESP8266ESPToolsDir}, 'elf2bin.py')
    local BinFile := $[target/(.+)\.elf/$1.bin/]
    # Convert ELF to BIN
    $rmfile(~${BinFile})
   +@setenv PYTHONDONTWRITEBYTECODE 1
   +@${Python3} ${Elf2Bin} ${__ArduinoESP8266_SB_Elf2BinFlags__} --app ~$[target] --out ~${BinFile}
    # Return the BIN file path
    return ${BinFile}
endfunction

function arduino_link_exe(?extraOptions)
    # Check the prerequisites
    if !${Arduino_ESP8266LDCompiled}     : $call(__exit_error_run_target_call_function_, 'arduino_esp8266_compile_ld'      , :"$[function]()")
    if !${Arduino_ESP8266CoreSLibBuilt}  : $call(__exit_error_run_target_call_function_, 'arduino_esp8266_build_core_slib' , :"$[function]()")
    if !${Arduino_ESP8266ExtraSLibBuilt} : $call(__exit_error_run_target_call_function_, 'arduino_esp8266_build_extra_slib', :"$[function]()")
    # Check if the needed Arduino tool is available
    if !&${ArduinoESP8266ESPToolsDir} : $call(__exit_error_nut__, 'elf2bin.py')
    # Link the executable
    local CppSysStaticLib +:= ${__ArduinoESP8266_ExtraSLib__/^\$(.+)$/$1/} ${__ArduinoESP8266_SB_LinkSLibs__}
    local extraLibDirs     := $series( '-L', $cat_path(${CppBuildDir}, ${ArduinoESP8266LDOutDir}) )
    local extraOptions     := $stack(${extraLibDirs}, ${__ArduinoESP8266_SB__LinkFlag__}, ${extraOptions})
    $call(link_exe, ${extraOptions})
    # Convert ELF to BIN
    $call(__bpt_bin__                                  )
    $exec(__elf_to_bin__                               )
    $call(__conditional_print_stdxxx_and_check_excode__)
endfunction


##### Function to create Arduino ESP8266 static libraries
function arduino_link_slib()
    $call(link_slib)
endfunction


##### Linking shared library files is not supported
function link_dlib(?extraOptions) supersede
    .$__exit_error_function_ns__
endfunction


##### Function to run the given Arduino ESP8266 executable file (in this case, print the size)
function __obj_size_py__(progName, dimColor)
    # Get the tool
    local Sizes := $cat_path(${ArduinoESP8266ESPToolsDir}, 'sizes.py')
    local MMU   := $ftspaces( $erase_ifempty(${__ArduinoESP8266_SB__CompileFlag__/^((?!-DMMU.+).)*$//}) )
    if !$valid_path(${Sizes}) : return -1
    # Get the size
    @setenv PYTHONDONTWRITEBYTECODE 1
    @${Python3} ${Sizes} --elf ~${progName} --path ~${CppToolBinDir} --mmu ${MMU}
    if $[excode] : return 0
    # Print the size
    local Color := __c_dgray__
    if !${dimColor}
        echoln __c_cyan__ -${progName} __c_reset__
        Color := __c_green__
    endif
    foreach local I, Line in $sflines( $stack($[stderr], $[stdout]) )
        # Filter the line number
        if ${I} ==  2 : continue
        if ${I} ==  7 : continue
        if ${I} == 11 : continue
        # Filter the line string
        Line := ${Line/^\. //}
        Line := ${Line/[\r\n]*//}
        # Skip the line if it is empty
        if !&${Line} : continue
        # Print the line
        if __os_windows__
            Line := ${Line/\\u2560/╠/}
            Line := ${Line/\\u255a/╚/}
            Line := ${Line/\\u2550/═/}
        endif
        echoln ${Color} '    ' ${Line} __c_reset__
    endforeach
    # Done
    return 1
endfunction

function __obj_size_exec__(progName, ldLibraryPath)
    # Modify the binary path as needed
    if &${CppToolBinDir} : local XtensaSize := $cat_path(${CppToolBinDir}, ${XtensaSize})
    # Get the size
    @setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    @${XtensaSize} ${XtensaFlags} ~${progName}
endfunction

function __obj_size__(progName, ldLibraryPath, dimColor)
    # Get the size text
    $exec(__obj_size_exec__, ${progName}, ${ldLibraryPath})
    # Format and print the size text
    local text  := $partn( $call(__format_section_size_text__, $[stdout]), 1 )
    local Color := __c_dgray__
    if !${dimColor}
        echoln __c_cyan__ -${progName} __c_reset__
        Color := __c_green__
    endif
    echoln ${Color} ${text} __c_reset__
    # Done
    return 1
endfunction

function arduino_run_exe(progName, ?dimColor)
    # Exit if the executable does not actually exist
    if !$valid_path(${progName}) : return
    # Print the size
                            $call( __bpt_exe_size_linespace__                                               )
               local res := $exec( __obj_size_py__, ${progName}                               , ${dimColor} )
    if  ${res} < 0 : res := $call( __obj_size__   , ${progName}, $call(__get_LDLibraryPaths__), ${dimColor} )
    if !${res} : $call(__print_stdxxx_and_check_excode__)
    echoln
endfunction


##### Function to create Arduino ESP8266 file system image
function __arduino_fsimage_path__()
    return :"${CppBuildDir}/filesystem.img"
endfunction

function __arduino_mkfs__(outFile)
   +@${__ArduinoESP8266_MakeFSBin__} -p ${__ArduinoESP8266_SB_FSPageSize__} -b ${__ArduinoESP8266_SB_FSBlockSize__} -s ${__ArduinoESP8266_SB_FSImageSize__} -c ~${fsRootDir} ${outFile}
   +@${__ArduinoESP8266_MakeFSBin__} -p ${__ArduinoESP8266_SB_FSPageSize__} -b ${__ArduinoESP8266_SB_FSBlockSize__} -s ${__ArduinoESP8266_SB_FSImageSize__} -l               ${outFile}
endfunction

function arduino_make_fsimage(fsRootDir)
    if !&${__ArduinoESP8266_MakeFSBin__} : return
    $exec( __arduino_mkfs__, $call(__arduino_fsimage_path__) )
    $call( __conditional_print_stdxxx_and_check_excode__     )
endfunction


##### Function to decode ESP8266 stack trace
function arduino_stdec(progName, stContent)
    if &${CppToolBinDir} : local XtensaAddr2Line := $cat_path(${CppToolBinDir}, ${XtensaAddr2Line})
    return $esp_st_decoder(${XtensaAddr2Line}, ${progName}, ${stContent})
endfunction


##### A helper macro and a helper function to compress and sign the Arduino ESP8266 binary
.macro __arduino_esp8266_compress_and_sign_bin__
    # Determine the base binary file name
    local BinFile := ~${progName/(.+)\.elf/$1.bin/}
    # Remove all signed files
    $rmfile(:"${BinFile}.signed"       )
    $rmfile(:"${BinFile}.legacy_sig"   )
    $rmfile(:"${BinFile}.gz.signed"    )
    $rmfile(:"${BinFile}.gz.legacy_sig")
    # Check if it is a file system upload
    if -${BinFile} &== $call(__arduino_fsimage_path__) : local FSUpload := 1
    # Compress the binary as needed
    if $str_lidx($[function], 'ota') > 0
        if !${FSUpload}
            local GZBinFile := :"${BinFile}.gz"
            $gzip(${BinFile}, ${GZBinFile})
            BinFile := ${GZBinFile}
        else
            ##### !!! TODO : ATOMIC_FS_UPDATE !!! #####
        endif
    endif
    # Sign the binary as needed (never sign the binary if it is a file system upload)
    if !${FSUpload}
        if &${__ArduinoESP8266_PrivateKey__} : signed := 1
        if ${signed}
            $exec(__arduino_upload_sign__                      )
            $call(__conditional_print_stdxxx_and_check_excode__)
        endif
    endif
.endmacro

function __arduino_upload_sign__()
    local Signing := $cat_path(${ArduinoESP8266ESPToolsDir}, 'signing.py')
    +@setenv PYTHONDONTWRITEBYTECODE 1
    +@${Python3} ${Signing} --mode sign --privatekey ~${__ArduinoESP8266_PrivateKey__} --bin ~${BinFile} --out :"~${BinFile}.signed" --legacy :"~${BinFile}.legacy_sig"
endfunction


##### Function to upload the given program via serial port using Arduino ESP8266 tools
#const __Arduino_DefSerialUploadResetMethod__ := '--before' 'no_reset'      '--after' 'soft_reset' # ESP-01 Black
 const __Arduino_DefSerialUploadResetMethod__ := '--before' 'default_reset' '--after' 'hard_reset' # NodeMCU
 const __Arduino_DefSerialUploadBaudrate__    := 921600

function __arduino_upload_serial_exec__(startAddress)
    # Determine the paths
    local Upload := $cat_path(${ArduinoESP8266ESPToolsDir}, 'upload.py')
    # Adjust the binary file name as needed
    if ${signed} : BinFile := :"${BinFile}.signed"
    # Perform upload
   +@setenv PYTHONDONTWRITEBYTECODE 1
   +@${Python3} ${Upload} --chip esp8266 --port ${device} --baud ${baudrate} ${eraseCmd} ${resetMethod} write_flash ${startAddress} ~${BinFile}
endfunction

function arduino_upload_serial(progName, device, ?baudrate, ?eraseCmd, ?resetMethod, ?signed)
    # Check if the needed Arduino tool is available
    if !&${ArduinoESP8266ESPToolsDir} : $call(__exit_error_nut__, 'upload.py')
    # Set the default values
    local eraseCmd    ?:=                                                                           ${__ArduinoESP8266_SB_EraseCmd__}
    local resetMethod ?:= $csel( $cmp( $flatten(${__ArduinoESP8266_SB_ResetMethod__}), '&!=', '' ), ${__ArduinoESP8266_SB_ResetMethod__}, ${__Arduino_DefSerialUploadResetMethod__})
    local baudrate    ?:= $csel( $cmp( $flatten(${__ArduinoESP8266_SB_UploadSpeed__}), '&!=', '' ), ${__ArduinoESP8266_SB_UploadSpeed__}, ${__Arduino_DefSerialUploadBaudrate__}   )
    # compress and sign the binary
    .$__arduino_esp8266_compress_and_sign_bin__
    # Perform upload
    $cmd_streaming_on()
    $exec(__arduino_upload_serial_exec__, 0x00         )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_streaming_off()
endfunction


##### Function to upload the given program via OTA using Arduino ESP8266 tools
const __Arduino_DefOTAPort__ := 8266

function __arduino_upload_ota_exec__(?extraParams)
    # Determine the paths
    local Upload := $cat_path(${ArduinoESP8266ESPToolsDir}, 'espota.py')
    # Adjust the binary file name as needed
    if ${signed} : BinFile := :"${BinFile}.signed"
    # Perform upload
    if &${otaPassword} : otaPassword := :"--auth=${otaPassword}"
   +@setenv PYTHONDONTWRITEBYTECODE 1
   +@${Python3} ${Upload} -r -i ${hostNameOrIP} -p ${progPort} -P ${progPort} ${otaPassword} ${extraParams} -f ~${BinFile}
endfunction

function arduino_upload_ota(progName, hostNameOrIP, ?progPort, ?otaPassword, ?signed)
    # Check if the needed Arduino tool is available
    if !&${ArduinoESP8266ESPToolsDir} : $call(__exit_error_nut__, 'espota.py')
    # Set the default value
    local progPort ?:= 8266
    # compress and sign the binary
    .$__arduino_esp8266_compress_and_sign_bin__
    # Perform upload
    $cmd_streaming_on()
    $exec(__arduino_upload_ota_exec__                  )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_streaming_off()
endfunction


##### Function to upload the file system image using Arduino ESP8266 tools
function arduino_uploadfs_serial(device, ?baudrate, ?resetMethod, ?signed)
    # Check if the needed Arduino tool is available
    if !&${ArduinoESP8266ESPToolsDir} : $call(__exit_error_nut__, 'upload.py')
    # Set the default values
    local progName     := $call(__arduino_fsimage_path__)
    local eraseCmd    ?:= ''
    local resetMethod ?:= $csel( $cmp( $flatten(${__ArduinoESP8266_SB_ResetMethod__}), '&!=', '' ), ${__ArduinoESP8266_SB_ResetMethod__}, ${__Arduino_DefSerialUploadResetMethod__})
    local baudrate    ?:= $csel( $cmp( $flatten(${__ArduinoESP8266_SB_UploadSpeed__}), '&!=', '' ), ${__ArduinoESP8266_SB_UploadSpeed__}, ${__Arduino_DefSerialUploadBaudrate__}   )
    # compress and sign the binary
    .$__arduino_esp8266_compress_and_sign_bin__
    # Show message
    echoln __c_white__ "\nThe file system image verification process may take a while, please be patient.\n" __c_reset__
    # Perform upload
    $cmd_streaming_on()
    $exec(__arduino_upload_serial_exec__, ${__ArduinoESP8266_SB_FSStart__})
    $call(__conditional_print_stdxxx_and_check_excode__                   )
    $cmd_streaming_off()
endfunction


##### Function to upload the file system image via OTA using Arduino ESP8266 tools
function arduino_uploadfs_ota(hostNameOrIP, ?progPort, ?otaPassword, ?signed)
    # Check if the needed Arduino tool is available
    if !&${ArduinoESP8266ESPToolsDir} : $call(__exit_error_nut__, 'espota.py')
    # Set the default value
    local progName  := $call(__arduino_fsimage_path__)
    local progPort ?:= 8266
    # compress and sign the binary
    .$__arduino_esp8266_compress_and_sign_bin__
    # Show message as needed
    if &${__ArduinoESP8266_PrivateKey__}
        ##### ??? TODO : Wait for the Arduino ESP8266 team to fix with this issue ??? #####
        echoln __c_white__
        echoln 'Binary signing verification for OTA programming is enabled.'
        echoln 'The file system image uploading process might stall or report an error even if the actual process was successful.'
        echoln __c_reset__
    endif
    # Perform upload
    $cmd_streaming_on()
    $exec(__arduino_upload_ota_exec__, '-s'            )
    $call(__conditional_print_stdxxx_and_check_excode__)
    $cmd_streaming_off()
endfunction


###################################################################################
##### ==================== Arduino ESP8266 Build Targets ==================== #####
###################################################################################

##### Target to compile Arduino ESP8266 linker script
target __arduino_esp8266_compile_ld__
    __stdxxx_from_syslib__ := true
    $call(compile_ld, ${__ArduinoESP8266_SB__CompileFlag__})
    __stdxxx_from_syslib__ := false
endtarget

target arduino_esp8266_compile_ld
    # Reset flag
    Arduino_ESP8266LDCompiled := false
    # Compile the linker script
    local Src := $cat_path(${ArduinoESP8266LDSourceDir}, 'eagle.app.v6.common.ld.h')
    local Out := $call(ld_fpath, :"${ArduinoESP8266LDOutDir}/local.eagle.app.v6.common")
    $add_target('__arduino_esp8266_compile_ld__', ${Out}, ${Src})
    jxmake ${Out}
    # Set flag
    Arduino_ESP8266LDCompiled := true
endtarget


##### Disable warnings from the SDK
const __ArduinoESP8266_SysLib_DisableWarnings__ := '-Wno-unused-parameter' '-Wno-unused-variable' '-Wno-sign-compare'


##### Target to build Arduino ESP8266 core library file
target __arduino_esp8266_compile_s__
    if ${__stdxxx_from_syslib__} : extraOptions +:= ${__ArduinoESP8266_SysLib_DisableWarnings__}
                                   extraOptions +:= $series( '-isystem', ~${XtensaGCCIncludeDir})
    $call(compile_s, ${extraOptions})
endtarget

target __arduino_esp8266_compile_c__
    .$__arduino_esp8266_extra_compile_options__
    if ${__stdxxx_from_syslib__} : extraOptions +:= ${__ArduinoESP8266_SysLib_DisableWarnings__}
                                   extraOptions +:= '-fno-inline-functions'
    $call(compile_c, ${extraOptions})
endtarget

target __arduino_esp8266_compile_cpp__
    .$__arduino_esp8266_extra_compile_options__
    if ${__stdxxx_from_syslib__} : extraOptions +:= ${__ArduinoESP8266_SysLib_DisableWarnings__}
    $call(compile_cpp, ${extraOptions})
endtarget

target __arduino_esp8266_link_slib__
    $call(link_slib)
endtarget

target arduino_esp8266_build_core_slib
    # Reset flag
    Arduino_ESP8266CoreSLibBuilt := false
    # List the source directories
    local SrcD   := $srdir_rec (${ArduinoESP8266CoreSrcDir}, __re_all__ )
    local SrcS   := $srfile_rec(${ArduinoESP8266CoreSrcDir}, '.+?\\.S'  )
    local SrcC   := $srfile_rec(${ArduinoESP8266CoreSrcDir}, '.+?\\.c'  )
    local SrcCpp := $srfile_rec(${ArduinoESP8266CoreSrcDir}, '.+?\\.cpp')
    # Prepare the output directory name and string offset
    local OutDir := $cat_path(${CppBuildDir}, ${ArduinoESP8266CoreOutDir})
    local Offset := $strlen(${ArduinoESP8266CoreSrcDir})
    add   Offset, ${Offset}, 2
    # Make the output directories
    foreach local Src in ${SrcD}
        $mkdir( $cat_path( ${OutDir}, $substr(${Src}, ${Offset}, -1) ) )
    endforeach
    # Create target for '*.S' source files
    local OutS
    foreach local Src in ${SrcS}
        local Out := $ftt_stack( $cat_path( ${OutDir}, $substr(${Src}, ${Offset}, -1) ), '.', ${ObjFileExt} )
        $add_target('__arduino_esp8266_compile_s__', ${Out}, ${Src})
        OutS +:= ${Out}
    endforeach
    # Create target for '*.c' source files
    local OutC
    foreach local Src in ${SrcC}
        local Out := $ftt_stack( $cat_path( ${OutDir}, $substr(${Src}, ${Offset}, -1) ), '.', ${ObjFileExt} )
        $add_target('__arduino_esp8266_compile_c__', ${Out}, ${Src})
        OutC +:= ${Out}
    endforeach
    # Create target for '*.cpp' source files
    local OutCpp
    foreach local Src in ${SrcCpp}
        local Out := $ftt_stack( $cat_path( ${OutDir}, $substr(${Src}, ${Offset}, -1) ), '.', ${ObjFileExt} )
        $add_target('__arduino_esp8266_compile_cpp__', ${Out}, ${Src})
        OutCpp +:= ${Out}
    endforeach
    # Split the target for '*.cpp' source files
    local OutCpp1
    local OutCpp2
    local OutIdx := 1
    while ${OutIdx} <= $part_count(${OutCpp})
        local Out1 := $partn(${OutCpp}, ${OutIdx}) ; inc OutIdx
        local Out2 := $partn(${OutCpp}, ${OutIdx}) ; inc OutIdx
        if &${Out1} : OutCpp1 +:= ${Out1}
        if &${Out2} : OutCpp2 +:= ${Out2}
    endwhile
    # Create target for the static library file
    local Src := $stack(${OutS}, ${OutC}, ${OutCpp})
    $add_target('__arduino_esp8266_link_slib__', ${ArduinoESP8266SLibPath}, ${Src})
    # Build the object and library files
    __stdxxx_from_syslib__ := true
   +jxmake ${OutS}
   +jxmake ${OutC}
   +jxmake ${OutCpp1}
   +jxmake ${OutCpp2}
    jxwait
    jxmake ${ArduinoESP8266SLibPath}
    __stdxxx_from_syslib__ := false
    # Set flag
    Arduino_ESP8266CoreSLibBuilt := true
endtarget


##### Target to build Arduino ESP8266 extra static library files
__ArduinoESP8266_ExtraSLib__ := ''

function __arduino_esp8266_extra_slib_cache_file__()
    # Ensure the directory for the board selector's cache and saved files exists
    local ArduinoESP8266BoardSelCacheDir ?:= $ptd()
    if ${ArduinoESP8266BoardSelCacheDir} &!= $ptd() : $mkdir(${ArduinoESP8266BoardSelCacheDir})
    # Return the cache file path
    return $cat_path(${ArduinoESP8266BoardSelCacheDir}, 'ArduinoESP8266ExtraSLib.cache')
endfunction

target arduino_esp8266_build_extra_slib
    # Reset flag
    Arduino_ESP8266ExtraSLibBuilt := false
    # Load the used extra library names from the cache file
    local CFN := $call(__arduino_esp8266_extra_slib_cache_file__)
    if $valid_path(${CFN}) : __ArduinoESP8266_ExtraSLib__ := $get_file(${CFN})
    # Process the libraries in the list
    local AllOutC
    local AllOutCpp
    local AllOutSLib
    foreach local UL in $erase_ifempty(${__ArduinoESP8266_ExtraSLib__})
        # List the source directories
        if $str_fidx(${UL}, '$') == 1
            UL := $str_rmfchr(${UL})
            local SrcDir := $map_get(${ArduinoESP8266LibMH}, :"{${UL}}:path")
        else
            local SrcDir := $map_get(${ArduinoGenericLibMH}, :"{${UL}}:path")
        endif
       #local SrcDir := $cat_path(${ArduinoESP8266LibRootDir}, ${UL})
        local SrcC   := $srfile_rec(${SrcDir}, '.+?\\.c'  )
        local SrcCpp := $srfile_rec(${SrcDir}, '.+?\\.cpp')
        # Exclude the examples
        SrcC   := $erase_if(${SrcC}  , '.+?examples.+', true)
        SrcCpp := $erase_if(${SrcCpp}, '.+?examples.+', true)
        # Prepare the output directory
        local OutDir := $cat_paths(${CppBuildDir}, ${ArduinoESP8266ELibOutDir}, ${UL})
        $mkdir(${OutDir})
        # Prepare the output subdirectories
        local SrcSubDir := $srdir_rec(${SrcDir}, __re_all__)
        if &${SrcSubDir}
            local SrcDirLen := $strlen(${SrcDir})
            add   SrcDirLen, ${SrcDirLen}, 2
            foreach local SSD in ${SrcSubDir}
                if $str_lidx   (${SSD}, '/docs'    ) : continue
                if $str_lidx   (${SSD}, '/examples') : continue
                if $str_endwith(${SSD}, '/src'     ) : continue
                local OutSubDir := $substr(${SSD}, ${SrcDirLen}, -1)
                if $str_begwith(${OutSubDir}, 'src/') : OutSubDir := $substr(${OutSubDir}, 5, -1)
                OutSubDir := $cat_path(${OutDir}, ${OutSubDir})
                $mkdir(${OutSubDir})
                __ArduinoESP8266_BuildSLib_ExtraIncludeDirs__ +:= $series('-isystem', ~${SSD})
                #echoln ${SSD}
                #echoln ${OutSubDir}
            endforeach
            #if $str_lidx(${SrcSubDir}, 'WebServer') > 0 : $exit(10)
        endif
        # Prepare the string offset
        local Offset := $strlen(${SrcDir})
        add   Offset, ${Offset}, 2
        # Create target for '*.c' source files
        local OutC
        foreach local Src in ${SrcC}
            local Dir := $substr(${Src}, ${Offset}, -1)
           #local Out := $ftt_stack( $cat_path(${OutDir}, ${Dir/(^src[\\\/])(.+)/$2/}), '.', ${ObjFileExt} )
            local Out := $ftt_stack( $cat_path(${OutDir}, ${Dir/(^src\/)(.+)/$2/}), '.', ${ObjFileExt} )
            $add_target('__arduino_esp8266_compile_c__', ${Out}, ${Src})
            OutC    +:= ${Out}
            AllOutC +:= ${Out}
        endforeach
        # Create target for '*.cpp' source files
        local OutCpp
        foreach local Src in ${SrcCpp}
            local Dir := $substr(${Src}, ${Offset}, -1)
           #local Out := $ftt_stack( $cat_path(${OutDir}, ${Dir/(^src[\\\/])(.+)/$2/}), '.', ${ObjFileExt} )
            local Out := $ftt_stack( $cat_path(${OutDir}, ${Dir/(^src\/)(.+)/$2/}), '.', ${ObjFileExt} )
            $add_target('__arduino_esp8266_compile_cpp__', ${Out}, ${Src})
            OutCpp    +:= ${Out}
            AllOutCpp +:= ${Out}
        endforeach
        # Create target for the static library file
        local Src := $stack(${OutC}, ${OutCpp})
        local Out := $call(slib_fpath, ${UL})
        $add_target('__arduino_esp8266_link_slib__', ${Out}, ${Src})
        # Add to the list of extra static libraries to build
        AllOutSLib +:= ${Out}
    endforeach
    AllOutSLib := $erase_ifempty(${AllOutSLib})
    # Split the target for '*.cpp' source files
    local AllOutCpp1
    local AllOutCpp2
    local AllOutIdx := 1
    while ${OutIdx} <= $part_count(${AllOutCpp})
        local Out1 := $partn(${AllOutCpp}, ${OutIdx}) ; inc OutIdx
        local Out2 := $partn(${AllOutCpp}, ${OutIdx}) ; inc OutIdx
        if &${Out1} : AllOutCpp1 +:= ${Out1}
        if &${Out2} : AllOutCpp2 +:= ${Out2}
    endwhile
    # Build the object and library files
    __stdxxx_from_syslib__ := true
   +jxmake ${AllOutC}
   +jxmake ${AllOutCpp1}
   +jxmake ${AllOutCpp2}
    jxwait
    jxmake ${AllOutSLib}
    __stdxxx_from_syslib__ := false
    # Set flag
    Arduino_ESP8266ExtraSLibBuilt := true
endtarget


##### Target to compile Arduino ESP8266 user source code files
function __get_used_lib_names__(text)
    # Get the include files
    local Include := $erase_ifempty(${text/^((?!^\s*#include\s*<\s*.+\s*>).)*$//})
    # Process the include files
    local FoundLibNames
    foreach local I in ${Include/.+?<(.+\.h)>.*/$1/}
        # Search from the ESP8266 library list first
        local found := false
        foreach local SName in $map_get(${ArduinoESP8266LibMH}, '__LRDirNames__')
            local LInc := $map_get(${ArduinoESP8266LibMH}, :"{${SName}}:includes")
            if $contains(${LInc}, ${I})
                FoundLibNames +:= :"\$${SName}"
                found         := true
                break
            endif
        endforeach
        if ${found} : continue
        # Search from the generic library list if it was not found
        foreach local SName in $map_get(${ArduinoGenericLibMH}, '__LRDirNames__')
            local LInc := $map_get(${ArduinoGenericLibMH}, :"{${SName}}:includes")
            if $contains(${LInc}, ${I})
                FoundLibNames +:= ${SName}
                break
            endif
        endforeach
    endforeach
    # Return the found library names
    return ${FoundLibNames}
endfunction

target :"${CppBuildDir}/%.ino.cpp.${ObjFileExt}" : :"${CppBuildDir}/%.ino.cpp"
    .$__arduino_esp8266_extra_compile_options__
    $call(compile_cpp, ${extraOptions})
endtarget

function __get_used_lib_recursive__(CheckLibNames)
    foreach local UL in ${CheckLibNames}
        # Check if the library has been checked
        if $contains(${__ArduinoESP8266_DetectExtraSLib_CheckedList__}, ${UL}) : continue
        __ArduinoESP8266_DetectExtraSLib_CheckedList__ +:= ${UL}
        # Get the source file path and library name
        if $str_fidx(${UL}, '$') == 1
            UL := $str_rmfchr(${UL})
            local Inc := $srfile_rec( $map_get(${ArduinoESP8266LibMH}, :"{${UL}}:path"   ), '.+?\\.h(pp)?' )
            local Src := $srfile_rec( $map_get(${ArduinoESP8266LibMH}, :"{${UL}}:path"   ), '.+?\\.c(pp)?' )
            local Dep :=              $map_get(${ArduinoESP8266LibMH}, :"{${UL}}:depends")
        else
            local Inc := $srfile_rec( $map_get(${ArduinoGenericLibMH}, :"{${UL}}:path"   ), '.+?\\.h(pp)?' )
            local Src := $srfile_rec( $map_get(${ArduinoGenericLibMH}, :"{${UL}}:path"   ), '.+?\\.c(pp)?' )
            local Dep :=              $map_get(${ArduinoGenericLibMH}, :"{${UL}}:depends")
        endif
        # Exclude the examples
        Inc := $erase_if(${Inc}, '.+?examples.+', true)
        Src := $erase_if(${Src}, '.+?examples.+', true)
        # Get the used extra library names
        local ULib  := $call( __get_used_lib_names__, $get_file_nel(~${Inc} ) )
        local ULib +:= $call( __get_used_lib_names__, $get_file_nel(~${Src} ) )
        # Accumulate the used extra library names
        local FoundLibNames := $erase_if(${ULib}, ${__ArduinoESP8266_DetectExtraSLib__})
        local FoundDepNames := $erase_if(${Dep} , ${__ArduinoESP8266_DetectExtraSLib__})
        # Accumulate the used extra library names
        if &${FoundLibNames} : __ArduinoESP8266_DetectExtraSLib__ +:= ${FoundLibNames}
        if &${FoundDepNames} : __ArduinoESP8266_DetectExtraSLib__ +:= ${FoundDepNames}
        # Recursively check the extra library names for more extra library names
        $call(__get_used_lib_recursive__, ${FoundLibNames})
        $call(__get_used_lib_recursive__, ${FoundDepNames})
    endforeach
endfunction

target :"${CppBuildDir}/%.ino.cpp" : %.ino
    # Get the '*.ino' file content
    local InoContent := $get_file(~$[preq*])
    # Find the used extra library names
    unset __ArduinoESP8266_DetectExtraSLib__
    unset __ArduinoESP8266_DetectExtraSLib_CheckedList__
    __ArduinoESP8266_DetectExtraSLib__ := $call(__get_used_lib_names__, ${InoContent})
    # Recursively check the extra library names for more extra library names
   #echoln $ftlines(${__ArduinoESP8266_DetectExtraSLib__}) ; echoln
    $call(__get_used_lib_recursive__, ${__ArduinoESP8266_DetectExtraSLib__})
    __ArduinoESP8266_DetectExtraSLib__ := $unique(${__ArduinoESP8266_DetectExtraSLib__})
   #echoln $ftlines(${__ArduinoESP8266_DetectExtraSLib__})
   #$exit(100)
    # Save the used extra library names to the cache file
    $put_file( $call(__arduino_esp8266_extra_slib_cache_file__), ${__ArduinoESP8266_DetectExtraSLib__} )
    # Delete the global variables used for the detection
    unset __ArduinoESP8266_DetectExtraSLib__
    unset __ArduinoESP8266_DetectExtraSLib_CheckedList__
    # Generate a '*.cpp' file from the '*.ino' file
    local Code  := "#include <Arduino.h>"
          Code +:= ${InoContent}
    $put_file(~$[target], ${Code})
endtarget


##### Undefine the helper macros here to prevent duplicated name later on
.undefmacro __arduino_esp8266_extra_compile_options__
.undefmacro __arduino_esp8266_compress_and_sign_bin__


