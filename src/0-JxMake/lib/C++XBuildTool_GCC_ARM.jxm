#####
#####
#####


##### Function to initialize the project build
function init_project(?buildSubdirectories) supersede
    # Skip this block if 'ARM_TOOLCHAIN_PATH' contains the special string constant
    if ${ARM_TOOLCHAIN_PATH} &!= ${__GTCP_NA__}
        # Check the paths
        if $or( $cmp(${ARM_TOOLCHAIN_PATH}, '&==', ''), $not( $valid_path(${ARM_TOOLCHAIN_PATH}) ) )
            $call(__exit_error_nf__, 'ARM Toolchain (GCC ARM)', true)
            $call(__armgcc_print_download_info__)
            $exit(-1)
        endif
        # Set the location of the C/C++ binaries
        CppToolBinDir := $cat_path(${ARM_TOOLCHAIN_PATH}, 'bin')
        # Set additional LD paths as needed
        if !__os_windows__
            LDLibraryPath +:= $cat_path(${ARM_TOOLCHAIN_PATH}, 'lib'  )
            LDLibraryPath +:= $cat_path(${ARM_TOOLCHAIN_PATH}, 'lib64')
        endif
    endif
    # Set extra configuration information text as needed
    if !&${__BuildTool_ExtraInfoName__}
        if &${CppToolBinDir}
            __BuildTool_ExtraInfoName__  +:= 'ARM GCC Directory'
            __BuildTool_ExtraInfoValue__ +:= ${CppToolBinDir}
        endif
    endif
    # Call the origin function
    $call(__origin__, ${buildSubdirectories})
endfunction


##### Function to link executable files (in this case, also create the HEX and BIN files if requested)
function link_exe(?extraOptions, ?createHEX, ?createBIN) supersede
    # Call the origin function
    $call(__origin__, ${extraOptions})
    # Convert ELF to HEX as needed
    if ${createHEX}
        $call( __bpt_hex__                                                                                                         )
        $exec( __generic_xgcc_elf_to_xxx__, ${ARMObjCopy}, ${ARMObjCopyE2HFlags}, ~$[target], 'hex', $call(__get_LDLibraryPaths__) )
        $call( __conditional_print_stdxxx_and_check_excode__                                                                       )
    endif
    # Convert ELF to BIN as needed
    if ${createBIN}
        $call( __bpt_bin__                                                                                                         )
        $exec( __generic_xgcc_elf_to_xxx__, ${ARMObjCopy}, ${ARMObjCopyE2BFlags}, ~$[target], 'bin', $call(__get_LDLibraryPaths__) )
        $call( __conditional_print_stdxxx_and_check_excode__                                                                       )
    endif
endfunction


##### Function to run the given executable file (in this case, print the size and some information)
function run_exe(progName, ?dimColor) supersede
    # Exit if the executable does not actually exist
    if !$valid_path(${progName}) : return
    # Print the size
                 $call( __bpt_exe_size_linespace__                                                                                   )
    local res := $call( __armgcc_obj_size__, ${ARMSize}, ${ARMSizeDefFlags}, ${progName}, $call(__get_LDLibraryPaths__), ${dimColor} )
    if !${res} : $call( __conditional_print_stdxxx_and_check_excode__                                                                )
endfunction


##### Function to generate LST files
function gen_lst(progName)
    $call(__gen_lst__, ${progName}, ${ARMObjDump})
endfunction


###################################################################################
##### ==================== Library Help Printer Function ==================== #####
###################################################################################

##### Function to display some informational message about how to obtain ARM GCC
function __armgcc_print_download_info__(?tcSimpleName, ?tcRootDirPathName, ?tcPathEnvVarName)
    local tcSimpleName      ?:= 'ARM'
    local tcRootDirPathName ?:= 'arm'
    local tcPathEnvVarName  ?:= 'ARM_TOOLCHAIN_PATH'
    echoln "Please use your operating system package manager to install the ${tcSimpleName} Toolchain (GCC ARM None EABI) or download and install it from:"
    echoln '    https://developer.arm.com/downloads/-/gnu-rm'
    echoln
    echoln 'Example (Linux):'
    echoln "    mkdir ~/${tcRootDirPathName}"
    echoln "    cd ~/${tcRootDirPathName}"
    echoln '    wget -c https://developer.arm.com/-/media/Files/downloads/gnu-rm/10.3-2021.10/gcc-arm-none-eabi-10.3-2021.10-x86_64-linux.tar.bz2'
    echoln '    tar -xjvpf gcc-arm-none-eabi-10.3-2021.10-x86_64-linux.tar.bz2'
    echoln '    cd ..'
    echoln "Set '${tcPathEnvVarName}' to the ${tcSimpleName} Toolchain location."
    echoln
endfunction


##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__(?NGInfo, ?xgfSpcCnt, ?hideComSel, ?noCpp20M, ?noSharedLib, ?noRunExe, ?userCompSel, ?userExtraFuncs) supersede
    # Use the generic information text if it was not defined
    if !&${NGInfo}
        local NGText := __c_cyan__  "Generic ARM" __c_white__
        local NGInfo := __c_white__ 'for ' ${NGText} ' '
    endif
    # Call the original function
    $call(__origin__, ${hideComSel}, ${noCpp20M}, ${noSharedLib}, ${noRunExe}, ${userCompSel}, ${userExtraFuncs})
    # Print some information
    local max xgfSpcCnt, ${xgfSpcCnt}, 1
    local     XGFSpc := $repeat(' ', ${xgfSpcCnt})
    $call(__btlib_help_print_title_cross__)
    $call(__btlib_help_print_title_variables__, ${NGInfo})
    echoln __c_green__ '    __gcc__              ' ${XGFSpc} __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __x_gcc__            ' ${XGFSpc} __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __arm_gcc__          ' ${XGFSpc} __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_green__ '    __arm_none_eabi_gcc__' ${XGFSpc} __c_white__ ': always evaluate to the value ' __c_yellow__ '1' __c_white__ ' in this case'
    echoln __c_reset__
endfunction
