##### Include the native C/C++ build tool and other utilities
__ForceGCC__ := 1

:::include_once 'C++BuildTool.jxm'
:::include_once 'OpenOCDHelper.jxm'


##### MSys may cause weird errors so exclude it from the supported build environment
if __os_msys__
    $call(__exit_error_ns_benv__, 'ARM GCC', 'MSys')
endif


##### Update the flags
const __x_gcc__             := 1
const __arm_gcc__           := 1
const __arm_none_eabi_gcc__ := 1

      __BuildTool_Name__    := 'ARM GNU Compiler Collection (GCC)'
      __BuildTool_Target__  := 'ARM'
      __BuildTool_Title__   := 'ARM C/C++'


##### Update the definitions of executables, paths, and options
      CppAssembler                 := 'arm-none-eabi-gcc'
      CppCommonAssemblerFlags     +:= '-x' 'assembler-with-cpp'

      CppCcCompiler                := 'arm-none-eabi-gcc'

      CppCxxCompiler               := 'arm-none-eabi-g++'
      CppMinimizeSizeCompileFlags +:= '-fno-use-cxa-atexit' '-fno-exceptions' '-fno-unwind-tables' '-fno-rtti'

      CppLinker                    := 'arm-none-eabi-gcc'

      CppLD                        := 'arm-none-eabi-ld'

const __Def_SLibBuilder__          := 'arm-none-eabi-ar'
      SLibBuilder                  := ${__Def_SLibBuilder__}

      ARMObjDump                   := 'arm-none-eabi-objdump'

      ARMObjCopy                   := 'arm-none-eabi-objcopy'
      ARMObjCopyE2BFlags           := '-O' 'binary'
      ARMObjCopyE2HFlags           := '-O' 'ihex'

      ARMSize                      := 'arm-none-eabi-size'
      ARMSizeDefFlags              := '--format=berkeley' '--radix=10'

      ARMAddr2Line                 := 'arm-none-eabi-addr2line'

      ARMDebugger                  := 'arm-none-eabi-gdb'


##### Fix the file extensions as needed
if !__os_linux__
    ExeFileExt  := elf
    DLibFileExt := so
endif


##### Function to print the size of the given executable file
function __armgcc_obj_size__(objSizeProg, objSizeFlag, progName, ldLibraryPath, dimColor)
    return $call(__generic_xgcc_obj_size__, ${objSizeProg}, ${objSizeFlag}, ${progName}, ${ldLibraryPath}, ${dimColor})
endfunction


##### Function to execute user command(s) via SWD
function __armgcc_user_cmd_swd__(ldLibraryPath, oocdProg, oocdScriptsDir, interface, transport, adapterSpeed, targetDev, commands, ?overrideCPUTapID)
    $exec(                                 \
        __openocd_gen_command_exec__     , \
        ${ldLibraryPath}                 , \
        ${oocdProg}                      , \
        ${oocdScriptsDir}                , \
        ${interface}                     , \
        ${transport}                     , \
        ${adapterSpeed}                  , \
        ${targetDev}                     , \
        ${commands}                      , \
        ${overrideCPUTapID}                \
    )
endfunction


##### Function to reset the MCU via SWD
function __armgcc_reset_swd__(ldLibraryPath, oocdProg, oocdScriptsDir, interface, transport, adapterSpeed, targetDev, ?overrideCPUTapID)
    $exec(                                 \
        __openocd_gen_command_exec__     , \
        ${ldLibraryPath}                 , \
        ${oocdProg}                      , \
        ${oocdScriptsDir}                , \
        ${interface}                     , \
        ${transport}                     , \
        ${adapterSpeed}                  , \
        ${targetDev}                     , \
        { 'init' 'reset run' 'shutdown' }, \
        ${overrideCPUTapID}                \
    )
endfunction


##### Function to upload the given program via SWD
function __armgcc_upload_swd_simple__(ldLibraryPath, oocdProg, oocdScriptsDir, interface, transport, adapterSpeed, targetDev, progName, ?overrideCPUTapID, ?flashWriteOffset)
    if &${flashWriteOffset} : local FWO := :" ${flashWriteOffset}"
    $exec(                                               \
        __openocd_gen_command_exec__                   , \
        ${ldLibraryPath}                               , \
        ${oocdProg}                                    , \
        ${oocdScriptsDir}                              , \
        ${interface}                                   , \
        ${transport}                                   , \
        ${adapterSpeed}                                , \
        ${targetDev}                                   , \
        :"program ~${progName} verify reset exit${FWO}", \
        ${overrideCPUTapID}                              \
    )
endfunction


##### Functions to debug the given program via SWD
function __armgcc_debug_swd_start_print_gdb_info__(funcName, mcuName, progName, gdbProg, gdbNoExecCmd)
    if &${CppToolBinDir} : local gdbProg := $cat_path(${CppToolBinDir}, ${gdbProg})
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    if !${gdbNoExecCmd}
        echoln __c_white__ 'You can start GDB by executing this command from another console:' __c_reset__
        echoln
        echoln             "\"${gdbProg}\" \"~${progName}\""
        echoln
        echoln __c_white__ 'or by calling this library function:' __c_reset__
        echoln
        echoln             "$call(${funcName}, '-${progName}')"
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
    endif
        echoln __c_white__ "GDB command examples to debug ${mcuName} via SWD:" __c_reset__
        echoln
        echoln             'target remote localhost:3333'
        echoln             'monitor reset init'
        echoln             'continue'
        echoln             '^C'
        echoln             'backtrace'
        echoln             'monitor shutdown'
        echoln             'quit'
        echoln
        echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
        echoln
endfunction

function __armgcc_debug_swd_start_exec_openocd__(ldLibraryPath, oocdProg, oocdScriptsDir, interface, transport, adapterSpeed, targetDev, gdbPort, tclPort, telnetPort, ?overrideCPUTapID)
    if &${overrideCPUTapID} ; overrideCPUTapID := -c :"set CPUTAPID ${overrideCPUTapID}"
    else                    ; overrideCPUTapID := ''
    endif
    if &${ldLibraryPath}
        +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    endif
        +@${oocdProg}                                          \
            -f :"${oocdScriptsDir}/interface/${interface}.cfg" \
            ${overrideCPUTapID}                                \
            -c :"transport select ${transport}"                \
            -c :"adapter speed ${adapterSpeed}"                \
            -f :"${oocdScriptsDir}/target/${targetDev}.cfg"    \
            -c :"gdb_port ${gdbPort}"                          \
            -c :"tcl_port ${tclPort}"                          \
            -c :"telnet_port ${telnetPort}"
endfunction

