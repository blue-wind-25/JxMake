##### Include the SDCC C/C++ build tool and other utilities
:::include_once 'AVRDUDEHelper.jxm'
:::include_once 'C++XBuildTool_SDCC.jxm'
:::include_once 'C++XBuildTool_ArduinoUtil.jxm'


##### Update the flags
const __BuildTool_Name__   := 'MCS51 Small Device C Compiler (SDCC)'
      __BuildTool_Target__  = "MCS51 (${MCS51_MCUType} - ${MCS51_CPUFrequency} Hz)"
const __BuildTool_Title__  := 'MCS51 C/C++'


##### Update the definitions of executables, paths, and options
CppAssembler              := 'sdas8051'

CppCommonCcCompileFlags  :+= '-mmcs51'
CppCommonCcCompileFlags   += ${__MCS51_CINCDIR__} ${__MCS51_DDEVICE__} ${__MCS51_DFCPU__}

CppCommonCxxCompileFlags  += ${__MCS51_CINCDIR__} ${__MCS51_DDEVICE__} ${__MCS51_DFCPU__}

CppCommonLinkFlags       :+= '-mmcs51'


##### Determine some settings
MCS51_TOOLCHAIN_PATH             ?:= $getenv('MCS51_TOOLCHAIN_PATH', '')

SDCC_MAP_FILE_ACC_SIZE_AREA_ATTR  := 'REL' 'CODE'


###################################################################################
##### ==================== Generic/Common MCS51 Functions =================== #####
###################################################################################

##### Function to initialize the project build
function init_project(?buildSubdirectories) supersede
    # Check the paths
    local pathError := false
    if $or( $cmp(${MCS51_TOOLCHAIN_PATH}, '&==', ''), $not( $valid_path(${MCS51_TOOLCHAIN_PATH}) ) )
        $call(__exit_error_nf__, 'MCS51 Toolchain (SDCC)', true)
        echoln "Please use your operating system package manager to install the MCS51 Toolchain (SDCC) or download and install it from:"
        echoln '    https://sdcc.sourceforge.net'
        echoln '    https://sourceforge.net/projects/sdcc/files'
        echoln
        echoln 'Example (Linux):'
        echoln '    mkdir ~/mcs51'
        echoln '    cd ~/mcs51'
        echoln '    tar -xjvpf sdcc-4.2.0-amd64-unknown-linux2.5.tar.bz2'
        echoln '    cd ..'
        echoln 'Set \'MCS51_TOOLCHAIN_PATH\' to the MCS51 Toolchain location.'
        echoln
        pathError := true
    endif
    if ${pathError} : $exit(-1)
    # Set the location of the C/C++ binaries
    CppToolBinDir := $cat_path(${MCS51_TOOLCHAIN_PATH}, 'bin')
    # Find the Arduino package directories only if the user has not manually set the variable
    if !&${ArduinoPackageDirs}
        ArduinoPackageDirs := $call(find_arduino_package_dirs)
    endif
    # Find the latest AVRDUDE from Arduino package(s)
    $call(__find_latest_arduino_avrdude_cmd__)
    # Check if the AVRDUDE support the MCS51 parts and update its configuration file as needed
    if !$call(__chk_sel_avrdude_part_support__, { at89s51 at89s52 at89s8253 })
        local CCF := $call(__create_custom_avrdude_config_mcs51_parts__, ${AVRDUDE_Cmd}<1>)
        if $part_count(${AVRDUDE_Cmd}) == 3
            AVRDUDE_Cmd := {{ ${AVRDUDE_Cmd}<1:2>, ${CCF} }}
        else
            AVRDUDE_Cmd +:= '-C' ${CCF}
        endif
    endif
    # Check the programmers supported by AVRDUDE
    local ChkProg := usbtiny usbasp
    local ChkRes  := $call(__chk_sel_avrdude_programmer_support_ext__, ${ChkProg})
    __AVRDUDE_SupportMCS51Progs__ := $erase_ifempty( $csel(${ChkRes}<2:0>, ${ChkProg}, '' ) )
    # Set extra configuration information text
    if &${MCS51_SDK_PATH}
        __BuildTool_ExtraInfoName__  +:= 'MCS51 SDK       Directory'
        __BuildTool_ExtraInfoValue__ +:= ${MCS51_SDK_PATH}
    endif
    if &${MCS51_TOOLCHAIN_PATH}
        __BuildTool_ExtraInfoName__  +:= 'MCS51 Toolchain Directory'
        __BuildTool_ExtraInfoValue__ +:= ${MCS51_TOOLCHAIN_PATH}
    endif
    if &${CppToolBinDir}
        __BuildTool_ExtraInfoName__  +:= 'MCS51 SDCC      Directory'
        __BuildTool_ExtraInfoValue__ +:= ${CppToolBinDir}
    endif
    $call(__add_sel_avrdude_cmd_to_bt_extra_info__)
    # Call the origin function
    __JXMAKELIB_AVR_DO_NOT_DOWNLOAD_DFU_PROG__ := true # MCS51 does not need DFU programmer
    $call(__origin__, ${buildSubdirectories})
endfunction


##### Function to check if the selected AVRDUDE support the given programmer
function __mcs51_chk_avrdude_prog_support__(programmer, ?descProgName)
    descProgName ?:= ${programmer}
    if !$contains( ${__AVRDUDE_SupportMCS51Progs__}, $lcase(${programmer/\s//}) ) : $call(__exit_error_ns_sprog__, ${descProgName}, 'AVRDUDE')
endfunction


##### Function to check signature and upload via USBtinyISP
const MCS51_Default_USBtinyISPVariant := 'USBtiny'

.macro __mcs51_usbtinyisp_common_entry_code__
    (*
    # NOTE : USBtinyISP and MCS51 does not work well and needs workaround that currently does not work on Windows!
    if __os_windows__
        $call(__exit_error_ns_benv__, 'USBtinyISP', 'MCS51/AVRDUDE/Windows')
    endif
    *)
    # Set the default values
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_mcs51__, ${MCS51_CPUFrequency})
    variant  ?:= ${MCS51_Default_USBtinyISPVariant}
    variant   := $lcase(${variant})
    # Check if AVRDUDE support the default programmer variant; NOTE : other variants are not checked!
    if ${variant} &== $lcase(${MCS51_Default_USBtinyISPVariant})
        $call(__mcs51_chk_avrdude_prog_support__, 'usbtiny', 'USBtinyISP')
    endif
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __mcs51_usbtinyisp_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_usbtinyisp_error_and_print_help__, $[function], true)
.endmacro

function __mcs51_chksig_usbtinyisp_exec__(bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__} -D -U signature:r:-:h
endfunction

function mcs51_chksig_usbtinyisp(?bitClock, ?variant)
    # Execute the common entry code
    .$__mcs51_usbtinyisp_common_entry_code__
    # Perform signature check
    $exec( __mcs51_chksig_usbtinyisp_exec__, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__mcs51_usbtinyisp_common_leave_code__
endfunction

function __mcs51_upload_usbtinyisp_exec__(progName, bitClock, variant, ldLibraryPath)
    (*
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@bash -c :"${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__} -e ${AVRDUDE_CmdSafeMode} ; exit 0"
              +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__}    ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
    *)
    # Erase flash
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__} -e ${AVRDUDE_CmdSafeMode}
    $nop($[excode]) # Ensure all pending commands are executed and ignore the exit code because '-e' with MCS51 and USBtinyISP always produce non zero exit code
    # Program flash
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__}    ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
    $nop($[excode])
endfunction

function mcs51_upload_usbtinyisp(progName, ?bitClock, ?variant)
    # Execute the common entry code
    .$__mcs51_usbtinyisp_common_entry_code__
    # Perform upload
    $exec( __mcs51_upload_usbtinyisp_exec__, ${progName}, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__mcs51_usbtinyisp_common_leave_code__
endfunction

.undefmacro __mcs51_usbtinyisp_common_entry_code__
.undefmacro __mcs51_usbtinyisp_common_leave_code__


##### Function to check signature and upload via USBasp
const MCS51_Default_USBaspVariant := 'USBasp'

.macro __mcs51_usbasp_common_entry_code__
    # Set the default values
    bitClock ?:= $call(__avrdude_get_safe_bit_clock_for_mcs51__, ${MCS51_CPUFrequency})
    variant  ?:= ${MCS51_Default_USBaspVariant}
    variant   := $lcase(${variant})
    # Check if AVRDUDE support the default programmer variant; NOTE : other variants are not checked!
    if ${variant} &== $lcase(${MCS51_Default_USBaspVariant})
        $call(__mcs51_chk_avrdude_prog_support__, 'usbasp', 'USBasp')
    endif
    # Enable streaming for '@'
    $cmd_streaming_on()
.endmacro

.macro __mcs51_usbasp_common_leave_code__
    # Disable streaming for '@'
    $cmd_streaming_off()
    # Check for error
    $call(__avrdude_check_usbasp_error_and_print_help__, $[function], false, true)
.endmacro

function __mcs51_chksig_usbasp_exec__(bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__} -D -U signature:r:-:h
endfunction

function mcs51_chksig_usbasp(?bitClock, ?variant)
    # Execute the common entry code
    .$__mcs51_usbasp_common_entry_code__
    # Perform upload
    $exec( __mcs51_chksig_usbasp_exec__, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__mcs51_usbasp_common_leave_code__
endfunction

function __mcs51_upload_usbasp_exec__(progName, bitClock, variant, ldLibraryPath)
    +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    +@${AVRDUDE_Cmd} -c ${variant} -B ${bitClock} -p ${__MCS51_AVRDUDE__} -e ${AVRDUDE_CmdSafeMode} -D -V -U :"flash:w:~${progName/(.+)\.elf/$1.hex/}:i"
endfunction

function mcs51_upload_usbasp(progName, ?bitClock, ?variant)
    # Execute the common entry code
    .$__mcs51_usbasp_common_entry_code__
    # Perform upload
    $exec( __mcs51_upload_usbasp_exec__, ${progName}, ${bitClock}, ${variant}, $call(__get_LDLibraryPaths__) )
    # Execute the common leave code
    .$__mcs51_usbasp_common_leave_code__
endfunction

.undefmacro __mcs51_usbasp_common_entry_code__
.undefmacro __mcs51_usbasp_common_leave_code__

