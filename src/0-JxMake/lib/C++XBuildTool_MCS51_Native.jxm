###################################################################################
##### ===================== Native MCS51 Build Functions ==================== #####
###################################################################################

##### Function to select the part number
const MCS51_Default_CPUFreq := 11059200

function mcs51_select_part(partNumber, ?cpuFreq)
    # Set the default value
    cpuFreq ?:= ${MCS51_Default_CPUFreq}
    # Convert the part number to uppercase
    partNumber := $ucase(${partNumber})
    # Save the part number and CPU frequency
    MCS51_MCUType      := ${partNumber}
    MCS51_CPUFrequency := ${cpuFreq}
    # Determine the include paths
    local PathPrefix := 'share/sdcc/'
    if !$valid_path(:"${MCS51_TOOLCHAIN_PATH}/${PathPrefix}") : PathPrefix := ''
    local IncPathRoot    := $cat_path(${MCS51_TOOLCHAIN_PATH}, :"${PathPrefix}include")
    local IncPathRootSub := $cat_path(${IncPathRoot}         , 'mcs51'                )
    # Set the special definition variables
    __MCS51_CINCDIR__ := $series    ( '-I', {{ ~${IncPathRoot}, ~${IncPathRootSub} }}          )
    __MCS51_DDEVICE__ := $series    ( '-D', { '' '__' '__MCS51_' }, ${partNumber}, { '' '__' } )
    __MCS51_DFCPU__   := $series    ( '-DF_CPU=', ${MCS51_CPUFrequency}, 'UL'                  )
    __MCS51_AVRDUDE__ := $re_replace( $lcase(${partNumber}), 'at89s(\d+)', '89s$1'             )
endfunction


###################################################################################
##### ==================== Library Help Printer Function ==================== #####
###################################################################################

##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__() supersede
    local NGText := __c_cyan__  "Native MCS51" __c_white__
    local NGInfo := __c_white__ 'for ' ${NGText} ' '
    $call(__origin__)
    $call(__btlib_help_print_title_cross__)
    $call(__btlib_help_print_title_variables__, ${NGInfo})
    echoln __c_green__ '    MCS51_TOOLCHAIN_PATH  ' __c_white__ ': location of ' ${NGText} ' toolchain'
    echoln
   #$call(__btlib_help_print_title_functions__, 9, 20, 1, ${NGInfo})
    $call(__btlib_help_print_title_functions__, 0,  0, 0, ${NGInfo})
    echoln __c_green__ '    mcs51_select_part      (partNumber, ?cpuFreq) ' __c_white__ ': select the ' __c_cyan__ 'MCS51' __c_white__ ' part number to use with the ' ${CGText} ' SDK; can only be called after calling \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_green__ '      partNumber' __c_white__ ' MCS51 part number   - for example    \'' __c_yellow__ 'AT89S52' __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_green__ '      cpuFreq   ' __c_white__ ' MCS51 CPU frequency - the default is \'' __c_yellow__ ${MCS51_Default_CPUFreq} __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_white__ '  these are the global variables that are initialized by this function:'
    echoln __c_green__ '                                                  ' __c_green__ '      MCS51_MCUType'
    echoln __c_green__ '                                                  ' __c_green__ '      MCS51_CPUFrequency'
    echoln
    echoln __c_green__ '    mcs51_chksig_usbtinyisp(           ?bitClock, ' __c_white__  ': check the ' __c_cyan__ 'MCS51' __c_white__ ' signature code via ' __c_cyan__ 'USBtinyISP'
    echoln __c_green__ '                            ?variant            ) '
    echoln __c_green__ '    mcs51_upload_usbtinyisp(progName , ?bitClock, ' __c_white__  ': upload program to ' __c_cyan__ 'MCS51' __c_white__ ' via ' __c_cyan__ 'USBtinyISP'
    echoln __c_green__ '                            ?variant            ) ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'MCS51_CPUFrequency' __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_green__  '      variant ' __c_white__ ' set this to the correct programmer name       - possible values are:'
    echoln __c_green__ '                                                  ' __c_white__  '                   \'' __c_yellow__ ${MCS51_Default_USBtinyISPVariant} __c_white__ '\' (the default)'
    echoln __c_green__ '                                                  ' __c_white__  '                   other programmers from \'' __c_yellow__ 'avrdude.conf' __c_white__ '\' with \'' __c_yellow__ 'type = "usbtiny"' __c_white__ '\''
    echoln
    echoln __c_green__ '    mcs51_chksig_usbasp    (           ?bitClock, ' __c_white__  ': check the ' __c_cyan__ 'MCS51' __c_white__ ' signature code via ' __c_cyan__ 'USBasp'
    echoln __c_green__ '                            ?variant            ) '
    echoln __c_green__ '    mcs51_upload_usbasp    (progName , ?bitClock, ' __c_white__  ': upload program to ' __c_cyan__ 'MCS51' __c_white__ ' via ' __c_cyan__ 'USBasp'
    echoln __c_green__ '                            ?variant            ) ' __c_green__  '      progName' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_green__  '      bitClock' __c_white__ ' set this to the correct programming bit clock - the default depends on \'' __c_green__ 'MCS51_CPUFrequency' __c_white__ '\''
    echoln __c_green__ '                                                  ' __c_green__  '      variant ' __c_white__ ' set this to the correct programmer name       - possible values are:'
    echoln __c_green__ '                                                  ' __c_white__  '                   \'' __c_yellow__ ${MCS51_Default_USBaspVariant} __c_white__ '\' (the default)'
    echoln __c_green__ '                                                  ' __c_white__  '                   other programmers from \'' __c_yellow__ 'avrdude.conf' __c_white__ '\' with \'' __c_yellow__ 'type = "usbasp"' __c_white__ '\''
    echoln
    $call(__avrdude_print_usbasp_supported_bit_clock__, 55)
    echoln __c_reset__
endfunction
