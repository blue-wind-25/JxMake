#### SDK related cache file paths
const Pico_LibSpecsCacheFilePath := $cat_path( $ptd(), 'PicoLibSpecs.cache' )
const Pico_InitSDKCacheFilePath  := $cat_path( $ptd(), 'PicoInitSDK.cache'  )


##### SDK related variables
Pico_SDKVersion      := '0' '0'
Pico_LibSpecMH       :=  0

Pico_BinutilsVersion := '0' '0'


##### Function to get binutils version
function __pico_get_binutils_version_exec__(ldLibraryPath)
    if &${CppToolBinDir} : local CppLD := $cat_path(${CppToolBinDir}, ${CppLD})
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   -@${CppLD} -v
    local excode := $[excode]
    $restore_sem()
    if &$[lserr] : return -1 # Check if the command turns out to be unexecutable
    return ${excode}
endfunction

function pico_get_binutils_version()
    # Check if the version number is already obtained
    if ${Pico_BinutilsVersion}<1> : return ${Pico_BinutilsVersion}
    # Get the version
    if !$exec( __pico_get_binutils_version_exec__, $call(__get_LDLibraryPaths__) )
        local text  := $partn( $erase_ifempty( $sflines($[stdout]) ), 1 )
              text  := $sfdots(${text/.+?(\d+\.\d+\.\d+).*/$1/})
        local major := $partn(${text}, 1)
        local minor := $partn(${text}, 2)
        local patch := $partn(${text}, 3)
        # Save the version number
        Pico_BinutilsVersion  := $call(calc_ver_numeric_222, ${major}, ${minor}, ${patch})
        Pico_BinutilsVersion +:= :"${major}.${minor}.${patch}"
    endif
    # Return the version number
    return ${Pico_BinutilsVersion}
endfunction


##### Check if the binutils version is at least/most
function pico_ld_ver_min(major, minor, revision)
    return $cmp( ${Pico_BinutilsVersion}, '>=', $call(calc_ver_numeric_222, ${major}, ${minor}, ${revision}) )
endfunction

function pico_ld_ver_max(major, minor, revision)
    return $cmp( ${Pico_BinutilsVersion}, '<=', $call(calc_ver_numeric_222, ${major}, ${minor}, ${revision}) )
endfunction


##### Functions to get SDK version
function pico_get_sdk_version()
    # Check if the version number is already obtained
    if ${Pico_SDKVersion}<1> : return ${Pico_SDKVersion}
    # Read the file
    local Lines := $get_file(:"${PICO_SDK_PATH}/pico_sdk_version.cmake")
          Lines := $ftlines(${Lines/(.*?)#.*/$1/}) # Remove comments from the lines and flatten
    # Get the version number
    local VMajor  := 0
    local VMinor  := 0
    local VRev    := 0
    local ProcRes := $re_split(${Lines}, '(?m)\bset\\s*\\(\\s*([^()]+)\\s*\\)')
    foreach local Entry in ${ProcRes}
        Entry := $sfspaces(${Entry})
          if ${Entry}<1> &== 'PICO_SDK_VERSION_MAJOR'    ; VMajor := ${Entry}<2>
        elif ${Entry}<1> &== 'PICO_SDK_VERSION_MINOR'    ; VMinor := ${Entry}<2>
        elif ${Entry}<1> &== 'PICO_SDK_VERSION_REVISION' ; VRev   := ${Entry}<2>
        endif
    endforeach
    # Save the version number
    Pico_SDKVersion  := $call(calc_ver_numeric_222, ${VMajor}, ${VMinor}, ${VRev})
    Pico_SDKVersion +:= :"${VMajor}.${VMinor}.${VRev}"
    # Return the version number
    return ${Pico_SDKVersion}
endfunction


##### Check if the SDK version is at least/most
function pico_sdk_ver_min(major, minor, revision)
    return $cmp( ${Pico_SDKVersion}, '>=', $call(calc_ver_numeric_222, ${major}, ${minor}, ${revision}) )
endfunction

function pico_sdk_ver_max(major, minor, revision)
    return $cmp( ${Pico_SDKVersion}, '<=', $call(calc_ver_numeric_222, ${major}, ${minor}, ${revision}) )
endfunction


##### Functions to get library specifications
const Pico_AVal_Prefix    := '`'
const Pico_AVal_Separator := '|'

const Pico_DefaultIType   := 'INTERFACE'
const Pico_ComIgnList     := '_LINK_DEPENDS' 'PICO_SDK_POST_LIST_FILES' 'PICO_RP2040_CONFIG_HEADER_FILES'

const Pico_CCmdKeywords   := 'APPEND' 'BYPRODUCTS' 'COMMAND' 'COMMAND_EXPAND_LISTS' 'COMMENT' 'DEPENDS' 'DEPFILE' 'IMPLICIT_DEPENDS' 'JOB_POOL' 'MAIN_DEPENDENCY' 'OUTPUT' 'USES_TERMINAL' 'VERBATIM' 'WORKING_DIRECTORY'

.macro __pico_cmlc__set__default_libname_itype__
    # Set the default library name and inheritance type
    Name  := ${cmlc}<1>
    Type  := ${Pico_DefaultIType}
    USelf := false
    UUser := true
.endmacro

.macro __pico_cmlc__extract_parts__common_prefix_code__
    # Get the enclosing function name for this entry
    FName := $call(__pico_get_lib_spec_get_function_name_for_entry__, ${Content}, ${Entry})
    # Get the parts
    unset Parts
    local Parts
    foreach local Line in $sflines(${Entry})
        Parts +:= $sfspaces(${Line})
    endforeach
.endmacro

.macro __pico_cmlc__extract_parts__ctname_depname__
    # Include the common code
    .$__pico_cmlc__extract_parts__common_prefix_code__
    # Check if the second term is 'DEPENDS'
    if ${Parts}<2> &!= 'DEPENDS' : $call( __exit_error_ni_cmake_eval__, $flatten( {{ 'list(... ', ${Parts}<2>, ' ...)' }} ) )
    # Extract the target name
    Name := ${Parts}<1>
    # Evaluate variables in the name
    Name := $call(__pico_cmlv_eval_parts__, ${Name}, ${mhSetVal}, ${FName}, ${Path})
.endmacro

.macro __pico_cmlc__extract_parts__ccmd_ctname__
    # Include the common code
    .$__pico_cmlc__extract_parts__common_prefix_code__
    # Extract the target name
    Name := ${Parts}<2>
    # Evaluate variables in the name
    Name := $call(__pico_cmlv_eval_parts__, ${Name}, ${mhSetVal}, ${FName}, ${Path})
.endmacro

.macro __pico_cmlc__extract_parts__libname__
    # Include the common code
    .$__pico_cmlc__extract_parts__common_prefix_code__
    # Extract the library name
    Name := ${Parts}<1>
    # Evaluate variables in the name
    Name := $call(__pico_cmlv_eval_parts__, ${Name}, ${mhSetVal}, ${FName}, ${Path})
.endmacro

.macro __pico_cmlc__extract_parts__libname__default_itype__
    # Include the common code
    .$__pico_cmlc__extract_parts__common_prefix_code__
    # Extract the library name and set the default inheritance type
    Name := ${Parts}<1>
    Type := ${Pico_DefaultIType}
    # Evaluate variables in the name
    Name := $call(__pico_cmlv_eval_parts__, ${Name}, ${mhSetVal}, ${FName}, ${Path})
    # Set the default the inheritance type
    USelf := false
    UUser := true
.endmacro

.macro __pico_cmlc__extract_parts__libname_itype__
    # Include the common code
    .$__pico_cmlc__extract_parts__common_prefix_code__
    # Extract the library name and inheritance type
    Name := ${Parts}<1>
    Type := ${Parts}<2>
    # Evaluate variables in the name
    Name := $call(__pico_cmlv_eval_parts__, ${Name}, ${mhSetVal}, ${FName}, ${Path})
    # Evaluate the inheritance type
      if ${Type} &== 'PUBLIC'    ; USelf := true  ; UUser := true  ; Skip := 2
    elif ${Type} &== 'PRIVATE'   ; USelf := true  ; UUser := false ; Skip := 2
    elif ${Type} &== 'INTERFACE' ; USelf := false ; UUser := true  ; Skip := 2
    else                         ; USelf := true  ; UUser := false ; Skip := 1 # Assume 'PRIVATE' if not specified
    endif
.endmacro

.macro __pico_cmlc__extract_parts__libname__store__set__
    # Include the common code
    .$__pico_cmlc__extract_parts__common_prefix_code__
    # Extract the name and evaluate variables in the name
    Name := ${Parts}<1>
    Name := $call(__pico_cmlv_eval_parts__, ${Name}, ${mhSetVal}, ${FName}, ${Path})
    # Store the name and values
    $map_put( ${mhSetVal}, :"\${${Name}}", $erase_ifempty( $partnm(${Parts}, 2, -1) ) )
.endmacro

.macro __pico_cmlc__store__libname_incpath__
    # Store the library name
    $map_add(${mhLibSpc}, '__LibraryNames__', ${Name})
    # Store the include path if it exist
    if &${IncDir} : $call( __pico_map_add_include__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, $cat_path(${Path}, 'include') )
.endmacro

function __pico_get_cmlc__(name, path, ?cmf)
    # Set the default value
    cmf ?:= 'CMakeLists.txt'
    # Check if the CMake specification file exist
    local CMLPath := $cat_path(${path}, ${cmf})
    if !$valid_path(${CMLPath}) : return
    # Read the file
    local Lines := $get_file(${CMLPath})
          Lines := $ftlines(${Lines/(.*?)#.*/$1/}) # Remove comments from the lines and flatten
    # Return the result
    return {{ ${name}, ${path}, ${Lines} }}
endfunction

function __pico_get_cmlc__src_common__(name)
    local path := $cat_paths(${PICO_SDK_PATH}, 'src/common', ${name})
    return $call(__pico_get_cmlc__, ${name}, ${path})
endfunction

function __pico_get_cmlc__src_rp2_common__(name)
    local path := $cat_paths(${PICO_SDK_PATH}, 'src/rp2_common', ${name})
    return $call(__pico_get_cmlc__, ${name}, ${path})
endfunction

function __pico_get_cmlc__src_rp2040__(name)
    local path := $cat_paths(${PICO_SDK_PATH}, 'src/rp2040', ${name})
    return $call(__pico_get_cmlc__, ${name}, ${path})
endfunction

function __pico_get_cmlc__lib_xxx__(name, subdir, ?cmf)
    local path := $cat_paths(${PICO_SDK_PATH}, 'lib', ${name}, ${subdir})
    return $call(__pico_get_cmlc__, ${name}, ${path}, ${cmf})
endfunction

function __pico_get_cmlc__lib_tinyusb__()
    return $call(__pico_get_cmlc__lib_xxx__, 'tinyusb', :"hw/bsp/${Pico_MCU_LC}", 'family.cmake')
endfunction

__disable__pico_cmlv_eval_remove_dqs_ts__ := false

function __pico_cmlv_eval_remove_dqs_ts__(part)
    # Simply return the part if it this function is disabled
    if ${__disable__pico_cmlv_eval_remove_dqs_ts__} : return ${part}
    # Remove quotes and trailing '/'
    part := ${part/"(.+?)"/$1/}
    part := ${part/\/$//}
    return ${part}
endfunction

function __pico_cmlv_eval_part_std__(part, mhSetVal, curFName, curProcDirPath)
    # Perform replacements - simple strings
    part := $re_replace(${part}, '\\$\\{name\\}'                                      , :"${Pico_ProjectName}"                          )
    part := $re_replace(${part}, '\\$\\{description\\}'                               , :"${Pico_ProjectDesc}"                          )
    part := $re_replace(${part}, '\\$\\{url\\}'                                       , :"${Pico_ProjectURL}"                           )
    part := $re_replace(${part}, '\\$\\{version\\}'                                   , :"${Pico_ProjectVer}"                           )
    part := $re_replace(${part}, '\\$\\{PICO_BOARD\\}'                                , :"${PICO_BOARD}"                                )
    part := $re_replace(${part}, '\\$\\{CMAKE_BUILD_TYPE\\}'                          , '\\${#CppBuildType}'                            )
    # Perform replacements - directories and paths
    local _CppBuildDir    := $cat_path( $cwd(), ${CppBuildDir}    )
    local _CurProcDirPath := $cat_path( $cwd(), ${curProcDirPath} )
    part := $re_replace(${part}, '\\$\\{CMAKE_BINARY_DIR\\}.*'                        , ${_CppBuildDir}                                 )
    part := $re_replace(${part}, '\\$\\{CMAKE_CURRENT_BINARY_DIR\\}.*'                , ${_CppBuildDir}                                 )
    part := $re_replace(${part}, '\\$\\{CMAKE_CURRENT_LIST_DIR\\}'                    , ${_CurProcDirPath}                              )
    part := $re_replace(${part}, '\\$\\{CMAKE_COMMAND\\}'                             , '\\${#CMake}'                                   )
    part := $re_replace(${part}, '\\$\\{CMAKE_OBJCOPY\\}'                             , '\\${PicoObjCopy}'                              )
    part := $re_replace(${part}, '\\$\\{Python3_EXECUTABLE\\}'                        , '\\${Python3}'                                  )
    part := $re_replace(${part}, '\\$\\{PICO_SDK_PATH\\}'                             , ${PICO_SDK_PATH}                                )
    part := $re_replace(${part}, '\\$\\{PICO_BOOT_STAGE2_DIR\\}'                      , :"${PICO_SDK_PATH}/src/rp2_common/boot_stage2"  )
    part := $re_replace(${part}, '\\$\\{PICO_CYW43_DRIVER_PATH\\}'                    , :"${PICO_SDK_PATH}/lib/cyw43-driver"            )
    part := $re_replace(${part}, '\\$\\{PICO_BTSTACK_PATH\\}'                         , :"${PICO_SDK_PATH}/lib/btstack"                 )
    part := $re_replace(${part}, '\\$\\{PICO_LWIP_PATH\\}'                            , :"${PICO_SDK_PATH}/lib/lwip"                    )
    part := $re_replace(${part}, '\\$\\{PICO_LWIP_CONTRIB_PATH\\}'                    , :"${PICO_SDK_PATH}/lib/lwip/contrib"            )
    # Perform replacements - Mbed-TLS
    part := $re_replace(${part}, '\\$\\{PICO_MBEDTLS_PATH\\}'                         , :"${PICO_SDK_PATH}/lib/mbedtls"                 )
    part := $re_replace(${part}, '\\$\\{PICO_MBEDTLS_CONFIG_FILE\\}'                  , ${PICO_MBEDTLS_CONFIG_FILE}                     )
    # Perform replacements - special cases
    if $str_endwith(${curProcDirPath}, 'rp2_common/boot_stage2')
        part := $re_replace(${part}, '\\$\\{PICO_DEFAULT_BOOT_STAGE2_FILE\\}'         , ${PICO_DEFAULT_BOOT_STAGE2_FILE}                )
    elif $str_endwith(${curProcDirPath}, 'lib/tinyusb/hw/bsp/rp2040')
        part := $re_replace(${part}, '\\$\\{TARGET\\}'                                , :"${Pico_MCU_LC}_tinyusb"                       )
        part := $re_replace(${part}, '\\$\\{LOG\\}'                                   , '0'                                             )
    endif
    if ${curFName} &== 'pico_define_boot_stage2'
        part := $re_replace(${part}, '\\$\\{NAME\\}'                                  , 'bs2_default'                                   )
        part := $re_replace(${part}, '\\$\\{BOOT_STAGE2_BI_NAME\\}'                   , 'boot2_w25q080'                                 )
    elif ${curFName} &== 'pico_btstack_make_gatt_header'
        part := $re_replace(${part}, '\\$\\{TARGET_LIB\\}'                            , :"${Pico_ProjectName}_gatt"                     )
        part := $re_replace(${part}, '\\$\\{GATT_NAME\\}'                             , :"${Pico_ProjectName}_gatt"                     )
        part := $re_replace(${part}, '\\$\\{GATT_FILE\\}'                             , :"${_CppBuildDir}/${Pico_ProjectName}_gatt.gatt")
        part := $re_replace(${part}, '\\$\\{GATT_PATH\\}'                             , :"${_CppBuildDir}"                              )
    elif $or( $cmp( ${curFName}                                     , '&==', 'pico_add_platform_library' ), \
              $cmp( $str_lidx(${curProcDirPath}, 'pico_binary_info'), '>'  , '0'                         )  \
            )
        part := $re_replace(${part}, '\\$\\{TARGET\\}'                                , ${Pico_ProjectName}                             )
    elif $cmp( $str_lidx(${curProcDirPath}, 'pico_stdio_usb'), '>', '0' )
        # NOTE : From Pico SDK 1.5.1 - JxMake always sets this to the default value of zero!
        part := $re_replace(${part}, '\\$\\{PICO_STDIO_USB_CONNECT_WAIT_TIMEOUT_MS\\}', '0'                                             )
    else
        local wfn := $re_split(${curFName}, 'wrap_([a-z]+)_functions')
        if &${wfn}
            wfn  := :"${Pico_AVal_Prefix}pico_${wfn}_(none${Pico_AVal_Separator}pico)"
            part := $re_replace(${part}, '\\$\\{TARGET\\}'                            ,     ${wfn}                                      )
        endif
    endif
    # Perform replacements - set values
    local repVal := $map_get(${mhSetVal}, ${part})
    if &${repVal} : part := ${repVal}
    # Return the result
    return $call(__pico_cmlv_eval_remove_dqs_ts__, ${part}) # Remove quotes and trailing '/'
endfunction

function __pico_cmlv_eval_part_gen__(part, curFName)
    # Simple values
    part := $re_replace( ${part}, '\s*(?<name>.*?PICO_NO_FLASH)=.*'       , :"\${name}=${PICO_NO_FLASH}"        )
    part := $re_replace( ${part}, '\s*(?<name>.*?PICO_USE_BLOCKED_RAM)=.*', :"\${name}=${PICO_USE_BLOCKED_RAM}" )
    part := $re_replace( ${part}, '\s*(?<name>.*?PICO_COPY_TO_RAM)=.*'    , :"\${name}=${PICO_COPY_TO_RAM}"     )
    # Target properties
    if $str_fidx(${part}, 'TARGET_PROPERTY') > 0
        # Declare a local variable for storing the replacement value
        local repl
        # Link the default 'pico_(bit_ops|divider|double|float|int64_ops|mem_ops|printf)'
        repl := $lcase( $re_replace(${part}, '.*?PICO_TARGET_([_A-Z0-9]+?)_IMPL.*?PICO_TARGET_\\1_IMPL.*?PICO_DEFAULT_\\1_IMPL.*', 'pico_$1_default') )
        if ${repl} &!= $lcase(${part}) : part := ${repl}
        # Link 'pico_stdio_uart' if 'PICO_TARGET_STDIO_UART' is 1
        repl := $re_replace( ${part}, '.*?(PICO_TARGET_STDIO_UART).*?\\1.*?(pico_stdio_uart).*', $csel(${PICO_TARGET_STDIO_UART}, '$2', '') )
        if ${repl} &!= ${part} : part := ${repl}
        # Link 'pico_stdio_usb' if 'PICO_TARGET_STDIO_USB' is 1
        repl := $re_replace( ${part}, '.*?(PICO_TARGET_STDIO_USB).*?\\1.*?(pico_stdio_usb).*', $csel(${PICO_TARGET_STDIO_USB}, '$2', '') )
        if ${repl} &!= ${part} : part := ${repl}
        # Link 'pico_stdio_semihosting' if 'PICO_TARGET_STDIO_SEMIHOSTING' is 1
        repl := $re_replace( ${part}, '.*?(PICO_TARGET_STDIO_SEMIHOSTING).*?\\1.*?(pico_stdio_semihosting).*', $csel(${PICO_TARGET_STDIO_SEMIHOSTING}, '$2', '') )
        if ${repl} &!= ${part} : part := ${repl}
        # Link 'bs2_default_library' if 'PICO_NO_FLASH' is 0
        repl := $re_replace( ${part}, '.*?(PICO_TARGET_BINARY_TYPE).*?\\1.*(PICO_TARGET_BOOT_STAGE2).*?\\2.*', $csel(${PICO_NO_FLASH}, '', 'bs2_default_library') )
        if ${repl} &!= ${part} : part := ${repl}
        # Add link option '-nostartfiles' if 'PICO_NO_FLASH' is 1
        local pnsf := $csel(${PICO_NO_FLASH}, '-nostartfiles', '')
        repl := $re_replace( ${part}, '.*?(PICO_TARGET_BINARY_TYPE).*?\\1.*?-nostartfiles.*', ${pnsf} )
        if ${repl} &!= ${part} : part := ${repl}
        # Set the linker script
        repl := $re_replace( ${part}, '.*?(LINKER:--script)=.*?(PICO_TARGET_LINKER_SCRIPT).*?\\2.*', :"\$1=\\${PICO_TARGET_LINKER_SCRIPT}" )
        if ${repl} &!= ${part} : part := ${repl}
    # Special cases
    elif ${curFName} &== 'pico_define_boot_stage2'
        repl := $str_replace(${part}, '$<TARGET_FILE:${NAME}>', ${PICO_BS2_DEFAULT_FILE_NAME})
        if ${repl} &!= ${part} : part := ${repl}
    endif
    # Return the result
    return $call(__pico_cmlv_eval_remove_dqs_ts__, ${part}) # Remove quotes and trailing '/'
endfunction

function __pico_cmlv_eval_part__(part, mhSetVal, curFName, curProcDirPath)
    # Check for generator expressions ('$<')
    if $str_fidx(${part}, '$<') > 0 : return {{ 0, $call(__pico_cmlv_eval_part_gen__, ${part}, ${curFName}) }}
    # Check if the part does contain a variable
    local f := $str_fidx(${part}, '${')
    # If the part does not contain a variable, simply remove quotes and trailing '/'
    if ${f} <= 0 : return {{ 0, $call(__pico_cmlv_eval_remove_dqs_ts__, ${part}) }}
    # Get the other indexes
    local l := $str_lidx(${part}, '${')
    local e := $str_lidx(${part}, '}' )
    local z := $strlen  (${part}      )
    # Check if it is a simple variable evaluation
    local eval m := (${f} == ${l}) && (${e} == ${z})
    # It is a simple variable evaluation
    if ${m}
        part := $call(__pico_cmlv_eval_part_std__, ${part}, ${mhSetVal}, ${curFName}, ${curProcDirPath})
    # It is not a simple variable evaluation
    else
        local subparts := $re_split(${part}, '\\$\\{(.+?)\\}')
        foreach local sp in ${subparts}
            local spn := :"\${${sp}}"
            local res := $call(__pico_cmlv_eval_part_std__, ${spn}, ${mhSetVal}, ${curFName}, ${curProcDirPath})
            part := $str_replace(${part}, ${spn}, ${res})
        endforeach
    endif
    # Return the evaluated result
    return { 1 ${part} }
endfunction

function __pico_cmlv_eval_parts__(parts, mhSetVal, curFName, curProcDirPath)
    # Evaluate the parts several times
    local loopCount := 0
    loop
        # A flag that indicates if anything was evaluated
        local anyEvaled := false
        # Process the parts
        unset evaledParts
        local evaledParts
        foreach local part in ${parts}
            local res := $call(__pico_cmlv_eval_part__, ${part}, ${mhSetVal}, ${curFName}, ${curProcDirPath})
            if ${res}<1> : anyEvaled := true
            evaledParts +:= $partnm(${res}, 2, -1)
        endforeach
        # Copy the evaluated result (without the empty entries)
        parts := $erase_ifempty(${evaledParts})
        # Break if nothing was evaluated
        if !${anyEvaled} : break
        # Break if the loop counter has exceeded the limit
        inc loopCount
        if ${loopCount} >= 10 : break
    endloop
    # Return the final evaluated result
    return ${parts}
endfunction

function __pico_cmlv_eval_parts__exclude_1__(parts, mhSetVal, curFName, curProcDirPath)
    # Exclude the name and type
    parts := $partnm(${parts}, 2, -1)
    # Evaluate variables
    return $call(__pico_cmlv_eval_parts__, ${parts}, ${mhSetVal}, ${curFName}, ${curProcDirPath})
endfunction

function __pico_cmlv_eval_parts__exclude_2__(parts, mhSetVal, curFName, curProcDirPath)
    # Exclude the name and type
    parts := $partnm(${parts}, 3, -1)
    # Evaluate variables
    return $call(__pico_cmlv_eval_parts__, ${parts}, ${mhSetVal}, ${curFName}, ${curProcDirPath})
endfunction

function __pico_kn_dependency__       (name) ; return :"{${name}}:dependency"        ; endfunction
function __pico_kn_custom_target__    (name) ; return :"{${name}}:custom_target"     ; endfunction
function __pico_kn_custom_command__   (name) ; return :"{${name}}:custom_command"    ; endfunction
function __pico_kn_include_self__     (name) ; return :"{${name}}:include:self"      ; endfunction
function __pico_kn_include_user__     (name) ; return :"{${name}}:include:user"      ; endfunction
function __pico_kn_source_self__      (name) ; return :"{${name}}:source:self"       ; endfunction
function __pico_kn_source_user__      (name) ; return :"{${name}}:source:user"       ; endfunction
function __pico_kn_compile_def_self__ (name) ; return :"{${name}}:#CompileMDef:self" ; endfunction
function __pico_kn_compile_def_user__ (name) ; return :"{${name}}:#CompileMDef:user" ; endfunction
function __pico_kn_link_option_self__ (name) ; return :"{${name}}:link_option:self"  ; endfunction
function __pico_kn_link_option_user__ (name) ; return :"{${name}}:link_option:user"  ; endfunction
function __pico_kn_link_library_self__(name) ; return :"{${name}}:link_library:self" ; endfunction
function __pico_kn_link_library_user__(name) ; return :"{${name}}:link_library:user" ; endfunction

function __pico_map_resolve_rel_path__(value)
    local resolved
    foreach local cp in ${value}
        if $and( $not( $str_begwith(${cp}, '$') ), $path_is_rel(${cp}) ) : cp := $cat_path(${Path}, ${cp})
        resolved +:= ${cp}
    endforeach
    return ${resolved}
endfunction

function __pico_map_add_dependency__(mh, name, value)
     $map_add( ${mh}, $call(__pico_kn_dependency__   , ${name}), ${value} )
endfunction

function __pico_map_add_custom_target__(mh, name, value)
     $map_add( ${mh}, $call(__pico_kn_custom_target__, ${name}), ${value} )
endfunction

function __pico_map_add_custom_command_get_part_midx__(value, idx, cnt)
    loop
        # Get the value
        local val := ${value}<idx>
        # Break if the value is one of CMake 'add_custom_command' sub-keywords
        if $contains(${Pico_CCmdKeywords}, ${val}) : break
        # Increment the index and break if the index has reached the maximum value
        inc idx
        if ${idx} > ${cnt} : break
    endloop
    return ${idx}
endfunction

function __pico_map_add_custom_command__(mh, name, value)
    # Variables for storing the extracted parts
    local depends
    local command
    # Extract the parts
    local idx := 1
    local cnt := $part_count(${value})
    local skw
    local end
    local lst
    while ${idx} <= ${cnt}
        # Get the CMake 'add_custom_command' sub-keyword and increment the index
        skw := ${value}<idx>
        inc idx
        # Gather the arguments
        end := $call(__pico_map_add_custom_command_get_part_midx__, ${value}, ${idx}, ${cnt})
        # Store the arguments to the appropriate variables
        sub lst, ${end}, 1
          if ${skw} &== 'DEPENDS'           ; depends := ${value}<idx:lst>
        elif ${skw} &== 'MAIN_DEPENDENCY'   ; depends := ${value}<idx:lst>
        elif ${skw} &== 'COMMAND'           ; command := ${value}<idx:lst>
        elif ${skw} &== 'WORKING_DIRECTORY' ; # Ignore this sub-keyword
        elif ${skw} &== 'VERBATIM'          ; # Ignore this sub-keyword
        else                                ; $call(__exit_error_ni_cmake_eval__, :"add_custom_command(... ${skw} ...)")
        endif
        # Update the index
        idx := ${end}
    endwhile
    # Store the dependency as needed
    if $part_count(${depends}) : $call(__pico_map_add_dependency__, ${mh}, ${name}, ${depends})
    # Store the command as needed
    if $part_count(${command}) : $map_put( ${mh}, $call(__pico_kn_custom_command__, ${name}), ${command}, false )
endfunction

function __pico_map_add_include__(mh, name, self, user, value)
    value := $call(__pico_map_resolve_rel_path__, ${value})
    if ${self} : $map_add( ${mh}, $call(__pico_kn_include_self__, ${name}), ${value} )
    if ${user} : $map_add( ${mh}, $call(__pico_kn_include_user__, ${name}), ${value} )
endfunction

function __pico_map_add_source__(mh, name, self, user, value)
    value := $call(__pico_map_resolve_rel_path__, ${value})
    if ${self} : $map_add( ${mh}, $call(__pico_kn_source_self__ , ${name}), ${value} )
    if ${user} : $map_add( ${mh}, $call(__pico_kn_source_user__ , ${name}), ${value} )
endfunction

function __pico_map_add_compile_def__(mh, name, self, user, value)
    if ${value} &== '-DPICO_CXX_ENABLE_EXCEPTIONS=1' : return # NOTE : JxMake always disables exception!
    if ${value} &== '-DCYW43_USE_HEX_BTFW=1'         : return # NOTE : JxMake always disables this test feature!
    if ${self} : $map_add( ${mh}, $call(__pico_kn_compile_def_self__ , ${name}), ${value} )
    if ${user} : $map_add( ${mh}, $call(__pico_kn_compile_def_user__ , ${name}), ${value} )
endfunction

function __pico_map_add_link_option__(mh, name, self, user, value)
    if ${self} : $map_add( ${mh}, $call(__pico_kn_link_option_self__ , ${name}), ${value} )
    if ${user} : $map_add( ${mh}, $call(__pico_kn_link_option_user__ , ${name}), ${value} )
endfunction

function __pico_map_add_link_library__(mh, name, self, user, value)
    if ${self} : $map_add( ${mh}, $call(__pico_kn_link_library_self__, ${name}), ${value} )
    if ${user} : $map_add( ${mh}, $call(__pico_kn_link_library_user__, ${name}), ${value} )
endfunction

function __pico_get_lib_spec_get_function_name_for_entry__(content, entry)
    # Get part of the content that contains the entry
    content := $substr  ( ${content}, 1                                   , $str_fidx(${content}, ${entry}) )
    content := $substr  ( ${content}, $str_lidx(${content}, 'endfunction'), -1                              )
    # Find and extract the function declaration
    content := $re_split( ${content}, '(?m)\bfunction\\s*\\(\\s*([^()]+)\\s*\\)*?' )
    content := $sfspaces( ${content}<-1>                                           )
    # Return the function name
    return ${content}<1>
endfunction

function __pico_get_lib_spec_evaluate_function_declaration_extract_parameters__(ignVals, entry)
    local Parts := $sfspaces(${entry})
    local Name  := ${Parts}<1>
    return {{ $series( ${Name}, '$', $partnm(${Parts}, 2, -1) ), ${ignVals} }}
endfunction

function __pico_get_lib_spec_evaluate_list_directive__(mh, curFName, ignVals, entry, path)
    # Extract the arguments
    local Parts   := $sfspaces(${entry})
    local Oper    := ${Parts}<1>
    local SetName := ${Parts}<2>
    local Action  := ${Parts}<3>
    local RepStr  := $flatten( $partnm(${Parts}, 4, -1) )
    # Simply exit if the set name on the common ignore list
    if $contains(${Pico_ComIgnList}, ${SetName}) : return
    # Simply exit if the set name on the given ignore list
    if &${curFName}
        if $contains(${ignVals}, :"${curFName}\$${SetName}") : return
    else
        if $contains(${ignVals},                ${SetName} ) : return
    endif
    # Get the set values
    SetName := :"\${${SetName}}"
    if !$map_num_vals(${mh}, ${SetName}) : $call(__exit_error_nd_cmake_list__, ${SetName}, ${path})
    local Values := $map_get(${mh}, ${SetName})
    # Process the set values
    if ${Oper} &== 'TRANSFORM'
          if ${Action} &== 'APPEND'  ; Values := $series(${Values}, ${RepStr})
        elif ${Action} &== 'PREPEND' ; Values := $series(${RepStr}, ${Values})
        else                         ; $call(__exit_error_ni_cmake_eval__, :"list(${Oper} ... ${Action} ...)")
        endif
    else
        $call(__exit_error_ni_cmake_eval__, :"list(${Oper} ...)")
    endif
    # Put the updated set values
    $map_put(${mh}, ${SetName}, ${Values})
endfunction

(*
function __pico_get_lib_spec_resolve_empty_source__(mh, type)
    ##### If a library has an empty ':source:type' try to fill it with the values from from the
    ##### referenced ':link_library:type' and remove the matching entries from the ':link_library:type'
    local LibNames := $map_get(${mh}, '__LibraryNames__')
    loop
        # Loop through the library names
        foreach local LibName in ${LibNames}
            # Skip if it as a non-empty ':source:type'
            if $map_num_vals( ${mh}, $call(:"__pico_kn_source_${type}__", ${LibName}) ) : continue
            # Loop through the referenced ':link_library:type'
            local LinkLibs  := $map_get( ${mh}, $call(:"__pico_kn_link_library_${type}__", ${LibName}) )
            local EraseLibs := ''
            foreach local LinkLib in ${LinkLibs}
                # Skip if the referenced library name is not inside the same map
                if !$contains(${LibNames}, ${LinkLib}) : continue
                # Get the ':source:type' from the referenced library and skip if it is empty
                local Srcs := $map_get( ${mh}, $call(:"__pico_kn_source_${type}__", ${LinkLib}) )
                if !$part_count(${Srcs}) : continue
                # Put the ':source:type' from the referenced library
                $map_add( ${mh}, $call(:"__pico_kn_source_${type}__", ${LibName} ), ${Srcs} )
                # Add the referenced library name to the removal list
                EraseLibs +:= ${LinkLib}
            endforeach
            # Remove entries for ':link_library:type'
            LinkLibs := $erase_if(${LinkLibs}, ${EraseLibs})
            # Update or remove the ':link_library:type'
            if $part_count(${LinkLibs}) ; $map_put   ( ${mh}, $call(:"__pico_kn_link_library_${type}__", ${LibName}), ${LinkLibs} )
            else                        ; $map_remove( ${mh}, $call(:"__pico_kn_link_library_${type}__", ${LibName})              )
            endif
        endforeach
        # Check if there are more empty ':source:type'
        local Done := true
        foreach local LibName in ${LibNames}
            # Skip if it as a non-empty ':source:type'
            if $map_num_vals( ${mh}, $call(:"__pico_kn_source_${type}__", ${LibName} ) ) : continue
            # Get the referenced ':link_library:type'
            local LinkLibs := $map_get( ${mh}, $call(:"__pico_kn_link_library_${type}__", ${LibName}) )
            # Check if they are inside the same map
            local RmdrLibs := $erase_ifnot(${LinkLibs}, ${LibNames})
            if $part_count(${RmdrLibs})
                local AllEmpty := true
                foreach local RmdrLib in ${RmdrLibs}
                    if $map_num_vals( ${mh}, $call(:"__pico_kn_source_${type}__", ${RmdrLib} ) )
                        AllEmpty := false
                        break
                    endif
                endforeach
                Done := ${AllEmpty}
                break
            endif
        endforeach
        if ${Done} : break
    endloop
endfunction
#*)

function __pico_get_lib_spec_impl__(cmlc)
    # Extract the data
    local Name    := ${cmlc}<1>
    local Path    := ${cmlc}<2>
    local Content := ${cmlc}<3>
    local Type
    local Skip
    local USelf
    local UUser
    local IgnVals
    local ProcRes
    local FName
    local LinkOpt
    # Create a new map for storing the set values and the library specifications
    local mhSetVal := $map_new()
    local mhLibSpc := $map_new()
    # Store the name and path
    $map_add(${mhLibSpc}, '__Name__', ${Name})
    $map_add(${mhLibSpc}, '__Path__', ${Path})
    # Get the common (root) include directory
    local IncDir := $cat_path(${Path}, 'include')
    if !$valid_path(${IncDir}) : unset IncDir
    # Process function declarations
    ProcRes := $re_split(${Content}, '(?m)\bfunction\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        IgnVals := $call(__pico_get_lib_spec_evaluate_function_declaration_extract_parameters__, ${IgnVals}, ${Entry})
    endforeach
    # Process set directives
    ProcRes := $re_split(${Content}, '(?m)\bset\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the set values
        .$__pico_cmlc__extract_parts__libname__store__set__
    endforeach
    # Process list directives
    ProcRes := $re_split(${Content}, '(?m)\blist\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Get the enclosing function name for this entry
        FName := $call(__pico_get_lib_spec_get_function_name_for_entry__, ${Content}, ${Entry})
        # Evaluate the directive
        $call( __pico_get_lib_spec_evaluate_list_directive__, ${mhSetVal}, ${FName}, ${IgnVals}, ${Entry}, ${Path} )
    endforeach
    # Process an add subdirectory directive
    ProcRes := $re_split(${Content}, '(?m)\b(?:pico_)?add_subdirectory\\s*\\(\\s*([^()]+)\\s*\\)')
    if &${ProcRes}
        $map_add(${mhLibSpc}, '__Subdirectories__', $partn( $sfspaces(${ProcRes}), 1 ) )
    endif
    # Process a simple header-only hardware target directive
    ProcRes := $re_split(${Content}, '(?m)\bpico_simple_hardware_headers_only_target\\s*\\(\\s*([^()]+)\\s*\\)')
    if &${ProcRes}
        # Store the library name and include path
        .$__pico_cmlc__set__default_libname_itype__
        .$__pico_cmlc__store__libname_incpath__
    endif
    # Process a simple hardware target directive
    ProcRes := $re_split(${Content}, '(?m)\bpico_simple_hardware_target\\s*\\(\\s*([^()]+)\\s*\\)')
    if &${ProcRes}
        # Store the library name and include path
        .$__pico_cmlc__set__default_libname_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the source file
        local SrcFile := $cat_path( ${Path}, :"${ProcRes}.c" )
        if $valid_path(${SrcFile}) : $call(__pico_map_add_source__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, ${SrcFile})
    endif
    # Process add custom target directives
    ProcRes := $re_split(${Content}, '(?m)\badd_custom_target\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts
        .$__pico_cmlc__extract_parts__ctname_depname__
        # Store the directive
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        $call( __pico_map_add_custom_target__, ${mhLibSpc}, ${Name}, $call(__pico_cmlv_eval_parts__exclude_2__, ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Process add custom command directives
    ProcRes := $re_split(${Content}, '(?m)\badd_custom_command\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts
        .$__pico_cmlc__extract_parts__ccmd_ctname__
        # Store the directive
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        $call( __pico_map_add_custom_command__, ${mhLibSpc}, ${Name}, $call(__pico_cmlv_eval_parts__exclude_2__, ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Process add dependencies directives
    ProcRes := $re_split(${Content}, '(?m)\badd_dependencies\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname__
        .$__pico_cmlc__store__libname_incpath__
        # Store the dependencies
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        $call( __pico_map_add_dependency__, ${mhLibSpc}, ${Name}, $call(__pico_cmlv_eval_parts__exclude_1__, ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Process add library directives
    ProcRes := $re_split(${Content}, '(?m)\badd_library\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname_itype__
        .$__pico_cmlc__store__libname_incpath__
    endforeach
    # Get the include files
    ProcRes := $re_split(${Content}, '(?m)\btarget_include_directories\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the include files
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        if ${FName} &== 'pico_btstack_make_gatt_header'
            if ${Type} &== '${TARGET_TYPE}' : continue
        endif
        $call( __pico_map_add_include__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, $call(:"__pico_cmlv_eval_parts__exclude_${Skip}__", ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Get the source files
    ProcRes := $re_split(${Content}, '(?m)\btarget_sources\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the source files
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        $call( __pico_map_add_source__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, $call(:"__pico_cmlv_eval_parts__exclude_${Skip}__", ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Process define boot-stage-2 directives and add the contents as source files
    ProcRes := $re_split(${Content}, '(?m)\bpico_define_boot_stage2\\s*\\(\\s*([^()]+)\\s*\\)')
    foreach local Entry in ${ProcRes}
        # Extract the parts
        .$__pico_cmlc__extract_parts__libname__
        # Skip if the name is a variable
        if $str_begwith(${Name}, '$') : continue
        # Store the directive
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        $call( __pico_map_add_source__, ${mhLibSpc}, ${Name}, true, false, $call(__pico_cmlv_eval_parts__exclude_1__, ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Get the compile definitions
    ProcRes := $re_split(${Content}, '(?m)\btarget_compile_definitions\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the compile definitions
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        __disable__pico_cmlv_eval_remove_dqs_ts__ := true
        foreach CDef in $call(:"__pico_cmlv_eval_parts__exclude_${Skip}__", ${Parts}, ${mhSetVal}, ${FName}, ${Path})
            if $str_fidx(${CDef}, '-D') <= 0 : CDef := :"-D${CDef}"
            $call(__pico_map_add_compile_def__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, ${CDef})
        endforeach
        __disable__pico_cmlv_eval_remove_dqs_ts__ := false
    endforeach
    # Get the linked libraries
    ProcRes := $re_split(${Content}, '(?m)\b(?:pico_mirrored_)?target_link_libraries\\s*\\(\\s*([^()]+)\\s*\\)*?')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the linked libraries
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        $call( __pico_map_add_link_library__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, $call(:"__pico_cmlv_eval_parts__exclude_${Skip}__", ${Parts}, ${mhSetVal}, ${FName}, ${Path}) )
    endforeach
    # Get the link options via the standard method
    ProcRes := $re_split(${Content}, '(?m)\btarget_link_options\\s*\\(\\s*([^()]+)\\s*\\)')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the link options
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        LinkOpt := $call(:"__pico_cmlv_eval_parts__exclude_${Skip}__", ${Parts}, ${mhSetVal}, ${FName}, ${Path})
       #LinkOpt := $erase_ifempty( ${LinkOpt/LINKER:(.*)/$1/} )
       #LinkOpt := $erase_if     ( $series('LINKER:', ${LinkOpt}), 'LINKER:' )
        $call(__pico_map_add_link_option__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, ${LinkOpt})
    endforeach
    # Get the link options via 'pico_wrap_function'
    ProcRes := $re_split(${Content}, '(?m)\bpico_wrap_function\\s*\\(\\s*([^()]+)\\s*\\)')
    foreach local Entry in ${ProcRes}
        # Extract the parts then store the library name and include path
        .$__pico_cmlc__extract_parts__libname__default_itype__
        .$__pico_cmlc__store__libname_incpath__
        # Store the link options
        # NOTE : The enclosing function name for this entry has already been obtained by the '__pico_cmlc__extract_parts__*__' above
        LinkOpt := $call(__pico_cmlv_eval_parts__exclude_1__, ${Parts}, ${mhSetVal}, ${FName}, ${Path})
        LinkOpt := $series('LINKER:--wrap=', ${LinkOpt})
        $call(__pico_map_add_link_option__, ${mhLibSpc}, ${Name}, ${USelf}, ${UUser}, ${LinkOpt})
    endforeach
    (*
    ##### If a library has an empty ':source:self|user' try to fill it with the values from from the
    ##### referenced ':link_library:self|user' and remove the matching entries from the ':link_library:self|user'
    ##### !!! TODO : These two lines are not actually needed and will even cause errors !!! #####
    $call(__pico_get_lib_spec_resolve_empty_source__, ${mhLibSpc}, 'self')
    $call(__pico_get_lib_spec_resolve_empty_source__, ${mhLibSpc}, 'user')
    #*)
    # Delete the map for storing the set values
    $map_delete(${mhSetVal})
    # Return the map handle for the library specifications
    return ${mhLibSpc}
endfunction

function __pico_get_lib_spec__(cmlc)
    # Check for empty content
    if !&${cmlc} : return
    # Get the library specifications
    local mhLibSpc := $call(__pico_get_lib_spec_impl__, ${cmlc})
    # Get the name, path, and subdirectories
    local Name    := $map_get(${mhLibSpc}, '__Name__'          )
    local Path    := $map_get(${mhLibSpc}, '__Path__'          )
    local SubDirs := $map_get(${mhLibSpc}, '__Subdirectories__')
    # Remove the name, path, and subdirectories
    $map_remove(${mhLibSpc}, '__Name__'          )
    $map_remove(${mhLibSpc}, '__Path__'          )
    $map_remove(${mhLibSpc}, '__Subdirectories__')
    # Process the subdirectories
    foreach local SubDir in ${SubDirs}
        local SName := :"${Name}/${SubDir}"
        local SPath := :"${Path}/${SubDir}"
        mhLibSpc := $map_new_from( {{ ${mhLibSpc}, $call( __pico_get_lib_spec__, $call(__pico_get_cmlc__, ${SName}, ${SPath}) ) }}, true, false )
    endforeach
    # Process merged-key-names
    local AllKeys := $map_keys(${mhLibSpc})
    local RemKeys
    foreach local Key in ${AllKeys}
        # Skip if this key has no merged-key-name at all
        if $str_fidx(${Key}, ${Pico_AVal_Prefix}   ) <= 0 : continue
        if $str_fidx(${Key}, ${Pico_AVal_Separator}) <= 0 : continue
        # Get the pattern, subkeys, and values
        local PKeyPat := $re_replace(${Key}, :"(.+?)\\${Pico_AVal_Prefix}(.+?)\\((?:.+?)\\)(.+)", '$1$2\\$\{\\}$3')
        local SubKeys := $explode(${Key/.+?\((.+?)\).+/$1/}, ${Pico_AVal_Separator})
        local Values  := $map_get(${mhLibSpc}, ${Key})
        # Add the subkeys
        foreach local SubKey in ${SubKeys}
            $map_add( ${mhLibSpc}, $re_replace(${PKeyPat}, '\\$\\{\\}', ${SubKey}), ${Values} )
        endforeach
        # Remove the original merged-key-name
        $map_remove(${mhLibSpc}, ${Key})
        # Add the key to the list of keys to be removed
        RemKeys +:= ${Key/(?:.*?)\{(.+)\}(?:.+)/$1/}
    endforeach
    #(there is no need to remove this key from  as well)
    $map_put( ${mhLibSpc}, '__LibraryNames__', $erase_if( $map_get(${mhLibSpc}, '__LibraryNames__'), $unique(${RemKeys}) ) )
    # Return the map handle
    return ${mhLibSpc}
endfunction

.undefmacro __pico_cmlc__set__default_libname_itype__
.undefmacro __pico_cmlc__extract_parts__common_prefix_code__
.undefmacro __pico_cmlc__extract_parts__ctname_depname__
.undefmacro __pico_cmlc__extract_parts__ccmd_ctname__
.undefmacro __pico_cmlc__extract_parts__libname__
.undefmacro __pico_cmlc__extract_parts__libname__default_itype__
.undefmacro __pico_cmlc__extract_parts__libname_itype__
.undefmacro __pico_cmlc__extract_parts__libname__store__set__
.undefmacro __pico_cmlc__store__libname_incpath__

function __pico_get_lib_specs__(rootPath)
    # Create a new map for storing the combined library specifications
    local mhLibSpc
    # Process the subdirectories
    foreach local SubDir in $lsdir( $cat_paths(${PICO_SDK_PATH}, ${rootPath}), 'd' )
        # Get the library specifications
        local lh := $call( __pico_get_lib_spec__, $call( :"__pico_get_cmlc__${rootPath/\//_/}__", $path_last_part(${SubDir}) ) )
        # Combine the maps
        mhLibSpc := $map_new_from({{ ${mhLibSpc}, ${lh} }}, true, false)
    endforeach
    # Return the map handle
    return ${mhLibSpc}
endfunction

function __pico_get_lib_specx__(cmlcGetFunc)
    return $call( __pico_get_lib_spec__, $call(:"__pico_get_cmlc__${cmlcGetFunc}__") )
endfunction

function pico_get_lib_specs()
    # A map handle for the specifications
    local mhLibSpc
    # Try to get the specifications from the cache file first
    (*
     * #####
     * ??? TODO : Which one is better to use: ???
     *                $uptodate_path(${Pico_LibSpecsCacheFilePath})
     *                $newer_path(${Pico_LibSpecsCacheFilePath}, ${PICO_SDK_PATH})
     * #####
     *)
   #$rmfile(${Pico_LibSpecsCacheFilePath})
   #if $uptodate_path(${Pico_LibSpecsCacheFilePath})
    if $newer_path(${Pico_LibSpecsCacheFilePath}, ${PICO_SDK_PATH})
        # Read the specifications
        mhLibSpc := $map_from_edata( $get_file(${Pico_LibSpecsCacheFilePath}) )
    # Parse the specifications
    else
        # Parse the specifications
        mhLibSpc := $map_new_from( {{ ${mhLibSpc}, $call(__pico_get_lib_specs__, 'src/common'    ) }}, true, false )
        mhLibSpc := $map_new_from( {{ ${mhLibSpc}, $call(__pico_get_lib_specs__, 'src/rp2_common') }}, true, false )
        mhLibSpc := $map_new_from( {{ ${mhLibSpc}, $call(__pico_get_lib_specs__, 'src/rp2040'    ) }}, true, false )
        mhLibSpc := $map_new_from( {{ ${mhLibSpc}, $call(__pico_get_lib_specx__, lib_tinyusb     ) }}, true, false )
        # Save the specifications to the cache file
        $put_file( ${Pico_LibSpecsCacheFilePath}, $map_to_edata(${mhLibSpc}) )
    endif
    # Return the map handle
    return ${mhLibSpc}
endfunction


