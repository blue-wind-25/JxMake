##### Update the flags
const __BuildTool_Name__   := 'ARM None EABI (STM32) GNU Compiler Collection (GCC)'
const __BuildTool_Target__ := 'ARM None EABI (STM32)'
const __BuildTool_Title__  := 'ARM None EABI (STM32) C/C++'


##### Determine some settings
STM32_SDK_PATH       ?:= $getenv('STM32_SDK_PATH'      , '')
STM32_TOOLCHAIN_PATH ?:= $getenv('STM32_TOOLCHAIN_PATH', '')


##### Update the definitions of executables, paths, and options
const STM32_ProjectPackageDir    := '__package__'

const __Def_STM32_FLASH_OFFSET__ :=        0
const __Def_STM32_HSE_VALUE__    := 25000000
const __Def_STM32_LSE_VALUE__    :=    32768

      STM32_CommonCPUOptions      = ${__STM32_CPU__} '-mlittle-endian' '-mthumb' ${__STM32_FPU__}  ${__STM32_FLOAT_ABI__}
      STM32_CommonCompileOptions  = '-ffunction-sections' '-fdata-sections' '--param' 'max-inline-insns-single=500'
      STM32_CommonCompileMDef     = ${__STM32_CMDEF_DEVICE__} ${__STM32_CMDEF_FAMILY__} ${__STM32_CMDEF_HSE_VALUE__} ${__STM32_CMDEF_LSE_VALUE__}
      STM32_CommonCompileMDef    += ${__STM32_USBDRIVER__} '-DUSE_HAL_DRIVER'
      #-fsingle-precision-constant

      CppCommonAssemblerFlags    += ${__STM32_CINCDIR__} ${STM32_CommonCPUOptions} ${STM32_CommonCompileOptions}

      CppCommonCcCompileFlags    += ${__STM32_CINCDIR__} ${STM32_CommonCPUOptions} ${STM32_CommonCompileOptions} ${STM32_CommonCompileMDef}

      CppCommonCxxCompileFlags   += ${__STM32_CINCDIR__} ${STM32_CommonCPUOptions} ${STM32_CommonCompileOptions} ${STM32_CommonCompileMDef}
      CppCommonCxxCompileFlags  :+= ${CppMinimizeSizeCompileFlags} '-fno-threadsafe-statics'

      CppCommonLinkFlags         += ${__STM32_CLIBDIR__} ${STM32_CommonCPUOptions}
      CppCommonLinkFlags         += ${__STM32_WLSYM_FLASH_OFFSET__} ${__STM32_WLSYM_MAX_SIZE__} ${__STM32_WLSYM_MAX_DATA_SIZE__}
      CppCommonLinkFlags        :+= '-Wl,--check-sections' '-Wl,--gc-sections'
      CppCommonLinkFlags        :+= '-Wl,--unresolved-symbols=report-all' '-Wl,--warn-common'
      CppCommonLinkFlags        :+= '-Wl,--entry=Reset_Handler' :"-Wl,-T${STM32_ProjectPackageDir}/ldscript.ld"
      CppCommonLinkFlags        :+= '-specs=nosys.specs'

      DebuggerProgram            := ${ARMDebugger}


##### Define some STM32-specific tools
STM32ObjCopy         := ${ARMObjCopy}
STM32ObjCopyE2BFlags := ${ARMObjCopyE2BFlags}
STM32ObjCopyE2HFlags := ${ARMObjCopyE2HFlags}

STM32Size            := ${ARMSize}
STM32SizeFlags       := ${ARMSizeDefFlags}


###################################################################################
##### =================== Native STM32 Detection Functions ================== #####
###################################################################################

##### Functions to decode STM32 part numbers
function __stm32_get_chip_spec_fse__(id)
    # Include the chip specification list
    :::include_once 'C++XBuildTool_STM32_Cube_CS.jxm'
    # Search the specification list
    foreach local I, V in ${STM32DecData} step ${STM32DecDataUnit}
        # Get the the reference ID
        local RefID := $partn(${STM32DecData}, ${I}, 0)
        # Check if the IDs match
        if ${RefID} &== ${id}
            local FlashSize  := $partn(${STM32DecData}, ${I}, 1)
            local SRAMSize   := $partn(${STM32DecData}, ${I}, 2)
            local EEPROMSize := $partn(${STM32DecData}, ${I}, 3)
            return { ${FlashSize} ${SRAMSize} ${EEPROMSize} }
        endif
    endforeach
    # The ID was not found in the list
    return { 0 0 0 }
endfunction

function __stm32_decode_flash_code_to_size__(code, ?inKB)
    local FZ := 0
      if ${code} &== '3' ; FZ :=    8
    elif ${code} &== '4' ; FZ :=   16
    elif ${code} &== '6' ; FZ :=   32
    elif ${code} &== '8' ; FZ :=   64
    elif ${code} &== 'B' ; FZ :=  128
    elif ${code} &== 'Z' ; FZ :=  192
    elif ${code} &== 'C' ; FZ :=  256
    elif ${code} &== 'D' ; FZ :=  384
    elif ${code} &== 'E' ; FZ :=  512
    elif ${code} &== 'F' ; FZ :=  768
    elif ${code} &== 'G' ; FZ := 1024
    elif ${code} &== 'H' ; FZ := 1536
    elif ${code} &== 'I' ; FZ := 2048
    endif
    if !${inKB} : mul FZ, ${FZ}, 1024
    return ${FZ}
endfunction

function __stm32_decode_device_family_number__(familyNumber)
    # Extract the parts
    #     https://en.m.wikipedia.org/wiki/STM32#Part_number_decoding
    #     https://stm32-base.org/cheatsheets/device-name-mapping.html
    #     https://www.digikey.com/en/maker/blogs/2020/understanding-stm32-naming-conventions
    local Part  := $ucase(${familyNumber})
          Part  := ${Part/(?:STM32)([CFGHLU]|MP|W(?:BA?|L)?)(\d)((?<=L4)[PQRS])?([0-9A-F]+)(?:[A-Z])?([3468B-IZ])(?:-([A-Z]))?(?:.*)/$1$3$6|$2|$4|$5/}
          Part  := $sfpipes(${Part})
    local Type  := ${Part}<1>
    local Core  := ${Part}<2>
    local Line  := ${Part}<3>
    local Flash := ${Part}<4>
    # Return the results
    return { ${Type} ${Core} ${Line} ${Flash} }
endfunction

function __stm32_decode_device_part_number__(partNumber)
    local Part := ${partNumber}
    if !$str_begwith(${Part}, 'STM32MP')
          # Extract the parts
          #     https://en.m.wikipedia.org/wiki/STM32#Part_number_decoding
          #     https://stm32-base.org/cheatsheets/device-name-mapping.html
          #     https://www.digikey.com/en/maker/blogs/2020/understanding-stm32-naming-conventions
          Part   := ${Part/(?:STM32)([CFGHLU]|W(?:BA?|L)?)(\d)((?<=L4)[PQRS])?([0-9A-F][0-9]?)([A-CF-KMNQRT-VZ])([3468B-IZ])([PHUTY])?([67])?(?:-([A-Z]))?(?:.*)/$1$3$9|$2|$4|$5|$6|$7|$8/}
    else
          # The MP1 series does not have internal flash
          #     https://www.st.com/en/microcontrollers-microprocessors/stm32mp1-series/products.html
          Part   := ${Part/(?:STM32)(MP)(\d)([0-9A-F][0-9]?)([ACDF])(?:A([A-G]))?([137])?(?:.*)/$1|$2|$3|$5|-1|$5|$6|$4/}
    endif
          Part   := $sfpipes(${Part})
    local Type   := ${Part}<1>
    local Core   := ${Part}<2>
    local Line   := ${Part}<3>
    local PinCnt := ${Part}<4>
    local Flash  := ${Part}<5>
   #local PType  := ${Part}<6>
   #local TRange := ${Part}<7>
   #local SecOpt := ${Part}<8>
    # Get the specification
    local Spec  := $call( __stm32_get_chip_spec_fse__, $flatten( { ${Type} ${Core} ${Line} ${Flash} } ) )
    # Convert flash-size code to flash size
    local FlashSize := -1
    if ${Flash} &!= -1 : FlashSize := $call(__stm32_decode_flash_code_to_size__, ${Flash})
    # Check the result (error if the flash size is zero or does not match the one in the specification list)
    if !${FlashSize}               : $call(__exit_error_ns_desc__, 'decoding chip specification for part number', ${partNumber})
    if  ${FlashSize} != ${Spec}<1> : $call(__exit_error_ni_desc__, 'decoding chip specification for part number', ${partNumber})
    # Return the results
    return {{                           \
        ${Type}     ,                   \
        ${Core}     ,                   \
        ${Line}     ,                   \
        ${Flash}    , (* Flash  Code *) \
        ${FlashSize}, (* Flash  Size *) \
        ${Spec}<2>  , (* SRAM   Size *) \
        ${Spec}<3>  , (* EEPROM Size *) \
        ${PinCnt}                       \
    }}
endfunction

function __stm32_tccode_to_cpu__(tccode)
    local CPU := ''
      if ${tccode} &== 'C0'  ; CPU := 'cortex-m0plus'
    elif ${tccode} &== 'F0'  ; CPU := 'cortex-m0'
    elif ${tccode} &== 'F1'  ; CPU := 'cortex-m3'
    elif ${tccode} &== 'F2'  ; CPU := 'cortex-m3'
    elif ${tccode} &== 'F3'  ; CPU := 'cortex-m4'
    elif ${tccode} &== 'F4'  ; CPU := 'cortex-m4'
    elif ${tccode} &== 'F7'  ; CPU := 'cortex-m7'
    elif ${tccode} &== 'G0'  ; CPU := 'cortex-m0plus'
    elif ${tccode} &== 'G4'  ; CPU := 'cortex-m4'
    elif ${tccode} &== 'H5'  ; CPU := 'cortex-m33'
    elif ${tccode} &== 'H7'  ; CPU := 'cortex-m7'
    elif ${tccode} &== 'L0'  ; CPU := 'cortex-m0plus'
    elif ${tccode} &== 'L1'  ; CPU := 'cortex-m3'
    elif ${tccode} &== 'L4'  ; CPU := 'cortex-m4'
    elif ${tccode} &== 'L5'  ; CPU := 'cortex-m33'
    elif ${tccode} &== 'MP1' ; CPU := 'cortex-a7'
    elif ${tccode} &== 'U5'  ; CPU := 'cortex-m33'
    elif ${tccode} &== 'WB'  ; CPU := 'cortex-m4'
    elif ${tccode} &== 'WBA' ; CPU := 'cortex-m33'
    elif ${tccode} &== 'WL'  ; CPU := 'cortex-m4'
    endif
    return ${CPU}
endfunction

function __stm32_tccode_to_co_cpu__(tccode, ?line)
    local CPU   := ''
          line ?:= ''
      if ${tccode} &== 'H7'  ; CPU :=                                    'cortex-m4'
    elif ${tccode} &== 'MP1' ; CPU := $csel( $str_begwith(${line}, '5'), 'cortex-m4'    , '' ) # The coprocessor is only available in the MP15x line.
    elif ${tccode} &== 'WB'  ; CPU :=                                    'cortex-m0plus'
    elif ${tccode} &== 'WL'  ; CPU :=                                    'cortex-m0plus'
    endif
    return ${CPU}
endfunction

function __stm32_tccode_to_fpu__(tccode)
    local FPU := ''
      if ${tccode} &== 'F3'  ; FPU := 'fpv4-sp-d16'
    elif ${tccode} &== 'F4'  ; FPU := 'fpv4-sp-d16'
    elif ${tccode} &== 'F7'  ; FPU := 'fpv5-sp-d16'
    elif ${tccode} &== 'G4'  ; FPU := 'fpv4-sp-d16'
    elif ${tccode} &== 'H5'  ; FPU := 'fpv5-sp-d16'
    elif ${tccode} &== 'H7'  ; FPU := 'fpv5-sp-d16'
    elif ${tccode} &== 'L4'  ; FPU := 'fpv4-sp-d16'
    elif ${tccode} &== 'L5'  ; FPU := 'fpv5-sp-d16'
    elif ${tccode} &== 'MP1' ; FPU := 'fpv4-sp-d16'
    elif ${tccode} &== 'U5'  ; FPU := 'fpv5-sp-d16'
    elif ${tccode} &== 'WB'  ; FPU := 'fpv4-sp-d16'
    elif ${tccode} &== 'WBA' ; FPU := 'fpv5-sp-d16'
    endif
    return ${FPU}
endfunction


##### Function to get the appropriate linker script URL from Arduino GitHUb for the given STM32 part number
function __stm32_get_chip_linker_script_url__(type, core, line, flash, pinCnt)
    # Include the linker script list
    :::include_once 'C++XBuildTool_STM32_Cube_LS.jxm'
    # Check for L4+ series
    local L4Plus   := $re_match(${type}, 'L[PQRS]')
    local TypeMain := $csel(${L4Plus}, 'L'                            , ${type})
    local CoreExt  := $csel(${L4Plus}, :"${core}${type/L([PQRS])/$1/}", ${core})
    # Filter by the type, core, line, and package pin count
    local FilterP := "${TypeMain}${CoreExt}${line}${pinCnt}"
    local FilterD := :".+?STM32${TypeMain}${core}xx/.*?${FilterP}.+?"
    local FList   := $erase_ifnot(${STM32LinkScripts}, ${FilterD}, true)
    # Filter by the flash-size code if there is more than one result
    local FLCount := $part_count(${FList})
    local FResult := ''
    if ${FLCount} > 1
        # Process the items
        local SIdx
        foreach local FItem in ${FList}
            # Process the parts
                FSIdx := $str_lidx(${FItem}, '/')
            inc FSIdx
           #echoln "    ${FItem}"
            foreach local FPart in $explode( $substr(${FItem}, ${FSIdx}, -1), '_' )
                # Check in case the flash-size code is attached directly to the part
                if $re_match(${FPart}, :"${FilterP}${flash}.*")
                    FResult := ${FItem}
                    break
                # Check in case the flash-size code is attached as alternatives to the part
                elif $str_fidx(${FPart}, '(') > 0
                    if $re_match(${FPart}, :"${FilterP}.*")
                        # Process flash-size codes
                        foreach local FC in $explode( ${FPart/.+?\((.+?)\).*/$1/}, '-' )
                            if ${FC} &== ${flash}
                                FResult := ${FItem}
                                break
                            endif
                        endforeach
                        # Break if a result has been found
                        if &${FResult} : break
                    endif
                endif
            endforeach
            # Break if a result has been found
            if &${FResult} : break
        endforeach
    # Otherwise, simply store the result
    elif ${FLCount}
        FResult := ${FList}
    endif
    # If nothing was found, use the default one
    if !&${FResult} : FResult := 'system'
    # Return the URL
    return :"https://raw.githubusercontent.com/stm32duino/Arduino_Core_STM32/main/${FResult}/ldscript.ld"
endfunction


###################################################################################
##### ==================== Native STM32 Utility Functions =================== #####
###################################################################################

##### Function to download the appropriate linker script from Arduino GitHUb for the given STM32 part number
const STM32_LDScripts_DirPath     := $cat_path( $jdd(), 'stm32ldscripts' )
const STM32_LDScripts_ChkInterval := ${JxMake_Download_ChkIntervalS}

function __stm32_download_chip_linker_script_by_url__(URL, ?onlyIfNotExist)
    # Determine the cache file path
    local OutName     := ${URL/:/__/}
          OutName     := ${OutName/\//_/}
    local OutPath     := $cat_path(${STM32_LDScripts_DirPath}, ${OutName})
    local OutPathETAG := :"${OutPath}.ETAG"
    local OutPathLCHK := :"${OutPath}.LAST_CHECKED"
    # Check if the linker script already exist
    local AlreadyExist := true
    if !$valid_path(${OutPath}    ) : AlreadyExist := false
    if !$valid_path(${OutPathETAG}) : AlreadyExist := false
    if !$valid_path(${OutPathLCHK}) : AlreadyExist := false
    if ${AlreadyExist}
        # If the 'onlyIfNotExist' flag is set, do no further checking
        if ${onlyIfNotExist} : return ${OutPath}
        # Check if the last checked time is still less than interval limit
        local LCh := $get_file(${OutPathLCHK})
        local CCh := $call(get_timestamp)
        eval  InR := @( ${CCh} - ${LCh} ) <= ${STM32_LDScripts_ChkInterval}
        if ${InR} : return ${OutPath}
    endif
    # Get the ETAG
    local Head := $lcase( $http_head(${URL}) )
   #$put_file( $cat_path( $ptd(), 'stm32.download.cls.head' ), ${Head} )
   #local Head := $get_file( $cat_path( $ptd(), 'stm32.download.cls.head' ) )
    local ETAG := $erase_ifnot(${Head}, '^etag=.+', true)
          ETAG := ${ETAG/(?:etag=")(.+)(?:")/$1/}
    # If the the linker script already exist, check if the ETAG matches
    if ${AlreadyExist}
        if ${ETAG} &== $get_file(${OutPathETAG})
            # Update the last checked time and exit
            $put_file( ${OutPathLCHK}, $call(get_timestamp) )
            return ${OutPath}
        endif
    endif
    # Make the directory in case it does not exist yet
    $mkdir(${STM32_LDScripts_DirPath})
    # Download and put the file
    $http_download(${URL}, ${STM32_LDScripts_DirPath}, ${OutName})
    # Put the ETAG
    $put_file(${OutPathETAG}, ${ETAG})
    # Put the last checked time
    $put_file( ${OutPathLCHK}, $call(get_timestamp) )
    # Return the linker script file path
    return ${OutPath}
endfunction

function __stm32_download_chip_linker_script_by_cs__(type, core, line, flash, pinCnt, ?onlyIfNotExist)
    # Get the URL
    local URL := $call(__stm32_get_chip_linker_script_url__, ${type}, ${core}, ${line}, ${flash}, ${pinCnt})
    # Download the linker script
    return $call(__stm32_download_chip_linker_script_by_url__, ${URL})
endfunction

