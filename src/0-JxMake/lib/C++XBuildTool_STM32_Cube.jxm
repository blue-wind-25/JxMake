##### Function to initialize the project build
function init_project(?buildSubdirectories, ?dlOnlyIfNotExist) supersede
    # Check the paths
    local pathError := false
    if $or( $cmp(${STM32_SDK_PATH}, '&==', ''), $not( $valid_path(${STM32_SDK_PATH}) ) )
        $call(__exit_error_nf__, 'STM32Cube SDK', true)
        echoln 'Please download and install the STM32Cube SDK from:'
        echoln '    https://www.st.com/en/development-tools/stm32cubemx.html#tools-software'
        echoln
        echoln 'Example (Linux):'
        echoln '    mkdir ~/stm32'
        echoln '    cd ~/stm32'
        echoln '    mkdir stm32-sdk'
        echoln '    cd stm32-sdk'
        echoln '    unzip en.stm32cubef4_v1-27-0.zip'
        echoln '    unzip en.patch-cubef4_v1-27-1.zip'
        echoln '    ...'
        echoln '    ... # Extract other STM32Cube packages as needed'
        echoln '    ...'
        echoln '    cd ..'
        echoln '    cd ..'
        echoln 'Set \'STM32_SDK_PATH\' to the STM32Cube SDK location.'
        echoln
        echoln 'It is also possible to get (some of) the STM32Cube SDK from GitHub:'
        echoln '    https://github.com/STM32-base/STM32-base-STM32Cube'
        echoln 'for example (Linux):'
        echoln '    mkdir ~/stm32'
        echoln '    cd ~/stm32'
        echoln '    mkdir stm32-sdk'
        echoln '    cd stm32-sdk'
        echoln '    git clone -b v1.27.1 https://github.com/STMicroelectronics/STM32CubeF4.git'
        echoln '    ...'
        echoln '    ... # Clone other STM32Cube SDK repository as needed'
        echoln '    ...'
        echoln '    cd ..'
        echoln '    cd ..'
        echoln
        pathError := true
    endif
    if $or( $cmp(${STM32_TOOLCHAIN_PATH}, '&==', ''), $not( $valid_path(${STM32_TOOLCHAIN_PATH}) ) )
        $call(__exit_error_nf__, 'STM32 Toolchain (GCC ARM None EABI)', true)
        $call(__armgcc_print_download_info__, 'STM32', 'stm32', 'STM32_TOOLCHAIN_PATH')
        pathError := true
    endif
    if ${pathError} : $exit(-1)
    # Download (and install) the latest and DFU-Util from SourceForge
    $call(download_latest_dfuutil, ${dlOnlyIfNotExist})
    # Download (and install) the latest and OpenOCD from xPack
    $call(download_latest_xpackopenocd_from_xpack, ${dlOnlyIfNotExist})
    # Set the location of the C/C++ binaries
    CppToolBinDir := $cat_path(${STM32_TOOLCHAIN_PATH}, 'bin')
    # Set additional LD paths as needed
    if !__os_windows__
        LDLibraryPath +:= $cat_path(${STM32_TOOLCHAIN_PATH}, 'lib'  )
        LDLibraryPath +:= $cat_path(${STM32_TOOLCHAIN_PATH}, 'lib64')
    endif
    # Set extra configuration information text
    if &${STM32_SDK_PATH}
        __BuildTool_ExtraInfoName__  +:= 'STM32 SDK       Directory'
        __BuildTool_ExtraInfoValue__ +:= ${STM32_SDK_PATH}
    endif
    if &${STM32_TOOLCHAIN_PATH}
        __BuildTool_ExtraInfoName__  +:= 'STM32 Toolchain Directory'
        __BuildTool_ExtraInfoValue__ +:= ${STM32_TOOLCHAIN_PATH}
    endif
    if &${CppToolBinDir}
        __BuildTool_ExtraInfoName__  +:= 'STM32 GCC       Directory'
        __BuildTool_ExtraInfoValue__ +:= ${CppToolBinDir}
    endif
    # Call the origin function
    ARM_TOOLCHAIN_PATH := ${__GTCP_NA__} # Inform the origin function that 'ARM_TOOLCHAIN_PATH' should not be used
    $call(__origin__, { ${buildSubdirectories} ${STM32_ProjectPackageDir} })
endfunction


##### Function to upload the given program via DFU
const __Def_STM32_VID__ := '0483'
const __Def_STM32_PID__ := 'df11'
const __Def_STM32_FAD__ := '0x08000000'
const __Def_STM32_MOD__ := 'leave'

function __stm32_upload_dfu_exec__(progName, vid, pid, flashAddress, modifiers, ldLibraryPath)
    # Prefer the statically linked DFU-Util if it is available
    local DFUUtil_util_static       := :"${DFUUtil_util}-static"
    local DFUUtil_util_static_found := $valid_path(${DFUUtil_util_static})
    local DFUUtil_prog              := $csel(${DFUUtil_util_static_found} , ${DFUUtil_util_static}, ${DFUUtil_util})
    # Determine the file paths
    local BinFile := ~${progName/(.+)\.elf/$1.bin/}
    local UplFile := ~${progName/(.+)\.elf/$1.raw/}
    local AddrCmd := $implode( $stack(${flashAddress}, ${modifiers}), ':' )
    # Copy the BIN file so we can add suffix later
    $cpfile(${BinFile}, ${UplFile}, true)
    # Perform upload
    if $and( $not(${DFUUtil_util_static_found}), $cmp(${ldLibraryPath}, '&!=', '') )
        +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
    endif
        +@${DFUUtil_suffix} -v ${vid} -p ${pid} -a ~${UplFile}
        +@${DFUUtil_prog} -i 0 -a 0 -s ${AddrCmd} -D ~${UplFile}
    $nop($[excode]) # Ensure all pending commands are executed
endfunction

function stm32_upload_dfu(progName, ?vid, ?pid, ?flashAddress, ?modifiers)
    # Set the default values
    vid          ?:= ${__Def_STM32_VID__}
    pid          ?:= ${__Def_STM32_PID__}
    flashAddress ?:= ${__Def_STM32_FAD__}
    modifiers    ?:= ${__Def_STM32_MOD__}
    # Perform upload
    $cmd_streaming_on()
    $exec( __stm32_upload_dfu_exec__, ${progName}, ${vid}, ${pid}, ${flashAddress}, ${modifiers}, $call(__ccat_LDLibraryPaths__, ${DFUUtil_dlib_dir}) )
    $cmd_streaming_off()
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    if __os_linux__
        if !$valid_path('/etc/udev/rules.d/40-dfuse.rules')
            # Based on 'https://github.com/wiieva/dfu-util/blob/master/doc/40-dfuse.rules'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
            echoln __c_white__ 'Either the target device is not connected or access is denied.' __c_reset__
            echoln
            echoln __c_white__ 'To fix access denied, please create a new \'udev\' rule in \'/etc/udev/rules.d/40-dfuse.rules\' as \'root\'' __c_reset__
            echoln __c_white__ '(or use \'sudo\') which contains:' __c_reset__
            echoln
           #echoln             '# Makes \'STM32 DfuSe\' device writeable for the \'plugdev\' group'
           #echoln             'SUBSYSTEM=="usb", ACTION=="add", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0664", GROUP="plugdev", TAG+="uaccess"'
            echoln             '# Makes \'STM32 DfuSe\' device writeable by all users'
            echoln             'SUBSYSTEM=="usb", ACTION=="add", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0666", TAG+="uaccess"'
            echoln
            echoln __c_white__ 'and then still as \'root\' (or use \'sudo\'), execute:' __c_reset__
            echoln
            echoln             'udevadm control --reload-rules && udevadm trigger'
            echoln
            echoln __c_white__ '---------------------------------------------------------------------------------------------------------' __c_reset__
            echoln
        endif
    endif
    # Exit program
    $exit($[excode])
endfunction


##### Define some default values for SWD
const STM32_SWD_Default_Interface    := 'stlink'
const STM32_SWD_Default_Transport    := 'hla_swd'
const STM32_SWD_Default_AdapterSpeed := 2000

const STM32_SWD_GDBPort              := ${OPENOCD_GDB_PORT}
const STM32_SWD_TCLPort              := ${OPENOCD_TCL_PORT}
const STM32_SWD_TelnetPort           := ${OPENOCD_TELNET_PORT}


##### Function to reset the MCU via SWD
function __stm32_check_swd_error_and_print_help__()
    # Simply exit if there was no error
    if !$[excode] : return
    # Print some helper information messages
    $call(__openocd_print_udev_rules__, ${XPackOOCD_udev_rule})
    # Exit program
    $exit($[excode])
endfunction

function stm32_reset_swd(?interface, ?transport, ?adapterSpeed, ?ignoreCPUID)
    # Set the default values
    interface    ?:= ${STM32_SWD_Default_Interface}
    transport    ?:= ${STM32_SWD_Default_Transport}
    adapterSpeed ?:= ${STM32_SWD_Default_AdapterSpeed}
    # Perform reset
    if ${ignoreCPUID} : local overrideCPUTapID := '0'
    $cmd_streaming_on()
    $call(                                                     \
        __armgcc_reset_swd__                                 , \
        $call(__ccat_LDLibraryPaths__, ${XPackOOCD_dlib_dir}), \
        ${XPackOOCD_openocd}                                 , \
        ${XPackOOCD_scripts_dir}                             , \
        ${interface}                                         , \
        ${transport}                                         , \
        ${adapterSpeed}                                      , \
        ${STM32_BASE_FNAME}                                  , \
        ${overrideCPUTapID}                                    \
    )
    $cmd_streaming_off()
    # Check for error
    $call(__stm32_check_swd_error_and_print_help__)
endfunction


##### Function to upload the given program via SWD
function stm32_upload_swd(progName, ?interface, ?transport, ?adapterSpeed, ?ignoreCPUID)
    # Set the default values
    interface    ?:= ${STM32_SWD_Default_Interface}
    transport    ?:= ${STM32_SWD_Default_Transport}
    adapterSpeed ?:= ${STM32_SWD_Default_AdapterSpeed}
    # Perform upload
    if ${ignoreCPUID} : local overrideCPUTapID := '0'
    $cmd_streaming_on()
    $call(                                                     \
        __armgcc_upload_swd_simple__                         , \
        $call(__ccat_LDLibraryPaths__, ${XPackOOCD_dlib_dir}), \
        ${XPackOOCD_openocd}                                 , \
        ${XPackOOCD_scripts_dir}                             , \
        ${interface}                                         , \
        ${transport}                                         , \
        ${adapterSpeed}                                      , \
        ${STM32_BASE_FNAME}                                  , \
        ${progName}                                          , \
        ${overrideCPUTapID}                                    \
    )
    $cmd_streaming_off()
    # Check for error
    $call(__stm32_check_swd_error_and_print_help__)
endfunction


##### Functions to debug the given program via SWD
function stm32_debug_swd_start(progName, ?interface, ?transport, ?adapterSpeed, ?noGDBExecCmd, ?ignoreCPUID)
    # Set the default values
    interface    ?:= ${STM32_SWD_Default_Interface}
    transport    ?:= ${STM32_SWD_Default_Transport}
    adapterSpeed ?:= ${STM32_SWD_Default_AdapterSpeed}
    # Print message about GDB as needed
    $call(__armgcc_debug_swd_start_print_gdb_info__, 'stm32_debug_swd_gdb', 'STM32', ${progName}, ${DebuggerProgram}, ${noGDBExecCmd})
    # Run OpenOCD in server mode
    if ${ignoreCPUID} : local overrideCPUTapID := '0'
    $cmd_streaming_on()
    $exec(                                                     \
        __armgcc_debug_swd_start_exec_openocd__,               \
        $call(__ccat_LDLibraryPaths__, ${XPackOOCD_dlib_dir}), \
        ${XPackOOCD_openocd}                                 , \
        ${XPackOOCD_scripts_dir}                             , \
        ${interface}                                         , \
        ${transport}                                         , \
        ${adapterSpeed}                                      , \
        ${STM32_BASE_FNAME}                                  , \
        ${STM32_SWD_GDBPort}                                 , \
        ${STM32_SWD_TCLPort}                                 , \
        ${STM32_SWD_TelnetPort}                              , \
        ${overrideCPUTapID}                                    \
    )
    $cmd_streaming_off()
    # Check for error
    $call(__stm32_check_swd_error_and_print_help__)
endfunction

function stm32_debug_swd_gdb(progName, ?autoConnect)
    # Set the default values
    autoConnect ?:= true
    # Execute GDB
    $sh_delay()
    $cmd_streaming_on()
    $exec(                             \
        __armgcc_debug_swd_gdb_exec__, \
        $call(__get_LDLibraryPaths__), \
        ${DebuggerProgram}           , \
        ${STM32_SWD_GDBPort}         , \
        ${progName}                  , \
        ${autoConnect}                 \
    )
    $cmd_streaming_off()
    $sh_restore()
    # Check for error
    $call(__conditional_print_stdxxx_and_check_excode__)
endfunction


###################################################################################
##### ===================== Native STM32 Build Functions ==================== #####
###################################################################################

##### Function to select the part number
function stm32cube_select_part(partNumber, ?usbDriver)
    # Convert the part number to uppercase
    partNumber := $ucase(${partNumber})
    # Save the selected part number
    STM32Cube_SelectedPartNumber := ${partNumber}
    # Try to get the initialization data from the cache file first
    local STM32CubePartInitDataCacheFilePath := $cat_path( $ptd(), :"STM32CubePartInitData.${STM32Cube_SelectedPartNumber}.cache" )
    if $uptodate_path(${STM32CubePartInitDataCacheFilePath})
        # Get the path to the latest directories
        local Lines := $get_file(${STM32CubePartInitDataCacheFilePath})
        # Get and split the lines
        STM32Cube_SDKRootDir              :=          ${Lines}< 1>
        STM32Cube_SDKRootDir_NLenOffset   :=          ${Lines}< 2>
        STM32Cube_SysLibDirs              := $sfpipes(${Lines}< 3>)
        STM32Cube_SysIncDirs              := $sfpipes(${Lines}< 4>)
        STM32Cube_SysSrcDir_CoreHAL       :=          ${Lines}< 5>
        STM32Cube_SysSrcDir_CoreHALLegacy :=          ${Lines}< 6>
        STM32Cube_SysSrcDir_USBCore       := $strim(  ${Lines}< 7>)
        STM32Cube_SysSrcDir_USBClass      := $strim(  ${Lines}< 8>)
        STM32CubeRef_PackageLicenseHTML   :=          ${Lines}< 9>
        STM32CubeRef_PackageLicenseMD     :=          ${Lines}<10>
        STM32CubeRef_LDScriptURL          :=          ${Lines}<11>
        STM32CubeRef_SysSrc_CMSISStartup  :=          ${Lines}<12>
        STM32CubeRef_SysSrc_CMSISSystem   :=          ${Lines}<13>
        STM32CubeRef_ProjectSubDir        :=          ${Lines}<14>
        STM32_CPU                         :=          ${Lines}<15>
        STM32_FPU                         :=          ${Lines}<16>
        STM32_FLOAT_ABI                   :=          ${Lines}<17>
        STM32_FLASH_OFFSET                :=          ${Lines}<18>
        STM32_FLASH_SIZE                  :=          ${Lines}<19>
        STM32_SRAM_SIZE                   :=          ${Lines}<20>
        STM32_DEVICE                      :=          ${Lines}<21>
        STM32_FAMILY                      :=          ${Lines}<22>
        STM32_FAMILY_XX                   :=          ${Lines}<23>
        STM32_HSE_VALUE                   :=          ${Lines}<24>
        STM32_LSE_VALUE                   :=          ${Lines}<25>
        STM32_BASE_FNAME                  :=          ${Lines}<26>
    # Determine the initialization data
    else
        # Decode the device part number
        local Res        := $call(__stm32_decode_device_part_number__, ${STM32Cube_SelectedPartNumber})
        local Type       := ${Res}<1>
        local Core       := ${Res}<2>
        local Line       := ${Res}<3>
        local FlashCode  := ${Res}<4>
        local FlashSize  := ${Res}<5>
        local SRAMSize   := ${Res}<6>
        local EEPROMSize := ${Res}<7>
        local PinCnt     := ${Res}<8>
        # Check for L4+ series
        local L4Plus   := $re_match(${Type}, 'L[PQRS]')
        local TypeMain := $csel(${L4Plus}, 'L'                            , ${Type})
        local CoreExt  := $csel(${L4Plus}, :"${Core}${Type/L([PQRS])/$1/}", ${Core})
        # Set the derivative values
        local TypeCore   := :"${Type}${Core}"
        local LType      := $lcase(${Type}     )
        local LTypeMain  := $lcase(${TypeMain} )
        local LCore      := $lcase(${Core}     )
        local LCoreExt   := $lcase(${CoreExt}  )
        local LLine      := $lcase(${Line}     )
        local LFlashCode := $lcase(${FlashCode})
        # Find the appropriate STM32Cube SDK directory
        local SDirs := $lsdir(${STM32_SDK_PATH}, 'd')
              SDirs := $sort_descending( $erase_ifnot(${SDirs}, :".*?STM32Cube(?:_FW_)?${TypeMain}${Core}.*", true) )
        local PVer  := 0
        local PDir
        foreach local SDir in ${SDirs}
            # Extract the version numbers
            local Parts := $get_file(:"${SDir}/package.xml")
                  Parts := $erase_ifnot(${Parts}, '.*?PackDescription\s+Release="[^"]+"(?:\s+Patch="[^"]+")?.*', true)
                  Parts := $sfdots(${Parts/.*?PackDescription\s+Release=".+?\..+?\.(\d+?)\.(\d+?)\.(\d+?)"(?:\s+Patch=".+?\..+?\.(\d+?)\.(\d+?)\.(\d+?)+")?.*/$1.$2.$3.$4.$5.$6/})
            # Calculate the numerical version numbers
            local Ver1 := $call(calc_ver_numeric_222, ${Parts}<1>, ${Parts}<2>, ${Parts}<3>)
            local Ver2 := $call(calc_ver_numeric_222, ${Parts}<4>, ${Parts}<5>, ${Parts}<6>)
            local max VerN, ${Ver1}, ${Ver2}
            # Compare the version numbers to get the latest SDK
            if ${VerN} > ${PVer}
                PVer := ${VerN}
                PDir := ${SDir}
            endif
        endforeach
        if !&${PDir} : $call(__exit_error_na_path__, 'a suitable STM32Cube SDK for part number', ${STM32Cube_SelectedPartNumber}, ${STM32_SDK_PATH})
        # Determine the USB driver to be used
        ##### !!! TODO : How about the other middlewares? !!! #####
        if &${usbDriver}
            local __MiddlewaresUSBDriverRoot__
            local __MiddlewaresUSBDriverCore__
            local __MiddlewaresUSBDriverClass__
            local USBDriver := $sfpipes(${usbDriver}   )
            local USBMode   := $lcase  (${USBDriver}<1>)
            local USBClass  := $ucase  (${USBDriver}<2>)
              if ${USBMode} &== 'device' ; __MiddlewaresUSBDriverRoot__ := :"${PDir}/Middlewares/ST/STM32_USB_Device_Library"
            elif ${USBMode} &== 'host'   ; __MiddlewaresUSBDriverRoot__ := :"${PDir}/Middlewares/ST/STM32_USB_Host_Library"
            endif
            __MiddlewaresUSBDriverCore__  := :"${__MiddlewaresUSBDriverRoot__}/Core"
            __MiddlewaresUSBDriverClass__ := :"${__MiddlewaresUSBDriverRoot__}/Class/${USBClass}"
            if !$valid_path(${__MiddlewaresUSBDriverCore__} ) : __MiddlewaresUSBDriverRoot__ := ''
            if !$valid_path(${__MiddlewaresUSBDriverClass__}) : __MiddlewaresUSBDriverRoot__ := ''
            if !&${__MiddlewaresUSBDriverRoot__} : $call(__exit_error_ns_desc__, 'USB driver', ${usbDriver})
        endif
        # Define the subdirectory shortcuts
        local __Drivers__                := :"${PDir}/Drivers"
        local __DriversCMSIS__           := :"${__Drivers__}/CMSIS"
        local __DriversCMSISTemplate__   := :"${__DriversCMSIS__}/Device/ST/STM32${TypeMain}${Core}xx/Source/Templates"
        local __DriversCoreHAL__         := :"${__Drivers__}/STM32${TypeMain}${Core}xx_HAL_Driver"
        # Set the subdirectory paths
        STM32Cube_SDKRootDir              :=   ${PDir}
        STM32Cube_SysLibDirs              := :"${__DriversCMSIS__}/Lib/GCC"
        STM32Cube_SysIncDirs              := :"${__DriversCMSIS__}/Include"                                     \
                                             :"${__DriversCMSIS__}/Device/ST/STM32${TypeMain}${Core}xx/Include" \
                                             :"${__DriversCoreHAL__}/Inc"                                       \
                                             :"${__DriversCoreHAL__}/Inc/Legacy"
        STM32Cube_SysSrcDir_CoreHAL       := :"${__DriversCoreHAL__}/Src"
        STM32Cube_SysSrcDir_CoreHALLegacy := :"${__DriversCoreHAL__}/Src/Legacy"
        # Set the USB drive subdirectory paths as needed
        if &${__MiddlewaresUSBDriverRoot__}
            STM32Cube_SysIncDirs         +:= :"${__MiddlewaresUSBDriverCore__}/Inc"  \
                                             :"${__MiddlewaresUSBDriverClass__}/Inc"
            STM32Cube_SysSrcDir_USBCore   := :"${__MiddlewaresUSBDriverCore__}/Src"
            STM32Cube_SysSrcDir_USBClass  := :"${__MiddlewaresUSBDriverClass__}/Src"
        else
            STM32Cube_SysSrcDir_USBCore   := ''
            STM32Cube_SysSrcDir_USBClass  := ''
        endif
        # Calculate the offset value to remove the STM32Cube SDK root directory name
            STM32Cube_SDKRootDir_NLenOffset := $strlen(${STM32Cube_SDKRootDir})
        add STM32Cube_SDKRootDir_NLenOffset, ${STM32Cube_SDKRootDir_NLenOffset}, 2
        # Set the reference file paths
        local CMSISStartup0  := :"${__DriversCMSISTemplate__}/gcc/startup_stm32${LTypeMain}${LCoreExt}${LLine}xx.s"
        local CMSISStartup1  := :"${__DriversCMSISTemplate__}/gcc/startup_stm32${LTypeMain}${LCoreExt}${LLine}x${LFlashCode}.s"
        local ProjectSubDirs := $erase_ifnot( $lsdir(:"${STM32Cube_SDKRootDir}/Projects", 'd'), :".+?/Projects/.*?${TypeMain}${CoreExt}.*", true)
        STM32CubeRef_PackageLicenseHTML  := :"${STM32Cube_SDKRootDir}/Package_license.html"
        STM32CubeRef_PackageLicenseMD    := :"${STM32Cube_SDKRootDir}/Package_license.md"
        STM32CubeRef_LDScriptURL         := $call(__stm32_get_chip_linker_script_url__, ${Type}, ${Core}, ${Line}, ${FlashCode}, ${PinCnt})
        STM32CubeRef_SysSrc_CMSISStartup := $csel( $valid_path(${CMSISStartup1}), ${CMSISStartup1}, ${CMSISStartup0} )
        STM32CubeRef_SysSrc_CMSISSystem  := :"${__DriversCMSISTemplate__}/system_stm32${LTypeMain}${LCore}xx.c"
        if $part_count(${ProjectSubDirs}) > 1
            # Refine by the line
            ProjectSubDirs := $erase_ifnot(${ProjectSubDirs}, :".+?/Projects/.*?${TypeMain}${CoreExt}${Line}.*", true)
            if $part_count(${ProjectSubDirs}) > 1
                # Refine by the flash-size code
                        local PSD := $erase_ifnot(${ProjectSubDirs}, :".+?/Projects/.*?${TypeMain}${CoreExt}${Line}${FlashCode}.*", true)
                if !&${PSD} : PSD := $erase_ifnot(${ProjectSubDirs}, :".+?/Projects/.*?${TypeMain}${CoreExt}${Line}.${FlashCode}.*", true)
                STM32CubeRef_ProjectSubDir := $partn( $sort_ascending(${PSD}), 1 )
            else
                STM32CubeRef_ProjectSubDir = ${ProjectSubDirs}
            endif
        else
            STM32CubeRef_ProjectSubDir = ${ProjectSubDirs}
        endif
        # Set the chip specification data
        local __STM32_TC_CODE__   := :"${Type}${Core}"
              STM32_CPU          ?:= $call(__stm32_tccode_to_cpu__, ${__STM32_TC_CODE__})
              STM32_FPU          ?:= $call(__stm32_tccode_to_fpu__, ${__STM32_TC_CODE__})
              STM32_FLOAT_ABI    ?:= $csel( $cmp(${STM32_FPU}, '&!=', ''), 'hard', 'soft' )
              STM32_FLASH_OFFSET ?:= ${__Def_STM32_FLASH_OFFSET__}
              STM32_FLASH_SIZE   ?:= ${FlashSize}
              STM32_SRAM_SIZE    ?:= ${SRAMSize}
              STM32_DEVICE       ?:= :"STM32${TypeMain}${CoreExt}${Line}${PinCnt}${FlashCode}"
              STM32_FAMILY       ?:= :"STM32${TypeMain}${CoreExt}${Line}x${FlashCode}"
              STM32_FAMILY_XX    ?:= :"STM32${TypeMain}${CoreExt}${Line}xx"
              STM32_HSE_VALUE    ?:= ${__Def_STM32_HSE_VALUE__}
              STM32_LSE_VALUE    ?:= ${__Def_STM32_LSE_VALUE__}
              STM32_BASE_FNAME   ?:= :"stm32${LTypeMain}${LCore}x"
        # Save the initialization data to the cache file
        local Lines  :=          ${STM32Cube_SDKRootDir}
              Lines +:=          ${STM32Cube_SDKRootDir_NLenOffset}
              Lines +:= $ftpipes(${STM32Cube_SysLibDirs})
              Lines +:= $ftpipes(${STM32Cube_SysIncDirs})
              Lines +:=          ${STM32Cube_SysSrcDir_CoreHAL}
              Lines +:=          ${STM32Cube_SysSrcDir_CoreHALLegacy}
              Lines +:=          ${STM32Cube_SysSrcDir_USBCore}
              Lines +:=          ${STM32Cube_SysSrcDir_USBClass}
              Lines +:=          ${STM32CubeRef_PackageLicenseHTML}
              Lines +:=          ${STM32CubeRef_PackageLicenseMD}
              Lines +:=          ${STM32CubeRef_LDScriptURL}
              Lines +:=          ${STM32CubeRef_SysSrc_CMSISStartup}
              Lines +:=          ${STM32CubeRef_SysSrc_CMSISSystem}
              Lines +:=          ${STM32CubeRef_ProjectSubDir}
              Lines +:=          ${STM32_CPU}
              Lines +:=          ${STM32_FPU}
              Lines +:=          ${STM32_FLOAT_ABI}
              Lines +:=          ${STM32_FLASH_OFFSET}
              Lines +:=          ${STM32_FLASH_SIZE}
              Lines +:=          ${STM32_SRAM_SIZE}
              Lines +:=          ${STM32_DEVICE}
              Lines +:=          ${STM32_FAMILY}
              Lines +:=          ${STM32_FAMILY_XX}
              Lines +:=          ${STM32_HSE_VALUE}
              Lines +:=          ${STM32_LSE_VALUE}
              Lines +:=          ${STM32_BASE_FNAME}
        $put_file(${STM32CubePartInitDataCacheFilePath}, ${Lines})
    endif
    # Configure the build
    $call(__stm32cube_config_build__)
endfunction


##### Function to configure the build
function __stm32cube_config_build__()
    # Set the project's package directory
    STM32Cube_ProjectPackageDir := $cat_path( $cwd(), ${STM32_ProjectPackageDir} )
    # Set the special definition variables
                       __STM32_CPU__                  := :"-mcpu=${STM32_CPU}"
    if &${STM32_FPU} : __STM32_FPU__                  := :"-mfpu=${STM32_FPU}"
                       __STM32_FLOAT_ABI__            := :"-mfloat-abi=${STM32_FLOAT_ABI}"
                       __STM32_CMDEF_DEVICE__         := $series('-D', { '' '__' '__STM32_' }, ${STM32_DEVICE}, { '' '__' })
                       __STM32_CMDEF_FAMILY__         := :"-D${STM32_FAMILY}" :"-D${STM32_FAMILY_XX}"
                       __STM32_CMDEF_HSE_VALUE__      := :"-DHSE_VALUE=${STM32_HSE_VALUE}U"
                       __STM32_CMDEF_LSE_VALUE__      := :"-DLSE_VALUE=${STM32_LSE_VALUE}U"
                       __STM32_WLSYM_FLASH_OFFSET__   := :"-Wl,--defsym=LD_FLASH_OFFSET=${STM32_FLASH_OFFSET}"
                       __STM32_WLSYM_MAX_SIZE__       := :"-Wl,--defsym=LD_MAX_SIZE=${STM32_FLASH_SIZE}"
                       __STM32_WLSYM_MAX_DATA_SIZE__  := :"-Wl,--defsym=LD_MAX_DATA_SIZE=${STM32_SRAM_SIZE}"
                       __STM32_CINCDIR__              := $series( '-I'      , $path_ndsep( $cwd() )           )
                       __STM32_CINCDIR__             +:= $series( '-I'      , ~${STM32Cube_ProjectPackageDir} )
                       __STM32_CINCDIR__             +:= $series( '-isystem', ~${STM32Cube_SysIncDirs}        )
                       __STM32_CLIBDIR__             +:= $series( '-L'      , ~${STM32Cube_SysLibDirs}        )
    if &${STM32Cube_SysSrcDir_USBCore}
        local USBClass := ${STM32Cube_SysSrcDir_USBClass/.+?Class\/(.+?)\/.+/$1/}
        if $str_lidx( $lcase(${STM32Cube_SysSrcDir_USBCore}), 'host' ) > 0
            __STM32_USBDRIVER__ := '-DSTM32_ENABLE_USB' '-DSTM32_ENABLE_USB_HOST'   :"-DSTM32_ENABLE_USB_HOST_${USBClass}"
        else
            __STM32_USBDRIVER__ := '-DSTM32_ENABLE_USB' '-DSTM32_ENABLE_USB_DEVICE' :"-DSTM32_ENABLE_USB_DEVICE_${USBClass}"
        endif
    endif
    # Determine the LL-USB HAL source file name
    __STM32Cube_HAL_SRC_LL_USB_NAME__ := :"${STM32_BASE_FNAME}x_ll_usb.c"
    (*
    # Unconditionally remove '-Wextra' to prevent printing a lot of warnings from the SDK source files
    $call(__unconditionally_remove_wextra__)
    #*)
endfunction


##### Function to list all source files (except the template files)
function __stm32cube_list_srcs__(srcRootDir)
    local PrefLen  := $strlen(${srcRootDir})
    add   PrefLen, ${PrefLen}, 2
    return $erase_if( $substr( $lsdir_rec(${srcRootDir}, 'f'), ${PrefLen}, 0 ), '.+template.+', true )
endfunction


##### Function to list all template source files
function __stm32cube_list_template_srcs__(srcRootDir)
    return $erase_ifnot( $lsdir_rec(${srcRootDir}, 'f'), '.+template.+', true )
endfunction


##### Function to copy all template source files
function __stm32cube_copy_template_srcs__(srcRootDir, dstPackageDir)
    foreach local MF in $call(__stm32cube_list_template_srcs__, ${srcRootDir})
        local DF := $file_name(${MF/_template//})
        if &${DF} : $cpfile( ${MF} , $cat_path(${dstPackageDir}, ${DF}), true, true )
    endforeach
endfunction


##### Function to copy files from template
function stm32cube_copy_template_files(dstDir)
    # Error if the project template for the selected part number is not available
    if !&${STM32CubeRef_ProjectSubDir}
        $call(__exit_error_na_path__, 'a suitable project template for part number', ${STM32Cube_SelectedPartNumber}, :"${STM32Cube_SDKRootDir}/Projects")
    endif
    # Create the destination directory in case it does not exist yet
    dstDir := ~${dstDir}
    $mkdir(${dstDir})
    # Error if the destination directory is not empty
    if &$lsdir(${dstDir}) : $call(__exit_error_build_process_cancel__, :"$[function]()", 'the destination directory is not empty')
    # Download the linker script
    local STM32CubeRef_LDScriptFileSrcPath := $call(__stm32_download_chip_linker_script_by_url__, ${STM32CubeRef_LDScriptURL})
    # Create the destination package directory
    local UPD := :"${dstDir}/${STM32_ProjectPackageDir}"
    $mkdir(${UPD})
    # Copy the standard files
    foreach local File in $stack(                                                     \
                              $lsdir(:"${STM32CubeRef_ProjectSubDir}/Templates/Inc"), \
                              $lsdir(:"${STM32CubeRef_ProjectSubDir}/Templates/Src")  \
                          )
        if $re_match(${File}, '.+/main.+')
            $cpfile( ${File} , $cat_path( ${dstDir}, $file_name(${File}) ), true, true )
        else
            $cpfile( ${File} , $cat_path( ${UPD}   , $file_name(${File}) ), true, true )
        endif
    endforeach
    $cpfile( ${STM32CubeRef_PackageLicenseHTML} , $cat_path( ${UPD}, $file_name(${STM32CubeRef_PackageLicenseHTML} ) ), true, true )
    $cpfile( ${STM32CubeRef_PackageLicenseMD}   , $cat_path( ${UPD}, $file_name(${STM32CubeRef_PackageLicenseMD}   ) ), true, true )
    $cpfile( ${STM32CubeRef_LDScriptFileSrcPath}, $cat_path( ${UPD}, 'ldscript.ld'                                   ), true, true )
    $cpfile( ${STM32CubeRef_SysSrc_CMSISStartup}, $cat_path( ${UPD}, $file_name(${STM32CubeRef_SysSrc_CMSISStartup}) ), true, true )
    $cpfile( ${STM32CubeRef_SysSrc_CMSISSystem} , $cat_path( ${UPD}, $file_name(${STM32CubeRef_SysSrc_CMSISSystem} ) ), true, true )
    $call(__stm32cube_copy_template_srcs__, ${STM32Cube_SysSrcDir_CoreHAL}, ${UPD})
    # Copy the USB driver files
    if &${STM32Cube_SysSrcDir_USBCore}
        $call(__stm32cube_copy_template_srcs__,   ${STM32Cube_SysSrcDir_USBCore}          , ${UPD})
        $call(__stm32cube_copy_template_srcs__, :"${STM32Cube_SysSrcDir_USBCore}/../Inc"  , ${UPD})
    endif
    if &${STM32Cube_SysSrcDir_USBClass}
        $call(__stm32cube_copy_template_srcs__,   ${STM32Cube_SysSrcDir_USBClass}         , ${UPD})
        $call(__stm32cube_copy_template_srcs__, :"${STM32Cube_SysSrcDir_USBClass}/../Inc" , ${UPD})
    endif
endfunction


##### Functions to add (include) the STM32Cube SDK source files to the build
const   STM32Cube_SysLibBuildDir   := 'stm32lib'
const   STM32Cube_SysSLibName      := 'STM32Cube'
const   STM32Cube_SysSLibPath      := $call(slib_fpath, ${STM32Cube_SysSLibName})

unset __STM32Cube_SysLibObjFileP__ # Package        object files
unset __STM32Cube_SysLibObjFile1__ # System library object files - part 1
unset __STM32Cube_SysLibObjFile2__ # System library object files - part 2
      __STM32Cube_SysLibObjFileN__ := 0

function __stm32cube_add_compile_target__(Obj, Src, isPkg)
    # Add the target to build the object file
    local Ext := $lcase( $file_ext(${Src}) )
    $add_target(:"__stm32cube_compile_${Ext}__", ${Obj}, ${Src})
    # Add the object file path to the list of package object files
    if ${isPkg}
        __STM32Cube_SysLibObjFileP__ +:= ${Obj}
    # Add the object file path to one of the lists of system library object files
    else
        if !${__STM32Cube_SysLibObjFileN__}
            __STM32Cube_SysLibObjFile1__ +:= ${Obj}
            __STM32Cube_SysLibObjFileN__  := 1
        else
            __STM32Cube_SysLibObjFile2__ +:= ${Obj}
            __STM32Cube_SysLibObjFileN__  := 0
        endif
    endif
endfunction

function stm32cube_add_pkg_src(srcFileName)
    foreach local SFN in ${srcFileName}
        # Determine the source file path
        local Src := $cat_path(${STM32Cube_ProjectPackageDir}, ${SFN})
        # Determine the object file path
        local Obj := $series( $cat_paths(~${CppBuildDir}, ${STM32_ProjectPackageDir}, ${SFN}), '.', ${ObjFileExt} )
        # Add the compile target
        $call(__stm32cube_add_compile_target__, ${Obj}, ${Src}, true)
    endforeach
endfunction

function stm32cube_add_hal_src(srcFileName)
    foreach local SFN in ${srcFileName}
        # Determine the source file path
        local Src := $cat_path(${STM32Cube_SysSrcDir_CoreHAL}, ${SFN})
        # Determine the object file path
        local Obj := $substr(${Src}, ${STM32Cube_SDKRootDir_NLenOffset}, -1)
              Obj := $series( $cat_paths(~${CppBuildDir}, ${STM32Cube_SysLibBuildDir}, ${Obj}), '.', ${ObjFileExt} )
        # Make the output directory in case it does not exist yet
        $mkdir( $dir_name(${Obj}) )
        # Add the compile target
        $call(__stm32cube_add_compile_target__, ${Obj}, ${Src}, false)
    endforeach
endfunction

function stm32cube_add_usbdrv_core_src(srcFileName)
    # Add the USB core driver source file
    foreach local SFN in ${srcFileName}
        # Determine the source file path
        local Src := $cat_path(${STM32Cube_SysSrcDir_USBCore}, ${SFN})
        # Determine the object file path
        local Obj := $substr(${Src}, ${STM32Cube_SDKRootDir_NLenOffset}, -1)
              Obj := $series( $cat_paths(~${CppBuildDir}, ${STM32Cube_SysLibBuildDir}, ${Obj}), '.', ${ObjFileExt} )
        # Make the output directory in case it does not exist yet
        $mkdir( $dir_name(${Obj}) )
        # Add the compile target
        $call(__stm32cube_add_compile_target__, ${Obj}, ${Src}, false)
    endforeach
    # Add the LL-USB HAL source file once and only once
    if &${__STM32Cube_HAL_SRC_LL_USB_NAME__}
        $call(stm32cube_add_hal_src, ${__STM32Cube_HAL_SRC_LL_USB_NAME__})
        unset __STM32Cube_HAL_SRC_LL_USB_NAME__
    endif
endfunction

function stm32cube_add_usbdrv_class_src(srcFileName)
    foreach local SFN in ${srcFileName}
        # Determine the source file path
        local Src := $cat_path(${STM32Cube_SysSrcDir_USBClass}, ${SFN})
        # Determine the object file path
        local Obj := $substr(${Src}, ${STM32Cube_SDKRootDir_NLenOffset}, -1)
              Obj := $series( $cat_paths(~${CppBuildDir}, ${STM32Cube_SysLibBuildDir}, ${Obj}), '.', ${ObjFileExt} )
        # Make the output directory in case it does not exist yet
        $mkdir( $dir_name(${Obj}) )
        # Add the compile target
        $call(__stm32cube_add_compile_target__, ${Obj}, ${Src}, false)
    endforeach
endfunction

function stm32cube_auto_add_pkg_srcs()
    # Try to get the list content from the cache file first
    local STM32CubePkgSrcListCacheFilePath := $cat_path( $ptd(), :"STM32CubePkgSrcList.${STM32Cube_SelectedPartNumber}.cache" )
    if $uptodate_path(${STM32CubePkgSrcListCacheFilePath})
        # Get the list content
        local PkgSrcs := $get_file(${STM32CubePkgSrcListCacheFilePath})
    # Determine the list content
    else
        # Generate a list of package source files to be included
        local PkgSrcs := $erase_ifnot( $file_name( $lsdir(${STM32Cube_ProjectPackageDir}, 'f') ), '.+\.[sc]', true )
              PkgSrcs := $sort_ascending(${PkgSrcs})
        (*
        # Remove USB driver source files if USB is not enabled
        if !&${STM32Cube_SysSrcDir_USBCore} : PkgSrcs := $erase_if(${PkgSrcs}, 'usbd_.*', true)
        #*)
        # Save the list content to the cache file
        $put_file(${STM32CubePkgSrcListCacheFilePath}, ${PkgSrcs})
    endif
    # Add the package source files
    $call(stm32cube_add_pkg_src, ${PkgSrcs})
endfunction

function stm32cube_auto_add_hal_srcs()
    # Determine the HAL configuration header file name
    local HALConfHPath := :"${STM32_ProjectPackageDir}/${STM32_BASE_FNAME}x_hal_conf.h"
    # Try to get the list content from the cache file first
    local STM32CubeHALModSrcListCacheFilePath := $cat_path( $ptd(), :"STM32CubeHALModSrcList.${STM32Cube_SelectedPartNumber}.cache" )
    if $and( $uptodate_path(${STM32CubeHALModSrcListCacheFilePath}), $newer_path(${STM32CubeHALModSrcListCacheFilePath}, ${HALConfHPath}) )
        # Get the list content
        local ModSrcs := $get_file(${STM32CubeHALModSrcListCacheFilePath})
    # Determine the list content
    else
        # Read the HAL configuration header file and remove all comments
        local METext := $get_file(${HALConfHPath}, true)
              METext := ${METext/(?s)\/\*.+?\*\///}
              METext := ${METext/\p{Blank}*\/\/.*//}
        # Get the list of enabled '#define' from the HAL configuration header file
        local MEList := $erase_ifnot( $sflines(${METext}), '^\\s*#define\\s+HAL_.+?_MODULE_ENABLED\\s*$', true )
              MEList := $lcase( ${MEList/.+HAL_(.+?)_MODULE.+/$1/} )
        # Generate a list of enabled HAL modules using the above list
        local MNList
        foreach local ME in ${MEList}
            if $str_endwith(${ME}, '_legacy') ; MNList +:= :"Legacy/${STM32_BASE_FNAME}x_hal_${ME/_legacy//}"
            else                              ; MNList +:= :"${STM32_BASE_FNAME}x_hal_${ME}"
            endif
        endforeach
        # List all available HAL module source files (except the template files)
        local ModFiles := $call(__stm32cube_list_srcs__, ${STM32Cube_SysSrcDir_CoreHAL})
        # Generate a list of HAL module source files to be included
        local ModSrcs := :"${STM32_BASE_FNAME}x_hal.c"
        foreach local MN in ${MNList}
            ModSrcs +:= $erase_ifempty( $csel( $str_begwith(${ModFiles}, ${MN}), ${ModFiles}, '' ) )
        endforeach
        ModSrcs := $sort_ascending(${ModSrcs})
        # Save the list content to the cache file
        $put_file(${STM32CubeHALModSrcListCacheFilePath}, ${ModSrcs})
    endif
    # Add the HAL module source files
    $call(stm32cube_add_hal_src, ${ModSrcs})
endfunction

function stm32cube_auto_add_usbdrv_srcs()
    # Add all available USB driver source files (except the template files)
    $call( stm32cube_add_usbdrv_core_src , $call(__stm32cube_list_srcs__, ${STM32Cube_SysSrcDir_USBCore} ) )
    $call( stm32cube_add_usbdrv_class_src, $call(__stm32cube_list_srcs__, ${STM32Cube_SysSrcDir_USBClass}) )
endfunction


##### Function to add the necessary extra dependencies to the given target path
function stm32cube_add_extradeps(targetPath)
    $add_extradep(${targetPath}, ${__STM32Cube_SysLibObjFileP__}, true)
endfunction


##### Function to compile assembly source codes
function stm32cube_compile_s(?extraOptions)
    $call(compile_s, ${extraOptions})
endfunction


##### Function to compile C++ and C++20 source codes
function stm32cube_compile_c(?extraOptions)
    return $call(compile_c, ${extraOptions}, false) # Disable shared library support
endfunction

function stm32cube_compile_cpp(?extraOptions)
    return $call(compile_cpp, ${extraOptions}, false) # Disable shared library support
endfunction

function compile_cpp20m(?extraOptions) supersede
    return $call(__origin__, ${extraOptions}, false) # Disable shared library support
endfunction


##### Function to link executable files (in case of STM32, also create the BIN and HEX files)
STM32Cube_SysSLibBuilt := false

function __elf_to_bin__(ldLibraryPath)
    # Determine the paths
    if &${CppToolBinDir} : local STM32ObjCopy := $cat_path(${CppToolBinDir}, ${STM32ObjCopy})
    local BinFile := ~$[target/(.+)\.elf/$1.bin/]
    # Convert ELF to BIN
    $rmfile(${BinFile})
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${STM32ObjCopy} ${STM32ObjCopyE2BFlags} ~$[target] ${BinFile}
endfunction

function __elf_to_hex__(ldLibraryPath)
    # Determine the paths
    if &${CppToolBinDir} : local STM32ObjCopy := $cat_path(${CppToolBinDir}, ${STM32ObjCopy})
    local HexFile := ~$[target/(.+)\.elf/$1.hex/]
    # Convert ELF to HEX
    $rmfile(${HexFile})
   +@setenv ${__Real_LDLibraryPath__} ${ldLibraryPath}
   +@${STM32ObjCopy} ${STM32ObjCopyE2HFlags} ~$[target] ${HexFile}
endfunction

function stm32cube_link_exe(?extraOptions)
    # Check the prerequisites
    if !${STM32Cube_SysSLibBuilt} : $call(__exit_error_run_target_call_function_, 'stm32cube_build_system_library', :"$[function]()")
    # Add the system library
    local CppUsrStaticLib :+= ${STM32Cube_SysSLibName}
    # Link the executable
    CppExtraLinkObjects := ${__STM32Cube_SysLibObjFileP__} # Object files in this list must not be included in the system library
    $call(link_exe, ${extraOptions})
    # Convert ELF to BIN
    $call( __bpt_bin__                                   )
    $exec( __elf_to_bin__, $call(__get_LDLibraryPaths__) )
    $call( __conditional_print_stdxxx_and_check_excode__ )
    # Convert ELF to HEX
    $call( __bpt_hex__                                   )
    $exec( __elf_to_hex__, $call(__get_LDLibraryPaths__) )
    $call( __conditional_print_stdxxx_and_check_excode__ )
endfunction


##### Function to create static libraries
function stm32cube_link_slib()
    $call(link_slib)
endfunction


##### Linking shared library files is not supported
function link_dlib(?extraOptions) supersede
    .$__exit_error_function_ns__
endfunction


##### Function to run the given executable file (in case of STM32, print the size)
function stm32cube_run_exe(progName, ?dimColor)
    # Exit if the executable does not actually exist
    if !$valid_path(${progName}) : return
    # Print the size
                 $call( __bpt_exe_size_linespace__                                                                                    )
    local res := $call( __armgcc_obj_size__, ${STM32Size}, ${STM32SizeFlags}, ${progName}, $call(__get_LDLibraryPaths__), ${dimColor} )
    if !${res} : $call( __conditional_print_stdxxx_and_check_excode__                                                                 )
endfunction


###################################################################################
##### ====================== Native STM32 Build Targets ===================== #####
###################################################################################

##### Disable warnings from the SDK
const __STM32Cube_SysLib_DisableWarnings__ := '-Wno-unused-function' '-Wno-unused-parameter' '-Wno-unused-variable' '-Wno-sign-compare' '-Wno-missing-field-initializers'


##### Targets to build STM32Cube library file
__STM32Cube_SysLib_SLibTargetAdded__ := 0

target __stm32cube_compile_s__
    $call(compile_s, ${__STM32Cube_SysLib_DisableWarnings__})
endtarget

target __stm32cube_compile_c__
    $call(compile_c, ${__STM32Cube_SysLib_DisableWarnings__})
endtarget

target __stm32cube_compile_cpp__
    $call(compile_cpp, ${__STM32Cube_SysLib_DisableWarnings__})
endtarget

target __stm32cube_link_slib__
    $call(link_slib)
endtarget

target stm32cube_build_system_library
    # Reset flag
    STM32Cube_SysSLibBuilt := false
    # Add the target to build the library file if it has not been added
    if !${__STM32Cube_SysLib_SLibTargetAdded__}
        (*
        # Erase empty entries from the lists of object files
        __STM32Cube_SysLibObjFileP__ := $erase_ifempty( ${__STM32Cube_SysLibObjFileP__} )
        __STM32Cube_SysLibObjFile1__ := $erase_ifempty( ${__STM32Cube_SysLibObjFile1__} )
        __STM32Cube_SysLibObjFile2__ := $erase_ifempty( ${__STM32Cube_SysLibObjFile2__} )
        #*)
        # Add the target to build the library file
        $add_target( '__stm32cube_link_slib__', ${STM32Cube_SysSLibPath}, $stack(${__STM32Cube_SysLibObjFile1__}, ${__STM32Cube_SysLibObjFile2__}) )
        # Set flag
        __STM32Cube_SysLib_SLibTargetAdded__ := 1
    endif
    # Build the object and library files
    __stdxxx_from_syslib__ := true
   +jxmake ${__STM32Cube_SysLibObjFileP__}
   +jxmake ${__STM32Cube_SysLibObjFile1__}
   +jxmake ${__STM32Cube_SysLibObjFile2__}
    jxwait
    jxmake ${STM32Cube_SysSLibPath}
    __stdxxx_from_syslib__ := false
    # Set flag
    STM32Cube_SysSLibBuilt := true
endtarget


