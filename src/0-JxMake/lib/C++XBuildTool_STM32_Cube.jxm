##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__() supersede
    local NGText := __c_cyan__  "Native STM32" __c_white__
    local NGInfo := __c_white__ 'for ' ${NGText} ' '
    local CGText := __c_cyan__  "Native STM32Cube" __c_white__
    local CGInfo := __c_white__ 'for ' ${CGText} ' '
    $call(__origin__, ${NGInfo}, 3, true, false, true, true)
    echoln __c_green__ '    STM32_SDK_PATH          ' __c_white__ ': location of ' ${NGText} ' SDK'
    echoln __c_green__ '    STM32_TOOLCHAIN_PATH    ' __c_white__ ': location of ' ${NGText} ' toolchain'
    echoln
    echoln __c_green__ '    STM32_CommonCompileMDef ' __c_white__ ': common compilation preprocessor defines (custom values can be added)'
    echoln
    $call(__openocd_btlib_help_print_ports__, 4)
   #$call(__btlib_help_print_title_functions__, 7, 27, 1, ${NGInfo})
    $call(__btlib_help_print_title_functions__, 0,  0, 0, ${NGInfo})
    echoln __c_green__ '    init_project         (?buildSubdirectories,        ' __c_white__ ': superseding the original \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '                          ?dlOnlyIfNotExist          ) ' __c_green__ '      buildSubdirectories' __c_white__ ' same meaning as the original implementation'
    echoln __c_green__ '                                                       ' __c_green__ '      dlOnlyIfNotExist   ' __c_white__ ' passed to the \'' __c_green__ '?onlyIfNotExist' __c_white__ '\' parameters when downloading'
    echoln
    echoln __c_green__ '    stm32_upload_dfu     (progName     , ?vid, ?pid,   ' __c_white__ ': upload program to the attached ' __c_cyan__ 'STM32' __c_white__ ' via ' __c_cyan__ 'DFU' __c_white__ ' using ' __c_cyan__ 'DFU-Util' __c_white__ '; ' __c_red__ 'this feature may only be supported by some chips'
    echoln __c_green__ '                          ?flashAddress, ?modifiers  ) ' __c_green__ '      progName    ' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      vid         ' __c_white__ ' device VID                          - the default is \'' __c_yellow__ ${__Def_STM32_VID__} __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      pid         ' __c_white__ ' device PID                          - the default is \'' __c_yellow__ ${__Def_STM32_PID__} __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      flashAddress' __c_white__ ' target address (flash memory start) - the default is \'' __c_yellow__ ${__Def_STM32_FAD__} __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      modifiers   ' __c_white__ ' target modifiers                    - the default is \'' __c_yellow__ ${__Def_STM32_MOD__} __c_white__ '\''
    echoln
    echoln __c_green__ '    stm32_reset_swd      (              ?interface   , ' __c_white__ ': reset the attached ' __c_cyan__ 'STM32' __c_white__ ' via ' __c_cyan__ 'SWD' __c_white__ ' using ' __c_cyan__ 'OpenOCD' __c_white__ ' tool'
    echoln __c_green__ '                          ?transport  , ?adapterSpeed, ' __c_green__ '      interface   ' __c_white__ ' SWD interface name    - the default is \'' __c_yellow__ ${STM32_SWD_Default_Interface} __c_white__ '\''
    echoln __c_green__ '                          ?ignoreCPUID               ) ' __c_green__ '      transport   ' __c_white__ ' transport             - the default is \'' __c_yellow__ ${STM32_SWD_Default_Transport} __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      adapterSpeed' __c_white__ ' adapter speed         - the default is \'' __c_yellow__ ${STM32_SWD_Default_AdapterSpeed} __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      ignoreCPUID ' __c_white__ ' ignore the CPU tap ID - the default is \'' __c_yellow__ 'false' __c_white__ '\' (set this to \'' __c_yellow__ 'true' __c_white__ '\' for clone chips)'
    echoln
    echoln __c_green__ '    stm32_upload_swd     (progName    , ?interface   , ' __c_white__ ': upload program to the attached ' __c_cyan__ 'STM32' __c_white__ ' via ' __c_cyan__ 'SWD' __c_white__ ' using ' __c_cyan__ 'OpenOCD' __c_white__ ' tool'
    echoln __c_green__ '                          ?transport  , ?adapterSpeed, ' __c_green__ '      progName    ' __c_white__ ' program name; use the value returned by \'' __c_green__ 'exe_fpath' __c_white__ '\''
    echoln __c_green__ '                          ?ignoreCPUID               ) ' __c_green__ '      interface   ' __c_white__ ' SWD interface name    - the default is \'' __c_yellow__ ${STM32_SWD_Default_Interface} __c_white__ '\''
    echoln __c_green__ '                                                       ' __c_green__ '      transport   ' __c_white__ ' transport             - the default is \'' __c_yellow__ ${STM32_SWD_Default_Transport} __c_white__ '\''
