   #$call(__btlib_help_print_title_functions__, 16, 19, 1, ${CGInfo})
    $call(__btlib_help_print_title_functions__,  0,  0, 0, ${CGInfo})
    echoln __c_green__ '    stm32cube_select_part         (partNumber,          ' __c_white__ ': select the STM32 part number to use with the ' ${CGText} ' SDK; can only be called after calling \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '                                   ?usbDriver         ) ' __c_green__ '      partNumber' __c_white__ ' STM32 part number        - for exmple \'' __c_yellow__ 'STM32F411CEU6' __c_white__ '\''
    echoln __c_green__ '                                                        ' __c_green__ '      usbDriver ' __c_white__ ' USB driver to be enabled - for exmple \'' __c_yellow__ 'device|cdc' __c_white__ '\'; the default is none (USB support is disabled)'
    echoln __c_green__ '                                                        ' __c_white__ '  these are the global variables that are initialized by this function:'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SDKRootDir'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SDKRootDir_NLenOffset'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SysLibDirs'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SysIncDirs'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SysSrcDir_CoreHAL'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SysSrcDir_CoreHALLegacy'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SysSrcDir_USBCore'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32Cube_SysSrcDir_USBClass'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32CubeRef_PackageLicenseHTML'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32CubeRef_PackageLicenseMD'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32CubeRef_LDScriptURL'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32CubeRef_SysSrc_CMSISStartup'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32CubeRef_SysSrc_CMSISSystem'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32CubeRef_ProjectSubDir'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_CPU' __c_white__ '                         - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_FPU' __c_white__ '                         - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_FLOAT_ABI' __c_white__ '                   - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_FLASH_OFFSET' __c_white__ '                - the default value is \'' __c_yellow__ ${__Def_STM32_FLASH_OFFSET__} __c_white__ '\'           (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_FLASH_SIZE' __c_white__ '                  - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_SRAM_SIZE' __c_white__ '                   - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_DEVICE' __c_white__ '                      - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_FAMILY' __c_white__ '                      - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_FAMILY_XX' __c_white__ '                   - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_HSE_VALUE' __c_white__ '                   - the default value is \'' __c_yellow__ ${__Def_STM32_HSE_VALUE__} __c_white__ '\'    (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_LSE_VALUE' __c_white__ '                   - the default value is \'' __c_yellow__ ${__Def_STM32_LSE_VALUE__} __c_white__ '\'       (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_green__ '      STM32_BASE_FNAME' __c_white__ '                  - the default value is chip specific (can be pre-filled)'
    echoln __c_green__ '                                                        ' __c_white__ '  in case \'' __c_green__ 'stm32cube_select_part' __c_white__ '\' does not support your chip\'s part number, you can either:'
    echoln __c_green__ '                                                        ' __c_white__ '      1. manually pre-fill some of the above variables before calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\'; or'
    echoln __c_green__ '                                                        ' __c_white__ '      2. manually fill all the above variables and then call \'' __c_green__ '__stm32cube_config_build__' __c_white__ '\' to finalize the configuration'
    echoln __c_green__ '                                                        ' __c_white__ '         process - use a supported part number first (such as \'' __c_yellow__ 'STM32F411CEU6' __c_white__ '\') as a starting point for determining the'
    echoln __c_green__ '                                                        ' __c_white__ '         appropriate values.'
    echoln
    echoln __c_green__ '    stm32cube_copy_template_files (dstDir             ) ' __c_white__ ': copy project template files to the destination directory  ; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\';'
    echoln __c_green__ '                                                        ' __c_red__   '  this feature is only supported for some chips!'
    echoln
    echoln __c_green__ '    stm32cube_add_pkg_src         (srcFileName        ) ' __c_white__ ': add     ' ${CGText} ' SDK package          source file ; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln __c_green__ '    stm32cube_add_hal_src         (srcFileName        ) ' __c_white__ ': add     ' ${CGText} ' SDK HAL              source file ; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln __c_green__ '    stm32cube_add_usbdrv_core_src (srcFileName        ) ' __c_white__ ': add     ' ${CGText} ' SDK USB core  driver source file ; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln __c_green__ '    stm32cube_add_usbdrv_class_src(srcFileName        ) ' __c_white__ ': add     ' ${CGText} ' SDK USB class driver source file ; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln
    echoln __c_green__ '    stm32cube_auto_add_pkg_srcs   (                   ) ' __c_white__ ': add all ' ${CGText} ' SDK package          source files; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln __c_green__ '    stm32cube_auto_add_hal_srcs   (                   ) ' __c_white__ ': add all ' ${CGText} ' SDK HAL              source files; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln __c_green__ '    stm32cube_auto_add_usbdrv_srcs(                   ) ' __c_white__ ': add all ' ${CGText} ' SDK USB driver       source files; can only be called after calling \'' __c_green__ 'stm32cube_select_part' __c_white__ '\''
    echoln
    echoln __c_green__ '    stm32cube_add_extradeps       (targetPath         ) ' __c_white__ ': add the necessary extra dependencies to the given target path; call this after the last call to \'' __c_green__ 'stm32cube_add_*_src' __c_white__ '\''
    echoln
    echoln __c_green__ '    stm32cube_compile_s           (?extraOptions      ) ' __c_white__ ': compile a ' ${CGText} ' assembly   source code; please use this instead of \'' __c_green__ 'compile_s' __c_white__ '\''
    echoln __c_green__ '    stm32cube_compile_c           (?extraOptions      ) ' __c_white__ ': compile a ' ${CGText} ' C          source code; please use this instead of \'' __c_green__ 'compile_c' __c_white__ '\''
    echoln __c_green__ '    stm32cube_compile_cpp         (?extraOptions      ) ' __c_white__ ': compile a ' ${CGText} ' C++        source code; please use this instead of \'' __c_green__ 'compile_cpp' __c_white__ '\''
    echoln
    echoln __c_green__ '    stm32cube_link_exe            (?extraOptions      ) ' __c_white__ ': link              a ' ${CGText} ' executable    ; please use this instead of \'' __c_green__ 'link_exe' __c_white__ '\''
    echoln __c_green__ '    stm32cube_link_slib           (                   ) ' __c_white__ ': link              a ' ${CGText} ' static library; please use this instead of \'' __c_green__ 'link_slib' __c_white__ '\''
    echoln __c_green__ '    stm32cube_run_exe             (progName, ?dimColor) ' __c_white__ ': print the size of a ' ${CGText} ' executable    ; please use this instead of \'' __c_green__ 'link_exe' __c_white__ '\''
    echoln
    echoln __c_white__ '    Using the \'' __c_green__ 'stm32cube_auto_add_*_srcs' __c_white__ '\' functions is easy and fast, but may result in a less efficient build and (sometimes) compile/link errors.'
    echoln
   #$call(__btlib_help_print_title_targets__, 21, ${CGInfo})
    $call(__btlib_help_print_title_targets__,  0, ${CGInfo})
    echoln __c_green__ '    stm32cube_build_system_library ' __c_white__ ': build the ' ${CGText} ' SDK system library file'
    echoln
    $call(__btlib_help_print_note_auto_parallelize__, false)
    echoln __c_reset__
endfunction

