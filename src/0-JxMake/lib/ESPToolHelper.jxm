##### Function to get the BIN file prefix for the given ELF file
function __esptool_get_bin_file_prefix__(elfFileAbsolutePath)
    return :"${elfFileAbsolutePath}-"
endfunction


##### Function to get a list of (a) BIN file(s) for the given ELF file
function __esptool_ls_bin_files__(elfFileAbsolutePath)
    # List directory and match file name(s) such as '*.elf-0x?????.bin'
    local Files := $lsdir        ( $path_rm_last_part(${elfFileAbsolutePath}), 'f' )
    local Match := $str_begwith  ( ${Files}, ${elfFileAbsolutePath}                )
          Files := $erase_ifempty( $csel(${Match}, ${Files}, '')                   )
          Files := $erase_ifnot  ( ${Files}, '.+\.elf-0x[0-9a-fA-F]+\.bin$', true  )
          Files := $sort_ascending(${Files})
    # If there no file is found, try the classic name
    if !&${Files}
        local CName := ${elfFileAbsolutePath/(.+)\.elf/$1.bin/}
        if $valid_path(${CName}) : Files := ${CName}
    endif
    # Return the file(s)
    return ${Files}
endfunction


##### Function to generate a list of address(es) and BIN file(s)
function __esptool_gen_abf_list__(binFilesAbsolutePath, ?defaultAddress)
    ##### Generate the list
    local ABFList
    local Address
    foreach local BinFile in ${binFilesAbsolutePath}
        Address := ${BinFile/.+\.elf-(0x[0-9a-fA-F]+)\.bin$/$1/}
        if ${Address} &== ${BinFile} : Address := ${defaultAddress}
        ABFList +:= ${Address}
        ABFList +:= ${BinFile}
    endforeach
    ##### Return the list
    return ${ABFList}
endfunction
