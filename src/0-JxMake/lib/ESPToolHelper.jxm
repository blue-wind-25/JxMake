##### Include the Python utility
:::include_once 'DownloadIntelHex.jxm'
:::include_once 'DownloadESPTool.jxm'
:::include_once 'PythonUtil.jxm'


##### Function to wrap 'esptool.py' so that it can be run using 'IntelHex' and 'pySerial' modules
##### that are located in non-standard locations
function __esptool_wrap_esptool_py__(esptoolPythonScriptAbsolutePath)
    # Determine the paths
    local WrapperScriptPath := $cat_path         ( $ptd(), '_esptool_wrapper.py'      )
    local ESPToolScriptPath := $path_rm_last_part( ${esptoolPythonScriptAbsolutePath} )
    # Create the wrapper script
    local PythonCommands := :[["
import sys
try:
    sys.path.insert(0, '${IntelHex_Path}')
    sys.path.insert(0, '${PySerial_Path}')
    sys.path.insert(0, '${ESPToolScriptPath}')
    import esptool
except ImportError as e:
    sys.stderr.write("Failed to import 'intelhex', 'pyserial', and/or 'esptool'\\n")
    sys.stderr.write('%s\\n' % e)
    sys.exit(-1)
try:
    esptool.main(sys.argv[1:])
except Exception as e:
    sys.stderr.write('%s\\n' % e)
    sys.exit(-1)
"]]
    $put_file(${WrapperScriptPath} , ${PythonCommands})
    # Return the wrapper script prefixed with the Python executable path
    return { ${Python3} ${WrapperScriptPath} }
endfunction


##### Function to download and/or adjust 'esptool.py' so that it can be run as if a normal program on multiple operating systems
function __esptool_download_and_adjust_esptool_py__(esptoolPythonScriptAbsolutePath, dlOnlyIfNotExist)
    # If the variable is not set, check if it is a valid path
    if &${esptoolPythonScriptAbsolutePath}
        # Clear the variable it is not a valid path
        if !$valid_path(${esptoolPythonScriptAbsolutePath}) : esptoolPythonScriptAbsolutePath := ''
    endif
    # If the variable is not set, try to download ESPTool
    if !&${esptoolPythonScriptAbsolutePath}
        $call(download_latest_esptool, ${onlyIfNotExist})
        esptoolPythonScriptAbsolutePath := ${ESPTool_esptool}
    endif
    # Wrap the ESPTool executable if it is a plain Python script
    if $str_endwith(${esptoolPythonScriptAbsolutePath}, '.py')
        esptoolPythonScriptAbsolutePath := $call(__esptool_wrap_esptool_py__, ${esptoolPythonScriptAbsolutePath})
    endif
    # Error if the command is not executable
    if !$call(cmd_is_executable, '', ${esptoolPythonScriptAbsolutePath}, '-h')
        $call( __exit_error_nup__, $call(__format_exit_error_multi_whats__, { 'esptool' 'esptool.py' }) )
    endif
    # Return the adjusted command
    return ${esptoolPythonScriptAbsolutePath}
endfunction


