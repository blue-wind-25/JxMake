##### Function to display some brief descriptions of the build tool's variables and functions
function __btlib_help__()
    $call(__btlib_help_print_title_main__)
    $call(__btlib_help_print_title_variables__)
    echoln __c_green__ '    __java__                  ' __c_white__ ': evaluate to the value ' __c_yellow__ '1' __c_white__ ' for both Oracle(R) JDK and OpenJDK'
    echoln
    echoln __c_green__ '    __BuildTool_Name__        ' __c_white__ ': evaluate to the Java compiler name'
    echoln __c_green__ '    __BuildTool_Version__     ' __c_white__ ': evaluate to the Java compiler version'
    echoln __c_green__ '    __BuildTool_Version_Num__ ' __c_white__ ': evaluate to the Java compiler version (in the form of combined numeric value)'
    echoln
    echoln __c_green__ '    JavaBuildDir              ' __c_white__ ': set the build directory under the source tree - the default is \'' __c_yellow__ 'build' __c_white__ '\'; can only be changed before calling \'' __c_green__ 'init_project' __c_white__ '\''
    echoln __c_green__ '    JavaToolBinDir            ' __c_white__ ': set the location of the Java binaries         - the default is empty (use the system\'s default)'
    echoln
    $call(__btlib_help_print_title_functions__, 10, 20, 1)
    echoln __c_green__ '    init_project            (?buildSubdirectories) ' __c_white__ ': initialize the project build; ' __c_red__ 'must be called first and as early as possible' __c_white__ ' (after changing the '
    echoln __c_green__ '                                                   ' __c_white__ '  global values of the variables above, if necessary)'
    echoln __c_green__ '    clean_project           (                    ) ' __c_white__ ': clean the project build (delete all the generated files)'
    echoln __c_green__ '    print_devenv_config     (                    ) ' __c_white__ ': print the development environment configuration summary; must only be called after \'' __c_green__ 'init_project' __c_white__ '\''
    echoln
    echoln __c_green__ '    silent_stdxxx           (?silent             ) ' __c_white__ ': silent/unsilent all    stderr/stdout outputs, unless the exit code is non-zero - the default is \'' __c_green__ 'false' __c_white__ '\''
    echoln __c_green__ '    silent_stdxxx_syslib    (?silent             ) ' __c_white__ ': silent/unsilent system stderr/stdout outputs, unless the exit code is non-zero - the default is \'' __c_green__ 'true' __c_white__ '\''
    echoln
    echoln __c_green__ '    java_compiler_ver_min   (mj, mn , pl         ) ' __c_white__ ': check if the Java compiler version is at least ' __c_yellow__ '<major>.<minor>.<patch>'
    echoln __c_green__ '    java_compiler_ver_max   (mj, mn , pl         ) ' __c_white__ ': check if the Java compiler version is at most  ' __c_yellow__ '<major>.<minor>.<patch>'
    echoln
    echoln __c_green__ '    deplist_fname           (baseName            ) ' __c_white__ ': generate the correct dependency list file name from the given base name (without extension)'
    echoln __c_green__ '    deplist_fpath           (baseName            ) ' __c_white__ ': generate the correct dependency list file path from the given base name (without extension)'
    echoln __c_green__ '    class_fname             (baseName            ) ' __c_white__ ': generate the correct class           file name from the given base name (without extension)'
    echoln __c_green__ '    class_fpath             (baseName            ) ' __c_white__ ': generate the correct class           file path from the given base name (without extension)'
    echoln __c_green__ '    jar_fname               (baseName            ) ' __c_white__ ': generate the correct JAR             file name from the given base name (without extension)'
    echoln __c_green__ '    jar_fpath               (baseName            ) ' __c_white__ ': generate the correct JAR             file path from the given base name (without extension)'
    echoln
    echoln __c_green__ '    class_target_glob       (                    ) ' __c_white__ ': generate the correct glob target name to build class file - ' __c_yellow__ '${JavaBuildDir}/%.${ClsFileExt}'
    echoln
    echoln __c_green__ '    treat_warnings_as_errors(enabled             ) ' __c_white__ ': enable/disable treat all warnings as errors - the default is disabled'
    echoln __c_green__ '    enable_debug_info       (enabled             ) ' __c_white__ ': enable/disable debugging information        - the default is disabled'
    echoln
    echoln __c_green__ '    select_java_langstd     (langstd             ) ' __c_white__ ': select the Java language standard (' __c_yellow__ ${__BuildTool_SupRelMin__} __c_white__ ' to ' __c_yellow__ ${__BuildTool_SupRelMax__} __c_white__ ' for the currently used JDK) - the default is not specified'
    echoln
    echoln __c_green__ '    compile_java            (?extraOptions       ) ' __c_white__ ': compile a Java source code'
    echoln
    echoln __c_green__ '    build_jar               (mainClassName,        ' __c_white__ ': build a Java JAR file'
    echoln __c_green__ '                             ?extraFiles         ) '
    echoln
    echoln __c_green__ '    run_jar                 (progName            ) ' __c_white__ ': run the given JAR file'
    echoln
    $call(__btlib_help_print_title_targets__, 1)
    $call(__btlib_help_print_note_clean_build_after_path_conf_change__)
    echoln __c_reset__
endfunction
