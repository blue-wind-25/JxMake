##### Include the basic platform utility
:::include_once 'BasicPlatformUtil.jxm'


##### Set flags
const __java__                  := 1
const __JavaBuildTool_Defined__ := 1
const __BuildTool_Title__       := 'Java'
      __BuildTool_Name__        := 'JDK'
      __BuildTool_Version__     := 0
      __BuildTool_Version_Num__ := 0
      __BuildTool_SupRelMin__   := 0
      __BuildTool_SupRelMax__   := 0


##### Define build directory
JavaBuildDir := 'build'


##### Get the compiler version
function __calc_java_compiler_ver_numeric__(major, minor, patch)
    return $call(calc_ver_numeric_222, ${major}, ${minor}, ${patch})
endfunction

function __get_java_compiler_ver_exec__()
    if &${JavaToolBinDir} : local JavaCompiler := $cat_path(${JavaToolBinDir}, ${JavaCompiler})
    if &${JavaToolBinDir} : local JavaJVM      := $cat_path(${JavaToolBinDir}, ${JavaJVM}     )
    $nop($[lserr]) # Ensure the last suppressed error message is cleared
    $silent_sem()
   -@${JavaJVM} -version
    $nop($[excode]) # Ensure all pending commands are executed
    if !&$[lserr]
        # If the command turns out to be executable, use the result from the command
        local OpenJDK := $str_fidx( $lcase( $stack($[stderr], $[stdout]) ), 'openjdk' )
        if ${OpenJDK} : __BuildTool_Name__ := :"Open${__BuildTool_Name__}"
    endif
   -@${JavaCompiler} -version -help
    local excode := $[excode]
    $restore_sem()
    if &$[lserr] : return -1 # Check if the command turns out to be unexecutable
    return ${excode}
endfunction

function __get_java_compiler_ver_impl__()
    # Prepare a zero result
    local result := '0' '0'
    # Get the version
    if !$exec(__get_java_compiler_ver_exec__)
        # Get and extract the lines
        local lines   := $strim( $lcase( $sflines( $stack($[stderr], $[stdout]) ) ) )
        local lineVer := $erase_ifnot(${lines}, 'javac .+', true)
        local lineRel := $erase_ifnot(${lines}, 'compile for.+', true)
        # Get and store the version
              lineVer := $sfdots(${lineVer/(?:.+\s)(\d+)(?:\.)?(\d+)?(?:\.)?(\d+)?(?:_(\d+))?/$1.$2.$3.$4/})
        local main    := $partn(${lineVer}, 1)
        local part1   := $partn(${lineVer}, 2)
        local part2   := $partn(${lineVer}, 3)
        local part3   := $partn(${lineVer}, 4)
        if ${main} <= 1
            local major := ${part1}
            local minor := ${part2}
            local patch := ${part3}
        else
            local major := ${main}
            local minor := ${part1}
            local patch := ${part2}
        endif
        if !&${minor} : minor := 0
        if !&${patch} : patch := 0
        result  := $call(__calc_java_compiler_ver_numeric__, ${major}, ${minor}, ${patch})
        result +:= :"${major}.${minor}.${patch}"
        # Get and store the supported releases
        if &${lineRel}
                  lineRel := $strim( $erase_ifempty( $explode( $sfdots(${lineRel/(?:.+?:)(.+)/$1/}), ',' ) ) )
            local minRel  := ${lineRel}< 1>
            local maxRel  := ${lineRel}<-1>
            result +:= ${minRel}
            result +:= ${maxRel}
        else
            result +:= 0 0
        endif
    endif
    # Return the result
    return ${result}
endfunction

function __get_java_compiler_ver__()
    local result  := $call(__get_java_compiler_ver_impl__)
    local numeric := ${result}<1>
    if ${numeric}
        __BuildTool_Version__     := ${result}<2>
        __BuildTool_Version_Num__ := ${numeric}
        __BuildTool_SupRelMin__   := ${result}<3>
        __BuildTool_SupRelMax__   := ${result}<4>
    endif
    return ${numeric}
endfunction


##### Check if the compiler version is at least/most
function java_compiler_ver_min(major, minor, patch)
    return $cmp( ${__BuildTool_Version_Num__}, '>=', $call(__calc_java_compiler_ver_numeric__, ${major}, ${minor}, ${patch}) )
endfunction

function java_compiler_ver_max(major, minor, patch)
    return $cmp( ${__BuildTool_Version_Num__}, '<=', $call(__calc_java_compiler_ver_numeric__, ${major}, ${minor}, ${patch}) )
endfunction


##### Define the file extensions
DepListFileExt := dep

ClsFileExt     := class
JarFileExt     := jar


##### Define the executables, paths, and options
const __MWE__ := $getenv('JXMAKELIB_MAX_WARNINGS_AND_ERRORS', ${DEFAULT_JXMAKELIB_MAX_WARNINGS_AND_ERRORS})

JavaToolBinDir         := ''

JavaCompiler           := 'javac'
if __os_windows__
JavaJVM                := 'javaw'
else
JavaJVM                := 'java'
endif

JavaCommonCompileFlags := '-Xlint:all' '-Xlint:-options' '-Xmaxerrs' ${__MWE__} '-Xmaxwarns' ${__MWE__}

JarBuilder             := 'jar'


##### Function to check if 'JavaBuildDir' is a relative path
function __check_JavaBuildDir__()
    $call(__exit_error_if_not_rel_path__, ${JavaBuildDir}, 'JavaBuildDir')
endfunction


##### Function to get classpaths
function __classpaths__()
    local CP := $abs_path(__class_paths__)
    local BD := $abs_path(${JavaBuildDir})
    if !$contains(${CP}, ${BD}) : CP +:= ${BD}
    return $implode( $path_ndsep(${CP}), __os_psep_char__ )
endfunction


##### Function to generate the correct dependency list file name from the given base name (without extension)
function deplist_fname(baseName)
    return $series(${baseName}, '.', ${DepListFileExt})
   #return :"${baseName}.${DepListFileExt}"
endfunction

##### Function to generate the correct dependency list file path from the given base name (without extension)
function deplist_fpath(baseName)
    $call(__check_JavaBuildDir__)
    return $cat_path( ${JavaBuildDir}, $call(deplist_fname, ${baseName}) )
endfunction


##### Function to generate the correct class file name from the given base name (without extension)
function class_fname(baseName)
    return $series(${baseName}, '.', ${ClsFileExt})
   #return :"${baseName}.${ClsFileExt}"
endfunction

##### Function to generate the correct class file path from the given base name (without extension)
function class_fpath(baseName)
    $call(__check_JavaBuildDir__)
    return $cat_path( ${JavaBuildDir}, $call(class_fname, ${baseName}) )
endfunction

##### Function to generate the correct glob target name to build class file
function class_target_glob()
    $call(__check_JavaBuildDir__)
    return :"${JavaBuildDir}/%.${ClsFileExt}"
endfunction


##### Function to generate the correct JAR file name from the given base name (without extension)
function jar_fname(baseName)
    return $series(${baseName}, '.', ${JarFileExt})
   #return :"${baseName}.${JarFileExt}"
endfunction

##### Function to generate the correct JAR file path from the given base name (without extension)
function jar_fpath(baseName)
    $call(__check_JavaBuildDir__)
    return $cat_path( ${JavaBuildDir}, $call(jar_fname, ${baseName}) )
endfunction


#####
#####
#####


##### Function to select whether to treat warnings as errors
JavaWarningAsErrorFlags := ''

function treat_warnings_as_errors(enabled)
    if ${enabled} ; JavaWarningAsErrorFlags := '-Werror'
    else          ; JavaWarningAsErrorFlags := ''
    endif
endfunction


##### Function to enable/disable debugging
JavaBuildType  := 'Release'
JavaDebugFlags := '-g:none'

function enable_debug_info(enabled)
    if ${enabled}
        JavaBuildType  := 'Debug'
        JavaDebugFlags := '-g'
    else
        JavaBuildType  := 'Release'
        JavaDebugFlags := '-g:none'
    endif
endfunction


##### Function to select language standard
JavaLangStdFlags := ''

function select_java_langstd(langstd)
    # Exit if the compiler does not support the '--release N' option
    if !${__BuildTool_SupRelMin__} : return
    if !${__BuildTool_SupRelMax__} : return
    # Check if the language version is empty
    langstd := $strim(${langstd})
    if !&${langstd}
        JavaLangStdFlags := ''
        return
    endif
    # Ensure that the language version is within the supported range
    if ${langstd} < ${__BuildTool_SupRelMin__} : langstd := ${__BuildTool_SupRelMin__}
    if ${langstd} > ${__BuildTool_SupRelMax__} : langstd := ${__BuildTool_SupRelMax__}
    # Set the version
    JavaLangStdFlags := '--release' ${langstd}
endfunction


##### Function to preprocess Java source codes
function preprocess_java(srcPath, dstPath, condFlags, svalmapHandle)
    $call       (__bpt_javapp__                                        )
    $rmfile     (${dstPath}                                            )
    $pp_java_scf(${srcPath}, ${dstPath}, ${condFlags}, ${svalmapHandle})
endfunction


##### Function to compile Java source codes
function __compile_java__(extraOptions, classpaths)
    if &${JavaToolBinDir} : local JavaCompiler := $cat_path(${JavaToolBinDir}, ${JavaCompiler})
   +@${JavaCompiler} ${JavaCommonCompileFlags} ${JavaWarningAsErrorFlags} ${JavaDebugFlags} ${JavaLangStdFlags} ${extraOptions} -cp ${classpaths} -d ${JavaBuildDir} ~$[preq*/(.+)\.class/$1.java/]
endfunction

function compile_java(?extraOptions)
    $call( __bpt_javac__                                            )
    $exec( __compile_java__, ${extraOptions}, $call(__classpaths__) )
    $call( __conditional_print_stdxxx_and_check_excode__            )
endfunction


##### Function to build Java JAR files
function __build_jar__(mainClassName, extraFiles)
    # Create the manifest file
    local MainClassSpec := :"Main-Class: ${mainClassName}"
    local ManifestFile  := $cat_path(${JavaBuildDir}, 'manifest.txt')
    $put_file( ~${ManifestFile}, ${MainClassSpec} )
    # Prepare the class file paths
    local CWD         := $cwd()
    local BDirNameLen := $strlen(${JavaBuildDir})
      add BDirNameLen, ${BDirNameLen}, 2
    local ClassFiles := $interleave( '-C', $cat_path(${CWD}, ${JavaBuildDir}), $substr(-$[preq*], ${BDirNameLen}, -1) )
    # Prepare the extra file paths
    local ExtraFiles
    foreach local EF in ~${extraFiles}
        if $str_begwith(${EF}, ${CWD}) ; ExtraFiles :+= '-C' ${CWD} -${EF}
        else                           ; ExtraFiles :+=              ${EF}
        endif
    endforeach
    # Create the JAR file
    if &${JavaToolBinDir} : local JarBuilder := $cat_path(${JavaToolBinDir}, ${JarBuilder})
   +@${JarBuilder} cfmv ~$[target] ~${ManifestFile} ${ClassFiles} ${ExtraFiles}
    if $[excode] : return
    # Delete the manifest file
    $rmfile(~${ManifestFile})
endfunction

function build_jar(mainClassName, ?extraFiles)
    $call(__bpt_jar__                                   )
    $exec(__build_jar__, ${mainClassName}, ${extraFiles})
    $call(__conditional_print_stdxxx_and_check_excode__ )
endfunction


##### Function to run the given JAR file
function __run_jar__(progName)
    if &${JavaToolBinDir} : local JavaJVM := $cat_path(${JavaToolBinDir}, ${JavaJVM})
   +@${JavaJVM} -jar ~${progName}
endfunction

function run_jar(progName)
    $exec(__run_jar__, ${progName}                     )
    $call(__conditional_print_stdxxx_and_check_excode__)
endfunction


#####
#####
#####


##### Function to initialize the project build
function init_project(?buildSubdirectories)
    # Get the compiler version
    $call(__get_java_compiler_ver__)
    # Ensure the Java binary is executable
    if !${__BuildTool_Version_Num__} : $call(__exit_error_nup_ext__, ${JavaCompiler}, ${JavaToolBinDir})
    # Create the build directory
    if &${buildSubdirectories}
        $mkdir( $cat_path(~${JavaBuildDir}, ${buildSubdirectories} ) )
    else
        $mkdir(~${JavaBuildDir})
    endif
endfunction

##### Function to clean the project build (delete all the generated files)
function clean_project()
    $call         (__check_JavaBuildDir__)
    $rmdir_rec    (~${JavaBuildDir}      )
    $clear_project(true                  )
endfunction


