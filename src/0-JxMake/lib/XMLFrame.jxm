    echoln __c_green__ '        xmlf_chkbox_ok_cancel(title, message, chkItems, ?iconType, ?width, ?height)    ' __c_white__ ': show check box dialog box with \'' __c_cyan__ 'OK' __c_white__ '\' \'' __c_cyan__ 'Cancel' __c_white__        '\' buttons'
    echoln __c_green__ '                                                                                       ' __c_white__ '      - valid       \'' __c_green__ 'iconType' __c_white__    '\' is \'' __c_yellow__ 'i' __c_white__ '\', \'' __c_yellow__ 'w' __c_white__ '\', \'' __c_yellow__ 'e' __c_white__ '\', \'' __c_yellow__ 'q' __c_white__ '\', or not specified'
    echoln __c_green__ '                                                                                       ' __c_white__ '      - the default \'' __c_green__ 'width'    __c_white__ '\'    is \'' __c_yellow__ ${XMLFrame_DefaultChkBoxWidth}  __c_white__ '\''
    echoln __c_green__ '                                                                                       ' __c_white__ '      - the default \'' __c_green__ 'height'   __c_white__  '\'   is \'' __c_yellow__ ${XMLFrame_DefaultChkBoxHeight} __c_white__ '\''
    echoln
    echoln __c_white__ '    Example code flow to create and execute an XML GUI:'
    echoln
    echoln __c_green__ '        local XMLFrame  := $call(xmlframe_begin                          , ...     )'
    echoln
    echoln __c_green__ '              XMLFrame +:= $call(xmlframe_panel_begin                    , ...     )'
    echoln __c_green__ '              XMLFrame +:= $call(xmlframe_panel_add_*                    , ...     )'
    echoln __c_cyan__  '                           ... repeat adding more controls as needed ...'
    echoln __c_green__ '              XMLFrame +:= $call(xmlframe_panel_end                      , ...     )'
    echoln __c_cyan__  '              ... repeat adding more panels as needed ...'
    echoln
    echoln __c_green__ '        local XDefs     := $call(xmlframe_xdef_en_key_escape_close_window          )'
    echoln __c_green__ '              XDefs    +:= $call(xmlframe_xdef_radiobutton_group         , ...     )'
    echoln __c_cyan__  '              ... repeat adding more groups as needed ...'
    echoln
    echoln __c_green__ '              XMLFrame +:= $call(xmlframe_end                            , ${XDefs})'
    echoln
    echoln __c_green__ '        local Results   := $xmlframe_string(${XMLFrame})'
    echoln
    echoln __c_cyan__  'Targets'
    echoln
    echoln __c_green__ '    xflib_help' __c_white__ ': show this help information'
    echoln __c_reset__
endtarget
