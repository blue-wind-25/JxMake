    echoln __c_green__ '                                                                        ' __c_white__ '      - valid \'' __c_green__ 'listener' __c_white__ '\' is \'' __c_yellow__ 'ButtonAcceptListener' __c_white__ '\' (the default) or \'' __c_yellow__ 'ButtonExitListener' __c_white__ '\''
