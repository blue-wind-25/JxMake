/***** PCPP_BEG *****/

/*
 * NOTE : Use PCPP and GNU sed to generate (preprocess) the implementation code for assembly instructions
 *        with conditional execution (please refer to the '../../../README' file for more details).
 *
 * The parenthesize-removal macros are written based on:
 *     http://coliru.stacked-crooked.com/a/3578969a94bb175a
 */
#define __NONE__

#define __STRI__(V     ) #V
#define __XSTR__(V     ) __STRI__(V)

#define __UNPI__(...   ) __UNPI__ __VA_ARGS__
#define __DONE__UNPI__

#define __CAT1__(D, ...) D ## __VA_ARGS__
#define __CAT2__(D, ...) __CAT1__( D, __VA_ARGS__ )
#define __UNPX__(   ...) __CAT2__( __DONE, __UNPI__ __VA_ARGS__  )
#define __UNPR__(   ...) __UNPX__( __UNPX__(__VA_ARGS__) )

#define __GEN_CODE_IMPL_NPR__(NAME, FIMPL, FBASE)                                        \
    public ARMCortexMThumb $_##FIMPL##_impl( final Cond cond ) throws JXMAsmError __NL__ \
    { return __itcd__( __XSTR__(NAME), cond, ()->{ return FBASE(); } ); }         __NL__ \
    __NL__

#define __GEN_CODE_IMPL_ONE__(NAME, FIMPL, PARAM, FBASE, CARG)                                                   \
    public ARMCortexMThumb $_##FIMPL##_impl( final Cond cond, __UNPR__(PARAM) ) throws JXMAsmError        __NL__ \
    { return __itcd__( __XSTR__(NAME), cond, ()->{ return FBASE( __UNPR__(CARG) ); }, __UNPR__(CARG) ); } __NL__ \
    __NL__

#define __GEN_CODE_IMPL_OBJ__(NAME, FIMPL, PARAM, FBASE, CARG)                                                              \
    public ARMCortexMThumb $_##FIMPL##_impl( final Cond cond, __UNPR__(PARAM) ) throws JXMAsmError                   __NL__ \
    { return __itcd__( __XSTR__(NAME), cond, ()->{ return FBASE( __UNPR__(CARG) ); }, (Object[]) __UNPR__(CARG) ); } __NL__ \
    __NL__

#define __GEN_CODE_IMPL_ALT__(NAME, FIMPL, PARAM, FSCODE, FBASE1, FBASE0, CARG)                                                                         \
    public ARMCortexMThumb $_##FIMPL##_impl( final Cond cond, __UNPR__(PARAM) ) throws JXMAsmError                                               __NL__ \
    { return __itcd__( __XSTR__(NAME), cond, ()->{ return (FSCODE) ? FBASE1( __UNPR__(CARG) ) : FBASE0( __UNPR__(CARG) ); }, __UNPR__(CARG) ); } __NL__ \
    __NL__

#define __GEN_CODE_CXIS_NPR__(NAME, SUFFIX, FIMPL)                                                                 \
    public ARMCortexMThumb $##NAME##eq##SUFFIX() throws JXMAsmError { return $_##FIMPL##_impl( Cond.EQ ); } __NL__ \
    public ARMCortexMThumb $##NAME##zr##SUFFIX() throws JXMAsmError { return $_##FIMPL##_impl( Cond.EQ ); } __NL__ \
    public ARMCortexMThumb $##NAME##ne##SUFFIX() throws JXMAsmError { return $_##FIMPL##_impl( Cond.NE ); } __NL__ \
