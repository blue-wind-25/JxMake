#define __GEN_CXI_NPR_NPR__(NAME, SUFFIX, FIMPL, FBASE) \
    __GEN_CODE_IMPL_NPR__(NAME,         FIMPL, FBASE)   \
    __GEN_CODE_CXIS_NPR__(NAME, SUFFIX, FIMPL       )

#define __GEN_CXI_ONE_STD__(NAME, SUFFIX, PARAM, FIMPL, FBASE, CARG) \
    __GEN_CODE_IMPL_ONE__(NAME,         FIMPL, PARAM, FBASE, CARG)   \
    __GEN_CODE_CXIS_STD__(NAME, SUFFIX, PARAM, FIMPL, CARG)

#define __GEN_CXI_OBJ_STD__(NAME, SUFFIX, PARAM, FIMPL, FBASE, CARG) \
    __GEN_CODE_IMPL_OBJ__(NAME,         FIMPL, PARAM, FBASE, CARG)   \
    __GEN_CODE_CXIS_STD__(NAME, SUFFIX, PARAM, FIMPL, CARG)

#define __GEN_CXI_ALT_STD__(NAME, SUFFIX, PARAM, FIMPL, FSCODE, FBASE1, FBASE0, CARG) \
    __GEN_CODE_IMPL_ALT__(NAME,         FIMPL, PARAM, FSCODE, FBASE1, FBASE0, CARG)   \
    __GEN_CODE_CXIS_STD__(NAME, SUFFIX, PARAM, FIMPL, CARG)

#define __GEN_CXI_ONE_SUP__(NAME, SUFFIX, PARAM, FIMPL1, FBASE1, FBASEPREFIX0, FBASESUFFIX0, CARG) \
    __GEN_CODE_IMPL_ONE__(NAME,         FIMPL1, PARAM , FBASE1      ,                        CARG) \
    __GEN_CODE_CXIS_SUP__(NAME, SUFFIX, PARAM , FIMPL1, FBASEPREFIX0, FBASESUFFIX0, CARG)                                                                                                                       \

/***** PCPP_END *****/


/*
 * Please refer to the comment block before the 'ARMCortexMThumb' class definition in the 'ARMCortexMThumb.java' file for more details and information.
