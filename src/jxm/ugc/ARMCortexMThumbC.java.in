#define __GEN_CODE_CXIS_SUP__(NAME, SUFFIX, PARAM, FIMPL1, BASEPREFIX0, BASESUFFIX0, CARG)                                                                                                                                      \
    public ARMCortexMThumb $##NAME##eq##SUFFIX( __UNPR__(PARAM) ) throws JXMAsmError { return insideITBlock() ? $_##FIMPL1##_impl( Cond.EQ, __UNPR__(CARG) ) : super.##BASEPREFIX0##eq##BASESUFFIX0( __UNPR__(CARG) ); } __NL__ \
