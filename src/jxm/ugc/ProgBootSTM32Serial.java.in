package jxm.ugc;


import java.util.HashSet;

import java.util.function.IntConsumer;

import java.util.stream.IntStream;

import jxm.*;
import jxm.xb.*;


/*
 * Simple implementation of the STM32 AN3155 protocol for programming MCUs with compatible bootloaders.
 *
 * ----------------------------------------------------------------------------------------------------
 *
 * This class is written partially based on the algorithms and information found from:
 *
 *     AN2606 - Introduction to System Memory Boot Mode on STM32 MCUs
 *     https://www.st.com/resource/en/application_note/an2606-stm32-microcontroller-system-memory-boot-mode-stmicroelectronics.pdf
 *
 *     AN3155 - USART Protocol Used in the STM32 Bootloader
 *     https://www.st.com/resource/en/application_note/cd00264342-usart-protocol-used-in-the-stm32-bootloader-stmicroelectronics.pdf
 *
 *     STM32 Host Programmer Implementation Using USART AN3155
 *     https://github.com/stm32-hotspot/stm32-host-programmer-usart
 *     https://github.com/stm32-hotspot/stm32-host-programmer-usart/tree/main/Core/Inc
 *     https://github.com/stm32-hotspot/stm32-host-programmer-usart/tree/main/Core/Src
 *     Apache-2.0 License
 *     BSD-3-Clause License
 */
public class ProgBootSTM32Serial extends ProgBootSerial {

    private static final String ProgClassName = "ProgBootSTM32Serial";

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    @SuppressWarnings("serial")
    public static class Config extends ProgBootSerial.Config {

        // NOTE : This class can use the same configuration as certain other classes
        #include "config.inc/BootSTM32Common.java.inc"

    } // class Config

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private static final int CMD_GET                  = 0x00;
    private static final int CMD_GET_VERSION          = 0x01;
    private static final int CMD_GET_ID               = 0x02;
    private static final int CMD_READ_MEMORY          = 0x11;
    private static final int CMD_GO                   = 0x21;
    private static final int CMD_WRITE_MEMORY         = 0x31;
    private static final int CMD_ERASE                = 0x43;
    private static final int CMD_EXTENDED_ERASE       = 0x44;
    private static final int CMD_SPECIAL              = 0x50;
    private static final int CMD_EXTENDED_SPECIAL     = 0x51;
    private static final int CMD_WRITE_PROTECT        = 0x63;
    private static final int CMD_WRITE_UNPROTECT      = 0x73;
    private static final int CMD_READOUT_PROTECT      = 0x82;
    private static final int CMD_READOUT_UNPROTECT    = 0x92;
    private static final int CMD_GET_CHECKSUM         = 0xA1;

    private static final int SYNC                     = 0x7F;

    private static final int RES_ACK                  = 0x79;
    private static final int RES_NAK                  = 0x1F;

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private static final int GET_CONNECT_RETRY_COUNT = 3;
    private              int WAIT_ACK_NAK_TIMEOUT_MS = TX_RX_TIMEOUT_MS_DEFL;

    private void _setWaitAckNakTimeout_default()
    { WAIT_ACK_NAK_TIMEOUT_MS = TX_RX_TIMEOUT_MS_DEFL; }

    // Erase timeout is 2000mS per 64kB of total flash, with a minimum of 5000mS
    private void _setWaitAckNakTimeout_chipErase()
    { WAIT_ACK_NAK_TIMEOUT_MS = Math.max( 5, (_config.memoryFlash.totalSize * 2 / 64 / 1024) ) * 1000; }

    private boolean _connect()
    {
        // Try to connect as several times
        for(int r = 0; r < GET_CONNECT_RETRY_COUNT; ++r) {

            // Reset the MCU via DTR/RTS
            // NOTE : This assumes the target board automatically manages BOOT0 and BOOT1
            if(true) {
                _serialResetMCU_DTR_RTS(); // 100uS 100mS
            }
            else {
               _ttyPort.pulse_DTR_RTS(100000, 100); // 100mS 100mS
            }
            SysUtil.sleepMS(25);

            // Send 'SYNC' for autobaud detection until 'ACK' is received
            _serialTx(SYNC);

            final int res = _waitFor_ACK_NAK();
            if(res <  0      ) return false;
            if(res == RES_ACK) return true;

        } // for

        // Error
        USB2GPIO.notifyError(Texts.ProgXXX_FailConnectBLTout, ProgClassName);
        return false;
    }

    private int _waitFor_ACK_NAK()
    {
        final XCom.TimeoutMS tms = new XCom.TimeoutMS(WAIT_ACK_NAK_TIMEOUT_MS);

        while(true) {

            if( serialRxUnreadCount() > 0 ) {
                final Integer ch = _serialRxUInt8();

                if(ch == null   ) return -1;
                if(ch == RES_ACK) return RES_ACK;
                if(ch == RES_NAK) return RES_NAK;
            }

            if( tms.timeout() ) {
                USB2GPIO.notifyError(Texts.PDevXXX_RxTimeout, ProgClassName);
                return -1;
            }

        } // while
    }

    private boolean _waitFor_ACK()
    { return _waitFor_ACK_NAK() == RES_ACK; }

    private boolean _waitFor_NAK()
    { return _waitFor_ACK_NAK() == RES_NAK; }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private final HashSet<Integer> _supportedCommands = new HashSet<>();

    private boolean _supportedCommand(final int cmd)
    { return _supportedCommands.isEmpty() || _supportedCommands.contains(cmd); }

    private boolean _sendByte_checksumFF(final int value)
    {
        // Send the command and XOR of the command and 0xFF
        _serialTx( new int[] { value, value ^ 0xFF } );

        // Wait for ACK
        if( !_waitFor_ACK() ) {
            _serialDrain();
            return false;
        }

        // Done
        return true;
    }

    private boolean _sendCmd(final int cmd)
    {
        // Error if the command is not supported
        if( !_supportedCommand(cmd) ) return false;

        // Send the command and return the the result
        return _sendByte_checksumFF(cmd);
    }

    private boolean _sendParamExt(final Integer firstValue, final int... values)
    {
        // Calculate the checksum
        int checksum = (firstValue != null) ? firstValue : 0;

        for(final int v : values) checksum ^= v;

        // Send the parameter and checksum
        if(firstValue != null) _serialTx(firstValue);
                               _serialTx(values    );
                               _serialTx(checksum  );

        // Wait for ACK
        if( !_waitFor_ACK() ) {
            _serialDrain();
            return false;
        }

        // Done
        return true;
    }

    private boolean _sendParam(final int... value)
    { return _sendParamExt(null, value); }

    private boolean _sendParam_U32(final long value)
    {
        return _sendParam(
            (int) ( (value >> 24) & 0xFF ),
            (int) ( (value >> 16) & 0xFF ),
            (int) ( (value >>  8) & 0xFF ),
            (int) ( (value >>  0) & 0xFF )
        );
    }

    private int[] _recvRes(final int len)
    {
        // Read the response
        final int[] res = _serialRx(len);

        if(res == null) return null;

        // Wait for ACK
        if( !_waitFor_ACK() ) {
            _serialDrain();
            return null;
        }

        // Done
        return res;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private static final long FlashBaseAddress = 0x08000000L;
    private static final int  MaxBulkDataSize  = 256;

    private boolean _cmdGetCaps()
    {
        // Send the command
        if( !_sendCmd(CMD_GET) ) return false;

        // Get the number of bytes (-1)
        final Integer numBytes = _serialRxUInt8();
        if(numBytes == null) return false;

        // Get the protocol version
        final Integer protoVer = _serialRxUInt8();
        if(protoVer == null) return false;

        /*
        SysUtil.stdDbg().printf("numBytes = %d\n", numBytes + 1);
        SysUtil.stdDbg().printf("protoVer = %d\n", protoVer    );
        //*/

        // Read the remaining bytes (the supported commands)
        final int[] res = _recvRes(numBytes);
        if(res == null) return false;

        for(final int i : res) {
            _supportedCommands.add(i);
            /*
            SysUtil.stdDbg().printf("CMD %02X\n", i);
            //*/
        }

        // Done
        return true;
    }

    private boolean _cmdGetVersion()
    {
        // Send the command
        if( !_sendCmd(CMD_GET_VERSION) ) return false;

        // Read the results
        final int[] res = _recvRes(3);
        if(res == null) return false;

        /*
        SysUtil.stdDbg().printf("protoVer = %d\n", res[0]);
        SysUtil.stdDbg().printf("option-0 = %d\n", res[1]);
        SysUtil.stdDbg().printf("option-1 = %d\n", res[2]);
        //*/

        // Done
        return true;
    }

    private boolean _cmdGetID()
    {
        // Send the command
        if( !_sendCmd(CMD_GET_ID) ) return false;

        // Get the number of bytes (-1)
        final Integer numBytes = _serialRxUInt8();
        if(numBytes == null) return false;

        /*
        SysUtil.stdDbg().printf("numBytes = %d\n", numBytes + 1);
        //*/

        // Read the remaining bytes (the ID) - use the product ID as the signature
        _mcuSignature = _recvRes(numBytes + 1);
        if(_mcuSignature == null) return false;

        // Done
        return true;
    }

    private boolean _cmdGo(final long address)
    {
        // Send the command
        if( !_sendCmd(CMD_GO) ) return false;

        // Send the address
        if( !_sendParam_U32(address) ) return false;

        // Done
        return true;
    }

    private int[] _cmdRead(final long address, final int len)
    {
        // Error if length is out of valid range
        if(len < 1 || len > MaxBulkDataSize) return null;

        // Send the command
        if( !_sendCmd(CMD_READ_MEMORY) ) return null;

        // Send the address
        if( !_sendParam_U32(address) ) return null;

        // Send the number of bytes (-1)
        if( !_sendByte_checksumFF(len - 1) ) return null; // NOTE : Use '_sendByte_checksumFF()' because the application note
                                                          //        requires the value to be XOR'ed with 0xFF as the checksum

        // Read and return the data
        return _serialRx(len);
    }

    private boolean _cmdWrite(final long address, final int[] buff)
    {
        // Error if length is out of valid range
        final int len = buff.length;

        if(len < 1 || len > MaxBulkDataSize) return false;

        // Send the command
        if( !_sendCmd(CMD_WRITE_MEMORY) ) return false;

        // Send the address
        if( !_sendParam_U32(address) ) return false;

        // Send the number of bytes (-1) and the bytes
        return _sendParamExt(len - 1, buff);
    }

    private boolean _cmdErase()
    {
        // Use longer timeout
        _setWaitAckNakTimeout_chipErase();

        // Perform the erase
        boolean doneErase = false;

        do {

            //*
            // Try mass erase first
            if( _sendCmd(CMD_ERASE) ) {
                if( _sendParam(0xFF, 0x00) ) { doneErase = true; break; }
            }

            if( _sendCmd(CMD_EXTENDED_ERASE) ) {
                if( _sendParam(0xFF, 0xFF) ) { doneErase = true; break; }
            }
            //*/

            //*
            // Try bank erase next
            if( _sendCmd(CMD_EXTENDED_ERASE) ) {
                if( !_sendParam(0xFF, 0xFE) ) break; // Bank 1 - break on error
                if( _sendCmd(CMD_EXTENDED_ERASE) ) {
                     _sendParam(0xFF, 0xFD);         // Bank 2 - ignore the error as bank 2 may not actually be available
                }
                doneErase = true; break;
            }
            //*/

            // Try page by page erase last
            //*
            if(_config.memoryFlash.numPages <= 256) {
                // ##### !!! TODO : VERIFY !!! #####
                // Prepare the page numbers
                final int[] pages = IntStream.range(0, _config.memoryFlash.numPages).toArray();
                // Erase the pages
                if( _sendCmd(CMD_ERASE) ) {
                    if( _sendParamExt(_config.memoryFlash.numPages - 1, pages) ) { doneErase = true; break; }
                }
            }
            //*/

            //*
            if(true) {
                // ##### !!! TODO : VERIFY !!! #####
                // Prepare the page numbers
                final int[] pages = IntStream.range(0, _config.memoryFlash.numPages).toArray();
                // Prepare the parameter
                final int[] param = new int[2 + _config.memoryFlash.numPages * 2];
                final int   N     = _config.memoryFlash.numPages - 1;
                param[0] = (N >> 8) & 0xFF;
                param[1] = (N >> 0) & 0xFF;
                for(int i = 0; i < _config.memoryFlash.numPages; ++i) {
                    param[2 + i * 2 + 0] = (pages[i] >> 8) & 0xFF;
                    param[2 + i * 2 + 1] = (pages[i] >> 0) & 0xFF;
                }
                // Erase the pages
                if( _sendCmd(CMD_EXTENDED_ERASE) ) {
                    if( _sendParam(param) ) { doneErase = true; break; }
                }
            }
            //*/

        } while(false);

        // Restore the timeout
        _setWaitAckNakTimeout_default();

        // Return the result
        return doneErase;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private boolean _inProgMode = false;
    private boolean _chipErased = false;

    private long    _goAddress  = -1;

    public ProgBootSTM32Serial(final ProgBootSTM32Serial.Config config) throws Exception
    {
        // Process the superclass
        super(ProgClassName, config);

        // Check the configuration values
        if(_config.memoryEEPROM.totalSize > 0) throw XCom.newJXMFatalLogicError(Texts.ProgXXX_InvMETotSize, ProgClassName);
    }

    @Override
    public byte _flashMemoryEmptyValue()
    { return FlashMemory_EmptyValue; }

    @Override
    public int _flashMemoryAlignWriteSize(final int numBytes)
    { return numBytes; }

    @Override
    public byte _eepromMemoryEmptyValue()
    { return FlashMemory_EmptyValue; }

    private boolean _begin_impl(final String serialDevice, final int baudrate, final long goAddress)
    {
        // Error if already in programming mode
        if(_inProgMode) return USB2GPIO.notifyError(Texts.ProgXXX_InProgMode, ProgClassName);

        // Clear flag
        _chipErased = false;

        // Save the GO address
        _goAddress = (goAddress >= 0) ? goAddress : FlashBaseAddress;

        // Open the serial port
        _openSerialPortEvenParity(serialDevice, baudrate);

        // Initialize the programmer
        if( !_connect      () ) return false;
        if( !_cmdGetCaps   () ) return false;
        if( !_cmdGetVersion() ) return false;
        if( !_cmdGetID     () ) return false;

        // Set flag
        _inProgMode = true;

        // Done
        return true;
    }

    public boolean begin(final String serialDevice, final int baudrate, final long goAddress)
    {
        if( _begin_impl(serialDevice, baudrate, goAddress) ) return true;

        _closeSerialPort();

        return USB2GPIO.notifyError(Texts.ProgXXX_FailInitPrgDev, ProgClassName);
    }

    @Override
    public boolean end()
    {
        // Error if not in programming mode
        if(!_inProgMode) return USB2GPIO.notifyError(Texts.ProgXXX_NotInProgMode, ProgClassName);

        // Start the application
        final boolean resStartApp = _cmdGo(_goAddress); // NOTE : This assumes the target board automatically manages BOOT0 and BOOT1

        // Close the serial port
        _closeSerialPort();

        // Clear flag
        _inProgMode = false;

        // Check for error(s)
        if(!resStartApp) {
            if(!resStartApp) USB2GPIO.notifyError(Texts.ProgXXX_FailUninitPrgDev, ProgClassName);
            return false;
        }

        // Done
        return true;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    @Override
    public boolean readSignature()
    {
        // Error if not in programming mode
        if(!_inProgMode) return USB2GPIO.notifyError(Texts.ProgXXX_NotInProgMode, ProgClassName);

        // NOTE : The MCU signature was read during 'begin()'

        // Done
        return _mcuSignature != null;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    // NOTE : Under the AN3155 protocol, this function is expected to erase only flash memory
    @Override
    public boolean chipErase()
    {
        // Error if not in programming mode
        if(!_inProgMode) return USB2GPIO.notifyError(Texts.ProgXXX_NotInProgMode, ProgClassName);

        // Exit if the device is already erased
        if(_chipErased) return true;

        // Erase the flash
        if( !_cmdErase() ) return false;

        // Set flag
        _chipErased = true;

        // Done
        return true;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private int _verifyReadFlash(final byte[] refData, final int startAddress, final int numBytes, final IntConsumer progressCallback)
    {
        // Error if not in programming mode
        if(!_inProgMode) {
            USB2GPIO.notifyError(Texts.ProgXXX_NotInProgMode, ProgClassName);
            return -1;
        }

        // Determine the start address and number of bytes
              long sa = (startAddress < 0) ? FlashBaseAddress              : startAddress;
        final int  nb = (numBytes     < 0) ? _config.memoryFlash.totalSize : numBytes;

        if(sa >= FlashBaseAddress) sa -= FlashBaseAddress;

        // Check the start address and number of bytes
        if( !USB2GPIO.checkStartAddressAndNumberOfBytes_even( (int) sa, nb, _config.memoryFlash.totalSize, ProgClassName ) ) return -1;

        // Prepare the result buffer
        if(_config.memoryFlash.readDataBuff == null || _config.memoryFlash.readDataBuff.length != numBytes) {
            _config.memoryFlash.readDataBuff = new int[numBytes];
        }

        // Call the progress callback function for the initial value
        final ProgressCB pcb = new ProgressCB();

        pcb.callProgressCallbackInitial(progressCallback, nb);

        // Index counter
        int rdbIdx = 0;
        int verIdx = 0;

        // Determine the number of chunks
        final int     ChunkSize  = Math.min(_config.memoryFlash.pageSize, MaxBulkDataSize);

        final boolean notAligned = (numBytes % ChunkSize) != 0;
        final int     numChunks  = (numBytes / ChunkSize) + (notAligned ? 1 : 0);

        // Read the bytes (and compare them if requested)
        for(int c = 0; c < numChunks; ++c) {

            // Read in chunk (flash can be read even without a page-aligned address)
            final int   numReads = Math.min(ChunkSize, numBytes - rdbIdx);
            final int[] cbytes   = _cmdRead(FlashBaseAddress + sa + c * ChunkSize, numReads);

            if(cbytes == null) {
                USB2GPIO.notifyError(Texts.ProgXXX_FailBLPrgCmdXErr, ProgClassName);
                return -1;
            }

            // Process the chunk bytes
            for(int b = 0; b < numReads; b += 2) {

                // Store the bytes to the result buffer
                _config.memoryFlash.readDataBuff[rdbIdx++] = cbytes[b    ];
                _config.memoryFlash.readDataBuff[rdbIdx++] = cbytes[b + 1];

                // Compare the bytes as needed
                if(refData != null && verIdx < refData.length) {
                    if( _config.memoryFlash.readDataBuff[verIdx] != (refData[verIdx] & 0xFF) ) return verIdx;
                    ++verIdx;
                    if( _config.memoryFlash.readDataBuff[verIdx] != (refData[verIdx] & 0xFF) ) return verIdx;
                    ++verIdx;
                }

                // Call the progress callback function for the current value
                pcb.callProgressCallbackCurrent(progressCallback, nb);

            } // for b

        } // for c

        // Call the progress callback function for the final value
        pcb.callProgressCallbackFinal(progressCallback, nb);

        // Done
        return numBytes;
    }

    @Override
    public boolean readFlash(final int startAddress, final int numBytes, final IntConsumer progressCallback)
    { return _verifyReadFlash(null, startAddress, numBytes, progressCallback) == numBytes; }

    @Override
    public int verifyFlash(final byte[] refData, final int startAddress, final int numBytes, final IntConsumer progressCallback)
    { return _verifyReadFlash(refData, startAddress, numBytes, progressCallback); }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    private boolean _writeFlash_impl(final byte[] data, final int sa, final int nb, final IntConsumer progressCallback)
    {
        // Get the number of chunks to be written and the current address
        final int  ChunkSize = Math.min(_config.memoryFlash.pageSize, MaxBulkDataSize);

        final int  numChunks = nb / ChunkSize;
              long cpgAddr   = sa;

        // Call the progress callback function for the initial value
        final ProgressCB pcb = new ProgressCB();

        pcb.callProgressCallbackInitial(progressCallback, nb);

        // Clear flag
        _chipErased = false;

        // Write the chunks
        int datIdx = 0;

        for(int p = 0; p < numChunks; ++p) {

            // ##### !!! TODO : Skip writing the chunk if it is blank (its contents are all 'FlashMemory_EmptyValue') !!! #####

            // Write the chunk
            if( !_cmdWrite( FlashBaseAddress + cpgAddr, USB2GPIO.ba2ia(data, datIdx, ChunkSize) ) ) return false;

            // Call the progress callback function for the current value as many times as necessary
            pcb.callProgressCallbackCurrentMulti(progressCallback, nb, ChunkSize / 2);

            // Increment the counters
            cpgAddr += ChunkSize;
            datIdx  += ChunkSize;

        } // for p

        // Call the progress callback function for the final value
        pcb.callProgressCallbackFinal(progressCallback, nb);

        // Done
        return true;
    }

    @Override
    public boolean writeFlash(final byte[] data, final int startAddress, final int numBytes, final IntConsumer progressCallback)
    {
        // Error if not in programming mode
        if(!_inProgMode) return USB2GPIO.notifyError(Texts.ProgXXX_NotInProgMode, ProgClassName);

        // Determine the start address and number of bytes
              long sa = (startAddress < 0) ? FlashBaseAddress              : startAddress;
        final int  nb = (numBytes     < 0) ? _config.memoryFlash.totalSize : numBytes;

        if(sa >= FlashBaseAddress) sa -= FlashBaseAddress;

        // Align the number of bytes and pad the buffer as needed
        final USB2GPIO.ANBResult anbr = USB2GPIO.alignNumberOfBytesAndPadBuffer( data, (int) sa, nb, _config.memoryFlash.pageSize, _config.memoryFlash.totalSize, FlashMemory_EmptyValue, ProgClassName );
        if(anbr == null) return false;

        // Check the start address and number of bytes
        if( !USB2GPIO.checkStartAddressAndNumberOfBytes_pageSize( (int) sa, anbr.nb, _config.memoryFlash.pageSize, ProgClassName ) ) return false;

        // Write the flash
        return _writeFlash_impl(anbr.buff, (int) sa, anbr.nb, progressCallback);
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////////

    // WARNING : Altough some STM32 MCUs have embedded EEPROM, AN3155 does not support EEPROM reading and writing!

    @Override
    public int readEEPROM(final int address)
    { return -1; }

    @Override
    public boolean writeEEPROM(final int address, final byte data)
    { return false; }

} // class ProgBootSTM32Serial
