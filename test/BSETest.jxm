:::include <BasicPlatformUtil>

eh := $bse_new()
echoln ${eh}
echoln $bse_valid_handle(${eh})
echoln $bse_size(${eh})
echoln

$bse_set_be   (${eh}                        )
$bse_wr_byte  (${eh}, 49                    )
$bse_wr_byte  (${eh}, 'a'                   )
$bse_wr_byte  (${eh}, 'A'                   )
$bse_wr_byte  (${eh}, 'ö'                   )
$bse_wr_sint08(${eh}, -1                    )
$bse_wr_sint08(${eh}, -2                    )
$bse_wr_sint08(${eh}, -3                    )
$bse_wr_uint08(${eh},  253                  )
$bse_wr_uint08(${eh},  254                  )
$bse_wr_uint08(${eh},  255                  )
$bse_wr_sint16(${eh}, -1                    )
$bse_wr_sint16(${eh}, -2                    )
$bse_wr_sint16(${eh}, -3                    )
$bse_wr_uint16(${eh},  65533                )
$bse_wr_uint16(${eh},  65534                )
$bse_wr_uint16(${eh},  65535                )
$bse_wr_sint32(${eh}, -1                    )
$bse_wr_sint32(${eh}, -2                    )
$bse_wr_sint32(${eh}, -3                    )
$bse_wr_uint32(${eh},  4294967293           )
$bse_wr_uint32(${eh},  4294967294           )
$bse_wr_uint32(${eh},  4294967295           )
$bse_wr_sint64(${eh}, -1                    )
$bse_wr_sint64(${eh}, -2                    )
$bse_wr_sint64(${eh}, -3                    )
$bse_wr_uint64(${eh}, '18446744073709551613')
$bse_wr_uint64(${eh}, '18446744073709551614')
$bse_wr_uint64(${eh}, '18446744073709551615')
$bse_wr_utf8  (${eh}, 'abc'                 )
$bse_wr_utf8  (${eh}, 'abc', false          )
$bse_wr_flt32 (${eh}, -0.15625              )
$bse_wr_flt32 (${eh},  0.15625              )
$bse_wr_dbl64 (${eh}, -0.15625              )
$bse_wr_dbl64 (${eh},  0.15625              )
$bse_wr_utf16 (${eh}, 'def'                 )
$bse_wr_utf16 (${eh}, 'def', false          )
$bse_wr_utf32 (${eh}, 'ghi'                 )
$bse_wr_utf32 (${eh}, 'ghi', false          )
$bse_set_le   (${eh}                        )
$bse_wr_byte  (${eh}, 49                    )
$bse_wr_byte  (${eh}, 'a'                   )
$bse_wr_byte  (${eh}, 'A'                   )
$bse_wr_byte  (${eh}, 'ö'                   )
$bse_wr_sint08(${eh}, '-1'                  )
$bse_wr_sint08(${eh}, '-2'                  )
$bse_wr_sint08(${eh}, '-3'                  )
$bse_wr_uint08(${eh},  253                  )
$bse_wr_uint08(${eh},  254                  )
$bse_wr_uint08(${eh},  255                  )
$bse_wr_sint16(${eh}, '-1'                  )
$bse_wr_sint16(${eh}, '-2'                  )
$bse_wr_sint16(${eh}, '-3'                  )
$bse_wr_uint16(${eh},  65533                )
$bse_wr_uint16(${eh},  65534                )
$bse_wr_uint16(${eh},  65535                )
$bse_wr_sint32(${eh}, '-1'                  )
$bse_wr_sint32(${eh}, '-2'                  )
$bse_wr_sint32(${eh}, '-3'                  )
$bse_wr_uint32(${eh},  4294967293           )
$bse_wr_uint32(${eh},  4294967294           )
$bse_wr_uint32(${eh},  4294967295           )
$bse_wr_sint64(${eh}, -1                    )
$bse_wr_sint64(${eh}, -2                    )
$bse_wr_sint64(${eh}, -3                    )
$bse_wr_uint64(${eh}, '18446744073709551613')
$bse_wr_uint64(${eh}, '18446744073709551614')
$bse_wr_uint64(${eh}, '18446744073709551615')
$bse_wr_utf8  (${eh}, 'abc'                 )
$bse_wr_utf8  (${eh}, 'abc', false          )
$bse_wr_flt32 (${eh}, '-0.15625'            )
$bse_wr_flt32 (${eh},  '0.15625'            )
$bse_wr_dbl64 (${eh}, '-0.15625'            )
$bse_wr_dbl64 (${eh},  '0.15625'            )
$bse_wr_utf16 (${eh}, 'def'                 )
$bse_wr_utf16 (${eh}, 'def', false          )
$bse_wr_utf32 (${eh}, 'ghi'                 )
$bse_wr_utf32 (${eh}, 'ghi', false          )

FilePathBin := $cat_path( $ptd(), 'BSETest.dat.bin' )
$bse_save_file(${eh}, ${FilePathBin})

echoln $bse_size(${eh})
$bse_seek_beg(${eh}, 0)
$bse_truncate(${eh})
echoln $bse_size(${eh})
echoln

$bse_delete(${eh})
echoln $bse_valid_handle(${eh})
echoln

echoln '----------------------------------------------------------------------------------------------------'
echoln

eh := $bse_new()
$bse_load_file(${eh}, ${FilePathBin})

Base64StrSv := $bse_save_base64str(${eh})
FilePathTxt := $cat_path( $ptd(), 'BSETest.dat.txt' )
$put_file(${FilePathTxt}, ${Base64StrSv})

echoln $bse_size(${eh})
$bse_seek_beg(${eh}, 0)
$bse_truncate(${eh})

Base64StrLD := $get_file(${FilePathTxt})
$bse_load_base64str(${eh}, ${Base64StrLD})
echoln $bse_size(${eh})

if ${Base64StrLD} == ${Base64StrSV}
    echoln ${Base64StrLD}
    echoln
endif

$bse_seek_beg        (${eh}, 0   )
$bse_set_be          (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_sint08(${eh}      )
echoln $bse_rd_sint08(${eh}      )
echoln $bse_rd_sint08(${eh}      )
echoln $bse_rd_uint08(${eh}      )
echoln $bse_rd_uint08(${eh}      )
echoln $bse_rd_uint08(${eh}      )
echoln $bse_rd_sint16(${eh}      )
echoln $bse_rd_sint16(${eh}      )
echoln $bse_rd_sint16(${eh}      )
echoln $bse_rd_uint16(${eh}      )
echoln $bse_rd_uint16(${eh}      )
echoln $bse_rd_uint16(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_uint32(${eh}      )
echoln $bse_rd_uint32(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_sint64(${eh}      )
echoln $bse_rd_sint64(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_utf8  (${eh}      )
echoln $bse_rd_utf8  (${eh}, true)
echoln $bse_rd_flt32 (${eh}      )
echoln $bse_rd_flt32 (${eh}      )
echoln $bse_rd_dbl64 (${eh}      )
echoln $bse_rd_dbl64 (${eh}      )
echoln $bse_rd_utf16 (${eh}      )
echoln $bse_rd_utf16 (${eh}, true)
echoln $bse_rd_utf32 (${eh}      )
echoln $bse_rd_utf32 (${eh}, true)
echoln
$bse_set_le          (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_byte  (${eh}      )
echoln $bse_rd_sint08(${eh}      )
echoln $bse_rd_sint08(${eh}      )
echoln $bse_rd_sint08(${eh}      )
echoln $bse_rd_uint08(${eh}      )
echoln $bse_rd_uint08(${eh}      )
echoln $bse_rd_uint08(${eh}      )
echoln $bse_rd_sint16(${eh}      )
echoln $bse_rd_sint16(${eh}      )
echoln $bse_rd_sint16(${eh}      )
echoln $bse_rd_uint16(${eh}      )
echoln $bse_rd_uint16(${eh}      )
echoln $bse_rd_uint16(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_sint32(${eh}      )
echoln $bse_rd_uint32(${eh}      )
echoln $bse_rd_uint32(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_sint64(${eh}      )
echoln $bse_rd_sint64(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_uint64(${eh}      )
echoln $bse_rd_utf8  (${eh}      )
echoln $bse_rd_utf8  (${eh}, true)
echoln $bse_rd_flt32 (${eh}      )
echoln $bse_rd_flt32 (${eh}      )
echoln $bse_rd_dbl64 (${eh}      )
echoln $bse_rd_dbl64 (${eh}      )
echoln $bse_rd_utf16 (${eh}      )
echoln $bse_rd_utf16 (${eh}, true)
echoln $bse_rd_utf32 (${eh}      )
echoln $bse_rd_utf32 (${eh}, true)
echoln

echoln '----------------------------------------------------------------------------------------------------'
echoln

$bse_seek_beg(${eh}, 0)
$bse_truncate(${eh})
for I := 0 to 9 step 1
    $bse_wr_uint08(${eh}, ${I})
endfor
$call(dump_bse_object_ext, ${eh}, 'ORIGINAL')

       $bse_seek_cur (${eh}, -7)
ch1 := $bse_range_cpy(${eh},  3)
$call(dump_bse_object_ext, ${eh}, '$bse_seek_cur(${eh}, -7) ; ch1 = $bse_range_cpy(${eh}, 3)')

       $bse_seek_cur (${eh},  2)
ch2 := $bse_range_cut(${eh},  5)
$call(dump_bse_object_ext, ${eh}, '$bse_seek_cur(${eh},  2) ; ch2 = $bse_range_cut(${eh}, 5)')

$call(dump_bse_object_ext, ${ch1}, 'BUFFER-1')
$call(dump_bse_object_ext, ${ch2}, 'BUFFER-2')

$bse_seek_end (${eh}, 0     )
$bse_range_pst(${eh}, ${ch1})
$call(dump_bse_object_ext, ${eh}, '$bse_seek_end(${eh}, 0) ; $bse_range_pst(${eh}, ${ch1})')

$bse_seek_beg (${eh}, 1     )
$bse_range_pst(${eh}, ${ch2})
$call(dump_bse_object_ext, ${eh}, '$bse_seek_beg(${eh}, 1) ; $bse_range_pst(${eh}, ${ch2})')

$bse_seek_end (${eh}, 0     )
$bse_range_ovr(${eh}, ${ch1})
$call(dump_bse_object_ext, ${eh}, '$bse_seek_end(${eh}, 0) ; $bse_range_ovr(${eh}, ${ch1})')

$bse_seek_beg (${eh}, 0     )
$bse_range_ovr(${eh}, ${ch2})
$call(dump_bse_object_ext, ${eh}, '$bse_seek_beg(${eh}, 0) ; $bse_range_ovr(${eh}, ${ch2})')

$bse_seek_end (${eh}, -2    )
$bse_range_ovr(${eh}, ${ch2})
$call(dump_bse_object_ext, ${eh}, '$bse_seek_end(${eh}, -2) ; $bse_range_ovr(${eh}, ${ch2})')

$bse_seek_cur (${eh}, -3    )
$bse_range_clr(${eh},  7    )
$call(dump_bse_object_ext, ${eh}, '$bse_seek_cur(${eh}, -3) ; $bse_range_clr(${eh}, 7)')

$bse_delete(${eh} )
$bse_delete(${ch1})
$bse_delete(${ch2})

echoln
