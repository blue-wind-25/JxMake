const ABC := 'abc'
const DEF := 'def'
      GHI := 'ghi'

echoln ${ABC}
echoln ${DEF}
echoln ${GHI}

echoln

deprecate ABC
deprecate DEF by DEF_new
deprecate GHI by GHI_new

echoln ${ABC}
echoln ${DEF}
echoln ${GHI}

echoln

GHI := 'ghi_other_1'
echoln ${GHI}

unset GHI
GHI := 'ghi_other_2'
echoln ${GHI}



echoln
echoln
echoln



function MyFunc(arg1, arg2, arg3)
    deprecate arg1
    deprecate MyVar1
    local     MyVar2
    deprecate MyVar2
    echoln "[I-ByArg] ${arg1} ${arg2} ${arg3}"
    echoln "[I-ByVar] ${MyVar1} ${MyVar2} ${MyVar3}"
endfunction

MyVar1 := 'MyVar1'
MyVar2 := 'MyVar2'
MyVar3 := 'MyVar3'

deprecate MyVar3;

echoln "[O-ByVar] ${MyVar1} ${MyVar2} ${MyVar3}"
echoln
$call(MyFunc, ${MyVar1}, ${MyVar2},  ${MyVar3})
echoln
echoln "[O-ByVar] ${MyVar1} ${MyVar2} ${MyVar3}"
