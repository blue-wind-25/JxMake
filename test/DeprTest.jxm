$__dummy_dep_1__()
$__dummy_dep_2__()
$__dummy_rep_2__()

function a()
    echoln 'A1'
endfunction

function b()
    echoln 'B1'
endfunction

$call(a)
$call(b)

echoln

function a() supersede
    echoln 'A2'
    $call(__origin__)
endfunction

function b() supersede deprecated by b_new
    echoln 'B2-DEPRECATED'
    $call(__origin__)
endfunction

function b() supersede
    echoln 'B3'
    $call(__origin__)
endfunction

function c() deprecated
    echoln 'C-DEPRECATED'
endfunction

function d() deprecated by d_new
    echoln 'D-DEPRECATED'
endfunction

$call(a)
$call(b)
$call(c)
$call(d)



echoln
echoln
echoln



echoln $[__dummy_vdep_1__]
echoln $[__dummy_vdep_2__]
echoln $[__dummy_vrep_2__]

echoln

echoln __dummy_sdep_1__
