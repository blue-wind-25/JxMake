(*
const __LDLibraryPath_OriVal__ := $explode( $getenv('LD_LIBRARY_PATH', ''), __os_psep_char__ )
LDLibraryPath := 'LDPath'

function __get_LDLibraryPaths__()
    local Value := $unique( $stack(~${LDLibraryPath}, ${__LDLibraryPath_OriVal__}) )
    return $implode(${Value}, __os_psep_char__)
endfunction


function __generic_xgcc_elf_to_xxx__(file, path)
    echoln ${file}
    echoln ${path}
endfunction

function link_exe()
    local Target := 'build/main.elf'
    $exec( __generic_xgcc_elf_to_xxx__, ~${Target}, $call(__get_LDLibraryPaths__) )
    echoln
    $exec( __generic_xgcc_elf_to_xxx__, $path_ndsep( $cat_path( $cwd(), ${Target} ) ), $call(__get_LDLibraryPaths__) )
endfunction

$call(link_exe)
#*)



