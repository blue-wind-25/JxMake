(*

function flush()
    if &$[stderr] : echoln $[stderr]
    if &$[stdout] : echoln $[stdout]
    if  $[excode] : $exit ($[excode])
    echoln
endfunction

function fsl()
    $cmd_streaming_on()
    echoln "$[cmdecho] $[cmdstreaming]"
    @sl
    echoln $[excode]
    $cmd_streaming_off()
    echoln "$[cmdecho] $[cmdstreaming]"
endfunction

function fml()
    $cmd_streaming_on()
    echoln "$[cmdecho] $[cmdstreaming]"
    @ml
    echoln $[excode]
    $cmd_streaming_off()
    echoln "$[cmdecho] $[cmdstreaming]"
endfunction

echoln ; $exec(fsl) ; $call(flush) ; echoln

echoln ; $exec(fml) ; $call(flush) ; echoln

#*)



