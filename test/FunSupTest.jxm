function function2(a, b, c)
    echoln "function2 : ${a} ${b} ${c}"
endfunction

function function2(a, b) supersede
    $call(__origin__, 'x', ${a}, ${b})
    echoln "function2 - supersede1"
endfunction

function function2(a) supersede
    $call(__origin__, 'y', ${a})
    echoln "function2 - supersede2"
endfunction



