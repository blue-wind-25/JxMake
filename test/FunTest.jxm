Start := $micros()
loop
    Current := $micros()
    sub Delta, ${Current}, ${Start}
    if ${Delta} > 500000 : break
endloop
echoln 'Done waiting 500000 uS'

Start := $millis()
loop
    Current := $millis()
    sub Delta, ${Current}, ${Start}
    if ${Delta} > 500 : break
endloop
echoln 'Done waiting 500 mS'



