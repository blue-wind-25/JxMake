function concat(a, b)
    local c  = ${a}
          c += ${b}
          c := $flatten(${c})
   #$exit(7)
   #-$mkdir('/root/test')
   #$printf("%s\n", ${c})
    return ${c}
endfunction

function concatPrint(a, b, ?opt)
    local c    := $call(concat, ${a}, ${b})
    local opt ?:= 'default'

    $printf("%s %s\n", ${c}, ${opt})
endfunction



