$map_put(${mh}, 'Key 1', 'Value1' )
$map_put(${mh}, 'Key 2', 'Value2a')
$map_add(${mh}, 'Key 2', 'Value2b')
echoln $part_count  ( $map_keys(${mh}) )
echoln $map_num_keys( ${mh}            )
echoln $map_num_vals( ${mh}, 'Key 1'   )
echoln $map_num_vals( ${mh}, 'Key 2'   )

$map_clear(${mh})
$map_delete(${mh})

echoln $map_num_keys( ${mh}            )
echoln $map_num_vals( ${mh}, 'Key 1'   )

echoln



mh := $map_new()
echoln ${mh}

$map_put(${mh}, 'Key 1', 'Value1' )
$map_put(${mh}, 'Key 1', 'ValueX' )
$map_put(${mh}, 'Key 2', 'Value2a')
$map_add(${mh}, 'Key 2', 'Value2b')

foreach key in $map_keys(${mh})
    echoln $implode( $map_get(${mh}, ${key}), '|' )
endforeach

echoln

$map_remove(${mh}, 'Key 1')

foreach key in $map_keys(${mh})
    echoln $implode( $map_get(${mh}, ${key}), '|' )
endforeach

$map_delete(${mh})

echoln



function aboard(path, ?title)
    local edata := $aboard_from_file(${path})
          edata := $aboard_selector(${edata}, ${title})
    if &${edata}
        local mh := $aboard_getselconf(${edata})
        local ed := $map_to_edata(${mh}) ; $map_delete(${mh})
              mh := $map_from_edata(${ed})
        foreach local K in $map_keys(${mh})
            $printf("[%s]\n", ${K})
            foreach local V in $map_get(${mh}, ${K})
                $printf("    %s\n", ${V})
            endforeach
        endforeach
        $map_delete(${mh})
    endif
    echoln
endfunction

#$call(aboard, '../0_excluded_directory/temporary/Arduino-AVR-Boards.txt') ; echoln

$call(aboard, 'arduino_partial_boards_1.txt') ; echoln
