$call(aboard, 'arduino_partial_boards_3.txt') ; echoln
$call(aboard, 'arduino_partial_boards_4.txt') ; echoln

echoln



function processGHR(mh)
    if !&${mh}<1>
        echoln $ftlines(${mh})
        echoln
        return
    endif
    $call(dump_map_object, ${mh})
    $map_delete(${mh})
    echoln
endfunction

echoln $ftlines( $call(gh_get_api_versions) )
echoln
#$exit(1)

$call( processGHR, $call(gh_get_rate_limit                                                                  ) )
#$exit(1)

$call( processGHR, $call(gh_get_tags                           , 'blue-wind-25', 'VMA-Solutions'            ) )
#$exit(1)

$call( processGHR, $call(gh_get_tags                           , 'arduino'     , 'rp2040tools'              ) )
$call( processGHR, $call(gh_get_assets_from_all_releases       , 'arduino'     , 'rp2040tools'              ) )
$call( processGHR, $call(gh_get_assets_from_latest_release     , 'arduino'     , 'rp2040tools'              ) )
$call( processGHR, $call(gh_get_assets_from_release_by_id      , 'arduino'     , 'rp2040tools'  , '40035159') )
$call( processGHR, $call(gh_get_assets_from_release_by_tag_name, 'arduino'     , 'rp2040tools'  , '1.0.1   ') )

