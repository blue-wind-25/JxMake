A = "10 \${ABC/(.*).c\/p\/p$/\/\/\//} ABC


for I = 1 to $[preq^] step 1
    R = $partn( $[preq*], ${I} )
endfor

while ${A} > 0

    if ${Error}
        break
    endif

    if ${Skip}
