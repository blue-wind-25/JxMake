function compile_cpp(source, output)
    if ${source} >  10
    endif
    if ${source} <= 10
    endif
    if ${source} >  10
    endif
    if ${source} >= 10
    endif
    if ${source} == 10
    endif
    if ${source} != 10
    endif
    return 1
endfunction

function compile_cpp(source, output)
    local Q = 10
    @<command_1>
    @<command_2>
    if __os_windows__
        @<command_3_windows> 1 '1' ${ABC} "${ABC}" '${ABC}' xyz $[target]
    elif __os_linux__
        @<command_3_linux> 1 '1' ${ABC} "${ABC}" \
        '${ABC}' xyz $[target] xyz xyz xyz
    elif __os_mac__
        @<command_3_mac>
    else
        return $[stderr]
    endif
    if  0 : echo 123
    if !0 : echo 123
    @<command_4>
    @<command_5>
    return 1
endfunction

target my_target : my_source.cpp
    local Q            = 10
    local osIsNotLinux = 0
    not osIsNotLinux, __os_linux__
    if osIsNotLinux
        $exit(-1)
    endif
    if !__os_linux__
        $exit(-1)
    endif
    if &${A}
        $exit(-1)
    endif
    if !&${A}
        $exit(-1)
    endif
    src = $lcase( $[target] )
    dst = $lcase( $[target] )
    $exec( compile_cpp, ${src}, ${dst} )
endtarget

target %.cpp.o : %.cpp
endtarget


target build/mylib.a : build/mylib/%.cpp.o
endtarget

