VOrg2 = 2
VOrg3 = 3

VRef1  = VOrg1
VRef2 := VOrg2
VRef3  = VOrg3

VRefX  = ${^VRef1} ${^VRef2} ${^VRef3}
VRefY  = VRefX

VRefU  = ${VRefY}
VRefV := ${VRefY}

echoln $sprintf('${ VRefX} = { %5s }', $ftspaces(${ VRefX}) )
echoln $sprintf('${^VRefX} = { %5s }', $ftspaces(${^VRefX}) )

echoln

echoln $sprintf('${ VRefY} = { %5s }', $ftspaces(${ VRefY}) )
echoln $sprintf('${^VRefY} = { %5s }', $ftspaces(${^VRefY}) )

echoln

echoln $sprintf('${ VRefU} = { %5s }', $ftspaces(${ VRefU}) )
echoln $sprintf('${^VRefU} = { %5s }', $ftspaces(${^VRefU}) )

echoln

echoln $sprintf('${ VRefV} = { %5s }', $ftspaces(${ VRefV}) )
echoln $sprintf('${^VRefV} = { %5s }', $ftspaces(${^VRefV}) )



