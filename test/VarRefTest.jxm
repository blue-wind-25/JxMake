RefA2  = ${^RefA1}

echoln $ftspaces( {{ ${^RefA1}<1>, ${^RefA1}<1,1>, ${^RefA1}<3:5> }} )
echoln $ftspaces( {{ ${ RefA2}<1>, ${ RefA2}<1,1>, ${ RefA2}<3:5> }} )
echoln $ftspaces( {{ ${^RefA2}<1>, ${^RefA2}<1,1>, ${^RefA2}<3:5> }} )

echoln

unset OVarA
echoln $ftspaces( {{ ${^RefA1}<1>, ${^RefA1}<1,1>, ${^RefA1}<3:5> }} )
echoln $ftspaces( {{ ${ RefA2}<1>, ${ RefA2}<1,1>, ${ RefA2}<3:5> }} )

echoln

