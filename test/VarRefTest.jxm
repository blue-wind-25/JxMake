function test_d(arg)
    foreach I, V in ${arg}
        echoln "[${I}] ${V}"
    endforeach
    echoln
endfunction

function test_r(arg)
    foreach I, V in ${^arg}
        echoln "[${I}] ${V}"
    endforeach
    echoln
endfunction

function test_l(arg)
    local MyVar := d e f
    foreach I, V in ${^arg}
        echoln "[${I}] ${V}"
    endforeach
    echoln
    local arg := g h i
    foreach I, V in ${arg}
        echoln "[${I}] ${V}"
    endforeach
    echoln
endfunction

MyVar := a b c
MyRef := MyVar

$call(test_d, ${^MyRef})
$call(test_r, ${ MyRef})
$call(test_l, ${ MyRef})

foreach I, V in ${^MyRef}
    echoln "[${I}] ${V}"
endforeach



echoln
echoln
echoln



VOrg = 10
RefA = VOrg
RefB = ${RefA}
echoln "'${ RefB}'"                          # It will print 'VOrg'
echoln "'${^RefB}'"                          # It will print '10'

^RefB = 20                                   # It will set the variable VOrg instead of the variable RefB
echoln "'${^RefB}'"                          # It will print '20'

.option warning push
.option warning enable 'inv-ref-var'
.option warning push
.option warning enable 'var-not-exist'

RefB = FooVar                                # It will set the variable RefB
echoln "'${^RefB}'"                          # It will print ''

^RefB = 30

.option warning pop

RefC = VOrg
RefD = ${^RefC} ${RefC} RefC
echoln {{ '\'', $ftspaces(${ RefD}), '\'' }} # It will print '20 VOrg RefC'
echoln {{ '\'', $ftspaces(${^RefD}), '\'' }} # It will print ''

.option warning pop



echoln
echoln
echoln



