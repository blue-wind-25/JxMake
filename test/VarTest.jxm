$printf(">>> Testing $mkdir, $touch, $rm, and $rmdir\n")

 $mkdir ('mydir'           )
 $touch ('mydir/myfile.txt')
 $printf("The last suppressed error message is '%s'\n", $[lserr])
-$rmdir ('mydir'           )
 $printf("The last suppressed error message is '%s'\n", $[lserr])
 $printf("The last suppressed error message is '%s'\n", $[lserr])
 $rmfile('mydir/myfile.txt')
 $rmdir ('mydir'           )

$printf("\n")

$printf(">>> Testing $mkdir, $touch, and $rmdir_rec\n")
$mkdir    ('mydir'           )
$touch    ('mydir/myfile.txt')
$rmdir_rec('mydir'           )

$printf("\n")

$printf(">>> Testing $newer_path\n")

Chk1  = 'myfileR.txt'
ChkN  = 'myfileR.txt' 'myfileR.txt' 'myfileR.txt'
Ref   = 'myfile1.txt'
Ref  += 'myfile2.txt'
Ref  += 'myfile3.txt'
All   = ${Chk1} ${Ref}

$touch(${All})

Res := $newer_path(${Chk1}, ${Ref})
Res := $implode(${Res}, ' ')
$printf("%s\n", ${Res})

Res := $newer_path(${ChkN}, ${Ref})
Res := $implode(${Res}, ' ')
$printf("%s\n", ${Res})

$touch('myfileR.txt')
Res := $newer_path(${Chk1}, ${Ref})
Res := $implode(${Res}, ' ')
$printf("%s\n", ${Res})

Res := $newer_path(${ChkN}, ${Ref})
Res := $implode(${Res}, ' ')
$printf("%s\n", ${Res})

$touch('myfile2.txt')
Res := $newer_path(${Chk1}, ${Ref})
Res := $implode(${Res}, ' ')
$printf("%s\n", ${Res})

Res := $newer_path(${ChkN}, ${Ref})
Res := $implode(${Res}, ' ')
$printf("%s\n", ${Res})

$rmfile(${All})

$printf("\n")

