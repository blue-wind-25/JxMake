##### Test lazy variable assignment #####
$printf("\n##### Testing variable lazy assignment #####\n\n")

B0 = ${X} ${A} ${Z}
B1 = ${A}
B2 = ${A/(.+)\.ref/$1.o/}
C  = "123 ${B1} ${B2} 456"
D  = "123 ${B2} ${B2/(.+)\.o/$1.o.o/} 456"

A  = test.ref
$printf("A  = '%s'\n", ${A} )
$printf("B0 = '%s'\n", ${B0})
$printf("B1 = '%s'\n", ${B1})
$printf("B2 = '%s'\n", ${B2})
$printf("C  = '%s'\n", ${C} )
$printf("D  = '%s'\n", ${D} )
$printf("\n")

A  = abc.ref
$printf("A  = '%s'\n", ${A} )
$printf("B0 = '%s'\n", ${B0})
$printf("B1 = '%s'\n", ${B1})
$printf("B2 = '%s'\n", ${B2})
$printf("C  = '%s'\n", ${C} )
$printf("D  = '%s'\n", ${D} )

$printf("\n")

