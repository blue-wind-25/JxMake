##### Test writable special-variable-shortcut #####
$printf("\n##### Testing writable special-variable-shortcut #####\n\n")

__include_paths__ = ${UHP}

Val = __include_paths__
UHP = myinclude1
$printf("%s %s\n", ${Val}, __include_paths__)

UHP = myinclude2
$printf("%s %s\n", ${Val}, __include_paths__)

UHP += myinclude3
__include_paths__ := ${UHP}
$printf("%s %s\n", ${Val}, __include_paths__)

UHP = myinclude4
$printf("%s %s\n", ${Val}, __include_paths__)

$printf("\n")

##### Test automatic special-variable #####
$printf("\n##### Testing automatic special-variable #####\n\n")

Val = $[target]
$printf("%s %s\n", ${Val}, $[target])

Val = $[target]
$printf("%s %s\n", ${Val/(.+)\.obj/$1.cpp.o/}, $[target/(.+)\.obj/$1.cpp.o/])

Val = $[target/(.+)\.obj/$1.cpp.o/]
Mod = ${Val/(.+)\.cpp.o/$1.cpp.obj/}
$printf("%s %s\n", ${Val}, ${Mod})

Val = $[preq^]
$printf("%s %s\n", ${Val}, $[preq^])

Val = $[preq*]
$printf("%s %s\n", ${Val}, $[preq*])

Val = $[preq?]
$printf("%s %s\n", ${Val}, $[preq?])

Val = $[preq1]
$printf("%s %s\n", ${Val}, $[preq1])

Val = $[preq9]
$printf("%s %s\n", ${Val}, $[preq9])

I   = 5
Val = $[preq:I]
$printf("%s %s\n", ${Val}, $[preq:I])

$printf("\n")

Val = $[preq+]
$printf("%s %s\n", ${Val}, $[preq+])

Val = $[preq%]
$printf("%s %s\n", ${Val}, $[preq%])

Val = $[preq~]
$printf("%s %s\n", ${Val}, $[preq~])

$printf("\n")

Val = $[excode]
$printf("%s %s\n", ${Val}, $[excode])

Val = $[stderr]
$printf("%s %s\n", ${Val}, $[stderr])

Val = $[stdout]
$printf("%s %s\n", ${Val}, $[stdout])

$printf("\n")

##### Test function calls that are related to string processing #####
$printf("\n##### Testing function calls that are related to string processing #####\n\n")

Val := -$sprintf('Test $sprintf(%s, %d, %b)', 'abc')
Err := $[lserr] # Consume (read and clear the last suppressed error message)
$printf("RESULT = '%s'\n", ${Val})

Val := $sprintf('Test $sprintf(%s, %d, %b)', 'abc', 123, false)
$printf("RESULT = '%s'\n", ${Val})

$printf("\n")

Val0  = 'abc'
Val1 := $ucase(${Val0})
Val2 := $lcase(${Val0})
$printf("'%s' '%s'\n", ${Val1}, ${Val2})

$printf("\n")

Val0  = ' abc '
Val1 := $ltrim(${Val0})
Val2 := $rtrim(${Val0})
Val3 := $strim(${Val0})
$printf("'%s' '%s' '%s'\n", ${Val1}, ${Val2}, ${Val3})

$printf("\n")

Val0  = 'abc'
Val0 += 'def'
Val0 += 'ghi'

Val1 := $implode(${Val0})
Val2 := $explode(${Val1})
$printf("%s\n", ${Val1})
$printf("%s\n", ${Val2})

$printf("\n")

ValS  = '['
ValS += ']'
Val1 := $implode(${Val0}, ${ValS})
Val2 := $explode(${Val1}, ${ValS})
$printf("%s\n", ${Val1})
$printf("%s\n", ${Val2})

$printf("\n")

Val1 := $implode(${Val0})
Val2 := $explode(${Val1})
$printf("%s\n", ${Val1})
$printf("%s\n", ${Val2})

$printf("\n")

Val1 := $implode(${Val0})
Val2 := $flatten(${Val0})
$printf("%s\n", ${Val1})
$printf("%s\n", ${Val2})

$printf("\n")

Val2 := $explode(${Val1})
ValN := $part_count(${Val2})
$printf("%s\n", ${ValN})

ValX := $partn(${Val2}, 1)
$printf("[1] %s\n", ${ValX})

ValX := $partn(${Val2}, 2)
$printf("[2] %s\n", ${ValX})

ValX := $partn(${Val2}, 3)
$printf("[3] %s\n", ${ValX})

ValX := $partn(${Val2}, 4)
$printf("[4] %s\n", ${ValX})

ValX := $partn(${Val2}, 5)
$printf("[5] %s\n", ${ValX})

$printf("\n")

##### Test split assignment  #####
$printf("\n##### Testing split assignment #####\n\n")

Val1  = 'My'   ' '   'Value 1'
ValN := $part_count(${Val1})
$printf("%d : %s\n", ${ValN}, ${Val1})

Val1  = 123
Val2  = "Value is ${Val1}"
ValN := $part_count(${Val2})
$printf("%d : %s\n", ${ValN}, ${Val2})

$printf("\n")

C := "123 ${B1} ${B2} 456"
D := "123 ${B2} ${B2/(.+)\.o/$1.o.o/} 456"

ValN := $part_count(${C})
$printf("%d : %s\n", ${ValN}, ${C})

ValN := $part_count(${D})
$printf("%d : %s\n", ${ValN}, ${D})
$printf("\n")

E    := $flatten(${C})
ValN := $part_count(${E})
$printf("%d : %s\n", ${ValN}, ${E})

E    := $flatten(${D})
ValN := $part_count(${E})
$printf("%d : %s\n", ${ValN}, ${E})

$printf("\n")

