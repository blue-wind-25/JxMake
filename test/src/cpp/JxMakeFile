target ${SLIB_NAME} : ${SLIB_OBJS}
    $call(link_slib)
endtarget

target ${DLIB_NAME} : $stack( $call(cppobj_preq_glob_dlib, ${DLIB_OBJS}), $call(sobj_preq_glob_dlib, ${DLIB_OBJS_S}) )
    $call(link_dlib)
endtarget

target $call(sobj_target_glob) : $call(ssrc_fname, '%')
    $call(compile_s)
endtarget

target $call(cobj_target_glob) : %.c
    $call(compile_c)
endtarget

target $call(cppobj_target_glob) : %.cpp
    local __include_paths__ := sys
    local CMDef             := $call(def_macro, "__MyMacro__", '"ABC \\\\ \\\\n DEF \\" \\\\\\" XYZ!"')
    $call(compile_cpp, ${CMDef})
endtarget

target $call(sobj_target_glob, true) : $call(ssrc_fname, '%')
    $call(compile_s (*, true*) )
endtarget

target $call(cppobj_target_glob, true) : %.cpp
    local __include_paths__ := sys
    $call( compile_cpp, $call(def_macro, 'USERLIB_EXPORTS'), true )
endtarget
