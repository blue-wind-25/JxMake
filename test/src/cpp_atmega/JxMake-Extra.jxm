# ./jxmake.sh -C ../test/src/cpp_atmega bootlil
# jxmake -C ..\test\src\cpp_atmega bootlil
target bootlil
    # Burn the bootloader for Arduino LilyPad 8MHz (ATmega328p)
    local AVR_MCUType      := atmega328p
    local AVR_CPUFrequency := 8000000
    $call(avr_upload_usbasp, 'ArduinoBootloaders/ATmegaBOOT_168_atmega328_pro_8MHz.elf')
endtarget


# ./jxmake.sh -C ../test/src/cpp_atmega boot162dfu
# jxmake -C ..\test\src\cpp_atmega boot162dfu
target boot162dfu
    # Burn the DFU bootloader for AT90USB162 8MHz
    # Pull down PD7/HWB to force bootloader execution after reset
    # avrdude -c usbasp -p at90usb162 -U flash:w:LUFA/LUFA-210130_BootloaderDFU_AT90USB162_8MHz.hex:i -U lfuse:w:0xFF:m -U hfuse:w:0xD9:m -U efuse:w:0xF4:m
    local AVR_MCUType      := at90usb162
    local AVR_CPUFrequency := 8000000
    $call(avr_upload_usbasp, 'LUFA/LUFA-210130_BootloaderDFU_AT90USB162_8MHz.elf')
endtarget

