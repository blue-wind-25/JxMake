# ./jxmake.sh -C ../test/src/cpp_atmega udeflil
# jxmake -C ..\test\src\cpp_atmega udeflil
target udeflil
    # Restore to the default test firmware for Arduino LilyPad 8MHz (ATmega328p)
    # You may need to press the physical reset button first if the running firmware does not support reset-from-USB
    local FirmwareFile     := 'ATmega328P_Default.elf'
    local AVR_MCUType      := atmega328p
    local AVR_CPUFrequency := 8000000
    local UPort            := $csel(__os_windows__, '\\\\.\\COM1', '/dev/ttyUSB0')
    local UBaudrate        := 57600
    local UProtocol        := arduino
    local UResetBL         := 0
    # The firmware is built from 'https://sourceforge.net/p/ecxx/code/HEAD/tree/trunk/src/Test/AVR/AnalogAndUART.cpp'
   #$call(avr_upload_usbasp , ${FirmwareFile}                                                                )
    $call(avr_upload_serial , ${FirmwareFile}, ${UPort}             , ${UBaudrate}, ${UProtocol}, ${UResetBL})
   #$call(avr_upload_ecxx   , ${FirmwareFile}, 'esp01au.local', 2323, ${UBaudrate}, ${UProtocol}             ) # Using eCxx firmware
   #$call(avr_upload_ecxx   , ${FirmwareFile}, '192.168.0.100', 2323, ${UBaudrate}, ${UProtocol}             ) # Using eCxx firmware (no mDNS)
   #$call(avr_upload_esplink, ${FirmwareFile}, '192.168.4.1'  , 2323, ${UBaudrate}, ${UProtocol}             ) # Using ESP-LINK firmware
endtarget


# ./jxmake.sh -C ../test/src/cpp_atmega udefleo
# jxmake -C ..\test\src\cpp_atmega udefleo
target udefleo
    # Restore to the default test firmware for Arduino Leonardo (ATmega32U4)
    # You may need to press the physical reset button first if the running firmware does not support reset-from-USB
    local AVR_MCUType      := atmega32u4
    local AVR_CPUFrequency := 16000000
    local UPort            := $csel(__os_windows__, '\\\\.\\COM3', '/dev/ttyACM0')
    local UBaudrate        := 57600
    local UProtocol        := avr109
    local UResetBL         := 1
    # The firmware is built from 'https://sourceforge.net/p/ecxx/code/HEAD/tree/trunk/src/Test/AVR/AVRC/VUARTLoopback.cpp'
    $call(avr_upload_serial, 'ATmega32U4_Default.elf', ${UPort}, ${UBaudrate}, ${UProtocol}, ${UResetBL})
endtarget


# ./jxmake.sh -C ../test/src/cpp_atmega udefthi
# jxmake -C ..\test\src\cpp_atmega udefthi
target udefthi
    # Restore to the default test firmware for Thinary ATmega4808 using eCxx firmware 'JTAG2UPDI_WORKAROUND_MAGIC'
    local AVR_MCUType      := atmega4808
    local AVR_CPUFrequency := 16000000
    local UPort            := $csel(__os_windows__, '\\\\.\\COM1', '/dev/ttyUSB0')
    local UBaudrate        := 115200
    local UProtocol        := jtag2updi
    local UResetBL         := 1
    local ResetByteSeq     := 0x00 0x00 0x55 0x00 0x00 0x55
    # The firmware is built from 'https://sourceforge.net/p/ecxx/code/HEAD/tree/trunk/src/Test/AVR/AnalogAndUART.cpp'
    $call(avr_upload_serial, 'ATmega4808_Default.elf', ${UPort}, ${UBaudrate}, ${UProtocol}, ${UResetBL}, ${ResetByteSeq})
endtarget


