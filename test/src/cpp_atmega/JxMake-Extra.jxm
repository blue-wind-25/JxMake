# ./jxmake.sh -C ../test/src/cpp_atmega boot1286c
# jxmake -C ..\test\src\cpp_atmega boot1286c
target boot1286c
    # Burn the Caterina (CDC-ACM) bootloader for AT90USB1286 16MHz
    local AVR_MCUType      := at90usb1286
    local AVR_CPUFrequency := 16000000
    $call(avr_upload_usbasp, 'LUFA/LUFA-111009_BootloaderCaterina_AT90USB1286_16MHz.elf')
endtarget


# ./jxmake.sh -C ../test/src/cpp_atmega boot32a
# jxmake -C ..\test\src\cpp_atmega boot32a
target boot32a
    # Burn the bootloader for ATmega32A 4MHz
    local AVR_MCUType      := atmega32a
    local AVR_CPUFrequency := 4000000
   #$call(avr_upload_usbasp  , 'MightyCoreBootloaders/optiboot_flash_atmega32_UART0_19200_4000000L_B0.elf'        )
    $call(avr_upload_atmelice, 'MightyCoreBootloaders/optiboot_flash_atmega32_UART0_19200_4000000L_B0.elf', 'jtag')
endtarget
