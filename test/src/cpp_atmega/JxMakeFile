(*
 * ####################################################################################################
 * ############################################### NOTE ###############################################
 * ####################################################################################################
 *
 * Building for the AVR SD series using AVR GCC requires a modified DFP directory structure
 * along with patched 'specs-avr*sd*' files. For example, to build for the AVR32SD28:
 *
 *     cd       Microchip.AVR-Sx_DFP.1.1.17
 *     mkdir -p gcc/dev/avr32sd28/{avrxmega3,device-specs}
 *     cd       gcc/dev/avr32sd28/avrxmega3
 *     cp       ../../../../xc8/avr/lib/avrxmega3/{crtavr32sd28.o,libavr32sd28.a} .
 *     cd       ../device-specs
 *     cp       ../../../../xc8/avr/device-specs/specs-avr32sd28 .
 *     cd       ../../../../..
 *
 * ----------------------------------------------------------------------------------------------------
 *
 * Edit the newly copied 'specs-avr32sd28' and make the following changes:
 *
 * Replace:
 *     *avrlibc_startfile:
 *         %{mno-interrupts|mcvt:crtavr32sd28.cvt.o; :crtavr32sd28.o}%s
 *     ...
 *     *link_data_start:
 *         -Tdata 0x807000
 *     ...
 *     *self_spec:
 *         %<mmcu=* -mmcu=avrxmega3 -mdevice=avr32sd28 %<mshort-calls -msafety-device-features %<msp8
 *     ...
 * With:
 *     *avrlibc_startfile:
 *         crtavr32sd28.o%s
 *     ...
 *     *link_data_start:
 *         %{!Tdata:-Tdata 0x807000}
 *     ...
 *     *self_spec:
 *         %<mmcu=* -mmcu=avrxmega3 %<mshort-calls %<msp8
 *     ...
 *
 * Then insert:
 *     *asm_gccisr:
 *         %{!mno-gas-isr-prologues: -mgcc-isr}
 * Between:
 *     *asm_rmw:
 * And:
 *     *asm_errata_skip:
 *
 * Finally, delete:
 *   *link_fuse_action_define_appdata:
 *       %{!mno-fuse-action:%{!mno-fuse-action=define-appdata:--fuse-action=define-appdata --fuse-action-param=define-appdata-codesize:0x7:0xFF:0x0 --fuse-action-param=define-appdata-bootsize:0x8:0xFF:0x0 --fuse-action-param=define-appdata-scalefactor:0x100}}
 *
 * ----------------------------------------------------------------------------------------------------
 *
 * NOTE : # The modified DFP above is not compatible with '-mcvt'.
 *        # If you need to use '-mcvt', you must use AVR-LibC version 2.3 or later:
 *              https://github.com/avrdudes/avr-libc
 *        # Certain code constructs or execution flows may be incompatible with specific compiler or linker options.
 *)
 
