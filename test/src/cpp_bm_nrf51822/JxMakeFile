:::include <C++XBuildTool_BM_NRF51>


if __os_windows__
    ARM_TOOLCHAIN_PATH := 'Z:/xsdk/stm32/gcc-arm-none-eabi-10.3-2021.10'
else
    ARM_TOOLCHAIN_PATH := $cat_path( $uhd(), 'xsdk/stm32/gcc-arm-none-eabi-10.3-2021.10' )
endif

#NRFUtilProgram := {{ 'python3.6', $cat_path( $uhd(), '.local/bin/adafruit-nrfutil' ) }}


if __os_windows__
    # VirtualBox serial port mapping:
    #     /dev/ttyUSB0 -> COM1
    #     /dev/ttyUSB1 -> COM2
    #     /dev/ttyACM0 -> COM3
    #     /dev/ttyACM1 -> COM4
    SPort := '\\\\.\\COM3'
   #SPort := '\\\\.\\COM4'
else
    SPort := '/dev/ttyACM0'
   #SPort := '/dev/ttyACM1'
endif


JXMAKELIB_DOWNLOAD_XPACK_OPENOCD_FORCE_TAG := 'v0.10.0-15'


BuildSubdir := 'nrfx/mdk' 'nrfx/drivers/src'

$call(init_project            , ${BuildSubdir})
$call(treat_warnings_as_errors, 1             )
$call(enable_debug_info       , 1             )
$call(select_optimization     , size          )
$call(print_devenv_config                     )
$call(silent_stdxxx           , false         )
$call(silent_stdxxx_syslib    , true          )

#$cmd_echo_off() ; $call(print_build_process_titles, true)


PROG_NAME := $call(  exe_fpath, main                                           )
PROG_OBJS := $call(  obj_fpath, main.cpp                                       )

MLIB_NAME := $call( slib_fpath, mdk                                            )
MLIB_OBJS := $call(  obj_fpath, $rel_path( $srfile_rec('nrfx', '.*\\.[cS]$') ) ) ##### ??? TODO : Use 'sobj_fpath' for assembly source file ??? #####

LD_DIR    := 'nrfx/mdk'
LD_SCRIPT := :"${LD_DIR}/nrf51822_xxaa.ld" # 256kB flash ; 16kB RAM


######################################
##### These are the SDK settings #####
######################################

# NOTE : SysTick timer is not implemented in nRF51822 SoC; use RTC1 instead!

NRF51822_CompileMDefs     := '-DNRF51' '-DNRFX_CLOCK_ENABLED=1' '-DNRFX_RTC_ENABLED=1' '-DNRFX_RTC1_ENABLED=1'
NRF51822_DisableWarnings  := '-Wno-unused-but-set-variable' '-Wno-unused-parameter'

CppCommonAssemblerFlags  +:= ${NRF51822_CompileMDefs}
CppCommonCcCompileFlags  +:= ${NRF51822_CompileMDefs}
CppCommonCxxCompileFlags +:= ${NRF51822_CompileMDefs}


CppCommonAssemblerFlags  +:= ${NRF51822_DisableWarnings}
CppCommonCcCompileFlags  +:= ${NRF51822_DisableWarnings}
CppCommonCxxCompileFlags +:= ${NRF51822_DisableWarnings}

CppCommonLinkFlags        := $erase_if(${CppCommonLinkFlags}, { '-nostdlib' '-nostartfiles' })
CppCommonLinkFlags       +:= :"-L${LD_DIR}" '--specs=nano.specs' '--specs=nosys.specs'

__include_paths__        +:= 'cmsis/CMSIS/Core/Include' 'nrfx' 'nrfx/drivers/include' 'nrfx/hal' 'nrfx/mdk' 'nrfx/templates'

######################################
######################################
######################################


target clean
    $call(clean_project)
endtarget


# jxmake -C ..\test\src\cpp_bm_nrf51822 clean
# jxmake -C ..\test\src\cpp_bm_nrf51822 run
target run
    jxmake ${MLIB_NAME}
    jxmake ${PROG_NAME}
    $call(run_exe, ${PROG_NAME})
endtarget


target ${PROG_NAME} : ${PROG_OBJS}
    local CppUsrStaticLib +:= mdk
    $call( n51bm_link_exe, $call(use_ld, ${LD_SCRIPT}) )
    $call( gen_lst       , ${PROG_NAME}                )
endtarget

target ${MLIB_NAME} : ${MLIB_OBJS}
    $call(link_slib)
endtarget

target $call(sobj_target_glob) : $call(ssrc_fname, '%')
    $call(compile_s)
endtarget

target $call(cobj_target_glob) : %.c
    $call(compile_c)
endtarget

target $call(cppobj_target_glob) : %.cpp
    $call(compile_cpp)
endtarget


