:::include <C++XBuildTool_ESP8266_Arduino>


if __os_windows__
    # VirtualBox serial port mapping:
    #     /dev/ttyUSB0 -> COM1
    #     /dev/ttyUSB1 -> COM2
    #     /dev/ttyACM0 -> COM3
    #     /dev/ttyACM1 -> COM4
    SPort := '\\\\.\\COM1'
else
    SPort := '/dev/ttyUSB0'
endif


ArduinoESP8266BoardSelCacheDir := $ftt_stack( $ptd(), '_bcd' )
BuildSubdir                    := 'ulib'

$call(init_project            , ${BuildSubdir})
$call(treat_warnings_as_errors, 1             )
$call(enable_debug_info       , 1             )
$call(select_optimization     , size          )
$call(silent_stdxxx           , false         )
$call(silent_stdxxx_syslib    , true          )

#$cmd_echo_off() ; $call(print_build_process_titles, true)

if !$contains($[cmdtargets], { btlib_help clean clean_all })
    const PUB_KEY := '../../../keys/public.key'
    const PRI_KEY := '../../../keys/private.key'
    $call(arduino_board_selector                         )
    $call(arduino_set_signing_key, ${PUB_KEY}, ${PRI_KEY}) ##### NOTE : After enabling/disaling signing, the target 'clean' must be run! #####
   #$call(arduino_use_spiffs                             ) ##### NOTE : After changing file system     , the target 'clean' must be run! #####
    $call(arduino_use_littlefs                           ) ##### NOTE : After changing file system     , the target 'clean' must be run! #####
    $call(print_devenv_config                            )
endif


PROG_NAME := $call( exe_fpath, main         )
PROG_OBJS := $call( obj_fpath, main.ino.cpp )

SLIB_NAME := $call(slib_fpath,   ulib                         )
SLIB_OBJS := $call( obj_fpath, { ulib/src1.cpp ulib/src2.cpp })


target clean
    $call(clean_project)
endtarget

target clean_all
    $call(clean_project)
    $rmdir_rec(${ArduinoESP8266BoardSelCacheDir})
    echoln
    echoln __c_red__ 'The board configuration data is deleted!' __c_reset__
    echoln
endtarget


# jxmake -C ..\test\src\cpp_esp8266 clean
# jxmake -C ..\test\src\cpp_esp8266 clean_all
# jxmake -C ..\test\src\cpp_esp8266 run
# jxmake -C ..\test\src\cpp_esp8266 userial
# jxmake -C ..\test\src\cpp_esp8266 sercon
target run
    jxmake ${SLIB_NAME}
    jxmake ${PROG_NAME}
    $call(arduino_run_exe, ${PROG_NAME})
endtarget


target ${PROG_NAME} : ${PROG_OBJS}
    jxmake arduino_esp8266_compile_ld
    jxmake arduino_esp8266_build_core_slib
    jxmake arduino_esp8266_build_extra_slib
    local CppUsrStaticLib :+= ulib
    $call(arduino_link_exe)
endtarget

target ${SLIB_NAME} : ${SLIB_OBJS}
    $call(arduino_link_slib)
endtarget

target $call(cppobj_target_glob) : %.cpp
    $call(arduino_compile_cpp, ${extraDef})
endtarget


# ./jxmake.sh -C ../test/src/cpp_esp8266 userial
# jxmake -C ..\test\src\cpp_esp8266 userial
target userial
    jxmake run
    $call(arduino_upload_serial, ${PROG_NAME}, ${SPort})
endtarget

# ./jxmake.sh -C ../test/src/cpp_esp8266 uota
# jxmake -C ..\test\src\cpp_esp8266 uota
target uota
    jxmake run
    $call(arduino_upload_ota, ${PROG_NAME}, 'nodemcu.local', ?, 'ota$*')
endtarget


# ./jxmake.sh -C ../test/src/cpp_esp8266 ufserial
