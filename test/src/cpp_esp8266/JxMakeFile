target ufsserial
    $call(arduino_make_fsimage, 'fs_root')
    $call(arduino_uploadfs_serial, ${SPort})
endtarget

# ./jxmake.sh -C ../test/src/cpp_esp8266 ufota
# jxmake -C ..\test\src\cpp_esp8266 ufota
target ufsota
    $call(arduino_make_fsimage, 'fs_root')
    $call(arduino_uploadfs_ota, 'nodemcu.local', ?, 'ota$*')
endtarget


# ./jxmake.sh -C ../test/src/cpp_esp8266 sercon
# jxmake -C ..\test\src\cpp_esp8266 sercon
target sercon
    echoln 'Opening serial console ...'
    echoln $serial_console(${SPort}, 9600)
    echoln 'The serial console has been closed'
endtarget


# ./jxmake.sh -C ../test/src/cpp_esp8266 serplot
# jxmake -C ..\test\src\cpp_esp8266 serplot
target serplot
    echoln 'Opening serial plotter ...'
    $serial_plotter(${SPort}, 115200)
    echoln 'The serial plotter has been closed'
endtarget


