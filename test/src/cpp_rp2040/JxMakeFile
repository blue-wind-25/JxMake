else
   #PICO_SDK_PATH       := $cat_path( $uhd(), 'xsdk/raspberry-pi-pico-2023-03-03-SDKv1.5.0/pico-sdk'  )
    PICO_SDK_PATH       := $cat_path( $uhd(), 'xsdk/raspberry-pi-pico-2023-06-23-SDKv1.5.1/pico-sdk'  )
