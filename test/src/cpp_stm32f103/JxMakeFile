target uswd
    jxmake run
    $call(stm32_upload_swd, ${PROG_NAME}, ?          , ?    , ?, true) # Set 'ignoreCPUID' to 'true' because there are many 'BluePill' boards that contains clone chips
   #$call(stm32_upload_swd, ${PROG_NAME}, 'jlink'    , 'swd', ?, true) # ---
