target rswd
    $call(stm32_reset_swd, ?          , ?    , ?, true) # Set 'ignoreCPUID' to 'true' because there are many 'BluePill' boards that contains clone chips
   #$call(stm32_reset_swd, 'jlink'    , 'swd', ?, true) # ---
   #$call(stm32_reset_swd, 'cmsis-dap', 'swd', ?, true) # ---; if using Atmel-ICE as a CMSIS-DAP device, then it may or may not work (depending on the firmware in the Atmel-ICE)
endtarget


