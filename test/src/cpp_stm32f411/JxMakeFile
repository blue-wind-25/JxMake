:::include <C++XBuildTool_STM32_Cube>


if __os_windows__
    STM32_SDK_PATH       := 'Z:/xsdk/stm32/stm32-sdk'
    STM32_TOOLCHAIN_PATH := 'Z:/xsdk/stm32/gcc-arm-none-eabi-10.3-2021.10'
else
    STM32_SDK_PATH       := $cat_path( $uhd(), 'xsdk/stm32/stm32-sdk'                      )
    STM32_TOOLCHAIN_PATH := $cat_path( $uhd(), 'xsdk/stm32/gcc-arm-none-eabi-10.3-2021.10' )
endif


if __os_windows__
    # VirtualBox serial port mapping:
    #     /dev/ttyUSB0 -> COM1
    #     /dev/ttyUSB1 -> COM2
    #     /dev/ttyACM0 -> COM3
    #     /dev/ttyACM1 -> COM4
    SPort := '\\\\.\\COM3'
else
    SPort := '/dev/ttyACM0'
endif


JXMAKELIB_DOWNLOAD_XPACK_OPENOCD_FORCE_TAG := 'v0.10.0-15'


USBDevice   := $csel(1, 'device|cdc', 'device|hid') # 0 = HID      ; 1 = CDC
USBDriver   := $csel(1, ${USBDevice}, ''          ) # 0 = disabled ; 1 = enabled for ${USBDevice}

BuildSubdir := 'ulib'

$call(init_project            , ${BuildSubdir}             )
$call(stm32cube_select_part   , STM32F411CEU6, ${USBDriver})
$call(treat_warnings_as_errors, 1                          )
$call(enable_debug_info       , 1                          )
$call(select_optimization     , size                       )
$call(select_c_langstd        , c11                        )
$call(select_cxx_langstd      , c++11                      )
$call(print_devenv_config                                  )
$call(silent_stdxxx           , false                      )
$call(silent_stdxxx_syslib    , true                       )

#$cmd_echo_off() ; $call(print_build_process_titles, true)


#(*
$rmdir_rec('test_dir')
$call(stm32cube_copy_template_files, 'test_dir')
#*)


PROG_NAME := $call(exe_fpath, main    )
PROG_OBJS := $call(obj_fpath, main.cpp)

if true
        $call(stm32cube_auto_add_pkg_srcs   )
        $call(stm32cube_auto_add_hal_srcs   )
    if &${USBDriver}
        $call(stm32cube_auto_add_usbdrv_srcs)
    endif
else
    $call(stm32cube_add_pkg_src, { \
        stm32f4xx_hal_msp.c        \
        stm32f4xx_it.c             \
        system_stm32f4xx.c         \
        startup_stm32f411xe.s      \
        usbd_if.c                  \
        usbd_conf.c                \
        usbd_desc.c                \
    } )
    $call(stm32cube_add_hal_src, { \
        stm32f4xx_hal.c            \
        stm32f4xx_hal_cortex.c     \
        stm32f4xx_hal_crc.c        \
        stm32f4xx_hal_exti.c       \
        stm32f4xx_hal_flash.c      \
        stm32f4xx_hal_gpio.c       \
        stm32f4xx_hal_pcd.c        \
        stm32f4xx_hal_pcd_ex.c     \
        stm32f4xx_hal_pwr.c        \
        stm32f4xx_hal_pwr_ex.c     \
        stm32f4xx_hal_rcc.c        \
        stm32f4xx_hal_rcc_ex.c     \
    } )
    if &${USBDriver}
        $call(stm32cube_add_usbdrv_core_src , { \
            usbd_ctlreq.c                       \
            usbd_core.c                         \
            usbd_ioreq.c                        \
        } )
        $call(stm32cube_add_usbdrv_class_src, { \
            usbd_cdc.c                          \
        } )
    endif
endif

SLIB_NAME := $call(slib_fpath,   ulib                         )
SLIB_OBJS := $call( obj_fpath, { ulib/src1.cpp ulib/src2.cpp })

$call(stm32cube_add_extradeps, ${PROG_NAME})


target clean
   #echoln $ftlines( $call(__stm32_decode_device_part_number__, STM32F103C8T6) ) ; echoln
   #echoln $ftlines( $call(__stm32_decode_device_part_number__, STM32F411CEU6) ) ; echoln
   #echoln $ftlines( $call(__stm32_decode_device_part_number__, STM32L4R9AI  ) ) ; echoln
   #echoln $ftlines( $call(__stm32_decode_device_part_number__, STM32L4P5AG  ) ) ; echoln
   #$call(__stm32_test_lds__)
    $call(clean_project)
endtarget


target run
    jxmake ${SLIB_NAME}
    jxmake ${PROG_NAME}
    $call(stm32cube_run_exe, ${PROG_NAME})
endtarget


target ${PROG_NAME} : ${PROG_OBJS}
    jxmake stm32cube_build_system_library
    local CppUsrStaticLib :+= ulib
    $call(stm32cube_link_exe)
endtarget

target ${SLIB_NAME} : ${SLIB_OBJS}
    $call(stm32cube_link_slib)
endtarget

target $call(cppobj_target_glob) : %.cpp
    $call(stm32cube_compile_cpp)
endtarget


