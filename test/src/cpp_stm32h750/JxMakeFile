:::include <C++XBuildTool_STM32_Cube>


if __os_windows__
    STM32_SDK_PATH       := 'Z:/xsdk/stm32/stm32-sdk'
    STM32_TOOLCHAIN_PATH := 'Z:/xsdk/stm32/gcc-arm-none-eabi-10.3-2021.10'
else
    STM32_SDK_PATH       := $cat_path( $uhd(), 'xsdk/stm32/stm32-sdk'                      )
    STM32_TOOLCHAIN_PATH := $cat_path( $uhd(), 'xsdk/stm32/gcc-arm-none-eabi-10.3-2021.10' )
endif

STM32_CommonCompileMDef :+= '-DAPPLICATION_ADDRESS=0x08000000L'


if __os_windows__
    # VirtualBox serial port mapping:
    #     /dev/ttyUSB0 -> COM1
    #     /dev/ttyUSB1 -> COM2
    #     /dev/ttyACM0 -> COM3
    #     /dev/ttyACM1 -> COM4
    SPort := '\\\\.\\COM3'
else
    SPort := '/dev/ttyACM0'
endif


JXMAKELIB_DOWNLOAD_XPACK_OPENOCD_FORCE_TAG := 'v0.10.0-15'


$call(init_project            , ${BuildSubdir})
$call(stm32cube_select_part   , STM32H750VBT6 )
$call(treat_warnings_as_errors, 1             )
$call(enable_debug_info       , 1             )
$call(select_optimization     , size          )
$call(select_c_langstd        , c11           )
$call(select_cxx_langstd      , c++11         )
$call(print_devenv_config                     )
$call(silent_stdxxx           , false         )
$call(silent_stdxxx_syslib    , true          )


#$cmd_echo_off() ; $call(print_build_process_titles, true)


PROG_NAME := $call(exe_fpath, main    )
PROG_OBJS := $call(obj_fpath, main.cpp)

if true
        $call(stm32cube_auto_add_pkg_srcs   )
        $call(stm32cube_auto_add_hal_srcs   )
else
    $call(stm32cube_add_pkg_src, { \
        stm32h7xx_hal_msp.c        \
        stm32h7xx_it.c             \
        system_stm32h7xx.c         \
        startup_stm32h750xx.s      \
    } )
    $call(stm32cube_add_hal_src, { \
        stm32h7xx_hal.c            \
        stm32h7xx_hal_cortex.c     \
        stm32h7xx_hal_crc.c        \
        stm32h7xx_hal_exti.c       \
        stm32h7xx_hal_flash.c      \
        stm32h7xx_hal_gpio.c       \
        stm32h7xx_hal_pcd.c        \
        stm32h7xx_hal_pcd_ex.c     \
        stm32h7xx_hal_pwr.c        \
        stm32h7xx_hal_pwr_ex.c     \
        stm32h7xx_hal_rcc.c        \
        stm32h7xx_hal_rcc_ex.c     \
    } )
endif

$call(stm32cube_add_extradeps, ${PROG_NAME})


target clean
    $call(clean_project)
endtarget


target run
    jxmake ${PROG_NAME}
    $call(stm32cube_run_exe, ${PROG_NAME})
endtarget


target ${PROG_NAME} : ${PROG_OBJS}
    jxmake stm32cube_build_system_library
    $call(stm32cube_link_exe)
endtarget

target $call(cppobj_target_glob) : %.cpp
    $call(stm32cube_compile_cpp)
endtarget


# ./jxmake.sh -C ../test/src/cpp_stm32h750 rswd
# jxmake -C ..\test\src\cpp_stm32h750 rswd
target rswd
    $call(stm32_reset_swd)
endtarget


# ./jxmake.sh -C ../test/src/cpp_stm32h750 uswd
# jxmake -C ..\test\src\cpp_stm32h750 uswd
target uswd
    jxmake run
    $call(stm32_upload_swd, ${PROG_NAME})
endtarget


# ./jxmake.sh -C ../test/src/cpp_stm32h750 dswd
# jxmake -C ..\test\src\cpp_stm32h750 dswd
target dswd
    jxmake run
    $call(stm32_debug_swd_start, ${PROG_NAME})
endtarget

# ./jxmake.sh -C ../test/src/cpp_stm32h750 dgdb
# jxmake -C ..\test\src\cpp_stm32h750 dgdb
target dgdb
    jxmake run
    $call(stm32_debug_swd_gdb, ${PROG_NAME})
endtarget
